    /**
     * Build a DeepSeek prompt for one page's copy.
     * Ported from: lu_wizard_build_copy_prompt (WP line 1322)
     */
    private function buildCopyPrompt(string $slug, array $sections, array $config): string
    {
        $business    = $config['business_name'] ?? '';
        $industry    = $config['industry']      ?? '';
        $location    = $config['location']      ?? '';
        $tone        = $config['tone']          ?? '';
        $audience    = $config['audience']      ?? '';
        $coreService = $config['core_service']  ?? '';

        if (!$business && !$industry) return '';

        // Map section labels/types to canonical spec keys
        $sectionTypes = [];
        foreach ($sections as $sec) {
            $secType = strtolower($sec['type'] ?? '');
            if ($secType === 'header' || $secType === 'footer') continue;

            $label = strtolower($sec['label'] ?? $sec['heading'] ?? '');
            if (str_contains($label, 'hero')        || $secType === 'hero')           $sectionTypes[] = 'hero';
            elseif (str_contains($label, 'stats'))                                     $sectionTypes[] = 'trust_bar';
            elseif (str_contains($label, 'service')  || $secType === 'services_grid')  $sectionTypes[] = 'service_grid';
            elseif (str_contains($label, 'testimonial'))                               $sectionTypes[] = 'testimonials';
            elseif (str_contains($label, 'cta')      || $secType === 'cta')            $sectionTypes[] = 'cta';
            elseif (str_contains($label, 'story')    || str_contains($label, 'about')) $sectionTypes[] = 'story';
            elseif (str_contains($label, 'process'))                                   $sectionTypes[] = 'process';
            elseif (str_contains($label, 'faq'))                                       $sectionTypes[] = 'faq';
            elseif (str_contains($label, 'contact')  || $secType === 'contact_form')   $sectionTypes[] = 'contact_form';
            elseif (str_contains($label, 'team')     || $secType === 'team')           $sectionTypes[] = 'team';
            elseif (str_contains($label, 'pric'))                                      $sectionTypes[] = 'pricing';
            elseif (str_contains($label, 'portfolio')|| str_contains($label, 'project')) $sectionTypes[] = 'portfolio';
            elseif (str_contains($label, 'case'))                                      $sectionTypes[] = 'case_studies';
            elseif (str_contains($label, 'value'))                                     $sectionTypes[] = 'values';
            elseif (str_contains($label, 'why')      || str_contains($label, 'feature') || $secType === 'features') $sectionTypes[] = 'features';
            else $sectionTypes[] = $secType ?: 'features';
        }

        if (empty($sectionTypes)) return '';

        $schemaSpec  = $this->sectionSchemaSpec($sectionTypes);
        $locStr      = $location    ? " based in {$location}"            : '';
        $audStr      = $audience    ? " targeting {$audience}"           : '';
        $svcStr      = $coreService ? " specialising in {$coreService}" : '';
        $toneStr     = $tone        ? " Tone: {$tone}." : '';
        $pageContext  = ucwords(str_replace(['-', '_'], ' ', $slug)) . ' page';

        return 'Write compelling website copy for the ' . $pageContext . ' of ' . $business
            . $locStr . $svcStr . $audStr . '. Industry: ' . $industry . '.' . $toneStr . "\n\n"
            . "Return a JSON array of sections matching this schema:\n"
            . "[\n" . $schemaSpec . "\n]\n\n"
            . 'RULES: Return ONLY the JSON array. Never return null or empty strings. '
            . 'Make copy specific to this business. '
            . 'Testimonial names must be authentic for ' . ($location ?: 'Middle East / International') . '. '
            . 'Icons must be real emoji. Stat numbers must be plausible. CTA button text max 4 words.';
    }

