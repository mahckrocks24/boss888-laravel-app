    public function getDashboard(int $wsId): array
    {
        $sites = DB::table('websites')->where('workspace_id', $wsId)->whereNull('deleted_at');
        $totalPages = DB::table('pages')
            ->join('websites', 'pages.website_id', '=', 'websites.id')
            ->where('websites.workspace_id', $wsId)->count();

        return [
            'total_websites' => (clone $sites)->count(),
            'published' => (clone $sites)->where('status', 'published')->count(),
            'draft' => (clone $sites)->where('status', 'draft')->count(),
            'total_pages' => $totalPages,
            'websites' => (clone $sites)->orderByDesc('updated_at')->limit(5)->get(),
        ];
    }

    // ═══════════════════════════════════════════════════════
    // PRIVATE — Wizard helpers
    // ═══════════════════════════════════════════════════════

    private function getWizardPages(string $goal, string $industry, array $services): array
    {
        $pages = [
            ['title' => 'Home', 'slug' => 'home', 'type' => 'page'],
            ['title' => 'About Us', 'slug' => 'about', 'type' => 'page'],
        ];

        if (!empty($services)) {
            $pages[] = ['title' => 'Services', 'slug' => 'services', 'type' => 'page'];
        }

        if (in_array($goal, ['portfolio', 'brand'])) {
            $pages[] = ['title' => 'Portfolio', 'slug' => 'portfolio', 'type' => 'page'];
        }

        if (in_array($goal, ['leads', 'ecommerce'])) {
            $pages[] = ['title' => 'Contact', 'slug' => 'contact', 'type' => 'page'];
        }

        $pages[] = ['title' => 'Blog', 'slug' => 'blog', 'type' => 'blog_post'];

        return $pages;
    }

    private function generatePageSections(array $template, string $business, string $industry, string $goal, array $bpOverrides = []): array
    {
        $sections = [];

        if ($template['slug'] === 'home') {
            $sections[] = $this->heroSection($business, $industry, $goal, $bpOverrides);
            $sections[] = $this->featuresSection($business, $bpOverrides['trust_signals'] ?? [], $industry, $goal);
            $sections[] = $this->ctaSection($goal, $bpOverrides['cta_primary'] ?? null);
        } elseif ($template['slug'] === 'about') {
            $sections[] = ['type' => 'text', 'heading' => "About {$business}", 'body' => "We are a {$industry} business dedicated to excellence."];
            $sections[] = ['type' => 'team', 'heading' => 'Our Team'];
        } elseif ($template['slug'] === 'services') {
            $sections[] = ['type' => 'services_grid', 'heading' => 'Our Services'];
        } elseif ($template['slug'] === 'contact') {
            $sections[] = ['type' => 'contact_form', 'heading' => 'Get in Touch', 'fields' => ['name', 'email', 'phone', 'message']];
            $sections[] = ['type' => 'map', 'heading' => 'Find Us'];
        } else {
            $sections[] = ['type' => 'text', 'heading' => $template['title'], 'body' => ''];
        }

        // Wrap with header (navigation) and footer
        $pageNames = array_map(fn($p) => $p['title'], $pageTemplates);
        $header = [
            'type' => 'header',
            'style' => ['bg' => 'rgba(15,17,23,0.95)'],
            'components' => [
                ['type' => 'heading', 'text' => $business],
                ['type' => 'text', 'text' => implode(' · ', $pageNames)],
                ['type' => 'button', 'text' => 'Contact Us', 'href' => '#contact', 'variant' => 'primary'],
            ],
        ];
        $footer = [
            'type' => 'footer',
            'business_name' => $business,
            'tagline' => "Your trusted {$industry} partner",
            'nav_items' => array_map(fn($p) => ['label' => $p, 'href' => '#' . strtolower($p)], $pageNames),
            'copyright' => '© ' . date('Y') . ' ' . $business . '. All rights reserved.',
        ];

        array_unshift($sections, $header);
        $sections[] = $footer;

        return ['schemaVersion' => 1, 'sections' => $sections];
    }

    private function heroSection(string $business, string $industry, string $goal, array $bp = []): array
    {
        $cta = $bp['cta_primary'] ?? match ($goal) {
            'leads'     => 'Get a Free Quote',
            'ecommerce' => 'Shop Now',
            'brand'     => 'Learn More',
            'portfolio' => 'View Our Work',
            default     => 'Get Started',
        };

        // Look up industry hero image from builder_default_assets
        $industryKey = $this->mapIndustryToKey($industry);
        $heroImage = DB::table('builder_default_assets')
            ->where('industry', $industryKey)
            ->where('asset_type', 'hero')
            ->value('url');

        // Fallback to default
        $heroImage = $heroImage ?? DB::table('builder_default_assets')
            ->where('industry', 'default')
            ->where('asset_type', 'hero')
            ->value('url');

        return [
            'type'             => 'hero',
            'heading'          => $bp['hero_headline'] ?? $business,
            'subheading'       => $bp['hero_sub'] ?? "Your trusted {$industry} partner",
            'cta_text'         => $cta,
            'cta_link'         => '#contact',
            'background_image' => $heroImage,
        ];
    }

    private function mapIndustryToKey(string $industry): string
    {
        $lower = strtolower($industry);
        if (preg_match('/interior|design|furniture|home decor/i', $lower)) return 'interior_design';
        if (preg_match('/restaurant|food|cafe|bakery|catering/i', $lower)) return 'restaurant';
        if (preg_match('/fitness|gym|sport|yoga|wellness/i', $lower)) return 'fitness';
        if (preg_match('/health|medical|dental|clinic|pharma/i', $lower)) return 'healthcare';
        if (preg_match('/law|legal|attorney/i', $lower)) return 'legal';
        if (preg_match('/real.estate|property|realty/i', $lower)) return 'real_estate';
        if (preg_match('/fashion|retail|clothing|boutique/i', $lower)) return 'fashion';
        if (preg_match('/tech|software|saas|digital|it/i', $lower)) return 'technology';
        if (preg_match('/event|wedding|conference|catering/i', $lower)) return 'events';
        if (preg_match('/beauty|spa|salon|cosmetic/i', $lower)) return 'beauty';
        if (preg_match('/finance|accounting|bank|insurance/i', $lower)) return 'legal';
        return 'default';
    }

    private function featuresSection(string $business, array $trustSignals = [], string $industry = '', string $goal = ''): array
    {
        // Try AI-generated industry-specific features
        if ($this->runtime->isConfigured() && $industry) {
            try {
                $result = $this->runtime->chatJson(
                    "You are a copywriter for {$industry} businesses. Output JSON only.",
                    "Generate 3 compelling features/benefits for '{$business}' ({$industry}).
                    Return: {\"features\":[{\"icon\":\"emoji\",\"title\":\"4-6 words\",\"description\":\"1 sentence\"}]}",
                    ['industry' => $industry], 400
                );
                if (($result['success'] ?? false) && !empty($result['parsed']['features'])) {
                    return ['type' => 'features', 'heading' => "Why Choose {$business}", 'items' => $result['parsed']['features']];
                }
            } catch (\Throwable $e) {
                \Illuminate\Support\Facades\Log::debug('[Builder] AI features failed, using defaults: ' . $e->getMessage());
            }
        }

        // Industry-specific fallbacks
        $items = $this->defaultFeatures($industry);
        return ['type' => 'features', 'heading' => "Why Choose {$business}", 'items' => $items];
    }

    private function defaultFeatures(string $industry): array
    {
        $lower = strtolower($industry);
