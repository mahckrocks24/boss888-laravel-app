    /**
     * Parse and validate AI JSON response into sections array.
     * Ported from: lu_wizard_parse_ai_sections (WP line ~1300)
     *
     * @return array|null  Array of sections on success, null on any failure
     */
    private function parseAiSections(string $raw): ?array
    {
        if (empty($raw)) return null;

        $text = $raw;

        // If the raw string is itself JSON (e.g. from chatJson), extract text/content
        $decoded = json_decode($raw, true);
        if (is_array($decoded)) {
            $text = $decoded['text'] ?? $decoded['content'] ?? $raw;
        }

        if (!$text || !is_string($text)) return null;

        // Strip markdown fences
        $text = preg_replace('/```(?:json)?\s*([\s\S]*?)\s*```/', '$1', $text);

        // Extract first JSON array
        if (!preg_match('/\[[\s\S]*\]/', $text, $m)) return null;

        $sections = json_decode($m[0], true);
        if (!is_array($sections) || empty($sections)) return null;

        return $sections;
    }

    /**
     * Merge AI-generated copy into template sections using type-based matching.
     * Ported from: lu_wizard_merge_ai_copy (WP line ~1420)
     *
     * Template = source of truth for section order, IDs, styles
     * AI = source of truth for all text/copy content
     */
    private function mergeAiCopy(array $sections, array $aiSections): array
    {
        $allowedTypes = ['heading', 'text', 'button', 'cards', 'form', 'image', 'list',
                         'gallery', 'divider', 'spacer', 'video', 'testimonials'];

        // Index AI sections by type (type-based matching, not index-based)
        $aiByType    = [];
        foreach ($aiSections as $aiSec) {
            $t = strtolower($aiSec['type'] ?? '');
            if (!isset($aiByType[$t])) $aiByType[$t] = [];
            $aiByType[$t][] = $aiSec;
        }
        $aiTypeCursor = [];

        $merged = [];
        foreach ($sections as $templateSec) {
            $tmplType = strtolower($templateSec['type'] ?? '');

            // Never AI-modify header or footer
            if ($tmplType === 'header' || $tmplType === 'footer') {
                $merged[] = $templateSec;
                continue;
            }

            // Find matching AI section by type
            $cursor = $aiTypeCursor[$tmplType] ?? 0;
            $aiSec  = $aiByType[$tmplType][$cursor] ?? null;
            $aiTypeCursor[$tmplType] = $cursor + 1;

            // Fallback: if no type match, try positional from remaining AI sections
            if (!$aiSec) {
                $aiSec = array_shift($aiSections);
            }

            if (!$aiSec || !isset($aiSec['components'])) {
                // No AI data — check for flat keys (heading, subheading, body, cta_text)
                // to merge AI content into the simpler Laravel section format
                if ($aiSec && is_array($aiSec)) {
                    $mergedSec = $templateSec;
                    if (!empty($aiSec['heading']))    $mergedSec['heading']    = $aiSec['heading'];
                    if (!empty($aiSec['subheading']))  $mergedSec['subheading'] = $aiSec['subheading'];
                    if (!empty($aiSec['body']))        $mergedSec['body']       = $aiSec['body'];
                    if (!empty($aiSec['cta_text']))    $mergedSec['cta_text']   = $aiSec['cta_text'];
                    if (!empty($aiSec['label']))       $mergedSec['label']      = $aiSec['label'];
                    if (!empty($aiSec['items']) && is_array($aiSec['items'])) {
                        $mergedSec['items'] = $aiSec['items'];
                    }
                    $merged[] = $mergedSec;
                } else {
                    $merged[] = $templateSec;
                }
                continue;
            }

            $mergedSec = $templateSec; // preserve style, id, section_order from template
            $mergedComponents = [];

            // If template has 'components' array, do component-level merge
            if (!empty($templateSec['components'])) {
                foreach ($templateSec['components'] as $ci => $templateCmp) {
                    $ctype = $templateCmp['type'] ?? 'text';

                    // Validate component type against whitelist
                    if (!in_array($ctype, $allowedTypes, true)) {
                        $ctype = 'text';
                        $templateCmp['type'] = 'text';
                    }

                    // Find matching AI component by type
                    $aiCmp = null;
                    foreach ($aiSec['components'] as $aiC) {
                        if (($aiC['type'] ?? '') === $ctype) {
                            $aiCmp = $aiC;
                            break;
                        }
                    }
                    // Positional fallback
                    if (!$aiCmp) $aiCmp = $aiSec['components'][$ci] ?? null;

                    $mergedCmp = $templateCmp;

                    if ($aiCmp) {
                        switch ($ctype) {
                            case 'heading':
                            case 'text':
                                if (!empty($aiCmp['text'])) {
                                    $mergedCmp['text'] = strip_tags($aiCmp['text']);
                                }
                                break;
                            case 'button':
                                if (!empty($aiCmp['text'])) {
                                    $mergedCmp['text']  = strip_tags($aiCmp['text']);
                                    $mergedCmp['label'] = $mergedCmp['text'];
                                }
                                // Never overwrite href from template
                                break;
                            case 'cards':
                                if (!empty($aiCmp['items']) && is_array($aiCmp['items'])) {
                                    $aiItems   = $aiCmp['items'];
                                    $tmplItems = $templateCmp['items'] ?? [];
                                    $count     = max(count($tmplItems), min(count($aiItems), 6));
                                    $mergedItems = [];
                                    for ($k = 0; $k < $count; $k++) {
                                        $aiItem   = $aiItems[$k]   ?? $aiItems[0]   ?? [];
                                        $tmplItem = $tmplItems[$k]  ?? $tmplItems[0]  ?? [];
                                        $mergedItems[] = [
                                            'icon'    => strip_tags($aiItem['icon']    ?? $tmplItem['icon']    ?? ''),
                                            'heading' => strip_tags($aiItem['heading'] ?? $tmplItem['heading'] ?? ''),
                                            'text'    => strip_tags($aiItem['text']    ?? $tmplItem['text']    ?? ''),
                                            'name'    => strip_tags($aiItem['name']    ?? $tmplItem['name']    ?? ''),
                                            'role'    => strip_tags($aiItem['role']    ?? $tmplItem['role']    ?? ''),
                                            'title'   => strip_tags($aiItem['title']   ?? $tmplItem['title']   ?? ''),
                                        ];
                                    }
                                    $mergedCmp['items'] = $mergedItems;
                                }
                                break;
                            case 'form':
                                // Never overwrite form fields — template structure is authoritative
                                break;
                        }
                    }
                    $mergedComponents[] = $mergedCmp;
                }
                $mergedSec['components'] = $mergedComponents;
            } else {
                // Template uses flat keys (heading, body, etc.) — merge AI component text into flat fields
                foreach ($aiSec['components'] as $aiCmp) {
                    $cmpType = $aiCmp['type'] ?? '';
                    if ($cmpType === 'heading' && !empty($aiCmp['text'])) {
                        $mergedSec['heading'] = strip_tags($aiCmp['text']);
                    } elseif ($cmpType === 'text' && !empty($aiCmp['text'])) {
                        // Use 'subheading' for hero, 'body' for others
                        if ($tmplType === 'hero') {
                            $mergedSec['subheading'] = strip_tags($aiCmp['text']);
                        } else {
                            $mergedSec['body'] = strip_tags($aiCmp['text']);
                        }
                    } elseif ($cmpType === 'button' && !empty($aiCmp['text'])) {
                        $mergedSec['cta_text'] = strip_tags($aiCmp['text']);
                    } elseif ($cmpType === 'cards' && !empty($aiCmp['items'])) {
                        $mergedSec['items'] = array_map(function ($item) {
                            return [
                                'icon'    => strip_tags($item['icon']    ?? ''),
                                'heading' => strip_tags($item['heading'] ?? $item['title'] ?? ''),
                                'text'    => strip_tags($item['text']    ?? $item['description'] ?? ''),
                                'name'    => strip_tags($item['name']    ?? ''),
                                'role'    => strip_tags($item['role']    ?? ''),
                            ];
                        }, $aiCmp['items']);
                    }
                }
            }

            $merged[] = $mergedSec;
        }

        return $merged;
    }
