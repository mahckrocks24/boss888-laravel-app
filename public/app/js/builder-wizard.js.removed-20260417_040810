  var typing = document.createElement('div');
  typing.id = 'arthur-typing';
  typing.className = 'aw-bubble-enter';
  typing.style.cssText = 'display:flex;gap:10px;align-items:flex-start';
  typing.innerHTML = '<div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#6C5CE7,#A855F7);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:900;color:#fff;flex-shrink:0;box-shadow:0 4px 10px rgba(108,92,231,.35)">\u26A1</div>'
    + '<div style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.07);border-radius:4px 18px 18px 18px;padding:14px 18px;display:flex;align-items:center;gap:5px">'
    + '<span class="aw-dot"></span><span class="aw-dot"></span><span class="aw-dot"></span>'
    + '</div>';
  var msgsEl = document.getElementById('arthur-wiz-msgs');
  if (msgsEl) { msgsEl.appendChild(typing); msgsEl.scrollTop = 99999; }
  inp.disabled = true;

  // ── AI call with retry ────────────────────────────────────────────────
  var aiReply = null;
  _arthurWizRetryCount = 0;

  try {

  while (_arthurWizRetryCount <= _arthurMaxRetries) {
    try {
      // LARAVEL ADAPTATION: POST /api/agent/dispatch with agent context
      var arthurCtx = {};
      arthurCtx.source       = 'arthur_wizard';
      arthurCtx.arthur_state = window._arthurState;
      arthurCtx.wizard_mode  = true;

      var r = await fetch(API + 'builder/arthur', {
        method: 'POST',
        headers: Object.assign({'Content-Type': 'application/json'}, authHeader()),
        body: JSON.stringify({
          mode: 'wizard',
          message: text,
          arthur_state: window._arthurState,
          history: _arthurConvo.slice(-8),
        })
      });

      if (r.status === 429) {
        _arthurWizRetryCount++;
        if (_arthurWizRetryCount <= _arthurMaxRetries) {
          if (requestId !== window._arthurLastRequestId) break;
          await new Promise(function(res){ setTimeout(res, _arthurWizRetryCount * 1000); });
          continue;
        }
        if (requestId === window._arthurLastRequestId) {
          aiReply = _arthurSmartFallback(text);
        }
        break;
      }
      if (!r.ok) {
        _arthurWizRetryCount++;
        if (_arthurWizRetryCount <= _arthurMaxRetries) {
          if (requestId !== window._arthurLastRequestId) break;
          await new Promise(function(res){ setTimeout(res, _arthurWizRetryCount * 1000); });
          continue;
        }
        if (requestId === window._arthurLastRequestId) {
          aiReply = _arthurSmartFallback(text);
        }
        break;
      }

      var d = await r.json();

      if (requestId !== window._arthurLastRequestId) { break; }

      if (!d.response && !d.reply) {
        aiReply = _arthurSmartFallback(text);
        break;
      }

      aiReply = d.response || d.reply || '';

      if (d.extracted && typeof d.extracted === 'object') {
        var aiFilled = _arthurMergeDetected(d.extracted, 'medium', 'ai');
        if (aiFilled.length > 0) _arthurTurnsWithoutProgress = 0;
      }

      if (d.ready === true) {
        if (requestId === window._arthurLastRequestId) {
          var typingEl = document.getElementById('arthur-typing');
          if (typingEl) typingEl.remove();
          window._arthurResponding = false;
          window._arthurState.ready = true;
          var wizInp = document.getElementById('arthur-wiz-input');
          if (wizInp) { wizInp.disabled = true; wizInp.placeholder = 'Generating your website...'; }
          if (aiReply) { _arthurConvo.push({role:'assistant', content: aiReply}); _arthurBub(aiReply); }
          setTimeout(_arthurWizGenerate, 800);
        }
        return;
      }

      break; // success

    } catch(e) {
      _arthurWizRetryCount++;
      if (_arthurWizRetryCount <= _arthurMaxRetries) {
        if (requestId !== window._arthurLastRequestId) break;
        await new Promise(function(res){ setTimeout(res, _arthurWizRetryCount * 1000); });
        continue;
      }
      if (requestId === window._arthurLastRequestId) {
        aiReply = _arthurSmartFallback(text);
      }
      break;
    }
  } // end while

  } finally {
    window._arthurResponding = false;
  }

  var typingEl2 = document.getElementById('arthur-typing');
  if (typingEl2) typingEl2.remove();
  inp.disabled = false;

  if (requestId !== window._arthurLastRequestId) {
    console.warn('[Arthur Wiz] Stale response dropped (requestId mismatch)');
    inp.focus();
    return;
  }

  if (aiReply && !window._arthurState.ready) {
    _arthurConvo.push({role: 'assistant', content: aiReply});
    _arthurBub(aiReply);
  }

  if (_arthurCheckReady()) {
