// Arthur sends EVERY message to the AI
async function _arthurWizSend() {
  var inp = document.getElementById('arthur-wiz-input');
  if (!inp || inp.disabled) return;
  var text = inp.value.trim();
  if (!text) return;

  if (window._arthurResponding === true) return;
  window._arthurResponding = true;

  var requestId = Date.now();
  window._arthurLastRequestId = requestId;

  inp.value = '';
  _arthurBub(text, true);
  _arthurConvo.push({role: 'user', content: text});

  // ── Correction handler ────────────────────────────────────────────────
  var correctionPatterns = [
    /(?:actually[,\s]+(?:the\s+)?(?:business|company|name|brand)\s+(?:is|called)\s+)([A-Z][A-Za-z0-9 &'.\-]{2,40})/i,
    /(?:actually[,\s]+it'?s?\s+)([A-Z][A-Za-z0-9 &'.\-]{2,40})/i,
    /(?:no[,\s]+it'?s?\s+)([A-Z][A-Za-z0-9 &'.\-]{2,40})/i,
    /(?:correction[:\s]+)([A-Z][A-Za-z0-9 &'.\-]{2,40})/i,
    /(?:not\s+\w+[,\s]+it'?s?\s+)([A-Z][A-Za-z0-9 &'.\-]{2,40})/i,
    /(?:not\s+\w+[,\s]+(?:it'?s?\s+called?\s+|the\s+name\s+is\s+))([A-Z][A-Za-z0-9 &'.\-]{2,40})/i,
    /(?:the\s+(?:company|business)\s+name\s+is\s+)([A-Z][A-Za-z0-9 &'.\-]{2,40})/i,
  ];
  var correctionApplied = false;
  for (var ci = 0; ci < correctionPatterns.length; ci++) {
    var cm = text.match(correctionPatterns[ci]);
    if (cm && cm[1]) {
      var corrVal = cm[1].trim().replace(/[,.\s]+$/, '');
      if (_arthurIsValidBusinessName(corrVal)) {
        window._arthurState.business_name = corrVal;
        window._arthurState._confidence['business_name'] = 'high';
        correctionApplied = true;
        _arthurTurnsWithoutProgress = 0;
        break;
      }
    }
  }

  // ── Run local interpreter BEFORE AI ─────────────────────────────────
  var interp = _arthurWizInterpretInput(text);
  var validFilled = interp.validFilled || interp.filled;
  var localFilled = _arthurMergeDetected(interp.detected, interp.confidence, 'interpreter');

  // ── Check readiness immediately ───────────────────────────────────────
  if (_arthurCheckReady()) {
    window._arthurState.ready = true;
    inp.disabled = true;
    inp.placeholder = 'Generating your website...';
    _arthurBub('Great, I have everything I need! Building your website now...');
    window._arthurResponding = false;
    setTimeout(_arthurWizGenerate, 800);
    return;
  }

  // ── Stall counter ─────────────────────────────────────────────────────
  if (validFilled.length > 0 || correctionApplied) {
    _arthurTurnsWithoutProgress = 0;
  } else {
    _arthurTurnsWithoutProgress++;
  }

  // ── Stall tracking (no hard stop — LLM handles all responses) ────────
  // Previously this would fire direct questions before AI got a chance.
  // Now the LLM always responds — it's instructed to infer and never re-ask.

  // ── Local greeting handler (only for very first message with no context) ──
  var isSimpleGreeting = /^(hi|hello|hey|hiya|howdy|greetings|start|begin|go|lets go|let'?s go)\s*[!.]*$/i.test(text.trim());
  if (isSimpleGreeting && !window._arthurState.business_name && !window._arthurState.industry && _arthurConvo.length <= 1) {
    var greetReply = "Hey! \uD83D\uDC4B Tell me about your business \u2014 what\u2019s it called and what do you do? I\u2019ll have your website ready in under a minute.";
    _arthurConvo.push({role: 'assistant', content: greetReply});
    _arthurBub(greetReply);
    inp.focus();
    window._arthurResponding = false;
    return;
  }

  // ── Local meta-question handler ───────────────────────────────────────
  var isMetaQuestion = /^(are you|who are you|what are you|who made you|what can you do|how do you work|what is this|what'?s this|tell me about yourself|introduce yourself|are you (a )?bot|are you real|are you human|what'?s your name|what do you do)\b/i.test(text.trim());
  if (isMetaQuestion) {
    var metaReply = "Yes, I'm Arthur \u26A1 \u2014 an AI website builder created by LevelUp. I specialise in one thing: building you a professional website fast. Just tell me your business name and what you do, and I'll have a site ready in under a minute.";
    _arthurConvo.push({role: 'assistant', content: metaReply});
    _arthurBub(metaReply);
    inp.focus();
    window._arthurResponding = false;
    return;
  }

  // Show typing indicator
  if (!document.getElementById('aw-dot-style')) {
    var ds = document.createElement('style');
    ds.id = 'aw-dot-style';
    ds.textContent = '@keyframes awDot{0%,80%,100%{transform:scale(.6);opacity:.3}40%{transform:scale(1);opacity:1}}'
      + '#arthur-typing .aw-dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:rgba(108,92,231,.7);animation:awDot 1.3s ease-in-out infinite}'
      + '#arthur-typing .aw-dot:nth-child(2){animation-delay:.16s}'
      + '#arthur-typing .aw-dot:nth-child(3){animation-delay:.32s}';
