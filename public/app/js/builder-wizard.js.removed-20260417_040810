    if (dq) _arthurBub(dq);
  }

  inp.focus();
}

function _arthurClassifyError(errMsg) {
  var msg = (errMsg || '').toLowerCase();
  if (/business_name.*required|name.*required/i.test(msg)) return 'MISSING_PARAM';
  if (/invalid|format|type|must be/i.test(msg))           return 'VALIDATION_ERROR';
  if (/timeout|connect|network|502|503|runtime/i.test(msg)) return 'API_ERROR';
  if (/permission|not allowed|unauthorized|403/i.test(msg)) return 'PERMISSION';
  return 'UNKNOWN';
}

function _arthurUserFriendlyError(errType, rawMsg) {
  switch (errType) {
    case 'MISSING_PARAM':    return 'I\'m missing a required detail. Please tell me your business name.';
    case 'VALIDATION_ERROR': return 'There was a format issue: ' + rawMsg + '. Please check your details.';
    case 'API_ERROR':        return 'The AI service is temporarily slow. I\'ll retry automatically...';
    case 'PERMISSION':       return 'Permission issue. Please refresh the page and try again.';
    default:                 return 'Something went wrong: ' + rawMsg + '. Please try again.';
  }
}

