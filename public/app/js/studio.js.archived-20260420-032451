            '<div class="std-tabs">' +
              ['background','text','colors'].map(function (t) {
                return '<div class="std-tab ' + (STD.activeTab === t ? 'active' : '') + '" data-tab="' + t + '" onclick="_studioSetTab(\'' + t + '\')">' + t.toUpperCase() + '</div>';
              }).join('') +
            '</div>' +
            '<div class="std-tab-body" id="std-tab-body"></div>' +
          '</div>' +
        '</div>' +
      '</div>';
    _renderCanvas();
    _renderTab();
  }

  window._studioSetTab = function (t) {
    STD.activeTab = t;
    document.querySelectorAll('.std-tab').forEach(function (el) { el.classList.toggle('active', el.dataset.tab === t); });
    _renderTab();
  };

  // ── Canvas render ─────────────────────────────────────────────────
  function _renderCanvas() {
    var wrap = document.getElementById('std-canvas-wrap');
    if (!wrap) return;
    var L = STD.design.layers;
    var cw = L.canvas_width, ch = L.canvas_height;
    // Compute scale so canvas fits inside viewport.
    var maxW = wrap.clientWidth - 60, maxH = wrap.clientHeight - 60;
    var scale = Math.min(maxW / cw, maxH / ch, 1);
    if (!isFinite(scale) || scale <= 0) scale = 0.5;

    var filterCss = _filterCssFromLayers(L.layers);
    var html = '<div class="std-canvas" id="std-canvas" data-design-id="' + STD.design.id + '" style="width:' + cw + 'px;height:' + ch + 'px;transform:scale(' + scale + ');' + filterCss + '">';
    L.layers.forEach(function (layer) {
      html += _renderLayer(layer, cw, ch);
    });
    html += '</div>';
    wrap.innerHTML = html;

    // Make text editable on click
    wrap.querySelectorAll('[data-studio-field]').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.stopPropagation();
        if (el.getAttribute('contenteditable') === 'true') return;
        el.setAttribute('contenteditable', 'true');
        el.focus();
      });
      el.addEventListener('blur', function () {
        if (el.getAttribute('contenteditable') !== 'true') return;
        el.removeAttribute('contenteditable');
        var fid = el.getAttribute('data-studio-field');
        _updateText(fid, el.textContent);
      });
      el.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); el.blur(); }
      });
    });
    // Background click → media picker
    wrap.querySelectorAll('[data-studio-bg]').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.stopPropagation();
        _studioPickBackground();
      });
    });
  }

  // ── Render engine v2 (2026-04-20 rebuild) ────────────────────────
  // All positioning is in percentage units — works in both editor (full-size
  // canvas) and inline thumbnails (scaled wrapper). No px conversion.
  // Effects layer applies as a CSS filter on the canvas wrapper, not as a DOM node.
  function _renderLayer(layer, cw, ch) {
    if (!layer) return '';
    var d = layer.data || {};
    if (layer.type === 'background') return _renderBg(d);
    if (layer.type === 'overlay'  && layer.visible) return _renderOverlay(d);
    if (layer.type === 'media'    && layer.visible) return _renderMedia(d);
    if (layer.type === 'shapes'   && layer.visible) return _renderShapes(d.items || []);
    if (layer.type === 'text'     && layer.visible) return _renderText(d.items || []);
    if (layer.type === 'effects')   return ''; // applied as canvas filter, not as element
    return '';
  }

  function _renderBg(d) {
    var style;
    if (d.mode === 'image' && d.image_url) {
      style = "background-color:#000;background-image:url('" + d.image_url + "');background-size:cover;background-position:center;background-repeat:no-repeat";
    } else if (d.mode === 'gradient' && d.gradient) {
      var dir  = d.gradient.direction || '135deg';
      var from = d.gradient.from || '#000';
      var to   = d.gradient.to   || '#333';
      style = "background:linear-gradient(" + dir + ',' + from + ',' + to + ')';
    } else {
      style = 'background-color:' + (d.color || '#1A1A1A');
    }
    var html = '<div data-studio-bg="1" style="position:absolute;inset:0;z-index:1;' + style + '"></div>';
    var op = parseInt(d.overlay_opacity, 10) || 0;
    if (op > 0 && d.overlay_color) {
      html += '<div style="position:absolute;inset:0;background:' + d.overlay_color + ';z-index:2;pointer-events:none"></div>';
    }
    return html;
  }

  function _renderOverlay(d) {
    var op = parseInt(d.opacity, 10) || 0;
    if (op <= 0 || !d.color) return '';
    return '<div style="position:absolute;inset:0;background:' + d.color + ';opacity:' + (op / 100) + ';z-index:3;pointer-events:none"></div>';
  }

  function _renderMedia(d) {
    if (!d.image_url) return '';
    var pos = d.position || { x: 50, y: 50 };
    var sz  = d.size     || { width: 60, height: 60 };
    var op  = (typeof d.opacity === 'number' ? d.opacity : 100) / 100;
    return '<img src="' + d.image_url + '" style="position:absolute;'
      + 'left:' + pos.x + '%;top:' + pos.y + '%;'
      + 'width:' + sz.width + '%;height:' + sz.height + '%;'
      + 'object-fit:cover;opacity:' + op + ';z-index:4;pointer-events:none" alt="">';
  }

  function _renderShapes(items) {
    return items.map(function (s) {
      var radius = s.type === 'circle' ? '50%' : ((s.border_radius || 0) + 'px');
      var border = (s.border_width && s.border_color)
        ? 'border:' + s.border_width + 'px solid ' + s.border_color + ';'
        : '';
      var bg = (s.color === 'transparent') ? 'transparent' : (s.color || '#FFFFFF');
      var op = (typeof s.opacity === 'number' ? s.opacity : 100) / 100;
      return '<div style="position:absolute;'
        + 'left:' + s.x + '%;top:' + s.y + '%;'
        + 'width:' + s.width + '%;height:' + s.height + '%;'
        + 'background:' + bg + ';opacity:' + op + ';'
        + 'border-radius:' + radius + ';' + border
        + 'z-index:5;pointer-events:none;box-sizing:border-box"></div>';
    }).join('');
  }

  function _renderText(items) {
    return items.map(function (t) {
      var align = t.alignment || 'left';
      // Translate origin so (x, y) corresponds visually:
      //   left   → x = left edge of text
      //   center → x = horizontal center
      //   right  → x = right edge
      // y is always vertical center of text.
      var translate;
      if (align === 'center')      translate = 'translate(-50%,-50%)';
      else if (align === 'right')  translate = 'translate(-100%,-50%)';
      else                         translate = 'translate(0,-50%)';
      var styles = [
        'position:absolute',
        'left:' + (t.x != null ? t.x : 5) + '%',
        'top:'  + (t.y != null ? t.y : 50) + '%',
        'transform:' + translate,
        'font-family:"' + (t.font_family || 'Inter') + '",-apple-system,system-ui,sans-serif',
        'font-size:' + (t.font_size || 16) + 'px',
        'font-weight:' + (t.font_weight || '400'),
        'color:' + (t.color || '#FFFFFF'),
        'text-align:' + align,
        'line-height:1.2',
        'max-width:90%',
        'z-index:10',
        'white-space:pre-wrap',
        'word-wrap:break-word',
        'overflow-wrap:break-word',
        'margin:0',
        'padding:0',
      ];
      if (t.text_transform) styles.push('text-transform:' + t.text_transform);
      if (t.letter_spacing) styles.push('letter-spacing:' + t.letter_spacing + 'px');
      var attr = t.editable ? (' data-studio-field="' + (t.id || '') + '"') : '';
      return '<div' + attr + ' data-role="' + (t.role || '') + '" style="' + styles.join(';') + '">' + _esc(t.content || '') + '</div>';
    }).join('');
  }

  // ── Tools panel render ────────────────────────────────────────────
  function _renderTab() {
    var body = document.getElementById('std-tab-body');
    if (!body) return;
    if (STD.activeTab === 'background') body.innerHTML = _bgTabHtml();
    else if (STD.activeTab === 'text')   body.innerHTML = _textTabHtml();
    else if (STD.activeTab === 'colors') body.innerHTML = _colorsTabHtml();
  }

  function _bgTabHtml() {
    var bg = STD.design.layers.layers.find(function (l) { return l.type === 'background'; });
    var d = bg.data;
    return '' +
      '<div class="std-row"><label class="std-label">Background mode</label>' +
        '<select class="std-input" onchange="_studioSetBgMode(this.value)">' +
          '<option value="color"' + (d.mode === 'color' ? ' selected' : '') + '>Solid color</option>' +
          '<option value="gradient"' + (d.mode === 'gradient' ? ' selected' : '') + '>Gradient</option>' +
          '<option value="image"' + (d.mode === 'image' ? ' selected' : '') + '>Image</option>' +
        '</select></div>' +
      (d.mode === 'color' ? '<div class="std-row"><label class="std-label">Color</label><input type="color" class="std-input" value="' + (d.color || '#1A1A1A') + '" oninput="_studioSetBg({color:this.value})"></div>' : '') +
      (d.mode === 'gradient' ? '<div class="std-row"><label class="std-label">From</label><input type="color" class="std-input" value="' + (d.gradient && d.gradient.from || '#1A1A2E') + '" oninput="_studioSetGradient({from:this.value})"></div><div class="std-row"><label class="std-label">To</label><input type="color" class="std-input" value="' + (d.gradient && d.gradient.to || '#0F3460') + '" oninput="_studioSetGradient({to:this.value})"></div>' : '') +
      (d.mode === 'image' ? '<div class="std-row"><button class="std-btn" style="width:100%" onclick="_studioPickBackground()">\uD83D\uDDBC Choose from Library</button></div>' : '') +
      '<div class="std-row"><label class="std-label">Overlay opacity</label><input type="range" min="0" max="100" value="' + (d.overlay_opacity || 0) + '" oninput="_studioSetOverlay({opacity:this.value})" style="width:100%"></div>';
  }

  function _textTabHtml() {
    var text = STD.design.layers.layers.find(function (l) { return l.type === 'text'; });
    var items = (text && text.data.items) || [];
    var html = '<div style="font-size:11px;color:var(--t3);margin-bottom:10px">Click any text on the canvas to edit it inline. Style controls apply to selected.</div>';
    items.forEach(function (t) {
      html += '<div style="padding:10px;background:var(--s2);border-radius:6px;margin-bottom:8px;border:1px solid ' + (STD.selectedTextId === t.id ? 'var(--p)' : 'var(--bd)') + ';cursor:pointer" onclick="_studioSelectText(\'' + t.id + '\')">' +
        '<div style="font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px">' + (t.role || 'text') + '</div>' +
        '<div style="font-size:12px;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + _esc(t.content) + '</div>' +
      '</div>';
    });
    if (STD.selectedTextId) {
      var sel = items.find(function (i) { return i.id === STD.selectedTextId; });
      if (sel) {
        html += '<hr style="border:none;border-top:1px solid var(--bd);margin:14px 0">' +
          '<div class="std-row"><label class="std-label">Font</label><select class="std-input" onchange="_studioSetTextProp(\'font_family\',this.value)">' + FONTS.map(function (f) { return '<option value="' + f + '"' + (sel.font_family === f ? ' selected' : '') + '>' + f + '</option>'; }).join('') + '</select></div>' +
          '<div class="std-row"><label class="std-label">Size: <span id="std-fs-val">' + sel.font_size + 'px</span></label><input type="range" min="10" max="240" value="' + sel.font_size + '" oninput="_studioSetTextProp(\'font_size\',+this.value);document.getElementById(\'std-fs-val\').textContent=this.value+\'px\'" style="width:100%"></div>' +
          '<div class="std-row"><label class="std-label">Color</label><input type="color" class="std-input" value="' + (sel.color || '#FFFFFF') + '" oninput="_studioSetTextProp(\'color\',this.value)"></div>' +
          '<div class="std-row"><label class="std-label">Alignment</label><div style="display:flex;gap:6px">' +
            ['left','center','right'].map(function (a) {
              return '<button class="std-btn-ghost std-btn" style="flex:1' + (sel.alignment === a ? ';border-color:var(--p);color:var(--p)' : '') + '" onclick="_studioSetTextProp(\'alignment\',\'' + a + '\')">' + a + '</button>';
            }).join('') +
          '</div></div>';
      }
    }
    return html;
  }

  function _colorsTabHtml() {
    return '<div style="font-size:11px;color:var(--t3);margin-bottom:10px">Click a palette to swap accent + text colors across the design.</div>' +
      '<div class="std-pal-grid">' +
      PALETTES.map(function (p) {
        return '<div class="std-pal-card" onclick="_studioApplyPalette(\'' + p.id + '\')">' +
          '<div class="std-pal-swatches"><span style="background:' + p.bg + '"></span><span style="background:' + p.accent + '"></span><span style="background:' + p.text + '"></span></div>' +
          '<div class="std-pal-name">' + p.name + '</div>' +
        '</div>';
      }).join('') + '</div>';
  }

  // ── Tool actions ──────────────────────────────────────────────────
  window._studioMarkDirty = function () {
    STD.isDirty = true;
    var s = document.getElementById('std-saving');
    if (s) { s.textContent = 'Saving\u2026'; s.classList.remove('saved'); }
    clearTimeout(STD.saveTimer);
    STD.saveTimer = setTimeout(function () { _studioSave(false); }, 1200);
  };

  function _updateText(fid, content) {
    var text = STD.design.layers.layers.find(function (l) { return l.type === 'text'; });
    if (!text) return;
    var item = text.data.items.find(function (i) { return i.id === fid; });
    if (item) { item.content = content; _studioMarkDirty(); }
  }

  window._studioSelectText = function (id) {
    STD.selectedTextId = id;
    _renderTab();
  };

  window._studioSetTextProp = function (prop, value) {
    if (!STD.selectedTextId) return;
    var text = STD.design.layers.layers.find(function (l) { return l.type === 'text'; });
    var item = text.data.items.find(function (i) { return i.id === STD.selectedTextId; });
    if (!item) return;
    item[prop] = value;
    _studioMarkDirty();
    _renderCanvas();
  };

  window._studioSetBgMode = function (mode) {
    var bg = STD.design.layers.layers.find(function (l) { return l.type === 'background'; });
    bg.data.mode = mode;
    _studioMarkDirty(); _renderCanvas(); _renderTab();
  };
  window._studioSetBg = function (patch) {
    var bg = STD.design.layers.layers.find(function (l) { return l.type === 'background'; });
    Object.assign(bg.data, patch);
    _studioMarkDirty(); _renderCanvas();
  };
  window._studioSetGradient = function (patch) {
    var bg = STD.design.layers.layers.find(function (l) { return l.type === 'background'; });
    bg.data.gradient = Object.assign({ from:'#1A1A2E', to:'#0F3460', direction:'135deg' }, bg.data.gradient || {}, patch);
    _studioMarkDirty(); _renderCanvas();
  };
  window._studioSetOverlay = function (patch) {
    var bg = STD.design.layers.layers.find(function (l) { return l.type === 'background'; });
    if (patch.opacity !== undefined) {
      bg.data.overlay_opacity = parseInt(patch.opacity, 10);
      bg.data.overlay_color = bg.data.overlay_color || 'rgba(0,0,0,0.5)';
    }
    _studioMarkDirty(); _renderCanvas();
  };

  window._studioPickBackground = function () {
    if (typeof window.openMediaPicker !== 'function') { alert('Media picker unavailable.'); return; }
    window.openMediaPicker({ type:'image', context:'studio', multiple:false }, function (file) {
      if (!file) return;
      var url = file.file_url || file.url || file.src || '';
      if (!url) return;
      var bg = STD.design.layers.layers.find(function (l) { return l.type === 'background'; });
      bg.data.mode = 'image';
      bg.data.image_url = url;
      _studioMarkDirty(); _renderCanvas(); _renderTab();
    });
  };

  // Apply palette: swap accent + text colors across all editable text + accent shapes.
  window._studioApplyPalette = function (paletteId) {
    var p = PALETTES.find(function (x) { return x.id === paletteId; });
    if (!p) return;
    var bg   = STD.design.layers.layers.find(function (l) { return l.type === 'background'; });
    var text = STD.design.layers.layers.find(function (l) { return l.type === 'text'; });
    var shapes = STD.design.layers.layers.find(function (l) { return l.type === 'shapes'; });

    if (bg.data.mode === 'color') bg.data.color = p.bg;
    text.data.items.forEach(function (t) {
      // Heuristic: badge/cta/brand → accent; muted-grey → muted; everything else → text.
      var current = (t.color || '').toLowerCase();
      var isAccent = (t.role === 'badge' || t.role === 'cta' || (current.indexOf('rgba(') === -1 && t.font_size && t.font_size <= 14 && (t.role === 'subheading')));
      if (t.role === 'badge' || t.role === 'cta') t.color = p.accent;
      else if (t.role === 'brand' || /rgba/.test(current)) t.color = p.muted;
      else t.color = p.text;
    });
    if (shapes && shapes.data.items) {
      shapes.data.items.forEach(function (s) {
        if (!s.color || s.color === 'transparent') return;
        // If shape was originally a "highlight bar" color, swap to palette accent.
        s.color = p.accent;
      });
    }
    _studioMarkDirty(); _renderCanvas();
  };

  // ── Save / Export ────────────────────────────────────────────────
  window._studioSave = function (showToastFlag) {
    if (!STD.design) return;
    var name = (document.getElementById('std-name') || {}).value || STD.design.meta.name;
    var payload = { name: name, layers_json: STD.design.layers };
    fetch('/api/studio/designs/' + STD.design.id, {
      method: 'PUT',
      headers: Object.assign({ 'Content-Type': 'application/json' }, TOKEN_HDR()),
      body: JSON.stringify(payload),
    }).then(function (r) { return r.json(); }).then(function (d) {
      var s = document.getElementById('std-saving');
      if (s) { s.textContent = 'All changes saved'; s.classList.add('saved'); }
      STD.isDirty = false;
      // Cache layers locally so re-opening this design renders correctly (MVP — proper GET endpoint to come).
      try { localStorage.setItem('lu_studio_design_' + STD.design.id, JSON.stringify({ meta: STD.design.meta, layers: STD.design.layers })); } catch (e) {}
      if (showToastFlag && typeof window.showToast === 'function') window.showToast('Design saved', 'success');
    }).catch(function () {
      var s = document.getElementById('std-saving');
      if (s) { s.textContent = 'Save failed'; s.style.color = '#F87171'; }
    });
  };

  window._studioExport = function () {
    _ensureHtml2Canvas(function (err, h2c) {
      if (err) { alert('Could not load export library.'); return; }
      var canvas = document.getElementById('std-canvas');
      if (!canvas) return;
      // Render at native canvas size by overriding scale temporarily.
      var prevTransform = canvas.style.transform;
      canvas.style.transform = 'scale(1)';
      h2c(canvas, { backgroundColor: null, useCORS: true, scale: 1 }).then(function (out) {
        canvas.style.transform = prevTransform;
        var dataUrl = out.toDataURL('image/png');
        // Send to server to persist + add to media library
        fetch('/api/studio/designs/' + STD.design.id + '/export', {
          method: 'POST',
          headers: Object.assign({ 'Content-Type': 'application/json' }, TOKEN_HDR()),
          body: JSON.stringify({ format: 'png', image_data: dataUrl }),
        }).then(function (r) { return r.json(); }).then(function (d) {
          if (d && d.success) {
            // Trigger browser download.
            var a = document.createElement('a');
            a.href = dataUrl;
            a.download = ((document.getElementById('std-name') || {}).value || 'design') + '.png';
            document.body.appendChild(a); a.click(); document.body.removeChild(a);
            if (typeof window.showToast === 'function') window.showToast('Exported and saved to Library', 'success');
          } else {
            alert('Export saved locally; server save failed.');
            var a2 = document.createElement('a'); a2.href = dataUrl; a2.download = 'design.png';
            document.body.appendChild(a2); a2.click(); document.body.removeChild(a2);
          }
        });
      });
    });
  };

  console.log('[LevelUp] Studio engine v0.1 loaded');
})();
