      '.std-tab{flex:1;padding:11px 8px;text-align:center;font-size:11px;font-weight:600;color:var(--t3,#777);cursor:pointer;text-transform:uppercase;letter-spacing:.05em;border-bottom:2px solid transparent}',
      '.std-tab.active{color:var(--p,#6C5CE7);border-bottom-color:var(--p)}',
      '.std-tab-body{flex:1;overflow:auto;padding:16px}',
      '.std-row{margin-bottom:14px}',
      '.std-label{display:block;font-size:11px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}',
      '.std-input{width:100%;background:var(--s2,#1e2030);border:1px solid var(--bd);color:var(--t1);padding:8px 10px;border-radius:6px;font-size:13px;font-family:inherit}',
      '.std-pal-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}',
      '.std-pal-card{padding:8px;border:1px solid var(--bd);border-radius:8px;cursor:pointer;background:var(--s2,#1e2030);transition:border-color .15s}',
      '.std-pal-card:hover{border-color:var(--p)}',
      '.std-pal-swatches{display:flex;gap:4px;height:18px;margin-bottom:6px;border-radius:4px;overflow:hidden}',
      '.std-pal-swatches span{flex:1}',
      '.std-pal-name{font-size:11px;color:var(--t2)}',
      // Editable hover
      '.std-canvas [data-studio-field]{cursor:text;outline-offset:3px;border-radius:2px}',
      '.std-canvas [data-studio-field]:hover{outline:2px dashed rgba(108,92,231,0.5)}',
      '.std-canvas [data-studio-field][contenteditable="true"]:focus{outline:2px solid #6C5CE7;background:rgba(108,92,231,0.08)}',
      '.std-canvas [data-studio-bg]{cursor:pointer;outline-offset:-2px}',
      '.std-canvas [data-studio-bg]:hover{outline:2px dashed rgba(108,92,231,0.5)}',
      '.std-saving{font-size:11px;color:var(--t3);margin-right:8px}',
