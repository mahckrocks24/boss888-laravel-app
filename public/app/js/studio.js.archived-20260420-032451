/* ── LevelUp Studio Engine v0.1 (MVP) ────────────────────────────────
 * AI-powered social-media image editor.
 * Two screens: Design Gallery + Canvas Editor.
 * Editor renders layers_json as scaled HTML/CSS, supports inline text edit,
 * background image swap via openMediaPicker, palette swap, PNG export via html2canvas.
 * Author: 2026-04-20
 */
(function () {
  'use strict';

  // ── Module state ──────────────────────────────────────────────────
  var STD = {
    view: 'gallery',      // 'gallery' | 'editor' | 'pick'
    designs: [],
    templates: [],
    pickFormat: 'square',
    pickCategory: 'all',
    design: null,         // current design { id, layers }
    selectedTextId: null,
    isDirty: false,
    saveTimer: null,
  };
  window._lustudio = STD;

  var TOKEN_HDR = function () {
    var t = localStorage.getItem('lu_token') || '';
    return { 'Authorization': 'Bearer ' + t, 'Accept': 'application/json' };
  };

  // ── 10 brand palettes (must match seeder list) ────────────────────
  var PALETTES = [
    { id:'dark_bold',    name:'Dark Bold',    bg:'#0A0A0A', accent:'#FF4D00', text:'#FFFFFF', muted:'rgba(255,255,255,0.65)' },
    { id:'navy_gold',    name:'Navy Gold',    bg:'#0F2044', accent:'#C9943A', text:'#FFFFFF', muted:'rgba(255,255,255,0.7)' },
    { id:'minimal',      name:'Pure Minimal', bg:'#FFFFFF', accent:'#1A1A1A', text:'#333333', muted:'#666666' },
    { id:'luxury_dark',  name:'Luxury Dark',  bg:'#1C1C1E', accent:'#C9943A', text:'#FAF7F2', muted:'rgba(250,247,242,0.65)' },
    { id:'fresh_green',  name:'Fresh Green',  bg:'#F0F7F0', accent:'#16A34A', text:'#1A1A1A', muted:'#546454' },
    { id:'blush_rose',   name:'Blush Rose',   bg:'#FDF0F3', accent:'#B76E79', text:'#2D1B1E', muted:'#7A5A5E' },
    { id:'ocean_blue',   name:'Ocean Blue',   bg:'#EBF4FF', accent:'#2563EB', text:'#0F172A', muted:'#475569' },
    { id:'warm_cream',   name:'Warm Cream',   bg:'#FDF6EC', accent:'#D4622A', text:'#2C1810', muted:'#7A5A44' },
    { id:'bold_red',     name:'Bold Red',     bg:'#1A0000', accent:'#DC2626', text:'#FFFFFF', muted:'rgba(255,255,255,0.7)' },
    { id:'sage_natural', name:'Sage Natural', bg:'#F2F7F2', accent:'#4A7C59', text:'#1A2A1A', muted:'#5C6E5F' },
  ];
  var FONTS = ['Bebas Neue','Playfair Display','Inter','Space Grotesk','Cormorant Garamond','Montserrat','DM Sans','Nunito','Barlow Condensed','Libre Baskerville'];
  var FORMATS = [
    { id:'square',    label:'Square',    w:1080, h:1080 },
    { id:'portrait',  label:'Portrait',  w:1080, h:1350 },
    { id:'story',     label:'Story',     w:1080, h:1920 },
    { id:'landscape', label:'Landscape', w:1200, h:628 },
    { id:'pinterest', label:'Pinterest', w:1000, h:1500 },
  ];

  function _esc(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

  // ── Public entry: window.studioLoad(rootEl) ───────────────────────
  window.studioLoad = function (root) {
    if (!root) return;
    STD.root = root;
    STD.view = 'gallery';
    _renderGallery();
  };

  // ── Load Google Fonts for the 10 template typefaces ──────────────
  function _ensureFonts() {
    if (document.getElementById('lu-studio-fonts')) return;
    var families = [
      'Bebas+Neue',
      'Playfair+Display:wght@400;500;600;700',
      'Inter:wght@400;500;600;700',
      'Space+Grotesk:wght@400;500;600;700',
      'Cormorant+Garamond:wght@400;500;600;700',
      'Montserrat:wght@400;500;600;700',
      'DM+Sans:wght@400;500;700',
      'Nunito:wght@400;600;700;800',
      'Barlow+Condensed:wght@400;600;700',
      'Libre+Baskerville:wght@400;700',
    ].map(function (f) { return 'family=' + f; }).join('&');
    var pre = document.createElement('link');
    pre.rel = 'preconnect'; pre.href = 'https://fonts.gstatic.com'; pre.crossOrigin = '';
    document.head.appendChild(pre);
    var l = document.createElement('link');
    l.id = 'lu-studio-fonts';
    l.rel = 'stylesheet';
    l.href = 'https://fonts.googleapis.com/css2?' + families + '&display=swap';
    document.head.appendChild(l);
  }

  // ── Inject CSS once ───────────────────────────────────────────────
  function _ensureCss() {
    _ensureFonts();
    if (document.getElementById('lu-studio-css')) return;
    var s = document.createElement('style');
    s.id = 'lu-studio-css';
    s.textContent = [
      '.std-wrap{display:flex;flex-direction:column;height:100%;color:var(--t1,#e0e0e0);font-family:var(--fb,system-ui)}',
      '.std-hdr{padding:14px 22px;border-bottom:1px solid var(--bd,#2a2d3e);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-shrink:0}',
      '.std-hdr h2{margin:0;font-size:18px;font-weight:700;font-family:var(--fh,system-ui)}',
      '.std-btn{background:var(--p,#6C5CE7);border:none;color:#fff;padding:9px 16px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit}',
      '.std-btn:hover{filter:brightness(1.1)}',
      '.std-btn-ghost{background:transparent;border:1px solid var(--bd,#2a2d3e);color:var(--t1)}',
      '.std-btn-danger{color:#F87171;background:transparent;border:1px solid var(--bd)}',
      '.std-body{flex:1;overflow:auto;padding:20px}',
      '.std-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px}',
      '.std-card{background:var(--s2,#1e2030);border:1px solid var(--bd);border-radius:10px;overflow:hidden;cursor:pointer;transition:transform .15s,border-color .15s}',
      '.std-card:hover{transform:translateY(-2px);border-color:var(--p,#6C5CE7)}',
      '.std-card-thumb{width:100%;aspect-ratio:1/1;background:#0f1117 center/cover}',
      '.std-card-thumb.f-portrait{aspect-ratio:4/5}',
      '.std-card-thumb.f-story{aspect-ratio:9/16}',
      '.std-card-thumb.f-landscape{aspect-ratio:1200/628}',
      '.std-card-thumb.f-pinterest{aspect-ratio:2/3}',
      '.std-card-meta{padding:10px 12px}',
      '.std-card-name{font-size:13px;font-weight:600;color:var(--t1);margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}',
      '.std-card-cat{font-size:11px;color:var(--t3,#777);text-transform:uppercase;letter-spacing:.08em}',
      '.std-pills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}',
      '.std-pill{padding:6px 12px;background:var(--s2,#1e2030);border:1px solid var(--bd);color:var(--t2,#aaa);border-radius:999px;cursor:pointer;font-size:12px;font-weight:500}',
      '.std-pill.active{background:var(--p,#6C5CE7);border-color:var(--p);color:#fff}',
      // Editor
      '.std-edit{display:flex;height:100%;min-height:0}',
      '.std-canvas-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:30px;background:#0a0c12;overflow:auto}',
      '.std-canvas{position:relative;background:#000;box-shadow:0 30px 80px rgba(0,0,0,0.6);overflow:hidden;transform-origin:top left}',
      '.std-tools{width:320px;flex-shrink:0;border-left:1px solid var(--bd);background:var(--s1,#14171f);display:flex;flex-direction:column}',
