  // ── Helper: load html2canvas from CDN once ────────────────────────
  function _ensureHtml2Canvas(cb) {
    if (window.html2canvas) return cb(null, window.html2canvas);
    if (window._h2cLoading) return setTimeout(function () { _ensureHtml2Canvas(cb); }, 200);
    window._h2cLoading = true;
    var sc = document.createElement('script');
    sc.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
    sc.onload  = function () { window._h2cLoading = false; cb(null, window.html2canvas); };
    sc.onerror = function () { window._h2cLoading = false; cb(new Error('html2canvas load failed')); };
    document.head.appendChild(sc);
  }

  // ─────────────────────────────────────────────────────────────────
  // SCREEN 1 — Design Gallery
  // ─────────────────────────────────────────────────────────────────
  function _renderGallery() {
    _ensureCss();
    STD.root.innerHTML =
      '<div class="std-wrap">' +
        '<div class="std-hdr">' +
          '<h2>\uD83C\uDFA8 Studio</h2>' +
          '<button class="std-btn" onclick="_studioOpenPicker()">+ New Design</button>' +
        '</div>' +
        '<div class="std-body" id="std-gallery-body">' +
          '<div style="color:var(--t3);font-size:13px">Loading your designs\u2026</div>' +
        '</div>' +
      '</div>';

    fetch('/api/studio/designs', { headers: TOKEN_HDR() })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        STD.designs = (d && d.designs) || [];
        var body = document.getElementById('std-gallery-body');
        if (!body) return;
        if (!STD.designs.length) {
          body.innerHTML =
            '<div style="text-align:center;padding:60px 20px;color:var(--t3)">' +
              '<div style="font-size:48px;margin-bottom:12px">\uD83C\uDFA8</div>' +
              '<h3 style="color:var(--t1);margin:0 0 8px;font-family:var(--fh,inherit)">No designs yet</h3>' +
              '<p style="margin:0 0 20px">Pick a template to get started — text and colors are fully editable.</p>' +
              '<button class="std-btn" onclick="_studioOpenPicker()">+ New Design</button>' +
            '</div>';
          return;
        }
        body.innerHTML = '<div class="std-grid">' + STD.designs.map(function (d) {
          var thumb = d.exported_url || d.thumbnail_url || '';
          var thumbStyle = thumb ? 'background-image:url(' + thumb + ')' : '';
          return '<div class="std-card" onclick="_studioOpenDesign(' + d.id + ')">' +
            '<div class="std-card-thumb f-' + d.format + '" style="' + thumbStyle + '"></div>' +
            '<div class="std-card-meta">' +
              '<div class="std-card-name">' + _esc(d.name) + '</div>' +
              '<div class="std-card-cat">' + d.format + ' \u00B7 ' + d.status + '</div>' +
            '</div>' +
          '</div>';
        }).join('') + '</div>';
      })
      .catch(function () {
        var body = document.getElementById('std-gallery-body');
        if (body) body.innerHTML = '<div style="color:#F87171">Failed to load designs.</div>';
      });
  }

  // ─────────────────────────────────────────────────────────────────
  // Template picker
  // ─────────────────────────────────────────────────────────────────
  window._studioOpenPicker = function () {
    _ensureCss();
    STD.root.innerHTML =
      '<div class="std-wrap">' +
        '<div class="std-hdr">' +
          '<h2>Choose a Template</h2>' +
          '<button class="std-btn-ghost std-btn" onclick="_studioBackToGallery()">\u2190 Back</button>' +
        '</div>' +
        '<div class="std-body">' +
          '<div class="std-pills" id="std-format-pills">' +
            FORMATS.map(function (f) {
              return '<div class="std-pill ' + (STD.pickFormat === f.id ? 'active' : '') + '" onclick="_studioSetPickFormat(\'' + f.id + '\')">' + f.label + ' \u00B7 ' + f.w + '\u00d7' + f.h + '</div>';
            }).join('') +
          '</div>' +
          '<div class="std-pills" id="std-cat-pills">' +
            ['all','promotional','quote','product','event','educational','brand','story','carousel','seasonal'].map(function (c) {
              return '<div class="std-pill ' + (STD.pickCategory === c ? 'active' : '') + '" onclick="_studioSetPickCategory(\'' + c + '\')">' + (c.charAt(0).toUpperCase() + c.slice(1)) + '</div>';
            }).join('') +
          '</div>' +
          '<div style="margin-bottom:12px;display:flex;justify-content:space-between;align-items:center">' +
            '<div id="std-tpl-count" style="color:var(--t3);font-size:12px"></div>' +
            '<button class="std-btn-ghost std-btn" onclick="_studioBlankCanvas()">\u270E Blank Canvas</button>' +
          '</div>' +
          '<div id="std-tpl-grid"><div style="color:var(--t3);font-size:13px">Loading templates\u2026</div></div>' +
        '</div>' +
      '</div>';
    _loadTemplates();
  };

  window._studioSetPickFormat   = function (f) { STD.pickFormat = f; _studioOpenPicker(); };
  window._studioSetPickCategory = function (c) { STD.pickCategory = c; _studioOpenPicker(); };
  window._studioBackToGallery   = function () { STD.view = 'gallery'; _renderGallery(); };

  function _loadTemplates() {
    var url = '/api/studio/templates?per_page=48&format=' + encodeURIComponent(STD.pickFormat);
    if (STD.pickCategory && STD.pickCategory !== 'all') url += '&category=' + encodeURIComponent(STD.pickCategory);
    fetch(url, { headers: TOKEN_HDR() })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        STD.templates = (d && d.templates) || [];
        var grid = document.getElementById('std-tpl-grid');
        var count = document.getElementById('std-tpl-count');
        if (count) count.textContent = STD.templates.length + ' templates';
        if (!grid) return;
        if (!STD.templates.length) {
          grid.innerHTML = '<div style="color:var(--t3);padding:40px 0;text-align:center">No templates match. Try a different format or category.</div>';
          return;
        }
        // BUG 2a fix (2026-04-20): render inline previews using the same layer engine
        // as the editor, scaled down. No DB thumbnail_url needed.
        grid.innerHTML = '<div class="std-grid">' + STD.templates.map(function (t, idx) {
          return '<div class="std-card" onclick="_studioUseTemplate(' + t.id + ',\'' + _esc(t.name).replace(/\'/g, "\\'") + '\')">' +
            '<div class="std-card-thumb f-' + t.format + '" id="std-thumb-' + t.id + '" style="position:relative;overflow:hidden"></div>' +
            '<div class="std-card-meta">' +
              '<div class="std-card-name">' + _esc(t.name) + '</div>' +
              '<div class="std-card-cat">' + _esc(t.category) + '</div>' +
            '</div>' +
          '</div>';
        }).join('') + '</div>';
        // Render inline thumbnails (one frame later so the thumb containers have layout dims).
        requestAnimationFrame(function () {
          STD.templates.forEach(function (t) {
            try { _renderInlineThumb(t); } catch (e) { /* per-template failure shouldn't break grid */ }
          });
        });
      })
      .catch(function () {
        var grid = document.getElementById('std-tpl-grid');
        if (grid) grid.innerHTML = '<div style="color:#F87171">Failed to load templates.</div>';
      });
  }

  // BUG 2b fix (2026-04-20): hand the editor the layers DIRECTLY from the template
  // listing payload (no extra round-trip needed since /api/studio/templates now
  // includes layers_json). Eliminates the localStorage round-trip + empty-canvas bug.
  window._studioUseTemplate = function (templateId, name) {
    var tpl = STD.templates.find(function (t) { return t.id === templateId; });
    if (!tpl) { alert('Template not found in current listing.'); return; }
    var layers = tpl.layers_json;
    if (typeof layers === 'string') { try { layers = JSON.parse(layers); } catch (e) { layers = null; } }
    if (!layers || !layers.layers) { alert('Template has no layers.'); return; }
    fetch('/api/studio/designs', {
      method: 'POST',
      headers: Object.assign({ 'Content-Type': 'application/json' }, TOKEN_HDR()),
      body: JSON.stringify({ template_id: templateId, name: name + ' (copy)', format: tpl.format }),
    }).then(function (r) { return r.json(); }).then(function (d) {
      if (!d || !d.success) { alert('Could not create design.'); return; }
      _renderEditor(d.design_id, { id: d.design_id, name: name + ' (copy)', format: tpl.format }, layers);
    });
  };
  window._studioBlankCanvas = function () {
    fetch('/api/studio/designs', {
      method: 'POST',
      headers: Object.assign({ 'Content-Type': 'application/json' }, TOKEN_HDR()),
      body: JSON.stringify({ name: 'Untitled Design', format: STD.pickFormat }),
    }).then(function (r) { return r.json(); }).then(function (d) {
      if (d && d.success) _studioOpenDesign(d.design_id);
    });
  };

  // ── BUG 2a (2026-04-20): inline thumbnail render using the same engine.
  function _renderInlineThumb(tpl) {
    var host = document.getElementById('std-thumb-' + tpl.id);
    if (!host) return;
    var layers = tpl.layers_json;
    if (typeof layers === 'string') { try { layers = JSON.parse(layers); } catch (e) { return; } }
    if (!layers || !layers.layers) return;
    var cw = layers.canvas_width || 1080;
    var ch = layers.canvas_height || 1080;
    var hostW = host.clientWidth  || 220;
    var hostH = host.clientHeight || 220;
    if (hostW < 20) hostW = 220;
    if (hostH < 20) hostH = 220;
    var scale = Math.min(hostW / cw, hostH / ch);
    if (!isFinite(scale) || scale <= 0) scale = 0.2;
    var inner = '';
    layers.layers.forEach(function (layer) { inner += _renderLayer(layer, cw, ch); });
    var filterCss = _filterCssFromLayers(layers.layers);
    // Wrap at native dims, then scale. transform-origin:top left so scaled box anchors to host's top-left.
    host.innerHTML =
      '<div style="width:' + cw + 'px;height:' + ch + 'px;transform:scale(' + scale + ');transform-origin:top left;position:absolute;top:0;left:0;' + filterCss + '">' +
        inner +
      '</div>';
  }

  // CSS filter string from the effects layer (vignette + filter preset).
  function _filterCssFromLayers(layers) {
    var fx = layers && layers.find ? layers.find(function (l) { return l && l.type === 'effects'; }) : null;
    if (!fx || !fx.visible) return '';
    var d = fx.data || {};
    var filters = [];
    var preset = d.filter || 'none';
    var intensity = (typeof d.filter_intensity === 'number' ? d.filter_intensity : 50) / 100;
    if (preset === 'warm')      filters.push('sepia(' + (intensity * 0.4) + ') saturate(' + (1 + intensity * 0.4) + ')');
    else if (preset === 'cool') filters.push('hue-rotate(' + (intensity * 30) + 'deg) saturate(' + (1 - intensity * 0.2) + ')');
    else if (preset === 'bw')   filters.push('grayscale(' + intensity + ')');
    else if (preset === 'fade') filters.push('contrast(' + (1 - intensity * 0.3) + ') brightness(' + (1 + intensity * 0.1) + ')');
    else if (preset === 'vivid')filters.push('saturate(' + (1 + intensity * 0.6) + ') contrast(' + (1 + intensity * 0.15) + ')');
    else if (preset === 'matte')filters.push('contrast(' + (1 - intensity * 0.2) + ') saturate(' + (1 - intensity * 0.15) + ')');
    else if (preset === 'film') filters.push('sepia(' + (intensity * 0.2) + ') contrast(' + (1 + intensity * 0.1) + ')');
    return filters.length ? 'filter:' + filters.join(' ') + ';' : '';
  }

  // ─────────────────────────────────────────────────────────────────
  // SCREEN 2 — Canvas Editor
  // ─────────────────────────────────────────────────────────────────
  // BUG 2b fix (2026-04-20): authoritative layers come from GET /api/studio/designs/{id}.
  // No more localStorage round-trip, no more stale-cache failure mode.
  window._studioOpenDesign = function (designId) {
    fetch('/api/studio/designs/' + designId, { headers: TOKEN_HDR() })
      .then(function (r) { return r.json(); })
      .then(function (d) {
        if (!d || !d.success || !d.design) {
          alert('Could not load design.');
          STD.view = 'gallery'; _renderGallery();
          return;
        }
        var design = d.design;
        var layers = design.layers_json;
        if (typeof layers === 'string') { try { layers = JSON.parse(layers); } catch (e) { layers = null; } }
        if (!layers || !layers.layers) layers = _blankLayers(design.format || 'square');
        _renderEditor(designId, {
          id: designId,
          name: design.name || 'Untitled Design',
          format: design.format || 'square',
        }, layers);
      })
      .catch(function () {
        alert('Network error loading design.');
        STD.view = 'gallery'; _renderGallery();
      });
  };

  function _blankLayers(fmt) {
    var sizes = { square:[1080,1080], portrait:[1080,1350], story:[1080,1920], landscape:[1200,628], pinterest:[1000,1500] };
    var s = sizes[fmt] || [1080, 1080];
    return {
      format: fmt, canvas_width: s[0], canvas_height: s[1],
      layers: [
        { id:'background', type:'background', locked:true, visible:true, data:{ mode:'color', color:'#1A1A1A', overlay_color:'rgba(0,0,0,0)', overlay_opacity:0 } },
        { id:'overlay',    type:'overlay',    locked:false, visible:false, data:{ mode:'color', color:'#000000', opacity:0, pattern:'none' } },
        { id:'media',      type:'media',      locked:false, visible:false, data:{ image_url:null } },
        { id:'shapes',     type:'shapes',     locked:false, visible:false, data:{ items:[] } },
        { id:'text',       type:'text',       locked:false, visible:true,  data:{ items:[
          { id:'headline', role:'headline', content:'Your Headline', x:50, y:50, font_family:'Inter', font_size:48, font_weight:'600', color:'#FFFFFF', alignment:'center', editable:true },
        ] } },
        { id:'effects',    type:'effects',    locked:false, visible:false, data:{ vignette:{ enabled:false, intensity:30 }, filter:'none', filter_intensity:50 } },
      ],
    };
  }

  function _renderEditor(designId, meta, layers) {
    _ensureCss();
    STD.view = 'editor';
    STD.design = { id: designId, meta: meta, layers: layers };
    STD.activeTab = 'background';
    STD.isDirty = false;
    STD.root.innerHTML =
      '<div class="std-wrap">' +
        '<div class="std-hdr">' +
          '<div style="display:flex;align-items:center;gap:14px">' +
            '<button class="std-btn-ghost std-btn" onclick="_studioBackToGallery()">\u2190</button>' +
            '<input id="std-name" class="std-input" style="width:240px" value="' + _esc(meta.name) + '" oninput="_studioMarkDirty()">' +
          '</div>' +
          '<div style="display:flex;align-items:center;gap:8px">' +
            '<span id="std-saving" class="std-saving">All changes saved</span>' +
            '<button class="std-btn-ghost std-btn" onclick="_studioExport()">\u2B07 Export PNG</button>' +
            '<button class="std-btn" onclick="_studioSave(true)">\uD83D\uDCBE Save</button>' +
          '</div>' +
        '</div>' +
        '<div class="std-edit">' +
          '<div class="std-canvas-wrap" id="std-canvas-wrap"></div>' +
