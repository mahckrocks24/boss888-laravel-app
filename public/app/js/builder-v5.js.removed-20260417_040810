// PREVIEW FIX: old builder.js renderSectionsHTML (line 11054) reads `txt`
// without declaring it in scope. Caller has its own local `txt` but doesn't
// pass it as a parameter. The unscoped read throws ReferenceError on first
// heading, killing the Preview path. Declaring `txt` here as a global gives
// the unscoped read a fallback default (#1a1a2e dark text). Per-section
// `secTxt` is computed correctly inside the function so we don't need to
// declare it.
var txt = '#1a1a2e';

// PHASE ARTHUR FIX (v5.0.5): smart fetch interceptor that bridges the inline
// action panel to the backend Arthur controller. The frontend posts to
// /api/builder/ai with action_type=improve|rewrite|expand|shorten|fix and
// expects {success, data, ai_action}. The backend defaults to mode='wizard'
// and returns {reply, extracted, ready}. The backend has an inline() method
// that returns {content: {text: '...'}} when called with mode='inline' and
// proper payload. We detect inline action types, translate the request to
// inline mode, then translate the response into a synthetic update_section
// action that the frontend's _bldApplyAIResponse already knows how to apply.
// For non-inline action types (e.g. action_type='chat') we fall through to
// the simpler chat-mode bridge.
//
// Wizard onboarding interview uses /api/builder/arthur (different route),
// so it is NOT touched by this interceptor.
(function() {
  if (window.__bld_v5_arthur_patched) return;
  window.__bld_v5_arthur_patched = true;
  var _origFetch = window.fetch;

  var INLINE_ACTIONS = ['improve','rewrite','expand','shorten','fix'];

  function _addSuccessFlag(response) {
    if (!response.ok) return Promise.resolve(response);
    var cloned;
    try { cloned = response.clone(); } catch(e) { return Promise.resolve(response); }
    return cloned.json().then(function(data) {
      if (data && typeof data === 'object' && 'ai_action' in data && !('success' in data)) {
        data.success = true;
        return new Response(JSON.stringify(data), {
          status: response.status,
          statusText: response.statusText,
          headers: response.headers,
        });
      }
      return response;
    }).catch(function() { return response; });
  }

  function _synth(payload, status) {
    return new Response(JSON.stringify(payload), {
      status: status || 200,
      statusText: 'OK',
      headers: { 'Content-Type': 'application/json' },
    });
  }

  function _handleInlineAction(body, init, url) {
    // v5.0.7: branch on action_type. Improve = design cycle (frontend),
    // Rewrite = text via backend inline() (the v5.0.5 path).
    var action = body.action_type || body.command || 'rewrite';
    if (action === 'improve') {
      return _handleImproveDesign(body);
    }
    return _handleRewriteText(body, init, url);
  }

  // === IMPROVE: cycle through design variations (frontend-only, no LLM) ===
  var DESIGN_VARIATIONS = [
    { gradient: "linear-gradient(135deg, var(--lubld-primary,#6C5CE7) 0%, var(--lubld-secondary,#A855F7) 100%)", bg: "", color: "#FFFFFF", paddingTop: "100px", paddingBottom: "100px", paddingX: "32px", textAlign: "center" },
    { gradient: "linear-gradient(135deg, #00E5A8 0%, #0099CC 100%)", bg: "", color: "#FFFFFF", paddingTop: "100px", paddingBottom: "100px", paddingX: "32px", textAlign: "center" },
    { gradient: "linear-gradient(135deg, #FF6B6B 0%, #FFD93D 100%)", bg: "", color: "#1a1a2e", paddingTop: "100px", paddingBottom: "100px", paddingX: "32px", textAlign: "center" },
    { gradient: "linear-gradient(135deg, #1a1535 0%, #3d2466 100%)", bg: "", color: "#FFFFFF", paddingTop: "100px", paddingBottom: "100px", paddingX: "32px", textAlign: "center" },
    { gradient: "", bg: "#0F1117", color: "#E8E9F0", paddingTop: "80px", paddingBottom: "80px", paddingX: "32px", textAlign: "center" },
    { gradient: "linear-gradient(135deg, #4C1D95 0%, #DB2777 100%)", bg: "", color: "#FFFFFF", paddingTop: "100px", paddingBottom: "100px", paddingX: "32px", textAlign: "center" },
    { gradient: "linear-gradient(135deg, #A7F3D0 0%, #67E8F9 100%)", bg: "", color: "#1a1a2e", paddingTop: "100px", paddingBottom: "100px", paddingX: "32px", textAlign: "center" },
    { gradient: "", bg: "#FFFFFF", color: "#1a1a2e", paddingTop: "80px", paddingBottom: "80px", paddingX: "32px", textAlign: "center" }
  ];

  function _handleImproveDesign(body) {
    var si = (body.context && typeof body.context.section_index === 'number')
      ? body.context.section_index
      : (typeof _bldSelSec === 'number' ? _bldSelSec : null);

    if (typeof si !== 'number' || !window.bldCurrentPage || !window.bldCurrentPage.sections || !window.bldCurrentPage.sections[si]) {
      return Promise.resolve(_synth({ success: false, error: 'Arthur: no section selected. Click an element first.' }));
    }

    var section = window.bldCurrentPage.sections[si];
    var siteName = (window.bldCurrentPage && window.bldCurrentPage.title) || 'this site';
    var industry = (window.wsCurrentSite && window.wsCurrentSite.industry) ||
                   (window.bldCurrentPage && window.bldCurrentPage.theme && window.bldCurrentPage.theme.industry) || '';
    var businessName = (window.wsCurrentSite && window.wsCurrentSite.title) ||
                       (window.bldCurrentPage && window.bldCurrentPage.title) || '';

    // Build focused design improvement prompt
    var prompt = "Improve the visual design of section at index " + si +
      " (type: " + (section.type || 'custom') + "). " +
      "Site: " + (businessName || siteName) +
      (industry ? " (industry: " + industry + ")" : "") + ". " +
      "Return ai_action='update_section' with a section object whose 'style' field has new values for: " +
      "bg or gradient, color, paddingTop, paddingBottom, paddingX, fontFamily, textAlign. " +
      "Use a tasteful gradient background and bold typography that matches the business industry. " +
      "Use generous padding (80-120px). Keep ALL text content (heading, body, items) unchanged - only update the style.";

    var chatBody = {
      mode: 'chat',
      command: prompt,
      page_structure: { sections: window.bldCurrentPage.sections },
      site_name: siteName
    };

    var newInit = {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''),
        'Accept': 'application/json'
      },
      body: JSON.stringify(chatBody)
    };

    console.log('[bld v5.0.8] Improve: calling backend chat() for design improvement on section', si);

    return _origFetch.call(window, '/api/builder/ai', newInit).then(function(response) {
      if (!response.ok) {
        console.warn('[bld v5.0.8] Improve: backend HTTP', response.status, '— falling back to cycle');
        return _improveFallbackCycle(si, section);
      }
      return response.json().then(function(data) {
        // Check if LLM returned a usable structured action
        var hasUsableData = data && data.ai_action &&
          data.ai_action !== 'text_response' && data.data &&
          (data.data.section || data.data.style);

        if (!hasUsableData) {
          console.warn('[bld v5.0.8] Improve: LLM returned text_response or empty — falling back to cycle');
          return _improveFallbackCycle(si, section);
        }

        // Normalize: ensure success flag and section_index
        if (!('success' in data)) data.success = true;
        if (data.data && typeof data.data.section_index !== 'number') {
          data.data.section_index = si;
        }
        // If LLM returned data.style without wrapping in section, wrap it
        if (data.data && data.data.style && !data.data.section) {
          var wrappedSec = JSON.parse(JSON.stringify(section));
          wrappedSec.style = Object.assign({}, wrappedSec.style || {}, data.data.style);
          data.data.section = wrappedSec;
        }
        // Ensure the returned section preserves the original text content
        if (data.data && data.data.section) {
          var newSec = data.data.section;
          // Preserve original heading/body/items if LLM accidentally changed them
          if (section.heading && !newSec.heading) newSec.heading = section.heading;
          if (section.body && !newSec.body) newSec.body = section.body;
          if (section.subheading && !newSec.subheading) newSec.subheading = section.subheading;
          if (section.cta_text && !newSec.cta_text) newSec.cta_text = section.cta_text;
          if (section.cta_link && !newSec.cta_link) newSec.cta_link = section.cta_link;
          if (Array.isArray(section.items) && !newSec.items) newSec.items = section.items;
          // Preserve flatToNested-generated components
          if (Array.isArray(section.components) && !Array.isArray(newSec.components)) {
            newSec.components = section.components;
          }
          // Preserve type
          if (!newSec.type) newSec.type = section.type;
          data.data.section = newSec;
        }
        console.log('[bld v5.0.8] Improve: LLM returned structured update_section');
        return _synth(data);
      }).catch(function(e) {
        console.warn('[bld v5.0.8] Improve: parse error', e, '— falling back to cycle');
        return _improveFallbackCycle(si, section);
      });
    }).catch(function(e) {
      console.warn('[bld v5.0.8] Improve: fetch error', e, '— falling back to cycle');
      return _improveFallbackCycle(si, section);
    });
  }

  // Fallback: cycle through preset variations if LLM fails
  function _improveFallbackCycle(si, section) {
    var idx = (typeof section.__variation_idx === 'number') ? (section.__variation_idx + 1) : 0;
    idx = idx % DESIGN_VARIATIONS.length;
    var updatedSec = JSON.parse(JSON.stringify(section));
    var existingStyle = updatedSec.style || {};
    updatedSec.style = Object.assign({}, existingStyle, DESIGN_VARIATIONS[idx]);
    updatedSec.__variation_idx = idx;
    console.log('[bld v5.0.8] Improve fallback: variation', idx + 1, '/', DESIGN_VARIATIONS.length);
    return Promise.resolve(_synth({
      success: true,
      ai_action: 'update_section',
      data: { section_index: si, section: updatedSec },
      explanation: 'Design variation ' + (idx + 1) + ' / ' + DESIGN_VARIATIONS.length + ' (LLM unavailable)'
    }));
  }

  // === REWRITE: text update via backend inline() (preserved from v5.0.5) ===
  function _handleRewriteText(body, init, url) {
    // Resolve which section/component the user is editing
    var si = (body.context && typeof body.context.section_index === 'number')
      ? body.context.section_index
      : (typeof _bldSelSec === 'number' ? _bldSelSec : null);

    if (typeof si !== 'number' || !window.bldCurrentPage || !window.bldCurrentPage.sections || !window.bldCurrentPage.sections[si]) {
      return Promise.resolve(_synth({ success: false, error: 'Arthur: no section selected. Click an element first.' }));
    }

    var section = window.bldCurrentPage.sections[si];
    var ci = (typeof _bldSelCmp === 'number') ? _bldSelCmp : null;
    var elementType, existingContent, applyTo;

    if (typeof ci === 'number' && section.components && section.components[ci]) {
      var cmp = section.components[ci];
      elementType = cmp.type || 'text';
      var curText = cmp.text || (cmp.content && cmp.content.text) || '';
      existingContent = { text: curText };
      applyTo = { kind: 'component', ci: ci };
    } else {
      // Section selected (no specific component) — default to its heading
      elementType = 'heading';
      existingContent = { text: section.heading || (section.components && section.components[0] && section.components[0].text) || '' };
      applyTo = { kind: 'section_heading' };
    }

    if (!existingContent.text) {
      return Promise.resolve(_synth({ success: false, error: 'Arthur: no text to edit on this element.' }));
    }

    var inlineBody = {
      mode: 'inline',
      command: body.action_type || body.command || 'improve',
      element_type: elementType,
      existing_content: existingContent,
      site_name: (window.bldCurrentPage && window.bldCurrentPage.title) || 'this site',
    };

    var newInit = Object.assign({}, init, { body: JSON.stringify(inlineBody) });

    return _origFetch.call(window, url, newInit).then(function(response) {
      if (!response.ok) return response;
      return response.json().then(function(inlineResult) {
        var newText = (inlineResult && inlineResult.content && inlineResult.content.text) || '';
        if (!newText) {
          return _synth({ success: false, error: 'Arthur returned empty content. Try rephrasing.' });
        }

        // Build updated section by deep-copying and patching the right field
        var updatedSec = JSON.parse(JSON.stringify(section));
        if (applyTo.kind === 'component') {
          var tci = applyTo.ci;
          if (updatedSec.components && updatedSec.components[tci]) {
            updatedSec.components[tci].text = newText;
            if (updatedSec.components[tci].content) updatedSec.components[tci].content.text = newText;
            // Also propagate to flat field if this component is the section's primary heading/body
            if (updatedSec.components[tci].type === 'heading' && tci === 0) updatedSec.heading = newText;
            if (updatedSec.components[tci].type === 'text') updatedSec.body = newText;
          }
        } else {
          updatedSec.heading = newText;
          if (updatedSec.components && updatedSec.components[0] && updatedSec.components[0].type === 'heading') {
            updatedSec.components[0].text = newText;
            if (updatedSec.components[0].content) updatedSec.components[0].content.text = newText;
          }
        }

        // Synthesize a response the frontend's _bldApplyAIResponse can apply
        return _synth({
          success: true,
          ai_action: 'update_section',
          data: {
            section_index: si,
            section: updatedSec,
          },
          explanation: 'Arthur updated the ' + elementType + '.',
        });
      }).catch(function(e) {
        console.warn('[bld v5.0.5] inline action parse error', e);
        return _synth({ success: false, error: 'Arthur response parse error: ' + e.message });
      });
    }).catch(function(e) {
      console.warn('[bld v5.0.5] inline action fetch error', e);
      return _synth({ success: false, error: 'Arthur network error: ' + e.message });
    });
  }

  window.fetch = function(input, init) {
    var url = (typeof input === 'string') ? input : (input && input.url) || '';
    if (url.indexOf('/api/builder/ai') !== -1 && init && init.method === 'POST') {
      var body = null;
      try {
        if (typeof init.body === 'string') body = JSON.parse(init.body);
      } catch(e) {}

      // Inline action path — translate via backend inline() mode
      if (body && INLINE_ACTIONS.indexOf(body.action_type) !== -1) {
        return _handleInlineAction(body, init, url);
      }

      // Other paths — chat mode bridge
      if (body && !body.mode) {
        body.mode = 'chat';
        init = Object.assign({}, init, { body: JSON.stringify(body) });
      }
      return _origFetch.call(this, input, init).then(_addSuccessFlag);
    }
    return _origFetch.apply(this, arguments);
  };
  console.log('[bld v5.0.5] Arthur fetch interceptor active (inline + chat modes)');
})();





// === flatToNested (ref 321-479) ===
function flatToNested(sec) {
  if (!sec || typeof sec !== 'object') return sec;
  // Already nested? Pass through unchanged.
  if (Array.isArray(sec.components) && sec.components.length > 0) return sec;

  const out = {
    type: sec.type || 'custom',
    label: sec.label || sec.type || 'Section',
    style: sec.style || {},
    props: sec.props || {},
    components: []
  };
  // Preserve any other top-level fields the renderer reads
  if (sec._layout) out._layout = sec._layout;
  if (sec._columns) out._columns = sec._columns;
  if (sec._variant) out._variant = sec._variant;

  // Type-specific expansion
  switch (sec.type) {
    case 'hero': {
      if (sec.background_image) {
        out.style = out.style || {};
        out.style.bgImage = sec.background_image;
        out.style.bgSize = 'cover';
        // Add dark overlay for text readability
        out.style.bgOverlay = 'linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.6))';
      }
      if (!out.style.bgImage && (!out.style || !out.style.gradient)) {
        out.style = out.style || {};
        out.style.gradient = 'linear-gradient(135deg, var(--lubld-primary,#6C5CE7) 0%, var(--lubld-secondary,#A855F7) 100%)';
      }
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 1 } });
      if (sec.subheading) out.components.push({ type: 'text',    component_type: 'text',    text: sec.subheading, content: { text: sec.subheading } });
      if (sec.cta_text)   out.components.push({ type: 'button',  component_type: 'button',  text: sec.cta_text, href: sec.cta_link || '#', content: { label: sec.cta_text, href: sec.cta_link || '#', variant: 'primary' } });
      break;
    }
    case 'features': {
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 2 } });
      if (sec.body)       out.components.push({ type: 'text',    component_type: 'text',    text: sec.body,    content: { text: sec.body } });
      if (Array.isArray(sec.items)) {
        out.components.push({
          type: 'cards', component_type: 'cards',
          items: sec.items,
          content: { items: sec.items }
        });
      }
      break;
    }
    case 'cta': {
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 2 } });
      if (sec.body)       out.components.push({ type: 'text',    component_type: 'text',    text: sec.body,    content: { text: sec.body } });
      if (sec.cta_text)   out.components.push({ type: 'button',  component_type: 'button',  text: sec.cta_text, href: sec.cta_link || '#', content: { label: sec.cta_text, href: sec.cta_link || '#', variant: 'primary' } });
      break;
    }
    case 'contact':
    case 'contact_form': {
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 2 } });
      if (sec.body)       out.components.push({ type: 'text',    component_type: 'text',    text: sec.body,    content: { text: sec.body } });
      out.components.push({
        type: 'form', component_type: 'form',
        fields: sec.fields || [
          { label: 'Name', placeholder: 'Your name' },
          { label: 'Email', placeholder: 'you@example.com' },
          { label: 'Message', placeholder: 'How can we help?' }
        ],
        content: { submit_label: sec.cta_text || 'Send Message' }
      });
      break;
    }
    case 'pricing': {
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 2 } });
      if (sec.body)       out.components.push({ type: 'text',    component_type: 'text',    text: sec.body,    content: { text: sec.body } });
      const tiers = sec.tiers || sec.items || [];
      tiers.forEach(t => {
        out.components.push({
          type: 'pricing', component_type: 'pricing',
          content: {
            name: t.name || t.heading,
            price: t.price,
            period: t.period || '/mo',
            features: t.features || []
          }
        });
      });
      break;
    }
    case 'faq': {
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 2 } });
      out.components.push({
        type: 'faq', component_type: 'faq',
        items: sec.items || [],
        content: { items: sec.items || [] }
      });
      break;
    }
    case 'testimonials': {
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 2 } });
      (sec.items || []).forEach(t => {
        out.components.push({
          type: 'testimonial', component_type: 'testimonial',
          content: {
            quote: t.quote || t.text,
            author: t.name || t.author,
            role: t.role || t.title || ''
          }
        });
      });
      break;
    }
    case 'services':
    case 'service_grid': {
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 2 } });
      if (sec.body)       out.components.push({ type: 'text',    component_type: 'text',    text: sec.body,    content: { text: sec.body } });
      if (Array.isArray(sec.items)) {
        out.components.push({
          type: 'cards', component_type: 'cards',
          items: sec.items,
          content: { items: sec.items }
        });
      }
      break;
    }
    case 'about':
    case 'story':
    case 'text_block': {
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 2 } });
      if (sec.body)       out.components.push({ type: 'text',    component_type: 'text',    text: sec.body,    content: { text: sec.body } });
      break;
    }
    case 'gallery': {
      if (sec.heading)    out.components.push({ type: 'heading', component_type: 'heading', text: sec.heading, content: { text: sec.heading, level: 2 } });
      out.components.push({
        type: 'gallery', component_type: 'gallery',
        images: sec.images || sec.items || [],
        content: { images: sec.images || sec.items || [] }
      });
      break;
    }
    case 'header':
    case 'navigation': {
      if (sec.logo)       out.components.push({ type: 'image',   component_type: 'image',   src: sec.logo, content: { src: sec.logo, alt: 'Logo' } });
      // Nav links rendered by section-level renderer
      break;
    }
    case 'footer': {
      if (sec.heading)    out.components.push({ type: 'text',    component_type: 'text',    text: sec.heading, content: { text: sec.heading } });
      if (sec.body)       out.components.push({ type: 'text',    component_type: 'text',    text: sec.body,    content: { text: sec.body } });
      break;
    }
    case 'header': {
      out.style = out.style || {};
      out.style.bg = 'rgba(15,17,23,0.95)';
      var navItems = (sec.nav_items || []).map(function(n){ return '<a href="' + (n.href||'#') + '" style="color:#9CA3AF;text-decoration:none;font-size:13px;font-weight:500">' + (n.label||'') + '</a>'; }).join('');
      out.components.push({ type: 'raw_html', component_type: 'raw_html', content: { html:
        '<div style="display:flex;align-items:center;justify-content:space-between;padding:16px 32px;max-width:1200px;margin:0 auto">' +
          '<div style="font-family:var(--lubld-font_heading,Syne);font-size:20px;font-weight:800;color:var(--lubld-primary,#6C5CE7)">' + (sec.logo_text||'Brand') + '</div>' +
          '<nav style="display:flex;gap:24px;align-items:center">' + navItems +
            (sec.cta_text ? '<a href="' + (sec.cta_href||'#') + '" style="background:var(--lubld-primary,#6C5CE7);color:#fff;padding:8px 20px;border-radius:8px;text-decoration:none;font-size:13px;font-weight:600">' + sec.cta_text + '</a>' : '') +
          '</nav></div>'
      }});
      break;
    }
    case 'footer': {
      out.style = out.style || {};
      out.style.bg = '#0B0E14';
