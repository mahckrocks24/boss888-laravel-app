// === bldRenderComponentPreview (ref 2774-2847) ===
function bldRenderComponentPreview(type, content, theme) {
  const t = k => _bldSafeText(content[k]);
  switch(type) {
    case 'heading':
      const lvl = parseInt(t('level')) || 2;
      return `<h${lvl} style="margin:0">${t('text') || 'Heading'}</h${lvl}>`;
    case 'text':
      return `<p style="margin:0">${t('text') || 'Text content'}</p>`;
    case 'image':
      return t('src')
        ? `<img src="${escH(t('src'))}" alt="${escH(t('alt'))}" style="max-width:100%;height:auto;border-radius:6px">`
        : `<div style="background:rgba(255,255,255,.05);aspect-ratio:16/9;border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3);font-size:13px">🖼 Image</div>`;
    case 'button':
      return `<a href="#" class="lubld-btn lubld-btn-${escH(t('variant')||'primary')}" style="pointer-events:none">${escH(t('label')||'Button')}</a>`;
    case 'divider':
      return `<hr style="border:none;border-top:${escH(t('thickness')||'1px')} solid rgba(255,255,255,.1);margin:0">`;
    case 'spacer':
      return `<div style="height:${escH(t('height')||'40px')}"></div>`;
    case 'cta':
      const btns = (content.buttons||[]).map(b=>`<a href="#" class="lubld-btn lubld-btn-${escH(b.variant||'primary')}" style="pointer-events:none">${escH(b.label)}</a>`).join('');
      return `<div style="text-align:center">
        <h2 style="margin-bottom:10px">${escH(t('heading')||'CTA Heading')}</h2>
        <p style="margin-bottom:20px">${escH(t('subtext')||'Subtext here')}</p>
        <div class="lubld-btn-group" style="justify-content:center">${btns||'<a href="#" class="lubld-btn lubld-btn-primary" style="pointer-events:none">Get Started</a>'}</div>
      </div>`;
    case 'testimonial':
      return `<blockquote><p style="font-style:italic;color:var(--lubld-t1,#F8F9FA);margin-bottom:8px">"${escH(t('quote')||'Testimonial quote')}"</p><cite style="font-style:normal;font-size:12px;color:var(--lubld-t2,#9CA3AF)">${escH(t('author')||'Author')}${t('role')?' — '+escH(t('role')):''}</cite></blockquote>`;
    case 'pricing':
      return `<div style="text-align:center"><h3 style="margin-bottom:4px">${escH(t('name')||'Plan Name')}</h3><div style="font-size:40px;font-weight:700;color:var(--lubld-t1,#F8F9FA)">${escH(t('price')||'$99')}<span style="font-size:14px;color:var(--lubld-t2)">${escH(t('period')||'/mo')}</span></div></div>`;
    case 'faq':
      const items = (content.items||[]).slice(0,2);
      return '<div>' + items.map(i=>`<div style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,.05)"><div style="font-weight:600;font-size:13px;color:var(--lubld-t1)">${escH(i.question||'')}</div><div style="font-size:12px;color:var(--lubld-t2);margin-top:4px">${escH(i.answer||'')}</div></div>`).join('') + '</div>';
    case 'form':
      const fs = (content.fields||[]).slice(0,3);
      return '<div>' + fs.map(f=>`<div style="margin-bottom:10px"><label style="font-size:12px;color:rgba(255,255,255,.6);display:block;margin-bottom:3px">${escH(f.label||'')}</label><div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:5px;padding:7px 10px;font-size:12px;color:rgba(255,255,255,.3)">${escH(f.placeholder||'...')}</div></div>`).join('') + `<button class="lubld-btn lubld-btn-primary" style="margin-top:4px;pointer-events:none;font-size:12px">${escH(content.submit_label||'Submit')}</button></div>`;
    case 'card':
      return `<div style="background:var(--lubld-s2,#1E2230);border-radius:8px;overflow:hidden">${t('image')?`<img src="${escH(t('image'))}" style="width:100%;height:120px;object-fit:cover">`:''}<div style="padding:16px"><h3 style="font-size:14px;margin-bottom:6px">${escH(t('heading')||'Card Heading')}</h3><p style="font-size:12px;margin:0">${escH(t('text')||'')}</p></div></div>`;
    case 'list':
      return '<ul style="padding-left:18px;font-size:13px">' + (content.items||[{text:'List item'}]).map(i=>`<li>${escH(i.text||'')}</li>`).join('') + '</ul>';
    case 'html':
      return `<div style="background:rgba(255,255,255,.03);border:1px dashed rgba(255,255,255,.1);border-radius:6px;padding:12px;font-family:monospace;font-size:11px;color:rgba(255,255,255,.4)">${escH((content.code||'<HTML>').slice(0,80))}</div>`;
    case 'video':
      var vSrc = t('src') || t('url') || '';
      if (vSrc && vSrc.match(/youtube|vimeo/)) {
        var vEmbed = vSrc.replace('watch?v=','embed/').replace('youtu.be/','youtube.com/embed/');
        return `<iframe src="${escH(vEmbed)}" style="width:100%;aspect-ratio:16/9;border:none;border-radius:8px" allowfullscreen></iframe>`;
