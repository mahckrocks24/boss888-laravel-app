// === bldRenderCanvasSection (ref 2712-2743) ===
function bldRenderCanvasSection(sec, si, theme) {
  const layout  = sec.layout || {};
  const cols    = parseInt(layout.columns) || 1;
  const py      = bldSpacing(layout.padding_y || 'xl');
  const px      = bldSpacing(layout.padding_x || 'md');
  const gap     = bldSpacing(layout.gap || 'md');
  const bg      = bldResolveBg(layout, theme);
  const grid    = cols > 1 ? `display:grid;grid-template-columns:repeat(${cols},1fr);gap:${gap}` : '';

  let contHtml  = '';
  (sec.containers || []).forEach((con, ci) => {
    contHtml += `<div class="bld-col-drop" data-si="${si}" data-ci="${ci}">`;
    (con.components || []).forEach((cmp, mi) => {
      contHtml += bldRenderCanvasComponent(cmp, si, ci, mi, theme);
    });
    contHtml += `<div onclick="bldAddComponent(${si},${ci})" style="text-align:center;padding:8px;cursor:pointer;color:var(--t3);font-size:12px;opacity:.6" onmouseenter="this.style.opacity='1'" onmouseleave="this.style.opacity='.6'">+ Component</div>`;
    contHtml += `</div>`;
  });

  return `<div class="bld-sec" data-si="${si}" style="padding:${py} ${px};${bg}position:relative">
    <div class="bld-sec-toolbar">
      <button class="bld-stb" onclick="bldMoveSection(${si},-1)">↑</button>
      <button class="bld-stb" onclick="bldMoveSection(${si},1)">↓</button>
      <button class="bld-stb" onclick="bldEditSection(${si})">⚙</button>
      <button class="bld-stb" onclick="bldDuplicateSection(${si})">⧉</button>
      <button class="bld-stb" onclick="bldDeleteSection(${si})" style="color:#F87171">✕</button>
    </div>
    <div style="max-width:var(--lubld-container_width,1200px);margin:0 auto;${grid}">
      ${contHtml}
    </div>
  </div>`;
}

