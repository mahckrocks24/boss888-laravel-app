// === bldSpacing (ref 3478-3480) ===
function bldSpacing(k) {
  return {none:'0',xs:'8px',sm:'16px',md:'24px',lg:'48px',xl:'80px','2xl':'120px'}[k] || k;
}

// === bldResolveBg (ref 3483-3491) ===
function bldResolveBg(layout, tokens) {
  const {bg_type='none', bg_value=''} = layout;
  if (bg_type === 'none')   return '';
  if (bg_type === 'color')  return 'background:'+bg_value+';';
  if (bg_type === 'token')  return 'background:var(--lubld-'+bg_value+',' + (tokens[bg_value]||bg_value) + ');';
  if (bg_type === 'gradient') return 'background:'+bg_value+';';
  if (bg_type === 'image')  return 'background-image:url('+bg_value+');background-size:cover;background-position:center;';
  return '';
}

// === bldStylesToInline (ref 3494-3525) ===
function bldStylesToInline(styles, tokens, themeTokens) {
  const parts = [];
  // PATCH 5: Expanded CSS property map — previously only 9 keys; AI (Railway + Arthur)
  // writes font_family, line_height, letter_spacing, opacity, max_width, width etc.
  // Unlisted keys were silently dropped. Added all properties from ARTHUR_SCHEMA.
  const props = {
    color:          'color',
    bg:             'background',
    font_size:      'font-size',
    font_weight:    'font-weight',
    font_family:    'font-family',
    text_align:     'text-align',
    line_height:    'line-height',
    letter_spacing: 'letter-spacing',
    padding:        'padding',
    margin:         'margin',
    border_radius:  'border-radius',
    border:         'border',
    shadow:         'box-shadow',
    opacity:        'opacity',
    max_width:      'max-width',
    width:          'width',
    gradient:       'background', // gradient value is a full CSS gradient string
  };
  const merged = Object.assign({}, styles, tokens);
  for (const [k, v] of Object.entries(merged)) {
    if (!v || !props[k]) continue;
    const resolved = v.startsWith('@') ? 'var(--lubld-'+v.slice(1)+','+(themeTokens[v.slice(1)]||v)+')' : v;
    parts.push(props[k]+':'+resolved);
  }
  return parts.join(';');
}

// === v5.0.7 COLOR PICKER OVERRIDE ===========================================
// Old _epColor renders an INVISIBLE color picker (opacity:0, pointer-events:none)
// — only the hex text field is usable. Override with a visible 36x32 native
// picker plus a hex text field. Same input id so the existing apply path
// (_bldApplyCmpProps / _bldApplySecProps / _bldApplyPageSettings) is unchanged.
function _epColor(label, id, val) {
  var safe = val || '';
  // Native <input type=color> only accepts #rrggbb. Use a fallback for the picker
  // when the value is empty or non-hex (rgb(), color name, gradient, etc).
  var pickerVal = /^#[0-9a-fA-F]{6}$/.test(safe) ? safe : '#000000';
  var labelEsc = (typeof bld_escH === 'function') ? bld_escH(label) : String(label);
  var safeEsc = (typeof bld_escH === 'function') ? bld_escH(safe) : safe;
  return '<div class="ep-row ep-color-row" style="margin-bottom:10px">'
    + '<label class="ep-lbl" style="font-size:11px;color:var(--t2);display:block;margin-bottom:4px">' + labelEsc + '</label>'
    + '<div style="display:flex;gap:6px;align-items:center">'
    + '<input type="color" id="' + id + '-picker" value="' + pickerVal + '"'
    + ' style="width:36px;height:32px;border:1px solid var(--bd);border-radius:6px;cursor:pointer;background:var(--s2);padding:2px;flex-shrink:0;outline:none"'
    + ' oninput="document.getElementById(\'' + id + '\').value=this.value;document.getElementById(\'' + id + '\').dispatchEvent(new Event(\'input\',{bubbles:true}));if(typeof _epColorSync===\'function\')_epColorSync(\'' + id + '\',this.value);">'
    + '<input id="' + id + '" type="text" value="' + safeEsc + '" placeholder="#000000"'
    + ' oninput="if(typeof _epColorSync===\'function\')_epColorSync(\'' + id + '\',this.value);if(/^#[0-9a-fA-F]{6}$/.test(this.value)){var pk=document.getElementById(\'' + id + '-picker\');if(pk)pk.value=this.value;}"'
    + ' style="flex:1;font-size:12px;padding:7px 9px;border:1px solid var(--bd);border-radius:6px;background:var(--s2);color:var(--t1);font-family:monospace;outline:none;box-sizing:border-box">'
    + '</div></div>';
}
