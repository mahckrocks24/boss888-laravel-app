      return `<div style="background:rgba(0,0,0,.3);aspect-ratio:16/9;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:32px">▶</div>`;
    case 'gallery': {
      let gImgs = content.images || content.items || [];
      return '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">' + (gImgs.length ? gImgs.slice(0,6).map(img => { let s = typeof img==='string'?img:(img.src||''); return s ? `<img src="${escH(s)}" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:6px">` : '<div style="aspect-ratio:1;background:rgba(255,255,255,.05);border-radius:6px;display:flex;align-items:center;justify-content:center">🖼</div>'; }).join('') : '<div style="grid-column:1/-1;padding:20px;text-align:center;color:rgba(255,255,255,.3);font-size:11px">Gallery</div>') + '</div>';
    }
    case 'map': {
      let mUrl = t('embedUrl') || t('src') || t('url');
      return mUrl ? `<iframe src="${escH(mUrl)}" style="width:100%;height:200px;border:none;border-radius:6px" loading="lazy"></iframe>` : '<div style="width:100%;height:150px;background:rgba(255,255,255,.05);border-radius:6px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3)">📍 Map</div>';
    }
    case 'catalog': {
      let cItems = content.items || [];
      return '<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px">' + (cItems.length ? cItems.slice(0,4).map(p => '<div style="background:rgba(255,255,255,.05);border-radius:8px;padding:10px;font-size:11px"><div style="font-weight:600;color:var(--lubld-t1,#F8F9FA)">' + escH(p.title||p.heading||'Item') + '</div>' + (p.price?'<div style="color:#00E5A8;font-weight:700">'+escH(p.price)+'</div>':'') + '</div>').join('') : '<div style="grid-column:1/-1;padding:16px;text-align:center;color:rgba(255,255,255,.3);font-size:11px">Catalog</div>') + '</div>';
    }
    case 'carousel': {
      let cSlides = content.slides || content.items || [];
      if (!cSlides.length) return '<div style="height:120px;background:rgba(255,255,255,.05);border-radius:6px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3)">🎠 Carousel</div>';
      let s0 = typeof cSlides[0]==='string'?{src:cSlides[0]}:cSlides[0];
      return '<div style="position:relative;border-radius:6px;overflow:hidden">' + (s0.src ? `<img src="${escH(s0.src)}" style="width:100%;height:180px;object-fit:cover">` : `<div style="height:150px;background:rgba(255,255,255,.05);display:flex;align-items:center;justify-content:center">${escH(s0.text||s0.heading||'Slide')}</div>`) + '<div style="position:absolute;bottom:6px;left:50%;transform:translateX(-50%);display:flex;gap:4px">' + cSlides.slice(0,5).map((_,i) => `<div style="width:6px;height:6px;border-radius:50%;background:${i===0?'#fff':'rgba(255,255,255,.4)'}"></div>`).join('') + '</div></div>';
    }
    case 'embed': {
      let eUrl = t('src') || t('url') || t('embedUrl');
      return eUrl ? `<iframe src="${escH(eUrl)}" style="width:100%;height:200px;border:none;border-radius:6px" loading="lazy"></iframe>` : '<div style="height:120px;background:rgba(255,255,255,.05);border-radius:6px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3)">🔗 Embed</div>';
    }
    case 'raw_html':
    case 'html':
    case 'custom_html':
      return content.html || '<div style="padding:16px;color:rgba(255,255,255,.3);text-align:center">Custom HTML block</div>';
    default:
      return `<div style="padding:16px;border:1px dashed rgba(255,255,255,.15);border-radius:6px;font-size:12px;color:rgba(255,255,255,.3);text-align:center">${type}</div>`;
  }
}

