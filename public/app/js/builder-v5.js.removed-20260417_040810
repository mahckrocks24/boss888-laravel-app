              <div style="font-size:12px;font-weight:600;color:var(--t1);margin-bottom:4px" ${editable?`contenteditable="true" onblur="bldCurrentPage.sections[${si}].components[${ci}].items[${ki}].heading=this.textContent;bldDirty=true"`:''} >${esc(card.heading||'')}</div>
              <div style="font-size:11px;color:var(--t3)" ${editable?`contenteditable="true" onblur="bldCurrentPage.sections[${si}].components[${ci}].items[${ki}].text=this.textContent;bldDirty=true"`:''} >${esc(card.text||'')}</div>
            </div>`;
          });
          html += '</div>';
        }
        else if (cmp.type === 'form' && Array.isArray(cmp.fields)) {
          html += `<div style="display:flex;flex-direction:column;gap:8px;margin:8px 0;max-width:400px;${selBorder}border-radius:8px" ${click}>`;
          cmp.fields.forEach(f => {
            html += `<div><div style="font-size:10px;color:var(--t3);margin-bottom:4px">${esc(f.label)}</div><div style="background:var(--s3);border:1px solid var(--bd);border-radius:6px;padding:8px 10px;${f.type==='textarea'?'min-height:60px;':''}font-size:12px;color:var(--t3)">${esc(f.label)}…</div></div>`;
          });
          html += '</div>';
        }
        else if (cmp.type === 'divider') {
          html += `<hr style="border:none;border-top:1px solid var(--bd);margin:12px 0;${selBorder}" ${click}>`;
        }
        else if (cmp.type === 'spacer') {
          html += `<div style="height:${cmp.height||'40px'};${selBorder}" ${click}></div>`;
        }
        else if (cmp.type === 'image') {
          html += `<div style="margin:8px 0;${selBorder}border-radius:8px" ${click}>${cmp.src ? `<img src="${esc(cmp.src)}" alt="${esc(cmp.alt||'')}" style="max-width:100%;border-radius:8px">` : '<div style="background:var(--s3);border:1px dashed var(--bd);border-radius:8px;padding:40px;text-align:center;color:var(--t3);font-size:12px">🖼 Click to set image URL in properties</div>'}</div>`;
        }

        // Close drag wrapper
        if (editable) html += '</div>';
      });
    }
    // Legacy blueprint format fallback
    else {
      if (heading) html += `<div style="font-size:13px;font-weight:600;color:var(--t1);margin-bottom:4px">${esc(heading)}</div>`;
      if (sub) html += `<div style="font-size:12px;color:var(--t2);line-height:1.5;margin-bottom:4px">${esc(typeof sub==='string'?sub.slice(0,120):'')}</div>`;
      if (Array.isArray(items) && items.length) {
        html += '<div style="display:flex;flex-wrap:wrap;gap:6px">';
        items.slice(0,6).forEach(item => {
          const label = typeof item === 'string' ? item : (item.title||item.name||item.text||item.question||JSON.stringify(item).slice(0,30));
          html += `<span style="background:var(--s3);border:1px solid var(--bd);border-radius:5px;padding:3px 8px;font-size:10px;color:var(--t2)">${esc(String(label).slice(0,40))}</span>`;
        });
        html += '</div>';
      }
      if (content.cta_text) html += `<div style="margin-top:8px"><span style="background:var(--p);color:#fff;padding:4px 12px;border-radius:5px;font-size:11px;font-weight:600">${esc(content.cta_text)}</span></div>`;
    }

    html += '</div>';
  });

  if (editable) {
    html += `<div style="text-align:center;padding:16px 0;border-top:1px dashed var(--bd);margin-top:8px">
      <button onclick="bldAddSection()" style="background:transparent;border:1.5px dashed rgba(108,92,231,.4);color:var(--pu);border-radius:8px;padding:10px 24px;font-size:13px;cursor:pointer">+ Add Section</button>
    </div>`;
  } else {
    html += `<div style="text-align:center;padding:16px 0;border-top:1px dashed var(--bd);margin-top:8px">
      <div style="font-size:11px;color:var(--t3);margin-bottom:10px">This is a blueprint preview. Hydrate to convert into editable sections.</div>
      <div style="display:flex;gap:8px;justify-content:center">
        <button class="ct-btn primary" onclick="bldHydratePage()" style="font-size:12px;padding:8px 20px">🔧 Hydrate &amp; Edit</button>
        <button class="ct-btn" onclick="bldExportPage()" style="font-size:12px;padding:8px 20px;border:1px solid var(--bd)">📤 Publish as HTML</button>
      </div>
    </div>`;
  }
  html += '</div>';
  return html;
}

