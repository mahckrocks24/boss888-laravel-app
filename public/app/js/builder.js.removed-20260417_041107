      }
      if ((comps[_pi].type === 'heading' || comps[_pi].component_type === 'heading')) {
        _p2Heading = comps[_pi].text || (comps[_pi].content && comps[_pi].content.text) || '';
      }
      if ((comps[_pi].type === 'text' || comps[_pi].component_type === 'text') && !_p2Text) {
        _p2Text = comps[_pi].text || (comps[_pi].content && comps[_pi].content.text) || '';
