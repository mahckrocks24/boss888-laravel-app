          parts.push('<div contenteditable="true" style="font-size:12px;font-weight:600;color:var(--t1);margin-bottom:4px" onblur="bldCurrentPage.sections[' + si + '].components[' + ci + '].items[' + ki + '].heading=this.textContent;bldDirty=true">' + bld_esc(card.heading || card.title || '') + '</div>');
          parts.push('<div contenteditable="true" style="font-size:11px;color:var(--t3)" onblur="bldCurrentPage.sections[' + si + '].components[' + ci + '].items[' + ki + '].text=this.textContent;bldDirty=true">' + bld_esc(card.text || card.description || '') + '</div>');
