// ── Task retry ───────────────────────────────────────────────────────────
async function retryTask(taskId) {
  try {
    const res = await fetch(API + 'tasks/' + taskId + '/retry', {
      method: 'POST', headers: authHeader(),
    });
    const data = await res.json();
    if (!res.ok) {
      showToast(data.error === 'max_retries_exceeded'
        ? 'Max retries reached (' + data.max + '). Task permanently failed.'
        : 'Retry failed: ' + (data.error || 'unknown'), 'error');
      return;
    }
    showToast('Task re-queued (retry ' + data.retry_count + ' of 4)', 'success');
    setTimeout(loadTasks, 800);
  } catch(e) { showToast('Retry error: ' + e.message, 'error'); }
}

