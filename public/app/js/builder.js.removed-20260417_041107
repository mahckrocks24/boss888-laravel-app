  parts.push('</div>');

  var secIcons = {header:'🔝',navigation:'☰',footer:'🔻',banner:'📢',sidebar:'📎',hero:'🎯',features:'⭐',cta:'📣',text_block:'📝',testimonials:'💬',service_grid:'🔧',faq:'❓',contact_form:'📋',pricing:'💰',story:'📖',custom:'▪',contact:'📋',gallery:'🖼️',map:'📍',catalog:'🛒',carousel:'🎠',video:'▶',services:'🔧',about:'ℹ️',content:'📄',team:'👥',stats:'📊',blog_list:'📰',logo_cloud:'🏢',tabs:'📑',accordion:'🪗',timeline:'📅',table:'📋',comparison:'⚖️',before_after:'🔄',masonry:'🧱',raw_html:'<>',unknown_fallback:'❓',crm_form:'📥',booking_widget:'📆',review_feed:'⭐',social_feed:'📱',whatsapp_cta:'💬',ai_widget:'🤖',property_list:'🏠',product_grid:'🛍️',quote_form:'📝',seo_local:'📍'};

  for (var si = 0; si < sections.length; si++) {
