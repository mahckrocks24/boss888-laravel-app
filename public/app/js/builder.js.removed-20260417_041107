var _wsContext = null;
var _wsContextTs = 0;

function _bldGetContext() {
  return {
    workspaceId: 1, // single-workspace for now
    siteId: (window._wsReturnToSite || (typeof wsCurrentSite !== 'undefined' && wsCurrentSite ? wsCurrentSite.id : 0)),
