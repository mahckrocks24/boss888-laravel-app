/**
 * Update the website usage display near the New Website button.
 */
function _luUpdateWebsiteUsage(usage) {
    if (!usage) return;
    var count = usage.count || 0;
    var limit = usage.limit || 1;
    var plan  = usage.plan || 'Free';
    var atLimit = count >= limit;

    var badge = document.getElementById('lu-website-usage');

    // Find the New Website button
    var newBtn = document.querySelector('[onclick*="wsShowCreate"], [onclick*="bldNewWebsite"], [onclick*="wsNewSite"], .bld-new-website-btn, #bld-new-site-btn');
    if (!newBtn) {
        var allBtns = document.querySelectorAll('button, .btn, a.btn');
        for (var i = 0; i < allBtns.length; i++) {
            if (allBtns[i].textContent.match(/new\s*(web)?site/i) || allBtns[i].textContent.match(/create.*site/i)) {
                newBtn = allBtns[i];
                break;
            }
        }
    }

    if (!badge && newBtn) {
        badge = document.createElement('div');
        badge.id = 'lu-website-usage';
        badge.style.cssText = 'display:inline-flex;align-items:center;gap:8px;margin-left:12px;font-size:13px;color:#9CA3AF;vertical-align:middle;';
        newBtn.parentNode.insertBefore(badge, newBtn.nextSibling);
    }

    if (newBtn) {
        if (atLimit) {
            newBtn.classList.add('disabled');
            newBtn.style.opacity = '0.5';
            newBtn.style.pointerEvents = 'none';
            newBtn.setAttribute('title', 'Website limit reached \u2014 upgrade your plan');
        } else {
            newBtn.classList.remove('disabled');
            newBtn.style.opacity = '';
            newBtn.style.pointerEvents = '';
            newBtn.removeAttribute('title');
        }
    }

    if (badge) {
        var barColor = atLimit ? '#EF4444' : '#6C5CE7';
        var pct = Math.min(100, Math.round((count / limit) * 100));
        badge.innerHTML = '<span style="font-weight:600;color:' + (atLimit ? '#EF4444' : '#D1D5DB') + '">'
            + count + '/' + limit + ' websites</span>'
            + '<span style="width:60px;height:5px;background:rgba(255,255,255,.08);border-radius:3px;display:inline-block;overflow:hidden">'
            + '<span style="display:block;height:100%;width:' + pct + '%;background:' + barColor + ';border-radius:3px;transition:width .3s"></span>'
            + '</span>'
            + (atLimit ? '<a href="/app/#upgrade" style="color:#A78BFA;font-size:12px;font-weight:600;text-decoration:none">Upgrade \u2192</a>' : '<span style="font-size:11px;color:#6B7280">' + plan + '</span>');
    }
}

/**
 * Parse website list API response — handles both old (array) and new (object) format.
 */
function _luParseWebsiteResponse(data) {
    if (Array.isArray(data)) {
        return { websites: data, usage: null };
    }
    return { websites: data.websites || [], usage: data.usage || null };
}

// ── Intercept fetch for POST create-website to show limit_reached errors ──
(function() {
    var _origFetch = window.fetch;
    window.fetch = function(url, opts) {
        return _origFetch.apply(this, arguments).then(function(response) {
            if (typeof url !== 'string') return response;

            // POST /api/websites or /api/websites/create or /api/builder/websites — handle limit_reached
            if (url.match(/\/api\/(builder\/)?websites(\/create)?\/?$/) && opts && opts.method === 'POST') {
                var cloned = response.clone();
                cloned.json().then(function(data) {
                    if (data && data.limit_reached) {
                        if (typeof showToast === 'function') {
                            showToast(data.error || 'Website limit reached', 'error');
                        } else {
                            alert(data.error || 'Website limit reached. Please upgrade your plan.');
                        }
                    }
                }).catch(function() {});
            }

            return response;
        });
    };
})();

