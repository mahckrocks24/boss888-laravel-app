    btn.style.background = 'var(--ps)';
    btn.style.border     = '1px solid var(--p)';
    btn.style.color      = 'var(--pu)';
  }
  renderCampaignList(type);
}

function renderCampaignList(filter) {
  const listEl = document.getElementById('cmp-list');
  if (!listEl) return;
  const campaigns = filter === 'all' ? _allCampaigns : _allCampaigns.filter(c => c.campaign_type === filter);

  if (!campaigns.length) {
    listEl.innerHTML = '<div style="text-align:center;padding:60px;color:var(--t3);font-size:13px">No campaigns yet. Click <strong>+ New Campaign</strong> to bld_get started.</div>';
    return;
  }

  const statusColors = { draft:'var(--t3)', active:'var(--ac)', paused:'var(--am)', completed:'var(--bl)' };
  const typeLabels   = { seo_growth:'SEO Growth', content_engine:'Content Engine', social_growth:'Social Growth', lead_generation:'Lead Generation' };

  listEl.innerHTML = campaigns.map(c => {
    const sc  = statusColors[c.status] || 'var(--t3)';
    const tl  = typeLabels[c.campaign_type] || c.campaign_type;
    const tasks = c.task_count || 0;
    return `<div onclick="openCampaignDetail(${c.id})" style="background:var(--s1);border:1px solid var(--bd);border-radius:var(--rg);padding:16px 20px;cursor:pointer;transition:border-color .15s;display:flex;align-items:center;gap:16px"
            onmouseover="this.style.borderColor='var(--p)'" onmouseout="this.style.borderColor='var(--bd)'">
      <div style="flex:1;min-width:0">
        <div style="font-family:var(--fh);font-size:14px;font-weight:700;color:var(--t1);margin-bottom:4px">${bld_esc(c.name)}</div>
        <div style="font-size:12px;color:var(--t3)">${bld_esc(tl)}</div>
      </div>
      <div style="display:flex;align-items:center;gap:16px;flex-shrink:0">
        <div style="text-align:center">
          <div style="font-size:18px;font-weight:700;color:var(--bl)">${tasks}</div>
          <div style="font-size:10px;color:var(--t3)">tasks</div>
        </div>
        <div style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;border:1px solid ${sc}20;background:${sc}15;font-size:11px;font-weight:700;color:${sc}">${c.status}</div>
        ${c.status === 'draft' || c.status === 'paused'
