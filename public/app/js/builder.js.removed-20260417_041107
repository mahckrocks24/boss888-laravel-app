async function _arthurExec(actionType, si) {
  var status = document.getElementById('arthur-status');
  if (status) { status.style.display = 'block'; status.textContent = '\u26A1 Executing...'; }

  var secEl = document.querySelector('#bld-canvas .bld-sec[data-si="' + si + '"]');
  if (secEl) secEl.classList.add('arthur-loading');

  try {
    var ctx = _bldGetAIContext(si);
    ctx.source = 'arthur_quick_action';
    // Ensure section_index is explicit — required for update_section apply
    ctx.section_index = si;

    var r = await fetch(API + 'builder/ai', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
      body: JSON.stringify({command: actionType, action_type: actionType, context: ctx})
    });
    var d = await r.json();

    // Execution layer — improve/rewrite MUST return structured data, never text
    if (d.ai_action === 'text_response' || (!d.data && d.success)) {
      // Retry once with explicit instruction
      if (status) status.textContent = '\u26A1 Retrying...';
      var retryCtx = Object.assign({}, ctx, {force_json: true, retry: true});
      var r2 = await fetch(API + 'builder/ai', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
        body: JSON.stringify({command: actionType, action_type: actionType, context: retryCtx})
      });
      d = await r2.json();
    }

    // Normalize: empty array is not valid data
    if (d.data && Array.isArray(d.data) && d.data.length === 0) d.data = null;

    if (d.success && d.data && d.ai_action && d.ai_action !== 'text_response') {
      // Inject section_index if not present in response data
      if (typeof d.data.section_index !== 'number') d.data.section_index = si;

      d.data = _bldNormalizeAIResponse(d.ai_action, d.data);
      var v = _bldValidateAIResponse(d.ai_action, d.data);
      if (v.valid) {
        _bldSnapshotForUndo();
        _bldApplyAIResponse(d.ai_action, d.data);
        bldDirty = true;
        bldRenderCanvas();
        setTimeout(function() { bldSelectComponent(si, null); }, 80);
        if (status) { status.textContent = '\u2705 Done!'; setTimeout(arthurHide, 1200); }
      } else {
        if (status) status.textContent = '\u26A0\uFE0F Could not apply — try rephrasing: ' + v.reason;
      }
    } else {
      var errMsg = d.error || (d.success ? 'AI did not return structured changes. Please retry.' : 'Request failed.');
      if (status) status.textContent = '\u26A0\uFE0F ' + errMsg;
    }
  } catch(e) {
    if (status) status.textContent = 'Error: ' + e.message;
  }

  if (secEl) secEl.classList.remove('arthur-loading');
}

