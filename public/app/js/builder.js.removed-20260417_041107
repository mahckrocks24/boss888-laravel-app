          + '<div style="height:100%;width:' + cv + '%;background:' + cc + ';border-radius:3px;transition:width .5s"></div></div>'
          + '<span style="font-size:10px;font-weight:600;color:' + cc + ';width:26px;text-align:right">' + cv + '</span></div>';
      }
      html += '</div>';
    }

    // Roadmap
    var rm = d.roadmap || [];
    if (rm.length) {
      html += '<div style="border-top:1px solid rgba(255,255,255,.06);padding-top:8px;margin-top:4px">'
        + '<div style="font-size:10px;color:var(--t2);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px">\uD83D\uDDFA\uFE0F Growth Roadmap</div>';
      rm.forEach(function(r, ri) {
        var pc = r.priority === 'high' ? '#EF4444' : r.priority === 'medium' ? '#F59E0B' : '#6B7280';
        html += '<div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.03)">'
          + '<span style="font-size:12px;font-weight:700;color:var(--t2);width:16px">' + (ri+1) + '</span>'
          + '<div style="flex:1;min-width:0">'
          + '<div style="font-size:11px;font-weight:600;color:#fff">' + bld_esc(r.title) + '</div>'
          + '<div style="font-size:9px;color:' + pc + ';margin-top:1px">' + bld_esc(r.impact) + '</div></div>'
          + '<button onclick="event.stopPropagation();_arthurApplySuggestion(' + si + ',' + ri + ',\'' + encodeURIComponent(r.action||'') + '\',\'' + encodeURIComponent(r.title||'') + '\')" '
          + 'style="flex-shrink:0;background:rgba(108,92,231,.2);border:1px solid rgba(108,92,231,.3);border-radius:6px;color:#A78BFA;font-size:9px;font-weight:600;padding:3px 8px;cursor:pointer" '
          + 'onmouseenter="this.style.background=\'rgba(108,92,231,.35)\'" onmouseleave="this.style.background=\'rgba(108,92,231,.2)\'">Apply</button></div>';
      });
      html += '</div>';
    }

    // Detailed suggestions (collapsible)
    if (d.suggestions && d.suggestions.length) {
      html += '<details style="border-top:1px solid rgba(255,255,255,.06);margin-top:6px;padding-top:6px">'
        + '<summary style="font-size:10px;color:var(--t2);cursor:pointer;text-transform:uppercase;letter-spacing:1px">' + d.issue_count + ' detailed suggestion' + (d.issue_count !== 1 ? 's' : '') + '</summary>'
        + '<div style="padding-top:6px">';
      d.suggestions.forEach(function(s, i) {
        html += '<div style="display:flex;align-items:flex-start;gap:6px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.03)">'
          + '<span style="font-size:14px">' + (s.icon||'\uD83D\uDCA1') + '</span>'
