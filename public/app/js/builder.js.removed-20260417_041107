// ═══════════════════════════════════════════════════════════════════════════
// AI CONTEXT — builds full context for AI requests
// ═══════════════════════════════════════════════════════════════════════════
function _bldGetAIContext(sectionIndex) {
  var ctx = {};
  if (bldCurrentPage) {
    ctx.page_title = bldCurrentPage.title || '';
    ctx.page_type = bldCurrentPage.type || '';
    ctx.page_id = bldCurrentPageId || null;
    ctx.page_slug = bldCurrentPage.slug || '';
    ctx.section_count = (bldCurrentPage.sections || []).length;
    ctx.sections = bldCurrentPage.sections || [];
    // Extract header/footer/nav structures for AI awareness
    var hdrIdx = _bldFindSectionByType('header');
    var ftrIdx = _bldFindSectionByType('footer');
    var navIdx = _bldFindSectionByType('navigation');
    if (hdrIdx >= 0) ctx.header = bldCurrentPage.sections[hdrIdx];
    if (ftrIdx >= 0) ctx.footer = bldCurrentPage.sections[ftrIdx];
    if (navIdx >= 0) ctx.navigation = bldCurrentPage.sections[navIdx];
  }
  if (typeof sectionIndex === 'number' && bldCurrentPage && bldCurrentPage.sections) {
    ctx.section = bldCurrentPage.sections[sectionIndex];
    ctx.section_index = sectionIndex;
  }
  var theme = bldCurrentPage ? (bldCurrentPage.theme || {}) : {};
  ctx.business_name = theme.business_name || bldCurrentPage?.title || '';
  ctx.industry      = theme.industry || '';
  ctx.location      = theme.location || '';

  // R1 FIX: Inject arthur_context (wizard intelligence) into every AI call.
  // bldCurrentPage.arthur_context is populated by wsEditSitePage from lu_websites.config.
  var ac = (bldCurrentPage && bldCurrentPage.arthur_context) ? bldCurrentPage.arthur_context : {};
  if (ac.core_service)    ctx.core_service    = ac.core_service;
  if (ac.tone)            ctx.tone            = ac.tone;
  if (ac.audience)        ctx.audience        = ac.audience;
  if (ac.location && !ctx.location)  ctx.location = ac.location;
  if (ac.primary_color)   ctx.primary_color   = ac.primary_color;
  if (ac.secondary_color) ctx.secondary_color = ac.secondary_color;
  if (ac.design_style)    ctx.design_style    = ac.design_style;

  // Website context
  if (window._wsReturnToSite && wsCurrentSite) {
    ctx.is_website = true;
    ctx.website_name = wsCurrentSite.title || '';
    ctx.website_id = wsCurrentSite.id;
    // Include sibling pages for multi-page awareness
    if (_bldWebsitePages && _bldWebsitePages.length) {
      ctx.all_pages = _bldWebsitePages.map(function(p) { return {id:p.id, title:p.title, slug:p.slug, type:p.page_type}; });
    }
  }
  return ctx;
}

// ═══════════════════════════════════════════════════════════════════════════
// AI APPLY — applies validated AI responses to builder state
// ═══════════════════════════════════════════════════════════════════════════
// ══════════════════════════════════════════════════════════════════════
// FORMAT C SAFETY LAYER — scope guard + style guard for legacy actions
// Applied before every _bldApplyAIResponse call.
// ══════════════════════════════════════════════════════════════════════

// Allowed style keys for incoming sections from AI
var _BLD_LEGACY_ALLOWED_STYLE_KEYS = [
  'bg','gradient','color','paddingTop','paddingBottom','paddingX','padding',
  'opacity','borderRadius','border','shadow','textAlign','maxWidth','overlay',
  'fontFamily','fontSize','fontWeight','lineHeight','letterSpacing','display',
  'alignItems','justifyContent','flexDirection','gap','minHeight',
];

// Guard 1: Scope — verify action targets are within bounds and match intended section
// Returns { ok:true } or { ok:false, reason:string }
function _bldLegacyScopeGuard(action, data, si) {
  if (!bldCurrentPage || !bldCurrentPage.sections) {
    return { ok: false, reason: 'No page loaded' };
  }
  var total = bldCurrentPage.sections.length;

  // update_section: section_index must match intended si (or be valid)
  if (action === 'update_section') {
    var idx = typeof data.section_index === 'number' ? data.section_index : si;
    if (typeof idx !== 'number' || idx < 0 || idx >= total) {
      return { ok: false, reason: 'update_section: section_index ' + idx + ' out of range (page has ' + total + ' sections)' };
    }
    // If si is provided (Arthur context), reject cross-section mutation
    if (typeof si === 'number' && idx !== si) {
      return { ok: false, reason: 'update_section: AI targeted section ' + idx + ' but context is section ' + si };
    }
  }

  // update_page / create_page: section count sanity check
  if (action === 'update_page' || action === 'create_page') {
    if (!data.sections || !Array.isArray(data.sections)) {
      return { ok: false, reason: action + ': missing sections array' };
    }
    if (data.sections.length === 0) {
      return { ok: false, reason: action + ': would replace page with zero sections' };
    }
    // Reject if incoming count differs by more than 3 (suspiciously large mutation)
    if (Math.abs(data.sections.length - total) > 3) {
      return { ok: false, reason: action + ': section count change too large (' + total + ' → ' + data.sections.length + ')' };
    }
  }

  // update_header/footer/nav: must find target section
  if (action === 'update_header') {
    var hIdx = _bldFindSectionByType('header');
    if (hIdx < 0) return { ok: false, reason: 'update_header: no header section found on page' };
  }
  if (action === 'update_footer') {
    var fIdx = _bldFindSectionByType('footer');
    if (fIdx < 0) return { ok: false, reason: 'update_footer: no footer section found on page' };
  }
  if (action === 'update_navigation') {
    var nIdx = _bldFindSectionByType('navigation');
    if (nIdx < 0) nIdx = _bldFindSectionByType('header');
    if (nIdx < 0) return { ok: false, reason: 'update_navigation: no navigation/header section found' };
  }

  return { ok: true };
}

// Guard 2: Style — strip unknown style keys from incoming section objects
// Modifies in-place (does not throw). Returns cleaned section.
function _bldLegacyStyleGuard(section) {
  if (!section || typeof section !== 'object') return section;
  // Clean section.style
  if (section.style && typeof section.style === 'object') {
    Object.keys(section.style).forEach(function(k) {
      if (_BLD_LEGACY_ALLOWED_STYLE_KEYS.indexOf(k) === -1) {
        console.warn('[LEGACY STYLE GUARD] Stripping unknown style key:', k);
        delete section.style[k];
      }
    });
  }
  // Clean component styles
  if (Array.isArray(section.components)) {
    section.components.forEach(function(cmp) {
      if (cmp && cmp.style && typeof cmp.style === 'object') {
        Object.keys(cmp.style).forEach(function(k) {
          if (_BLD_LEGACY_ALLOWED_STYLE_KEYS.indexOf(k) === -1) {
            delete cmp.style[k];
          }
        });
      }
    });
  }
  return section;
}

// Guard 3: Structure — reject responses that would break editability
// Returns { ok:true } or { ok:false, reason:string }
function _bldLegacyStructureGuard(action, data) {
  // Reject if data.section or sections have null/missing type
  function checkSec(sec, label) {
    if (!sec || typeof sec !== 'object') return label + ': invalid section object';
    // Components must be array if present
    if (sec.components !== undefined && !Array.isArray(sec.components)) {
      return label + ': components must be array';
    }
    // Each component must have a type string
    if (Array.isArray(sec.components)) {
      for (var i = 0; i < sec.components.length; i++) {
        var c = sec.components[i];
        if (!c || typeof c.type !== 'string' || c.type.trim() === '') {
          return label + ': component[' + i + '] missing type';
        }
      }
    }
    return null;
  }

  if (action === 'update_section' || action === 'create_section' ||
      action === 'update_header' || action === 'update_footer' || action === 'update_navigation') {
    var sec = data.section || data;
    var err = checkSec(sec, action);
    if (err) return { ok: false, reason: err };
    // Apply style guard in-place
    _bldLegacyStyleGuard(sec);
  }

  if (action === 'update_page' || action === 'create_page') {
    if (Array.isArray(data.sections)) {
      for (var s = 0; s < data.sections.length; s++) {
        var serr = checkSec(data.sections[s], 'sections[' + s + ']');
        if (serr) return { ok: false, reason: serr };
        _bldLegacyStyleGuard(data.sections[s]);
      }
    }
  }

  return { ok: true };
}

// ── Combined legacy safety check — call before every _bldApplyAIResponse ──
// Returns { ok:true } or { ok:false, reason:string }
function _bldLegacySafetyCheck(action, data, si) {
  var scope = _bldLegacyScopeGuard(action, data, si);
  if (!scope.ok) return scope;
  var struct = _bldLegacyStructureGuard(action, data);
  if (!struct.ok) return struct;
  return { ok: true };
}

function _bldApplyAIResponse(action, data) {
  try {
  if (!bldCurrentPage) return;
  if (!bldCurrentPage.sections) bldCurrentPage.sections = [];

  // Normalize before applying
  data = _bldNormalizeAIResponse(action, data);

  // Sanitize incoming sections data
  if (data && data.sections) data.sections = _bldSanitizeSections(data.sections);
  if (data && data.section && data.section.components) data.section.components = _bldSanitizeSections([data.section])[0]?.components || data.section.components;

  var diffSummary = '';

  switch (action) {
    case 'create_section':
      var newSec = data.section || data;
      if (newSec && (newSec.type || newSec.components)) {
        bldCurrentPage.sections.push(newSec);
        diffSummary = '+ Added ' + (newSec.type || 'custom') + ' section';
      }
      break;

    case 'update_section':
      var si = (typeof data.section_index === 'number') ? data.section_index : _bldSelSec;
      if (typeof si !== 'number' || si < 0 || si >= bldCurrentPage.sections.length) {
        console.warn('[AI APPLY] Invalid section_index:', si);
        return;
      }
      var oldType = bldCurrentPage.sections[si].type;
      var updatedSec = data.section || data;
      if (updatedSec.components) {
        bldCurrentPage.sections[si] = updatedSec;
      } else {
        Object.assign(bldCurrentPage.sections[si], updatedSec);
      }
      diffSummary = 'Updated ' + (oldType || 'section') + ' at position ' + (si + 1);
      break;

    case 'update_header':
      // Header = first section of type 'header', or sections[0]
      var hdrIdx = _bldFindSectionByType('header');
      if (hdrIdx >= 0) {
        var hdrSec = data.section || data;
        if (hdrSec.components) bldCurrentPage.sections[hdrIdx] = hdrSec;
        else Object.assign(bldCurrentPage.sections[hdrIdx], hdrSec);
        diffSummary = 'Updated header';
      }
      break;

    case 'update_footer':
      var ftrIdx = _bldFindSectionByType('footer');
      if (ftrIdx >= 0) {
        var ftrSec = data.section || data;
        if (ftrSec.components) bldCurrentPage.sections[ftrIdx] = ftrSec;
        else Object.assign(bldCurrentPage.sections[ftrIdx], ftrSec);
        diffSummary = 'Updated footer';
      }
      break;

    case 'update_navigation':
      var navIdx = _bldFindSectionByType('navigation');
      if (navIdx === -1) navIdx = _bldFindSectionByType('header');
      if (navIdx >= 0) {
        var navSec = data.section || data;
        if (navSec.components) bldCurrentPage.sections[navIdx] = navSec;
        else Object.assign(bldCurrentPage.sections[navIdx], navSec);
        diffSummary = 'Updated navigation';
      }
      break;

    case 'update_page':
    case 'create_page':
      if (data.sections && Array.isArray(data.sections)) {
        var oldCount = bldCurrentPage.sections.length;
        var newCount = data.sections.length;
        bldCurrentPage.sections = data.sections;
        var added = Math.max(0, newCount - oldCount);
        var removed = Math.max(0, oldCount - newCount);
        diffSummary = 'Page replaced: ' + newCount + ' sections';
        if (added) diffSummary += ' (+' + added + ' new)';
        if (removed) diffSummary += ' (-' + removed + ' removed)';
      }
      break;

    case 'create_website':
      // Multi-page: handled by bldAIAction which creates pages via API
      diffSummary = 'Website generation requested';
      break;

    case 'update_component':
      var csi = data.section_index;
      var cci = data.component_index;
      if (typeof csi === 'number' && typeof cci === 'number') {
        var comps = bldCurrentPage.sections[csi]?.components;
        if (comps && comps[cci]) {
          Object.assign(comps[cci], data.component || data.changes || {});
          diffSummary = 'Updated component ' + (comps[cci].type || '') + ' in section ' + (csi + 1);
        }
      }
      break;
  }

  if (diffSummary) console.log('[AI APPLY]', diffSummary);
  // ── PATCH 1: Post-apply schema sync — ensures component_type↔type are aligned
  // immediately after any AI mutation, not only at render time.
  if (bldCurrentPage && bldCurrentPage.sections) {
    bldCurrentPage.sections = _bldSanitizeSections(bldCurrentPage.sections);
  }
  bldDirty = true;
  bldRenderCanvas();
  try { bldRenderLayers(); } catch(e) {}

  // ── Progress tracking: record score after successful edit ──
  if (diffSummary) {
    try { _arthurRecordProgress(); } catch(pe) { console.warn('[PROGRESS] Record failed:', pe); }
  }

  return diffSummary;
  } catch(applyErr) {
    console.error('[AI APPLY] Safe fallback — edit could not be applied:', applyErr);
    showToast('Edit could not be applied safely. Try again.', 'warning');
    return '';
  }
}

// Find section by type — returns FIRST match index, warns on duplicates
function _bldFindSectionByType(type) {
  if (!bldCurrentPage || !bldCurrentPage.sections) return -1;
  var found = -1;
  var count = 0;
  for (var i = 0; i < bldCurrentPage.sections.length; i++) {
    if (bldCurrentPage.sections[i].type === type) {
      if (found === -1) found = i;
      count++;
    }
  }
  if (count > 1) console.warn('[Builder] Multiple ' + type + ' sections found (' + count + '). Using first at index ' + found + '.');
  return found;
}

// ═══════════════════════════════════════════════════════════════════════════
// AI ACTION BUTTONS — all go through validation + undo pipeline
// ═══════════════════════════════════════════════════════════════════════════
async function bldAIAction(actionType, sectionIndex, extraPrompt) {
  var ctx = _bldGetAIContext(sectionIndex);
  var command = extraPrompt || '';

  // Verify section still exists for section-targeted actions
  if ((actionType === 'rewrite' || actionType === 'improve') && typeof sectionIndex === 'number') {
    if (!bldCurrentPage || !bldCurrentPage.sections || !bldCurrentPage.sections[sectionIndex]) {
      showToast('Section no longer exists', 'warning');
      return;
    }
  }

  var secEls = document.querySelectorAll('#bld-canvas .bld-sec');
  var targetEl = (typeof sectionIndex === 'number' && secEls[sectionIndex]) ? secEls[sectionIndex] : null;
  if (targetEl) targetEl.classList.add('arthur-loading');

  showToast('AI is working...', 'info');
  ctx.source = 'arthur_action';

  try {
    var r = await fetch(API + 'builder/ai', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
      body: JSON.stringify({command: command, action_type: actionType, context: ctx})
    });
    var d = await r.json();

    if (!d.success) {
      showToast(d.error || 'AI request failed.', 'error');
    } else if (d.ai_action === 'text_response') {
      showToast(d.explanation || 'AI had no structural changes.', 'info');
    } else if (d.ai_action === 'create_website' && d.data && d.data.website) {
      // Multi-page website generation — create pages via API
      showToast('Creating website pages...', 'info');
      await _bldCreateWebsiteFromAI(d.data.website);
    } else {
      // Normalize → Validate → Safety → Snapshot → Apply
      d.data = _bldNormalizeAIResponse(d.ai_action, d.data);
      var vResult = _bldValidateAIResponse(d.ai_action, d.data);
      if (!vResult.valid) {
        console.warn('[AI VALIDATOR] Rejected:', vResult.reason, d);
        showToast('AI response rejected: ' + vResult.reason, 'warning');
      } else {
        // FORMAT C SAFETY: scope + structure guards
        var safetyCheck = _bldLegacySafetyCheck(d.ai_action, d.data, sectionIndex);
        if (!safetyCheck.ok) {
          console.warn('[LEGACY SAFETY] Blocked:', safetyCheck.reason, d.ai_action);
          showToast('Edit blocked: ' + safetyCheck.reason, 'warning');
        } else {
          _bldSnapshotForUndo();
          var savedSec = _bldSelSec;
          var savedCmp = _bldSelCmp;
          var diff = _bldApplyAIResponse(d.ai_action, d.data);
          // Re-render props panel after AI apply so properties stay live
          setTimeout(function() {
            if (typeof savedSec === 'number') {
              _bldRenderProps(savedSec, savedCmp);
            }
          }, 80);
          showToast((d.explanation || 'AI changes applied!') + (diff ? ' (' + diff + ')' : ''), 'success');
        }
      }
    }
  } catch(e) {
    showToast('AI failed: ' + e.message, 'error');
  }

  if (targetEl) targetEl.classList.remove('arthur-loading');
}

function bldAIRewrite(si) { bldAIAction('rewrite', si); }
function bldAIImprove(si) { bldAIAction('improve', si); }
function bldAIGenSection(type) { bldAIAction('generate_section', null, type || 'hero'); }
function bldAIOptimize() { bldAIAction('optimize'); }
function bldAIGenPage(pageType) { bldAIAction('generate_page', null, pageType || 'home'); }
function bldAIEditHeader() {
  var idx = _bldFindSectionByType('header');
  if (idx === -1) { bldAIAction('generate_section', null, 'header'); return; }
  bldAIAction('improve', idx);
}
function bldAIEditFooter() {
  var idx = _bldFindSectionByType('footer');
  if (idx === -1) { bldAIAction('generate_section', null, 'footer'); return; }
  bldAIAction('improve', idx);
}
function bldAIEditNav() {
  var idx = _bldFindSectionByType('navigation');
  if (idx === -1) idx = _bldFindSectionByType('header');
  if (idx === -1) { bldAIAction('generate_section', null, 'navigation'); return; }
  bldAIAction('improve', idx);
}

async function bldAIGenWebsite() {
  if (!window._wsReturnToSite) {
    showToast('Switch to Website Builder to generate a full website.', 'warning');
    return;
  }
  var ok = await luConfirm('This will generate a complete multi-page website using AI. Existing pages in this website will NOT be affected — new pages will be added.', 'Generate Full Website', 'Generate', 'Cancel');
  if (!ok) return;
  bldAIAction('create_website', null, 'Generate a complete multi-page website');
}

// Create multiple pages from AI website response
async function _bldCreateWebsiteFromAI(websiteData) {
  var pages = websiteData.pages || [];
  if (!pages.length) { showToast('AI returned no pages.', 'warning'); return; }

  var websiteId = window._wsReturnToSite || 0;
  var sharedHeader = websiteData.header || null;
  var sharedFooter = websiteData.footer || null;
  var sharedNav = websiteData.navigation || null;
  var created = 0;

  for (var p = 0; p < pages.length; p++) {
    var pg = pages[p];
    var sections = [];

    // Prepend shared header if provided
    if (sharedHeader) sections.push(JSON.parse(JSON.stringify(sharedHeader)));
    if (sharedNav) sections.push(JSON.parse(JSON.stringify(sharedNav)));

    // Page sections
    if (pg.sections && Array.isArray(pg.sections)) {
      for (var s = 0; s < pg.sections.length; s++) sections.push(pg.sections[s]);
    }

    // Append shared footer
    if (sharedFooter) sections.push(JSON.parse(JSON.stringify(sharedFooter)));

    try {
      var r = await fetch(API + 'builder/create', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
        body: JSON.stringify({title: pg.title || ('Page ' + (p+1)), type: pg.slug || 'page', website_id: websiteId})
      });
      var d = await r.json();
      if (d.success && d.page && d.page.id) {
        await fetch(API + 'builder/save', {
          method: 'POST',
          headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
          body: JSON.stringify({page_id: d.page.id, layout: {title: pg.title, type: pg.slug, sections: sections, theme: {}}})
        });
        created++;
      }
    } catch(e) { console.error('[AI Website] Page creation failed:', pg.title, e); }
  }

  showToast('AI generated ' + created + ' pages!', 'success');

  // Reload website pages
  if (websiteId && typeof wsOpenSite === 'function') {
    // Go back to website page list
    document.getElementById('bld-editor-state').style.display = 'none';
    document.getElementById('view-builder').style.display = 'none';
    nav('websites');
    setTimeout(function() { wsOpenSite(websiteId); }, 100);
  }
}

