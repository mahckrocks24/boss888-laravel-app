function _luShowSubdomainPicker(websiteId, businessName) {
  _luSubPickerWebsiteId = websiteId;
  var existing = document.querySelector('.lu-subdomain-picker-overlay');
  if (existing) existing.remove();

  var suggested = (businessName || 'my-business').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').substring(0, 40);

  var ov = document.createElement('div');
  ov.className = 'lu-subdomain-picker-overlay';
  ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:99999;backdrop-filter:blur(4px)';
  ov.innerHTML =
    '<div style="background:#fff;border-radius:16px;padding:36px 32px;max-width:520px;width:92%;font-family:inherit">' +
      '<h2 style="font-size:22px;font-weight:700;margin:0 0 6px;color:#1a1a2e">Choose your web address</h2>' +
      '<p style="color:#888;font-size:14px;margin:0 0 24px">This is where your website will be accessible.</p>' +
      '<div style="display:flex;align-items:center;gap:0;margin-bottom:8px">' +
        '<div style="flex:1;position:relative">' +
          '<input id="lu-sub-input" type="text" value="' + suggested + '" placeholder="your-business-name" autocomplete="off" spellcheck="false" ' +
            'style="width:100%;padding:12px 14px;border:2px solid #e0e0e0;border-right:none;border-radius:10px 0 0 10px;font-size:15px;outline:none;font-family:inherit;color:#1a1a2e;transition:border-color .2s" />' +
        '</div>' +
        '<div style="background:#f4f2ff;border:2px solid #e0e0e0;border-left:none;border-radius:0 10px 10px 0;padding:12px 14px;font-size:15px;color:#6C5CE7;font-weight:600;white-space:nowrap">.levelupgrowth.io</div>' +
        '<span id="lu-sub-status" style="margin-left:10px;font-size:20px;min-width:28px;text-align:center"></span>' +
      '</div>' +
      '<p id="lu-sub-preview" style="font-size:13px;color:#6C5CE7;margin:0 0 6px;word-break:break-all">https://' + suggested + '.levelupgrowth.io</p>' +
      '<p id="lu-sub-msg" style="font-size:12px;color:#888;margin:0 0 16px;min-height:18px"></p>' +
      '<div id="lu-sub-suggestion" style="display:none;background:#f8f9fa;border-radius:8px;padding:10px 14px;margin-bottom:16px;font-size:13px;color:#555">' +
        'Suggested: <strong id="lu-sub-suggest-val"></strong> ' +
        '<a id="lu-sub-use-suggest" href="#" style="color:#6C5CE7;font-weight:600;text-decoration:none;margin-left:8px">Use this</a>' +
      '</div>' +
      '<div style="display:flex;gap:10px;justify-content:flex-end;margin-top:8px">' +
        '<button id="lu-sub-cancel" style="background:#f0f0f0;color:#333;border:none;padding:11px 24px;border-radius:8px;cursor:pointer;font-weight:600;font-size:14px">Cancel</button>' +
        '<button id="lu-sub-confirm" disabled style="background:#6C5CE7;color:#fff;border:none;padding:11px 28px;border-radius:8px;cursor:pointer;font-weight:700;font-size:14px;opacity:.5;transition:opacity .2s">Publish Website \u2192</button>' +
      '</div>' +
    '</div>';

  document.body.appendChild(ov);

  var inp = document.getElementById('lu-sub-input');
  var confirmBtn = document.getElementById('lu-sub-confirm');
  var cancelBtn = document.getElementById('lu-sub-cancel');
  var useSuggest = document.getElementById('lu-sub-use-suggest');

  // Auto-check the suggested slug
  setTimeout(function(){ _luCheckSubdomain(suggested); }, 100);

  inp.addEventListener('input', function() {
    var val = inp.value.toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-');
    if (val !== inp.value) inp.value = val;
    document.getElementById('lu-sub-preview').textContent = 'https://' + (val || '___') + '.levelupgrowth.io';
    confirmBtn.disabled = true;
    confirmBtn.style.opacity = '.5';
    document.getElementById('lu-sub-status').textContent = '';
    document.getElementById('lu-sub-msg').textContent = '';
    document.getElementById('lu-sub-suggestion').style.display = 'none';
    clearTimeout(_luSubPickerTimer);
    if (val.length >= 2) {
      _luSubPickerTimer = setTimeout(function(){ _luCheckSubdomain(val); }, 500);
    }
  });

  inp.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !confirmBtn.disabled) confirmBtn.click();
  });

  cancelBtn.addEventListener('click', function() { ov.remove(); });
  ov.addEventListener('click', function(e) { if (e.target === ov) ov.remove(); });

  useSuggest.addEventListener('click', function(e) {
    e.preventDefault();
    var sugVal = document.getElementById('lu-sub-suggest-val').textContent;
    if (sugVal) {
      inp.value = sugVal;
      document.getElementById('lu-sub-preview').textContent = 'https://' + sugVal + '.levelupgrowth.io';
      document.getElementById('lu-sub-suggestion').style.display = 'none';
      _luCheckSubdomain(sugVal);
    }
  });

  confirmBtn.addEventListener('click', function() {
    var slug = inp.value.replace(/^-|-$/g, '');
    if (!slug || slug.length < 2) { showToast('Subdomain must be at least 2 characters', 'warning'); return; }
    confirmBtn.disabled = true;
    confirmBtn.textContent = 'Publishing\u2026';

    // Set subdomain then publish
    fetch('/api/builder/websites/' + _luSubPickerWebsiteId, {
      method: 'PUT',
      headers: {'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'},
      body: JSON.stringify({ subdomain: slug + '.levelupgrowth.io' })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.error) { showToast(d.error, 'error'); confirmBtn.disabled = false; confirmBtn.textContent = 'Publish Website \u2192'; return; }
      // Now actually publish
      return fetch('/api/builder/websites/' + _luSubPickerWebsiteId + '/publish', {
        method: 'POST',
        headers: {'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'},
        body: '{}'
      }).then(function(r2){ return r2.json(); });
    })
    .then(function(pubData) {
      if (!pubData) return;
      ov.remove();
      if (pubData.success) {
        var liveUrl = pubData.url || 'https://' + slug + '.levelupgrowth.io';
        _luShowPublishedModal(liveUrl);
        showToast('Your website is live!', 'success');
        // Update local state
        var s = typeof wsSites !== 'undefined' && wsSites ? wsSites.find(function(s){return s.id === _luSubPickerWebsiteId;}) : null;
        if (s) { s.subdomain = slug + '.levelupgrowth.io'; s.publish_state = 'published'; s.status = 'published'; }
        if (typeof wsCurrentSite !== 'undefined' && wsCurrentSite && wsCurrentSite.id === _luSubPickerWebsiteId) {
          wsCurrentSite.subdomain = slug + '.levelupgrowth.io';
        }
        if (typeof wsUpdateStats === 'function') wsUpdateStats();
        if (typeof wsRenderGrid === 'function') wsRenderGrid();
      } else {
        showToast(pubData.error || 'Publish failed', 'error');
      }
    })
    .catch(function(err) {
      showToast('Publish failed: ' + err.message, 'error');
      confirmBtn.disabled = false;
      confirmBtn.textContent = 'Publish Website \u2192';
    });
  });

  inp.focus();
  inp.select();
}

function _luCheckSubdomain(slug) {
  if (!slug || slug.length < 2) return;
  var status = document.getElementById('lu-sub-status');
  var msg = document.getElementById('lu-sub-msg');
  var confirmBtn = document.getElementById('lu-sub-confirm');
  var suggestion = document.getElementById('lu-sub-suggestion');

  status.textContent = '\u23F3';
  msg.textContent = 'Checking availability\u2026';
  msg.style.color = '#888';

  fetch('/api/builder/check-subdomain?slug=' + encodeURIComponent(slug) + '&exclude=' + (_luSubPickerWebsiteId || ''), {
    headers: {'Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'}
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    // Only update if input still matches
    var currentVal = document.getElementById('lu-sub-input');
    if (!currentVal || currentVal.value !== slug) return;

    if (data.available) {
      status.textContent = '\u2705';
      msg.textContent = 'Available!';
      msg.style.color = '#27ae60';
      confirmBtn.disabled = false;
      confirmBtn.style.opacity = '1';
      suggestion.style.display = 'none';
    } else {
      status.textContent = '\u274C';
      msg.textContent = 'Already taken';
      msg.style.color = '#e74c3c';
      confirmBtn.disabled = true;
      confirmBtn.style.opacity = '.5';
      if (data.suggestion) {
        document.getElementById('lu-sub-suggest-val').textContent = data.suggestion;
        suggestion.style.display = 'block';
      }
    }
  })
  .catch(function() {
    status.textContent = '\u26A0\uFE0F';
    msg.textContent = 'Could not check availability';
    msg.style.color = '#e67e22';
  });
}

function _luShowPublishedModal(url) {
  var existing = document.querySelector('.lu-pub-modal-overlay');
  if (existing) existing.remove();
  var modal = document.createElement('div');
  modal.className = 'lu-pub-modal-overlay';
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:99999';
  modal.innerHTML =
    '<div style="background:#fff;border-radius:16px;padding:40px 36px;max-width:480px;width:90%;text-align:center;font-family:inherit">' +
      '<div style="font-size:52px;line-height:1;margin-bottom:14px">\uD83D\uDE80</div>' +
      '<h2 style="font-size:22px;font-weight:700;margin:0 0 8px">Website Published!</h2>' +
      '<p style="color:#888;font-size:14px;margin:0 0 18px">Your website is now live at:</p>' +
      '<a href="' + url + '" target="_blank" style="display:block;background:#f4f2ff;border:1.5px solid #6C5CE7;border-radius:8px;padding:11px 14px;font-size:14px;color:#6C5CE7;text-decoration:none;font-weight:600;word-break:break-all;margin-bottom:22px">' + url + '</a>' +
      '<div style="display:flex;gap:10px;justify-content:center">' +
        '<button class="lu-copy-url-btn" style="background:#6C5CE7;color:#fff;border:none;padding:10px 26px;border-radius:8px;cursor:pointer;font-weight:600;font-size:14px">Copy URL</button>' +
        '<button class="lu-close-modal-btn" style="background:#f0f0f0;color:#333;border:none;padding:10px 26px;border-radius:8px;cursor:pointer;font-weight:600;font-size:14px">Close</button>' +
      '</div>' +
    '</div>';
  document.body.appendChild(modal);
  modal.querySelector('.lu-copy-url-btn').addEventListener('click', function() {
    navigator.clipboard.writeText(url).then(function() {
      modal.querySelector('.lu-copy-url-btn').textContent = 'Copied!';
    }).catch(function() {
      showToast('Could not copy URL', 'warning');
    });
  });
  modal.querySelector('.lu-close-modal-btn').addEventListener('click', function() { modal.remove(); });
  modal.addEventListener('click', function(e) { if (e.target === modal) modal.remove(); });
}

// ── Publish website ──────────────────────────────────────────────────────
async function publishLuWebsite(websiteId) {
  try {
    const res  = await fetch(API + 'websites/' + websiteId + '/publish', {
      method: 'POST',
      headers: Object.assign({'Content-Type':'application/json'}, authHeader()),
      body: '{}'
    });
    const data = await res.json();
    if (!res.ok) { showToast(data.error || 'Publish failed', 'error'); return; }
    const liveUrl = data.url || data.home_url || (data.subdomain ? 'https://' + data.subdomain + '.levelupgrowth.io' : null);
    if (liveUrl) {
      _luShowPublishedModal(liveUrl);
      showToast('Your website is live!', 'success');
    } else {
      showToast('Website published! ' + (data.files_written || 0) + ' pages written.', 'success');
    }
    return data;
  } catch(e) { showToast('Error: ' + e.message, 'error'); return null; }
}

// ── Settings view loader ─────────────────────────────────────────────────────
async function bld_loadSettings() {
  try {
    const [health, cred, sub, profile] = await Promise.allSettled([
      fetch(API + 'system/health').then(r => r.ok ? r.json() : null),
      fetch(API + 'workspace/credits', { headers: authHeader() }).then(r => r.ok ? safeJson(r) : null),
      fetch(API + 'workspace/subscription', { headers: authHeader() }).then(r => r.ok ? safeJson(r) : null),
      fetch(API + 'workspace/profile/status', { headers: authHeader() }).then(r => r.ok ? safeJson(r) : null),
    ]);
    const h = health.status  === 'fulfilled' ? health.value  : null;
    const c = cred.status    === 'fulfilled' ? cred.value    : null;
    const s = sub.status     === 'fulfilled' ? sub.value     : null;
    const p = profile.status === 'fulfilled' ? profile.value : null;

    const nameEl    = document.getElementById('st-ws-name');
    const planEl    = document.getElementById('st-ws-plan');
    const creditEl  = document.getElementById('st-ws-credits');
    const seoDot    = document.getElementById('st-seo-dot');
    const seoSt     = document.getElementById('st-seo-status');
    const bldDot    = document.getElementById('st-builder-dot');
    const bldSt     = document.getElementById('st-builder-status');

    if (nameEl) nameEl.textContent = BN || 'My Workspace';
    if (planEl && s?.subscription?.plan_name) planEl.textContent = s.subscription.plan_name;
    if (creditEl && c?.balance !== undefined) creditEl.textContent = Number(c.balance).toLocaleString() + ' credits';

    if (seoDot && seoSt) {
      const active = h?.seo_suite_active;
      seoDot.textContent = active ? '🟢' : '⚪';
      seoSt.textContent  = active ? 'Active' : 'Not installed';
      seoSt.style.color  = active ? 'var(--ac)' : 'var(--t3)';
    }
    if (bldDot && bldSt) {
      const active = h?.builder_active;
      bldDot.textContent = active ? '🟢' : '⚪';
      bldSt.textContent  = active ? 'Active' : 'Not installed';
      bldSt.style.color  = active ? 'var(--ac)' : 'var(--t3)';
    }

    // ── Populate Intelligence Profile form ──────────────────────────────
    if (p?.fields) {
      const f = p.fields;
      const set = (id, val) => { const el = document.getElementById(id); if (el) el.value = val || ''; };
      set('st-industry',   f.industry);
      set('st-location',   f.location);
      set('st-biz-desc',   f.business_desc);
      set('st-audience',   f.target_audience);
      set('st-brand-voice',f.brand_voice);
      set('st-goals',      f.goals);
      set('st-competitors',f.competitors);
      // Services: array → comma-separated string
      const svcEl = document.getElementById('st-services');
      if (svcEl) svcEl.value = Array.isArray(f.services) ? f.services.join(', ') : (f.services || '');
    }

    // ── Profile completeness badge + gate banner ─────────────────────────
    const badge   = document.getElementById('ws-profile-badge');
    const gateDiv = document.getElementById('ws-profile-gate');
    const missingDiv = document.getElementById('ws-missing-fields');
    if (badge) {
      const complete = p?.minimum_met;
      badge.textContent = complete ? '✅ Profile Complete' : '⚠ Profile Incomplete';
      badge.style.background = complete ? 'rgba(0,229,168,.1)' : 'rgba(245,158,11,.1)';
      badge.style.color      = complete ? 'var(--ac)' : 'var(--am)';
      badge.style.borderColor= complete ? 'rgba(0,229,168,.3)' : 'rgba(245,158,11,.3)';
    }
    if (gateDiv) gateDiv.style.display = p?.minimum_met ? 'none' : 'block';
    if (missingDiv && p?.missing?.length) {
      missingDiv.textContent = 'Missing required fields: ' + p.missing.join(', ');
    }
  } catch(e) { console.warn('[Settings]', e); }

  // ── Load execution policies ────────────────────────────────────────
  try {
    const [polData, sugData] = await Promise.all([
      bld_get(API + 'policy'),
      bld_get(API + 'policy/suggestions').catch(() => ({suggestions:[]})),
    ]);
    const grouped = polData.by_domain || {};
    const allPolicies = polData.policies || [];
    const suggestions = sugData.suggestions || [];
    const grid = document.getElementById('policy-grid');
    const simple = document.getElementById('policy-simple');
    const modeBadge = document.getElementById('policy-mode-badge');
    const sugBox = document.getElementById('policy-suggestions');

    if (modeBadge) {
      modeBadge.textContent = execMode === 'autopilot' ? '⚡ AUTOPILOT' : '🔒 APPROVAL';
      modeBadge.style.color = execMode === 'autopilot' ? 'var(--ac)' : 'var(--p)';
      modeBadge.style.background = execMode === 'autopilot' ? 'rgba(0,229,168,.1)' : 'rgba(108,92,231,.1)';
      modeBadge.style.borderColor = execMode === 'autopilot' ? 'rgba(0,229,168,.3)' : 'rgba(108,92,231,.2)';
    }

    // ── Suggestions (DMM-mediated, not direct action) ──
    if (sugBox && suggestions.length) {
      sugBox.style.display = 'block';
      sugBox.innerHTML = `<div style="background:rgba(108,92,231,.06);border:1px solid rgba(108,92,231,.15);border-radius:8px;padding:10px 14px;font-size:11px">
        <div style="font-weight:700;color:var(--p);margin-bottom:4px">👩‍💼 Sarah's Policy Recommendation</div>
        <div style="color:var(--t2)">Based on your approval history, Sarah suggests enabling auto-execution for these tools:</div>
        <div style="display:flex;flex-wrap:wrap;gap:4px;margin-top:6px">${suggestions.map(s =>
          `<span style="font-size:10px;padding:3px 8px;border-radius:4px;background:var(--s1);border:1px solid var(--bd);color:var(--t1)">${s.label||s.tool_id} <span style="color:var(--ac)">(${s.approve_count}× approved)</span></span>`
        ).join('')}</div>
        <div style="margin-top:8px;display:flex;gap:6px">
          <button class="btn btn-primary btn-sm" style="font-size:10px" onclick="approveSuggestions([${suggestions.map(s=>"'"+s.tool_id+"'").join(',')}])">✓ Enable All Suggested</button>
          <button class="btn btn-outline btn-sm" style="font-size:10px" onclick="this.parentElement.parentElement.parentElement.style.display='none'">Dismiss</button>
        </div>
      </div>`;
    }

    // ── Simple Mode (engine-level toggles) ──
    if (simple) {
      const domainLabels = {seo:'🔍 SEO',content:'✍️ Content',marketing:'📧 Marketing',social:'📱 Social',crm:'🎯 CRM',calendar:'📅 Calendar',builder:'🏗️ Builder',system:'⚙️ System'};
      let shtml = '';
      for (const [domain, tools] of Object.entries(grouped)) {
        const autoCount = tools.filter(t => parseInt(t.auto_execute)).length;
        const totalCount = tools.length;
        const allAuto = autoCount === totalCount;
        const someAuto = autoCount > 0 && !allAuto;
        shtml += `<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:var(--s2);border:1px solid var(--bd);border-radius:8px">
          <div style="display:flex;align-items:center;gap:10px">
            <span style="font-size:16px">${(domainLabels[domain]||domain).split(' ')[0]}</span>
            <div>
              <div style="font-size:12px;font-weight:600;color:var(--t1)">${(domainLabels[domain]||domain).split(' ').slice(1).join(' ')||domain}</div>
              <div style="font-size:10px;color:var(--t3)">${autoCount}/${totalCount} auto · ${tools.filter(t=>['publish_post','send_campaign','create_campaign','update_campaign','export_website','export_page','publish_builder_page','create_lead','enroll_sequence','create_booking_slot'].includes(t.tool_id)).length} 🛡️ protected</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:8px">
            <span style="font-size:10px;color:${allAuto?'var(--ac)':someAuto?'var(--am)':'var(--t3)'};font-weight:700">${allAuto?'⚡ AUTO':someAuto?'⚠️ MIXED':'🔒 REVIEW'}</span>
            <label style="position:relative;display:inline-block;width:40px;height:22px;cursor:pointer">
              <input type="checkbox" class="eng-toggle" data-domain="${domain}" ${allAuto?'checked':''} onchange="toggleEnginePol('${domain}',this.checked)" style="opacity:0;width:0;height:0">
              <span style="position:absolute;inset:0;background:${allAuto?'var(--ac)':'var(--bd2)'};border-radius:22px;transition:.3s">
                <span style="position:absolute;width:16px;height:16px;background:#fff;border-radius:50%;top:3px;${allAuto?'left:21px':'left:3px'};transition:.3s"></span>
              </span>
            </label>
          </div>
        </div>`;
      }
      simple.innerHTML = shtml;
    }

    // ── Advanced Mode (tool-level checkboxes) ──
    if (grid) {
      const domainLabels = {seo:'🔍 SEO',content:'✍️ Content',marketing:'📧 Marketing',social:'📱 Social',crm:'🎯 CRM',calendar:'📅 Calendar',builder:'🏗️ Builder',system:'⚙️ System'};
      let html = '';
      for (const [domain, tools] of Object.entries(grouped)) {
        html += `<div style="background:var(--s2);border:1px solid var(--bd);border-radius:8px;padding:12px 14px">`;
        html += `<div style="font-size:12px;font-weight:700;color:var(--t1);margin-bottom:10px">${domainLabels[domain]||domain}</div>`;
        html += `<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">`;
        tools.forEach(p => {
          const checked = parseInt(p.auto_execute) ? 'checked' : '';
          const riskCol = p.risk_level==='high'?'var(--rd)':p.risk_level==='medium'?'var(--am)':'var(--ac)';
          const appRej = (parseInt(p.approve_count)||0) + (parseInt(p.reject_count)||0) > 0;
          const stats = appRej ? ` <span style="font-size:8px;color:var(--t3)">(✓${p.approve_count||0} ✕${p.reject_count||0})</span>` : '';
          html += `<label style="display:flex;align-items:center;gap:6px;font-size:11px;color:var(--t2);cursor:pointer;padding:4px 6px;border-radius:4px;background:var(--s1)">
            <input type="checkbox" class="pol-cb" data-tool="${p.tool_id}" ${checked} style="accent-color:var(--p)">
            <span>${p.label||p.tool_id}${stats}</span>
            <span style="font-size:8px;color:${riskCol};font-weight:700;margin-left:auto">${(p.risk_level||'').toUpperCase()}</span>
          </label>`;
        });
        html += `</div></div>`;
      }
      grid.innerHTML = html;
    }
  } catch(e) { console.warn('[PolicyLoad]', e); }
}

// ── Save Workspace Intelligence Profile ─────────────────────────────────────
async function saveWorkspaceProfile() {
  const bld_get = id => { const el = document.getElementById(id); return el ? el.value.trim() : ''; };
  const servicesRaw = bld_get('st-services');
  const services    = servicesRaw.split(',').map(s => s.trim()).filter(Boolean);

  if (!bld_get('st-industry') || services.length === 0) {
    showToast('Industry and Services are required fields.', 'error');
    return;
  }

  const msg = document.getElementById('st-profile-save-msg');
  if (msg) { msg.textContent = 'Saving…'; msg.style.color = 'var(--t3)'; }

  try {
    const res = await fetch(API + 'workspace/settings', {
      method: 'POST',
      headers: { ...authHeader(), 'Content-Type': 'application/json' },
      body: JSON.stringify({
        industry:        bld_get('st-industry'),
        location:        bld_get('st-location'),
        business_desc:   bld_get('st-biz-desc'),
        target_audience: bld_get('st-audience'),
        brand_voice:     bld_get('st-brand-voice'),
        goals:           bld_get('st-goals'),
        competitors:     bld_get('st-competitors'),
        services,
