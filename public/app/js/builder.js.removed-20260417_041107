    + '</div></div>';
}

// Sync swatch + picker when hex field changes (or picker changes)
function _epColorSync(id, val) {
  var swatch = document.getElementById(id + '-swatch');
  var picker = document.getElementById(id + '-picker');
  var hex    = document.getElementById(id);
  if (swatch) swatch.style.background = val || 'transparent';
  if (swatch) swatch.innerHTML = val ? '' : '<span style="font-size:9px;color:var(--t3)">—</span>';
  // Only sync picker if valid hex (avoid picker throwing on invalid input)
  if (picker && /^#[0-9a-fA-F]{3,6}$/.test(val)) picker.value = val;
  if (hex && hex !== document.activeElement) hex.value = val;
}

