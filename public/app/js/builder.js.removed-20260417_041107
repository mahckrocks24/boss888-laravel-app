    html += '<button id="lu-modal-cancel" style="background:var(--s3);border:1px solid var(--bd);color:var(--t2);border-radius:8px;padding:8px 20px;font-size:13px;cursor:pointer">' + bld_escH(cancelLabel || 'Cancel') + '</button>';
    html += '<button id="lu-modal-ok" style="background:var(--p);border:none;color:#fff;border-radius:8px;padding:8px 20px;font-size:13px;font-weight:600;cursor:pointer">' + bld_escH(confirmLabel || 'Confirm') + '</button>';
    html += '</div>';
    var overlay = _luModal(html);
    overlay.querySelector('#lu-modal-ok').onclick = function() { overlay.remove(); resolve(true); };
    overlay.querySelector('#lu-modal-cancel').onclick = function() { overlay.remove(); resolve(false); };
    overlay.addEventListener('click', function(e) { if (e.target === overlay) { overlay.remove(); resolve(false); } });
    overlay.querySelector('#lu-modal-ok').focus();
  });
}

function luPrompt(msg, defaultVal, title) {
