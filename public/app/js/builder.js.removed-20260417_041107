async function bldRenderPagesPanel() {
  var el = document.getElementById('bld-pages-list');
  if (!el) return;

  var websiteId = window._wsReturnToSite || 0;

  // If we're in website context, load pages from DB
  if (websiteId && !_bldWebsitePages.length) {
    el.innerHTML = '<div style="text-align:center;padding:16px;color:var(--t3);font-size:12px">Loading pages...</div>';
    try {
      var r = await fetch(API + 'builder/pages?website_id=' + websiteId, {headers:{'Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'}});
      var res = await r.json();
      _bldWebsitePages = bld_ensureArray(res.pages ?? res);
    } catch(e) { console.error('[Pages Panel] Load failed:', e); }
  }

  // Landing page mode — no multi-page panel, show hint
  if (!websiteId && !_bldWebsitePages.length) {
    el.innerHTML = '<div style="text-align:center;padding:20px 8px;color:var(--t3)">' +
      '<div style="font-size:24px;margin-bottom:8px">📄</div>' +
      '<div style="font-size:12px;line-height:1.5">Landing pages are single-page.<br>Use <strong>Websites</strong> for multi-page sites.</div></div>';
    return;
  }

  var html = '';
  var pageIcons = {home:'\u{1F3E0}',landing:'\u{1F3E0}',about:'\u2139\uFE0F',services:'\u{1F527}',contact:'\u{1F4CB}',blog:'\u{1F4F0}',pricing:'\u{1F4B0}',faq:'\u2753',portfolio:'\u{1F3A8}',terms:'\u{1F4C4}',privacy:'\u{1F512}',page:'\u{1F4C4}'};

  for (var i = 0; i < _bldWebsitePages.length; i++) {
    var pg = _bldWebsitePages[i];
    var isActive = (pg.id == bldCurrentPageId);
    var icon = pageIcons[pg.slug] || pageIcons[pg.page_type] || '\u{1F4C4}';

    html += '<div onclick="bldSwitchPage(' + pg.id + ')" style="display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;cursor:pointer;border:1px solid ' + (isActive ? 'var(--pu)' : 'transparent') + ';background:' + (isActive ? 'rgba(108,92,231,.12)' : 'transparent') + ';transition:all .15s;margin-bottom:2px">';
    html += '<span style="font-size:16px">' + icon + '</span>';
    html += '<div style="flex:1;min-width:0">';
    html += '<div style="font-size:12px;font-weight:' + (isActive ? '700' : '500') + ';color:' + (isActive ? 'var(--t1)' : 'var(--t2)') + ';white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + bld_escH(pg.title) + '</div>';
    html += '<div style="font-size:10px;color:var(--t3)">/' + bld_escH(pg.slug || '') + '</div>';
    html += '</div>';
    if (isActive) {
      html += '<span style="font-size:9px;background:var(--pu);color:#fff;padding:1px 6px;border-radius:8px;font-weight:600">editing</span>';
    }
    html += '</div>';
  }

  // Quick Add section (only for website context)
  if (websiteId) {
    html += '<div style="margin-top:12px;padding-top:10px;border-top:1px solid var(--bd)">';
    html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">';
    html += '<p style="font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin:0">Quick Add</p>';
    html += '<button onclick="bldAddPage()" style="background:var(--p);border:none;color:#fff;border-radius:5px;padding:3px 8px;font-size:9px;font-weight:600;cursor:pointer">+ Custom</button>';
    html += '</div>';

    var presets = [
      {title:'Home',slug:'home',icon:'\u{1F3E0}'},
      {title:'About',slug:'about',icon:'\u2139\uFE0F'},
      {title:'Services',slug:'services',icon:'\u{1F527}'},
      {title:'Contact',slug:'contact',icon:'\u{1F4CB}'},
      {title:'Blog',slug:'blog',icon:'\u{1F4F0}'},
      {title:'Pricing',slug:'pricing',icon:'\u{1F4B0}'},
      {title:'FAQ',slug:'faq',icon:'\u2753'},
      {title:'Portfolio',slug:'portfolio',icon:'\u{1F3A8}'},
    ];
    var existingSlugs = {};
    for (var j = 0; j < _bldWebsitePages.length; j++) existingSlugs[_bldWebsitePages[j].slug] = true;
    var available = presets.filter(function(p) { return !existingSlugs[p.slug]; });

    if (available.length) {
      html += '<div style="display:flex;flex-wrap:wrap;gap:4px">';
      for (var k = 0; k < available.length; k++) {
        var pr = available[k];
        html += '<button onclick="bldAddPresetPage(\'' + pr.title + '\',\'' + pr.slug + '\')" style="background:var(--s2);border:1px solid var(--bd);border-radius:6px;padding:4px 8px;font-size:10px;color:var(--t2);cursor:pointer;display:flex;align-items:center;gap:3px">' + pr.icon + ' ' + pr.title + '</button>';
      }
      html += '</div>';
    } else {
      html += '<div style="font-size:11px;color:var(--t3)">All common pages added.</div>';
    }
    html += '</div>';
  }

  el.innerHTML = html;
}

// Add a custom page (from Pages panel in editor)
async function bldAddPage() {
  var websiteId = window._wsReturnToSite || 0;
  var title = await luPrompt('Enter page title:', '', 'New Page');
  if (!title) return;
  try {
    var r = await fetch(API + 'builder/create', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
      body: JSON.stringify({title: title, type: 'page', website_id: websiteId})
    });
    var d = await r.json();
    if (d.success && d.page) {
      _bldWebsitePages.push({
        id: d.page.id,
        title: d.page.title,
        slug: d.page.slug,
        page_type: 'page',
        is_homepage: 0,
      });
      bldRenderPagesPanel();
      showToast('Page "' + title + '" added', 'success');
    }
  } catch(e) { showToast('Failed to create page: ' + e.message, 'error'); }
}

// Add preset page (About, Services, etc.)
async function bldAddPresetPage(title, slug) {
  var websiteId = window._wsReturnToSite || 0;
  try {
    var r = await fetch(API + 'builder/create', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
      body: JSON.stringify({title: title, type: slug, website_id: websiteId})
    });
    var d = await r.json();
    if (d.success && d.page) {
      _bldWebsitePages.push({
        id: d.page.id,
        title: d.page.title,
        slug: d.page.slug || slug,
        page_type: slug,
        is_homepage: 0,
      });
      bldRenderPagesPanel();
      showToast(title + ' page added', 'success');
    }
  } catch(e) { showToast('Failed: ' + e.message, 'error'); }
}

// Switch to a different page
async function bldSwitchPage(pageId) {
  if (pageId === bldCurrentPageId) return;
  if (bldDirty) {
    var ok = await luConfirm('You have unsaved changes that will be lost.', 'Unsaved Changes', 'Switch Anyway', 'Stay'); if (!ok) return;
  }
  bldCurrentPageId = pageId;
  _bldPageSource = 'standalone';
  await bldLoadEditorPage();
  bldRenderPagesPanel();
}

// Delete a page from the website (Pages tab in editor)
async function bldDeleteWebsitePage(pageId) {
  var ok = await luConfirmDelete('This page will be permanently deleted.', 'Page'); if (!ok) return;
  try {
    console.log('[BLD DELETE] Website page:', pageId);
    var resp = await fetch(API + 'builder/delete/' + pageId, {
      method: 'POST',
      headers: {'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json', 'Content-Type': 'application/json'},
      body: JSON.stringify({confirm: true})
    });
    var result = await resp.json();
    console.log('[BLD DELETE] Response:', resp.status, result);
    if (!resp.ok) { showToast('Delete failed: ' + (result.error || resp.status), 'error'); return; }
  } catch(e) { showToast('Delete failed: ' + e.message, 'error'); return; }
  _bldWebsitePages = _bldWebsitePages.filter(function(p) { return p.id !== pageId; });
  bldRenderPagesPanel();
  showToast('Page deleted permanently', 'success');
}

function bldInsertElement(type) {
  console.log('[BLD] InsertElement:', type, 'sections:', bldCurrentPage?.sections?.length);
  if (!bldCurrentPage?.sections?.length) {
    showToast('Add a section first, then add elements to it.', 'info');
    return;
  }
  const si = bldCurrentPage.sections.length - 1;
  const sec = bldCurrentPage.sections[si];
  if (!sec.components) sec.components = [];

  let cmp;
  switch(type) {
    case 'heading':    cmp = {type:'heading', tag:'h2', text:'New Heading'}; break;
    case 'text':       cmp = {type:'text', text:'New text block. Click to edit.'}; break;
    case 'button':     cmp = {type:'button', text:'Button', variant:'primary', href:'#'}; break;
    case 'image':      cmp = {type:'image', src:'', alt:'Image'}; break;
    case 'divider':    cmp = {type:'divider'}; break;
    case 'spacer':     cmp = {type:'spacer', height:'40px'}; break;
    case 'cta':        cmp = {type:'heading', tag:'h2', text:'Call to Action'}; break;
    case 'card':       cmp = {type:'cards', items:[{icon:'⭐',heading:'Card',text:'Description'}]}; break;
    case 'testimonial':cmp = {type:'cards', items:[{icon:'💬',heading:'Name',text:'"Great service!"'}]}; break;
    case 'faq':        cmp = {type:'cards', items:[{icon:'❓',heading:'Question?',text:'Answer here.'}]}; break;
    case 'form':       cmp = {type:'form', fields:[{label:'Name',type:'text',required:true},{label:'Email',type:'email',required:true}]}; break;
    case 'list':       cmp = {type:'text', text:'• Item 1\n• Item 2\n• Item 3'}; break;
    case 'html':       cmp = {type:'text', text:'<custom HTML>'}; break;
    default:           cmp = {type:'text', text:'New element'}; break;
  }
  sec.components.push(cmp);
  bldDirty = true;
  console.log('[BLD] Element added to section', si, '- components now:', sec.components.length);
  bldRenderCanvas();
  bldRenderLayers();
}

