          parts.push('</div>');
        }
        if (!imgs.length) parts.push('<div style="padding:24px;text-align:center;color:var(--t3);font-size:11px;border:1px dashed var(--bd);border-radius:6px;grid-column:1/-1">No images — edit in properties</div>');
        parts.push('</div>');
      }
      else if (cmp.type === 'map') {
        var mapUrl = cmp.embedUrl || cmp.src || cmp.url || '';
        parts.push('<div style="margin:8px 0;border-radius:8px;overflow:hidden;' + selCss + extraCss + '"' + clk + '>');
        if (mapUrl) {
          parts.push('<iframe src="' + bld_esc(mapUrl) + '" style="width:100%;height:250px;border:none;border-radius:8px" loading="lazy" allowfullscreen></iframe>');
        } else {
          parts.push('<div style="width:100%;height:200px;background:var(--s3);border:1px dashed var(--bd);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--t3);font-size:13px">📍 Map — set embed URL in properties</div>');
        }
        parts.push('</div>');
      }
      else if (cmp.type === 'catalog') {
        var catItems = Array.isArray(cmp.items) ? cmp.items : [];
        parts.push('<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;margin:8px 0;' + selCss + extraCss + '"' + clk + '>');
        for (var pi = 0; pi < catItems.length; pi++) {
          var prod = catItems[pi] || {};
          parts.push('<div style="background:var(--s3);border:1px solid var(--bd);border-radius:10px;overflow:hidden">');
          if (prod.image) parts.push('<img src="' + bld_esc(prod.image) + '" alt="' + bld_esc(prod.title||'') + '" style="width:100%;height:140px;object-fit:cover">');
          else parts.push('<div style="width:100%;height:100px;background:var(--s2);display:flex;align-items:center;justify-content:center;font-size:28px">🛒</div>');
          parts.push('<div style="padding:12px">');
          parts.push('<div style="font-size:13px;font-weight:600;color:var(--t1);margin-bottom:4px">' + bld_esc(prod.title||prod.heading||'Item') + '</div>');
          if (prod.price) parts.push('<div style="font-size:14px;font-weight:700;color:var(--ac);margin-bottom:4px">' + bld_esc(prod.price) + '</div>');
          if (prod.text) parts.push('<div style="font-size:11px;color:var(--t3)">' + bld_esc(prod.text) + '</div>');
          parts.push('</div></div>');
        }
        if (!catItems.length) parts.push('<div style="grid-column:1/-1;padding:24px;text-align:center;color:var(--t3);font-size:11px;border:1px dashed var(--bd);border-radius:6px">No items — edit in properties</div>');
        parts.push('</div>');
      }
      else if (cmp.type === 'carousel') {
        var slides = Array.isArray(cmp.slides) ? cmp.slides : (cmp.items || []);
        parts.push('<div style="position:relative;margin:8px 0;border-radius:8px;overflow:hidden;' + selCss + extraCss + '"' + clk + '>');
        if (slides.length) {
          var sl = slides[0]; // Show first slide
          if (typeof sl === 'string') sl = {src:sl};
          if (sl.src) parts.push('<img src="' + bld_esc(sl.src) + '" alt="' + bld_esc(sl.alt||'') + '" style="width:100%;height:250px;object-fit:cover;border-radius:8px">');
          else parts.push('<div style="width:100%;height:200px;background:var(--s3);display:flex;align-items:center;justify-content:center;color:var(--t3)"><div style="text-align:center"><div style="font-size:24px;margin-bottom:8px">🎠</div><div>' + bld_esc(sl.text||sl.heading||'Slide 1') + '</div></div></div>');
          parts.push('<div style="position:absolute;bottom:8px;left:50%;transform:translateX(-50%);display:flex;gap:6px">');
          for (var di = 0; di < Math.min(slides.length,6); di++) {
            parts.push('<div style="width:8px;height:8px;border-radius:50%;background:' + (di===0?'#fff':'rgba(255,255,255,.4)') + '"></div>');
          }
          parts.push('</div>');
        } else {
          parts.push('<div style="width:100%;height:200px;background:var(--s3);border:1px dashed var(--bd);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--t3);font-size:13px">🎠 Carousel — add slides in properties</div>');
        }
        parts.push('</div>');
      }
      else if (cmp.type === 'embed') {
        var embedHtml = cmp.html || cmp.embedHtml || cmp.content || '';
        var embedUrl = cmp.src || cmp.url || cmp.embedUrl || '';
        parts.push('<div style="margin:8px 0;border-radius:8px;overflow:hidden;' + selCss + extraCss + '"' + clk + '>');
        if (embedUrl) {
          parts.push('<iframe src="' + bld_esc(embedUrl) + '" style="width:100%;height:300px;border:none;border-radius:8px" loading="lazy" allowfullscreen></iframe>');
        } else if (typeof embedHtml === 'string' && embedHtml.length > 10) {
          parts.push('<div style="background:var(--s3);border:1px solid var(--bd);border-radius:8px;padding:12px;font-size:11px;color:var(--t3);max-height:200px;overflow:auto"><div style="font-size:10px;color:var(--pu);margin-bottom:4px;font-weight:600">EMBED BLOCK</div>' + embedHtml.slice(0,500) + '</div>');
        } else {
          parts.push('<div style="width:100%;height:150px;background:var(--s3);border:1px dashed var(--bd);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--t3);font-size:13px">🔗 Embed — set URL or HTML in properties</div>');
        }
        parts.push('</div>');
      }
      else if (cmp.type === 'video') {
        var vidSrc = cmp.src || cmp.url || '';
        parts.push('<div style="margin:8px 0;border-radius:8px;overflow:hidden;aspect-ratio:16/9;background:var(--s3);' + selCss + extraCss + '"' + clk + '>');
        if (vidSrc && vidSrc.match(/youtube|vimeo/)) {
          var embedSrc = vidSrc.replace('watch?v=','embed/').replace('youtu.be/','youtube.com/embed/');
          parts.push('<iframe src="' + bld_esc(embedSrc) + '" style="width:100%;height:100%;border:none" allowfullscreen></iframe>');
        } else if (vidSrc) {
          parts.push('<video src="' + bld_esc(vidSrc) + '" controls style="width:100%;height:100%"></video>');
        } else {
          parts.push('<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--t3);font-size:13px">▶ Video — set URL in properties</div>');
        }
        parts.push('</div>');
      }
      else {
        // Unknown type — render gracefully instead of crashing
        parts.push('<div style="font-size:12px;color:var(--t3);padding:4px;border:1px dashed var(--bd);border-radius:4px;margin:4px 0;' + selCss + '"' + clk + '>[' + bld_esc(cmp.type || '?') + '] ' + bld_esc(cmp.text || cmp.content || '') + '</div>');
      }
      } catch(renderErr) {
        console.warn('[BLD Render] Component error at section ' + si + ' component ' + ci + ':', renderErr);
        parts.push('<div style="color:var(--am);font-size:10px;padding:4px;border:1px dashed var(--am);border-radius:4px;margin:4px 0">[render error: ' + bld_esc(String(renderErr.message || renderErr)) + ']</div>');
      }
    }

    // Empty section hint
    if (comps.length === 0) {
      parts.push('<div style="padding:20px;text-align:center;color:var(--t3);font-size:12px;border:1px dashed var(--bd);border-radius:6px">Empty section — click an Element from the left panel to add content here</div>');
    }
    } // end if (!_p2Rendered)

    parts.push('</div>'); // close section
  }

  // ── DROP ZONE after last section ──
  parts.push('<div class="bld-dropzone" data-insert-at="' + sections.length + '" ondragover="bldDropZoneOver(event,' + sections.length + ')" ondragleave="bldDropZoneLeave(event)" ondrop="bldDropZoneDrop(event,' + sections.length + ')" style="height:6px;margin:0 0 8px 0;border-radius:4px;transition:all .2s"></div>');

  // Add section button
  parts.push('<div style="text-align:center;padding:16px 0">');
  parts.push('<button onclick="bldInsertCoreBlock(\'custom\')" style="background:transparent;border:1.5px dashed rgba(108,92,231,.4);color:var(--pu);border-radius:8px;padding:10px 24px;font-size:13px;cursor:pointer">+ Add Section</button>');
  parts.push('</div>');
  parts.push('</div>');

  var finalHtml = parts.join('');
  canvas.innerHTML = finalHtml;
  console.log('[BLD] Standalone render complete:', sections.length, 'sections, HTML length:', finalHtml.length);
}

// ── BLUEPRINT PREVIEW — renders page_json from wizard as visual preview ──
function _bldRenderBlueprintPreview(blueprint, pageTitle, editable) {
  const sections = blueprint.sections || [];
  const icons = {hero:'🎯',service_grid:'🔧',features:'⭐',testimonials:'💬',cta:'📣',contact_form:'📋',portfolio:'🎨',team:'👥',text_image:'📝',faq:'❓',steps:'📊',pricing:'💰',blog_grid:'📰',map:'📍',newsletter:'✉',values:'💎',social_proof:'🏆',benefits:'✓',guarantee:'🛡',logos:'📰',categories:'📂',product_grid:'🛒',case_studies:'📈',case_study:'📈',text:'📄',story:'📖',custom:'▪',contact:'📋'};

  let html = `<div style="padding:20px">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--bd)">
      <div style="background:linear-gradient(135deg,var(--p),#9B8DF8);width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px">${editable?'✏️':'🪄'}</div>
      <div>
        <div style="font-family:var(--fh);font-size:16px;font-weight:700;color:var(--t1)" ${editable?'contenteditable="true" onblur="bldCurrentPage.title=this.textContent;bldDirty=true"':''}>${bld_esc(pageTitle || 'Page')}</div>
        <div style="font-size:11px;color:var(--t3)">${sections.length} sections${editable?' · Click any text to edit':''}${!editable?' · Generated by Website Wizard':''}</div>
      </div>
    </div>`;

  sections.forEach((sec, si) => {
    const icon = icons[sec.type] || '▪';
    const hasComponents = Array.isArray(sec.components) && sec.components.length;
    // Legacy blueprint format
    const content = sec.content || {};
    const heading = content.heading || content.title || sec.label || sec.type;
    const sub = content.subheading || content.text || '';
    const items = content.items || content.steps || content.members || content.plans || content.fields || [];

    html += `<div class="${editable?'bld-sec':''}" style="background:var(--s2);border:1px solid var(--bd);border-radius:10px;padding:16px;margin-bottom:10px;transition:border-color .15s,opacity .2s;position:relative"
      ${editable?`draggable="true" ondragstart="bldSecDragStart(event,${si})" ondragover="bldSecDragOver(event,${si})" ondragleave="bldSecDragLeave(event)" ondrop="bldSecDrop(event,${si})" ondragend="bldSecDragEnd(event)"`:''}
      onmouseenter="this.style.borderColor='rgba(108,92,231,.4)'" onmouseleave="this.style.borderColor='var(--bd)'"
      onclick="${editable?`bldSelectComponent(${si},null)`:''}">`;

    // Section toolbar (editable mode only)
    if (editable) {
      html += `<div style="position:absolute;top:8px;right:8px;display:flex;gap:4px;opacity:.6">
        ${si>0?`<button onclick="bldMoveSection(${si},-1);bldRenderCanvas()" style="background:var(--s3);border:1px solid var(--bd);border-radius:4px;padding:2px 6px;font-size:10px;cursor:pointer;color:var(--t2)">↑</button>`:''}
        ${si<sections.length-1?`<button onclick="bldMoveSection(${si},1);bldRenderCanvas()" style="background:var(--s3);border:1px solid var(--bd);border-radius:4px;padding:2px 6px;font-size:10px;cursor:pointer;color:var(--t2)">↓</button>`:''}
        <button onclick="bldDeleteSection(${si})" style="background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.2);border-radius:4px;padding:2px 6px;font-size:10px;cursor:pointer;color:#F87171">✕</button>
      </div>`;
    }

    // Section header
    html += `<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
      <span style="font-size:18px">${icon}</span>
      <div style="flex:1">
        <div style="font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.04em">${bld_esc(sec.type.replace(/_/g,' '))} · Section ${si+1}</div>
      </div>
    </div>`;

    // Render components (standalone format)
    if (hasComponents) {
      sec.components.forEach((cmp, ci) => {
        const ce = editable ? 'contenteditable="true"' : '';
        const blur = editable ? `onblur="bldCurrentPage.sections[${si}].components[${ci}].text=this.textContent;bldDirty=true"` : '';
        const isSel = editable && _bldSelSec === si && _bldSelCmp === ci;
        const selBorder = isSel ? 'outline:2px solid var(--p);outline-offset:2px;' : '';
        const click = editable ? `onclick="event.stopPropagation();bldSelectComponent(${si},${ci})"` : '';

        // Drag wrapper for components (editable mode)
        if (editable) {
          html += `<div class="bld-cmp-drag" draggable="true" data-si="${si}" data-ci="${ci}"
            ondragstart="bldCmpDragStart(event,${si},${ci})" ondragover="bldCmpDragOver(event,${si},${ci})"
            ondragleave="bldCmpDragLeave(event)" ondrop="bldCmpDrop(event,${si},${ci})" ondragend="bldCmpDragEnd(event)">`;
        }

        if (cmp.type === 'heading') {
          const tag = cmp.tag || 'h2';
          const sz = tag==='h1'?'24px':tag==='h2'?'20px':'16px';
          html += `<div style="font-family:var(--fh);font-size:${sz};font-weight:700;color:var(--t1);margin-bottom:8px;outline:none;border-radius:4px;cursor:text;${selBorder}" ${ce} ${blur} ${click}>${bld_esc(cmp.text||'')}</div>`;
        }
        else if (cmp.type === 'text') {
          html += `<div style="font-size:13px;color:var(--t2);line-height:1.6;margin-bottom:8px;outline:none;border-radius:4px;cursor:text;${selBorder}" ${ce} ${blur} ${click}>${bld_esc(cmp.text||'')}</div>`;
        }
        else if (cmp.type === 'button') {
          html += `<div style="margin:8px 0;${selBorder}border-radius:8px" ${click}><span style="display:inline-block;background:var(--p);color:#fff;padding:8px 20px;border-radius:8px;font-size:13px;font-weight:600;cursor:default" ${editable?`contenteditable="true" onblur="bldCurrentPage.sections[${si}].components[${ci}].text=this.textContent;bldDirty=true"`:''} >${bld_esc(cmp.text||'Button')}</span></div>`;
        }
        else if (cmp.type === 'cards' && Array.isArray(cmp.items)) {
          html += `<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin:8px 0;${selBorder}border-radius:8px" ${click}>`;
          cmp.items.forEach((card, ki) => {
            html += `<div style="background:var(--s3);border:1px solid var(--bd);border-radius:8px;padding:12px;text-align:center">
              <div style="font-size:24px;margin-bottom:6px">${card.icon||'⭐'}</div>
              <div style="font-size:12px;font-weight:600;color:var(--t1);margin-bottom:4px" ${editable?`contenteditable="true" onblur="bldCurrentPage.sections[${si}].components[${ci}].items[${ki}].heading=this.textContent;bldDirty=true"`:''} >${bld_esc(card.heading||'')}</div>
              <div style="font-size:11px;color:var(--t3)" ${editable?`contenteditable="true" onblur="bldCurrentPage.sections[${si}].components[${ci}].items[${ki}].text=this.textContent;bldDirty=true"`:''} >${bld_esc(card.text||'')}</div>
            </div>`;
          });
          html += '</div>';
        }
        else if (cmp.type === 'form' && Array.isArray(cmp.fields)) {
          html += `<div style="display:flex;flex-direction:column;gap:8px;margin:8px 0;max-width:400px;${selBorder}border-radius:8px" ${click}>`;
          cmp.fields.forEach(f => {
            html += `<div><div style="font-size:10px;color:var(--t3);margin-bottom:4px">${bld_esc(f.label)}</div><div style="background:var(--s3);border:1px solid var(--bd);border-radius:6px;padding:8px 10px;${f.type==='textarea'?'min-height:60px;':''}font-size:12px;color:var(--t3)">${bld_esc(f.label)}…</div></div>`;
          });
          html += '</div>';
        }
        else if (cmp.type === 'divider') {
          html += `<hr style="border:none;border-top:1px solid var(--bd);margin:12px 0;${selBorder}" ${click}>`;
        }
        else if (cmp.type === 'spacer') {
          html += `<div style="height:${cmp.height||'40px'};${selBorder}" ${click}></div>`;
        }
        else if (cmp.type === 'image') {
          html += `<div style="margin:8px 0;${selBorder}border-radius:8px" ${click}>${cmp.src ? `<img src="${bld_esc(cmp.src)}" alt="${bld_esc(cmp.alt||'')}" style="max-width:100%;border-radius:8px">` : '<div style="background:var(--s3);border:1px dashed var(--bd);border-radius:8px;padding:40px;text-align:center;color:var(--t3);font-size:12px">🖼 Click to set image URL in properties</div>'}</div>`;
        }

        // Close drag wrapper
        if (editable) html += '</div>';
      });
    }
    // Legacy blueprint format fallback
    else {
      if (heading) html += `<div style="font-size:13px;font-weight:600;color:var(--t1);margin-bottom:4px">${bld_esc(heading)}</div>`;
      if (sub) html += `<div style="font-size:12px;color:var(--t2);line-height:1.5;margin-bottom:4px">${bld_esc(typeof sub==='string'?sub.slice(0,120):'')}</div>`;
      if (Array.isArray(items) && items.length) {
        html += '<div style="display:flex;flex-wrap:wrap;gap:6px">';
        items.slice(0,6).forEach(item => {
          const label = typeof item === 'string' ? item : (item.title||item.name||item.text||item.question||JSON.stringify(item).slice(0,30));
          html += `<span style="background:var(--s3);border:1px solid var(--bd);border-radius:5px;padding:3px 8px;font-size:10px;color:var(--t2)">${bld_esc(String(label).slice(0,40))}</span>`;
        });
        html += '</div>';
      }
      if (content.cta_text) html += `<div style="margin-top:8px"><span style="background:var(--p);color:#fff;padding:4px 12px;border-radius:5px;font-size:11px;font-weight:600">${bld_esc(content.cta_text)}</span></div>`;
    }

    html += '</div>';
  });

  if (editable) {
    html += `<div style="text-align:center;padding:16px 0;border-top:1px dashed var(--bd);margin-top:8px">
      <button onclick="bldAddSection()" style="background:transparent;border:1.5px dashed rgba(108,92,231,.4);color:var(--pu);border-radius:8px;padding:10px 24px;font-size:13px;cursor:pointer">+ Add Section</button>
    </div>`;
  } else {
    html += `<div style="text-align:center;padding:16px 0;border-top:1px dashed var(--bd);margin-top:8px">
      <div style="font-size:11px;color:var(--t3);margin-bottom:10px">This is a blueprint preview. Hydrate to convert into editable sections.</div>
      <div style="display:flex;gap:8px;justify-content:center">
        <button class="ct-btn primary" onclick="bldHydratePage()" style="font-size:12px;padding:8px 20px">🔧 Hydrate &amp; Edit</button>
        <button class="ct-btn" onclick="bldExportPage()" style="font-size:12px;padding:8px 20px;border:1px solid var(--bd)">📤 Publish as HTML</button>
      </div>
    </div>`;
  }
  html += '</div>';
  return html;
}

function bldBuildThemeCssVars(tokens) {
  if (!Object.keys(tokens).length) return '';
  const vars = Object.entries(tokens).map(([k,v]) => `--lubld-${k}:${v}`).join(';');
  return `<style>:root{${vars}}body{background:var(--lubld-bg,#0F1117);color:var(--lubld-t1,#F8F9FA);font-family:var(--lubld-font_body,"DM Sans",sans-serif)}</style>`;
}

function bldBuildCanvasBaseStyles() {
  return `<style>
    .bld-sec{position:relative;transition:outline .15s,opacity .2s}.bld-sec:hover{outline:1.5px dashed rgba(108,92,231,.4)}
    .bld-sec[draggable]{cursor:grab}.bld-sec[draggable]:active{cursor:grabbing}
    .bld-sec.bld-dragging{opacity:.35;outline:2px dashed rgba(108,92,231,.3)}
    .bld-sec.bld-drop-target{outline:2px dashed #8b5cf6;outline-offset:2px;background:rgba(108,92,231,.04)}
    .bld-sec-toolbar{display:none;position:absolute;top:8px;right:8px;z-index:10;gap:4px}
    .bld-sec:hover .bld-sec-toolbar{display:flex}
    .bld-stb{background:rgba(15,17,23,.9);backdrop-filter:blur(8px);border:1px solid rgba(108,92,231,.3);border-radius:6px;color:#fff;padding:4px 8px;font-size:11px;cursor:pointer;white-space:nowrap}
    .bld-cmp-wrap{position:relative;border-radius:4px;transition:outline .15s,opacity .2s}.bld-cmp-wrap:hover{outline:1.5px solid var(--lubld-primary,#6C5CE7)}
    .bld-cmp-drag{cursor:grab}.bld-cmp-drag:active{cursor:grabbing}
    .bld-cmp-drag.bld-dragging{opacity:.35}
    .bld-cmp-drag.bld-drop-target{outline:2px dashed #8b5cf6;outline-offset:1px}
    .bld-cmp-toolbar{display:none;position:absolute;top:-28px;left:0;z-index:10;gap:4px;background:var(--lubld-primary,#6C5CE7);border-radius:4px;padding:2px 4px}
    .bld-cmp-wrap:hover .bld-cmp-toolbar{display:flex}
    .bld-ctb{background:transparent;border:none;color:#fff;padding:2px 5px;font-size:10px;cursor:pointer}
    h1,h2,h3,h4,h5,h6{font-family:var(--lubld-font_heading,"Syne",sans-serif);color:var(--lubld-t1,#F8F9FA);line-height:1.2;margin-bottom:8px}
    p{color:var(--lubld-t2,#9CA3AF);line-height:1.6;margin-bottom:8px}
    .lubld-btn{display:inline-flex;align-items:center;padding:10px 22px;border-radius:var(--lubld-radius_md,10px);font-size:14px;font-weight:600;text-decoration:none;cursor:pointer;transition:all .2s;border:none}
    .lubld-btn-primary{background:var(--lubld-primary,#6C5CE7);color:#fff}.lubld-btn-outline{background:transparent;border:1.5px solid var(--lubld-primary,#6C5CE7);color:var(--lubld-primary,#6C5CE7)}
    .lubld-btn-secondary{background:var(--lubld-s2,#1E2230);color:var(--lubld-t1,#F8F9FA)}
    .lubld-btn-group{display:flex;gap:12px;flex-wrap:wrap}
    blockquote{border-left:3px solid var(--lubld-primary,#6C5CE7);padding-left:20px}
    hr{border:none;border-top:1px solid rgba(255,255,255,.1)}
    ul,ol{padding-left:20px;color:var(--lubld-t2,#9CA3AF)}
    .bld-col-drop{min-height:60px;border:1.5px dashed rgba(108,92,231,.2);border-radius:6px;padding:8px;transition:all .2s}
    .bld-col-drop.drag-over{border-color:var(--lubld-primary,#6C5CE7);background:rgba(108,92,231,.05)}
  </style>`;
}

function bldRenderCanvasSection(sec, si, theme) {
  const layout  = sec.layout || {};
  const cols    = parseInt(layout.columns) || 1;
  const py      = bldSpacing(layout.padding_y || 'xl');
  const px      = bldSpacing(layout.padding_x || 'md');
  const gap     = bldSpacing(layout.gap || 'md');
  const bg      = bldResolveBg(layout, theme);
  const grid    = cols > 1 ? `display:grid;grid-template-columns:repeat(${cols},1fr);gap:${gap}` : '';

  let contHtml  = '';
  (sec.containers || []).forEach((con, ci) => {
    contHtml += `<div class="bld-col-drop" data-si="${si}" data-ci="${ci}">`;
    (con.components || []).forEach((cmp, mi) => {
      contHtml += bldRenderCanvasComponent(cmp, si, ci, mi, theme);
    });
    contHtml += `<div onclick="bldAddComponent(${si},${ci})" style="text-align:center;padding:8px;cursor:pointer;color:var(--t3);font-size:12px;opacity:.6" onmouseenter="this.style.opacity='1'" onmouseleave="this.style.opacity='.6'">+ Component</div>`;
    contHtml += `</div>`;
  });

  return `<div class="bld-sec" data-si="${si}" style="padding:${py} ${px};${bg}position:relative">
    <div class="bld-sec-toolbar">
      <button class="bld-stb" onclick="bldMoveSection(${si},-1)">↑</button>
      <button class="bld-stb" onclick="bldMoveSection(${si},1)">↓</button>
      <button class="bld-stb" onclick="bldEditSection(${si})">⚙</button>
      <button class="bld-stb" onclick="bldDuplicateSection(${si})">⧉</button>
      <button class="bld-stb" onclick="bldDeleteSection(${si})" style="color:#F87171">✕</button>
    </div>
    <div style="max-width:var(--lubld-container_width,1200px);margin:0 auto;${grid}">
      ${contHtml}
    </div>
  </div>`;
}

function bldRenderCanvasComponent(cmp, si, ci, mi, theme) {
  // FIX 7: Dual-key type read — matches the fix already applied to bldShowComponentProps.
  // AI-created components have cmp.type only; manual components have cmp.component_type.
  const type    = cmp.component_type || cmp.type;
  const content = cmp.content || {};
  const styles  = cmp.styles  || {};
  const tokens  = cmp.tokens  || {};
  const isSelected = bldSelectedComp &&
    bldSelectedComp.si === si && bldSelectedComp.ci === ci && bldSelectedComp.mi === mi;

  const styleStr = bldStylesToInline(styles, tokens, theme);
  const selStyle = isSelected ? 'outline:2px solid var(--lubld-primary,#6C5CE7);' : '';

  return `<div class="bld-cmp-wrap" style="${selStyle}" onclick="event.stopPropagation();bldSelectComponent(${si},${ci},${mi})">
    <div class="bld-cmp-toolbar">
      <button class="bld-ctb" onclick="event.stopPropagation();bldMoveComponent(${si},${ci},${mi},-1)">↑</button>
      <button class="bld-ctb" onclick="event.stopPropagation();bldMoveComponent(${si},${ci},${mi},1)">↓</button>
      <button class="bld-ctb" onclick="event.stopPropagation();bldDeleteComponent(${si},${ci},${mi})" style="color:#F87171">✕</button>
    </div>
    <div style="${styleStr}">
      ${bldRenderComponentPreview(type, content, theme)}
    </div>
  </div>`;
}

function bldRenderComponentPreview(type, content, theme) {
  const t = k => _bldSafeText(content[k]);
  switch(type) {
    case 'heading':
      const lvl = parseInt(t('level')) || 2;
      return `<h${lvl} style="margin:0">${t('text') || 'Heading'}</h${lvl}>`;
    case 'text':
      return `<p style="margin:0">${t('text') || 'Text content'}</p>`;
    case 'image':
      return t('src')
        ? `<img src="${bld_escH(t('src'))}" alt="${bld_escH(t('alt'))}" style="max-width:100%;height:auto;border-radius:6px">`
        : `<div style="background:rgba(255,255,255,.05);aspect-ratio:16/9;border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3);font-size:13px">🖼 Image</div>`;
    case 'button':
      return `<a href="#" class="lubld-btn lubld-btn-${bld_escH(t('variant')||'primary')}" style="pointer-events:none">${bld_escH(t('label')||'Button')}</a>`;
    case 'divider':
      return `<hr style="border:none;border-top:${bld_escH(t('thickness')||'1px')} solid rgba(255,255,255,.1);margin:0">`;
    case 'spacer':
      return `<div style="height:${bld_escH(t('height')||'40px')}"></div>`;
    case 'cta':
      const btns = (content.buttons||[]).map(b=>`<a href="#" class="lubld-btn lubld-btn-${bld_escH(b.variant||'primary')}" style="pointer-events:none">${bld_escH(b.label)}</a>`).join('');
      return `<div style="text-align:center">
        <h2 style="margin-bottom:10px">${bld_escH(t('heading')||'CTA Heading')}</h2>
        <p style="margin-bottom:20px">${bld_escH(t('subtext')||'Subtext here')}</p>
        <div class="lubld-btn-group" style="justify-content:center">${btns||'<a href="#" class="lubld-btn lubld-btn-primary" style="pointer-events:none">Get Started</a>'}</div>
      </div>`;
    case 'testimonial':
      return `<blockquote><p style="font-style:italic;color:var(--lubld-t1,#F8F9FA);margin-bottom:8px">"${bld_escH(t('quote')||'Testimonial quote')}"</p><cite style="font-style:normal;font-size:12px;color:var(--lubld-t2,#9CA3AF)">${bld_escH(t('author')||'Author')}${t('role')?' — '+bld_escH(t('role')):''}</cite></blockquote>`;
    case 'pricing':
      return `<div style="text-align:center"><h3 style="margin-bottom:4px">${bld_escH(t('name')||'Plan Name')}</h3><div style="font-size:40px;font-weight:700;color:var(--lubld-t1,#F8F9FA)">${bld_escH(t('price')||'$99')}<span style="font-size:14px;color:var(--lubld-t2)">${bld_escH(t('period')||'/mo')}</span></div></div>`;
    case 'faq':
      const items = (content.items||[]).slice(0,2);
      return '<div>' + items.map(i=>`<div style="padding:10px 0;border-bottom:1px solid rgba(255,255,255,.05)"><div style="font-weight:600;font-size:13px;color:var(--lubld-t1)">${bld_escH(i.question||'')}</div><div style="font-size:12px;color:var(--lubld-t2);margin-top:4px">${bld_escH(i.answer||'')}</div></div>`).join('') + '</div>';
    case 'form':
      const fs = (content.fields||[]).slice(0,3);
      return '<div>' + fs.map(f=>`<div style="margin-bottom:10px"><label style="font-size:12px;color:rgba(255,255,255,.6);display:block;margin-bottom:3px">${bld_escH(f.label||'')}</label><div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:5px;padding:7px 10px;font-size:12px;color:rgba(255,255,255,.3)">${bld_escH(f.placeholder||'...')}</div></div>`).join('') + `<button class="lubld-btn lubld-btn-primary" style="margin-top:4px;pointer-events:none;font-size:12px">${bld_escH(content.submit_label||'Submit')}</button></div>`;
    case 'card':
      return `<div style="background:var(--lubld-s2,#1E2230);border-radius:8px;overflow:hidden">${t('image')?`<img src="${bld_escH(t('image'))}" style="width:100%;height:120px;object-fit:cover">`:''}<div style="padding:16px"><h3 style="font-size:14px;margin-bottom:6px">${bld_escH(t('heading')||'Card Heading')}</h3><p style="font-size:12px;margin:0">${bld_escH(t('text')||'')}</p></div></div>`;
    case 'list':
      return '<ul style="padding-left:18px;font-size:13px">' + (content.items||[{text:'List item'}]).map(i=>`<li>${bld_escH(i.text||'')}</li>`).join('') + '</ul>';
    case 'html':
      return `<div style="background:rgba(255,255,255,.03);border:1px dashed rgba(255,255,255,.1);border-radius:6px;padding:12px;font-family:monospace;font-size:11px;color:rgba(255,255,255,.4)">${bld_escH((content.code||'<HTML>').slice(0,80))}</div>`;
    case 'video':
      var vSrc = t('src') || t('url') || '';
      if (vSrc && vSrc.match(/youtube|vimeo/)) {
        var vEmbed = vSrc.replace('watch?v=','embed/').replace('youtu.be/','youtube.com/embed/');
        return `<iframe src="${bld_escH(vEmbed)}" style="width:100%;aspect-ratio:16/9;border:none;border-radius:8px" allowfullscreen></iframe>`;
      }
      return `<div style="background:rgba(0,0,0,.3);aspect-ratio:16/9;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:32px">▶</div>`;
    case 'gallery': {
      let gImgs = content.images || content.items || [];
      return '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">' + (gImgs.length ? gImgs.slice(0,6).map(img => { let s = typeof img==='string'?img:(img.src||''); return s ? `<img src="${bld_escH(s)}" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:6px">` : '<div style="aspect-ratio:1;background:rgba(255,255,255,.05);border-radius:6px;display:flex;align-items:center;justify-content:center">🖼</div>'; }).join('') : '<div style="grid-column:1/-1;padding:20px;text-align:center;color:rgba(255,255,255,.3);font-size:11px">Gallery</div>') + '</div>';
    }
    case 'map': {
      let mUrl = t('embedUrl') || t('src') || t('url');
      return mUrl ? `<iframe src="${bld_escH(mUrl)}" style="width:100%;height:200px;border:none;border-radius:6px" loading="lazy"></iframe>` : '<div style="width:100%;height:150px;background:rgba(255,255,255,.05);border-radius:6px;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.3)">📍 Map</div>';
    }
