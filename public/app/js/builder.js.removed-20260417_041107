// ── SEO DATA LAYER — unified constants and fetch helpers ──────────────────
const _seoBase  = () => window.location.origin + '/api/seo/';
const _lugsBase = () => window.location.origin + '/api/seo/';

// Unified cache — cleared on full refresh, shared across all tabs
window._seoCache = window._seoCache || {};

async function _seoGet(path, bustCache) {
  if (!bustCache && window._seoCache[path] !== undefined) return window._seoCache[path];
  const r = await fetch(_seoBase() + path, { cache:'no-store', headers: authHeader() });
  if (!r.ok) throw new Error('SEO API ' + path + ' → ' + r.status);
  const data = await r.json();
  window._seoCache[path] = data;
  return data;
}
async function _seoPost(path, body) {
  // Invalidate related cache on writes
  delete window._seoCache[path];
  delete window._seoCache[path.split('/')[0]];
  const r = await fetch(_seoBase() + path, {
    method:'POST', cache:'no-store',
    headers: { ...authHeader(), 'Content-Type':'application/json' },
    body: JSON.stringify(body || {}),
  });
  return r.json();
}
async function _seoDel(path) {
  delete window._seoCache[path];
  const r = await fetch(_seoBase() + path, { method:'DELETE', headers: authHeader() });
  return r.json();
}

// Reliable suite status — cached, auth-bearing, graceful
async function _seoGetStatus(forceRefresh) {
  if (!forceRefresh && window._seoStatus !== undefined) return window._seoStatus;
  try {
    const r = await fetch(_seoBase() + 'suite/status', { cache:'no-store', headers: authHeader() });
    if (r.ok) {
      window._seoStatus = await r.json();
    } else if (r.status === 401 || r.status === 403) {
      // Auth failed — REST is working but user not logged in; report honestly
      window._seoStatus = { active: false, error: 'auth_failed', status: r.status };
    } else {
      // Unknown error — assume active to avoid false negatives
      window._seoStatus = { active: true, assumed: true };
    }
  } catch (e) {
    // Network error — assume active, will fail gracefully per-tab
    window._seoStatus = { active: true, assumed: true, error: e.message };
  }
  return window._seoStatus;
}

