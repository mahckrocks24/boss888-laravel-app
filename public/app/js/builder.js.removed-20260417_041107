    function setLiveDot(live) {
      const dot = document.getElementById('act-live-dot');
      if (dot) dot.style.background = live ? 'var(--ac)' : 'var(--rd)';
    }

    function renderActivityEvents(events, replace) {
      const el = document.getElementById('act-feed-list');
      if (!el) return;
      const rows = events.map(e => buildActivityRow(e)).join('');
      if (replace) {
        el.innerHTML = rows || '<div style="color:#4a5568;font-size:13px">No events yet.</div>';
      } else {
        el.insertAdjacentHTML('afterbegin', rows);
        const children = Array.from(el.children);
        if (children.length > ACT_MAX_ROWS) children.slice(ACT_MAX_ROWS).forEach(c => c.remove());
      }
    }

    function buildActivityRow(e) {
      const ts   = new Date(e.ts).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit', second:'2-digit' });
      const col  = ACT_COLORS[e.type]  || 'var(--t2)';
      const icon = ACT_ICONS[e.type]   || '·';
      const ac   = e.agent_color || 'var(--t2)';
      const prog = e.progress != null ? `<span style="color:#4a5568;font-size:10px;margin-left:auto">${e.progress}%</span>` : '';
      const safeMsg = (e.message || e.type).replace(/</g,'&lt;').replace(/>/g,'&gt;');
      const taskLink = e.task_id
        ? `<span onclick="openTimeline('${e.task_id}')" style="color:#4a5568;font-size:10px;font-family:monospace;cursor:pointer;text-decoration:underline dotted" title="View timeline">${e.task_id.slice(0,14)}</span>`
        : '';
      return `<div class="eng-feed-row" style="align-items:flex-start">
        <span class="eng-feed-ts" style="flex-shrink:0">${ts}</span>
        <span style="color:${col};flex-shrink:0;width:18px">${icon}</span>
        <span style="color:${ac};flex-shrink:0;min-width:52px;font-weight:600;font-size:11px">${e.agent_name || e.agent_id}</span>
        <span style="color:#c8d0e0;font-size:12px;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${safeMsg}">${safeMsg}</span>
        ${taskLink}${prog}
      </div>`;
    }

    window.openTimeline = async function(task_id) {
      const drawer = document.getElementById('act-timeline-drawer');
      const idEl   = document.getElementById('act-timeline-task-id');
      const list   = document.getElementById('act-timeline-list');
      const stats  = document.getElementById('act-timeline-stats');
      if (!drawer) return;
      drawer.style.display = 'block';
      if (idEl)  idEl.textContent  = task_id;
      if (list)  list.innerHTML    = '<div style="color:#4a5568;font-size:13px">Loading…</div>';
      if (stats) stats.innerHTML   = '';
      try {
        const res = await fetch(`${API}activity/timeline/${task_id}/summary`, { headers: authHeader() });
        const d   = await res.json();
        if (stats) renderTimelineStats(stats, d.stats || {});
        if (list)  renderTimelineEvents(list, d.events || []);
      } catch(e) {
        if (list) list.innerHTML = '<div style="color:#F87171;font-size:12px">Failed to load timeline.</div>';
      }
    };

    window.closeTimeline = function() {
      const drawer = document.getElementById('act-timeline-drawer');
      if (drawer) drawer.style.display = 'none';
    };

    function renderTimelineStats(el, s) {
      const dur = s.duration_ms ? (s.duration_ms / 1000).toFixed(1) + 's' : '—';
      const col = { completed:'var(--ac)', partial:'var(--am)', failed:'var(--rd)', running:'var(--bl)' }[s.final_status] || 'var(--t2)';
      el.innerHTML = [
        `<div class="eng-stat">Status <span style="color:${col}">${s.final_status || '—'}</span></div>`,
        `<div class="eng-stat">Duration <span>${dur}</span></div>`,
        s.tools_total ? `<div class="eng-stat">Tools <span>${s.tools_ok}/${s.tools_total} ok</span></div>` : '',
      ].filter(Boolean).join('');
    }

    function renderTimelineEvents(el, events) {
      if (!events.length) { el.innerHTML = '<div style="color:#4a5568;font-size:13px">No events recorded.</div>'; return; }
      let prevTs = null;
      el.innerHTML = events.map((e, i) => {
        const ts  = new Date(e.ts).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit', second:'2-digit' });
        const col = ACT_COLORS[e.type]  || 'var(--t2)';
        const ico = ACT_ICONS[e.type]   || '·';
        const ac  = e.agent_color || 'var(--t2)';
        const gap = prevTs ? Math.round((e.ts - prevTs) / 1000) : 0;
        prevTs = e.ts;
        const gapHtml = gap > 0 ? `<div style="font-size:9px;color:#2a2f4a;text-align:center;margin:2px 0">+${gap}s</div>` : '';
        const prog = e.progress != null ? `<span style="color:#4a5568;font-size:10px">${e.progress}%</span>` : '';
        const safeMsg = (e.message || e.type).replace(/</g,'&lt;').replace(/>/g,'&gt;');
        return `${i > 0 ? gapHtml : ''}<div class="eng-feed-row">
          <span class="eng-feed-ts" style="flex-shrink:0">${ts}</span>
          <span style="color:${col};flex-shrink:0;width:18px">${ico}</span>
          <span style="color:${ac};font-size:11px;font-weight:600;flex-shrink:0;min-width:52px">${e.agent_name || e.agent_id}</span>
          <span style="color:#c8d0e0;font-size:12px;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${safeMsg}">${safeMsg}</span>
          ${prog}
        </div>`;
      }).join('');
      el.scrollTop = el.scrollHeight;
    }

    const _origShowEngine = window.showEnginePanel;
    window.showEnginePanel = function() {
      if (typeof _origShowEngine === 'function') _origShowEngine();
      startActivityPoller();
    };

    function startActivityPoller() {
      if (_actPoller) return;
      loadActivityFeed(true);
      _actPoller = setInterval(() => loadActivityFeed(false), ACT_POLL_INTERVAL);
      window._actPollerActive = true;
    }

    window.stopActivityPoller = function() {
      if (_actPoller) { clearInterval(_actPoller); _actPoller = null; }
      _actPaused = true;
    };

  })(); // end Phase 8 IIFE
});

