            out += '<summary style="padding:16px 20px;font-size:15px;font-weight:600;cursor:pointer;color:' + aTxt + ';list-style:none;display:flex;justify-content:space-between;align-items:center">' + escP(aq.question || aq.heading || '') + '<span style="color:' + accent + ';font-size:20px;font-weight:300">+</span></summary>';
