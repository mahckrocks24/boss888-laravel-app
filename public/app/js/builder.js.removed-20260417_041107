function _arthurSavePos() {
  try { sessionStorage.setItem('lu_arthur_pos', JSON.stringify(_arthurPos)); } catch(e) {}
}

function _arthurApplyPos() {
  var panel = document.getElementById('arthur-inline-panel');
  if (!panel) return;
  panel.style.transform = 'translate(' + _arthurPos.x + 'px,' + _arthurPos.y + 'px)';
}

// Clamp position so panel stays inside viewport
function _arthurClampPos(x, y) {
  var panel = document.getElementById('arthur-inline-panel');
  if (!panel) return {x:x, y:y};
  var pw = panel.offsetWidth  || 300;
  var ph = panel.offsetHeight || 200;
  var vw = window.innerWidth;
  var vh = window.innerHeight;
  // Get base position (the panel's initial fixed position before translate)
  var rect = panel.getBoundingClientRect();
  var baseLeft = rect.left - _arthurPos.x;
  var baseTop  = rect.top  - _arthurPos.y;
  var minX = -baseLeft;
  var maxX = vw - baseLeft - pw;
  var minY = -baseTop;
  var maxY = vh - baseTop  - ph;
  return { x: Math.min(Math.max(x, minX), maxX), y: Math.min(Math.max(y, minY), maxY) };
}

// Initialize drag on page load (runs once after DOMContentLoaded)
function _arthurInitDrag() {
  var handle = document.getElementById('arthur-drag-handle');
  var panel  = document.getElementById('arthur-inline-panel');
  if (!handle || !panel) return;

  handle.addEventListener('pointerdown', function(e) {
    // Only block drag if clicking exactly on the close button or its icon
    var closeBtn = handle.querySelector('.arthur-panel-close');
    if (closeBtn && (e.target === closeBtn || closeBtn.contains(e.target))) return;
    // Also skip if clicking on the input or any interactive element
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;

    _arthurDrag.active = true;
    _arthurDrag.startX = e.clientX;
    _arthurDrag.startY = e.clientY;
    _arthurDrag.origX  = _arthurPos.x;
    _arthurDrag.origY  = _arthurPos.y;
    panel.style.transition = 'none';
    // Use panel-level pointer capture so drag works even if cursor leaves handle
    try { panel.setPointerCapture(e.pointerId); } catch(err) {}
    e.stopPropagation();
    // Do NOT preventDefault here — it breaks pointer capture on some browsers
  });

  // Listen on PANEL not handle — pointer capture on panel means events come here
  panel.addEventListener('pointermove', function(e) {
    if (!_arthurDrag.active) return;
    var dx = e.clientX - _arthurDrag.startX;
    var dy = e.clientY - _arthurDrag.startY;
    var clamped = _arthurClampPos(_arthurDrag.origX + dx, _arthurDrag.origY + dy);
    _arthurPos.x = clamped.x;
    _arthurPos.y = clamped.y;
    panel.style.transform = 'translate(' + _arthurPos.x + 'px,' + _arthurPos.y + 'px)';
  });

  panel.addEventListener('pointerup', function(e) {
    if (!_arthurDrag.active) return;
    _arthurDrag.active = false;
    panel.style.transition = '';
    _arthurSavePos();
    try { panel.releasePointerCapture(e.pointerId); } catch(err) {}
  });

  panel.addEventListener('pointercancel', function(e) {
    _arthurDrag.active = false;
    panel.style.transition = '';
    try { panel.releasePointerCapture(e.pointerId); } catch(err) {}
  });
}

// Smart default: position near selected component, avoid overlap
function _arthurPositionNear(si, ci) {
  var panel = document.getElementById('arthur-inline-panel');
  if (!panel) return;

  // Try to find the selected component's DOM position
  var canvas = document.getElementById('bld-canvas');
  var targetEl = null;
  if (canvas) {
    // Try data-si/data-ci selectors
    targetEl = canvas.querySelector('[data-si="'+si+'"][data-ci="'+ci+'"]') ||
               canvas.querySelector('.bld-sec[data-si="'+si+'"]');
  }

  if (targetEl) {
    var rect = targetEl.getBoundingClientRect();
    var pw   = panel.offsetWidth  || 300;
    var ph   = panel.offsetHeight || 200;
    var vw   = window.innerWidth;
    var vh   = window.innerHeight;
    // Position to the right of the element if space exists, else left, else bottom
    var preferX = rect.right + 12;
    if (preferX + pw > vw) preferX = rect.left - pw - 12;
    if (preferX < 0)       preferX = 20;
    var preferY = Math.max(20, Math.min(rect.top, vh - ph - 20));
    // Convert to translate offset from panel's initial fixed position
    var base = panel.getBoundingClientRect();
    _arthurPos.x = preferX - (base.left - _arthurPos.x);
    _arthurPos.y = preferY - (base.top  - _arthurPos.y);
  } else {
    // Fallback: bottom-right corner
    var panelBase = panel.getBoundingClientRect();
    _arthurPos.x = 0;
    _arthurPos.y = 0;
  }
  _arthurApplyPos();
}

