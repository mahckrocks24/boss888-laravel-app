async function _bldCreateBlank() {
  document.getElementById('bld-tpl-picker')?.remove();
  var title = await luPrompt('Enter a name for your website:', '', 'New Website');
  if (!title) return;
  try {
    // 1. Create website entry
    var wr = await fetch(API + 'websites', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
      body: JSON.stringify({title: title, description: '', site_config: {created_from: 'blank'}})
    });
    var wd = await wr.json();
    var websiteId = wd.id || wd.website_id || 0;

    // 2. Create a blank Home page with website_id
    var r = await fetch(API + 'builder/create', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
      body: JSON.stringify({title: 'Home', type: 'home', website_id: websiteId})
    });
    var d = await r.json();
    showToast('Website "' + title + '" created', 'success');
    // 3. Navigate to website pages
    await wsLoadSites();
    if (websiteId) wsOpenSite(websiteId);
  } catch(e) { showToast('Failed: ' + e.message, 'error'); }
}

async function _bldCreateFromTemplate(industry) {
  document.getElementById('bld-tpl-picker')?.remove();
  var tpl = null;
  for (var i = 0; i < WEBSITE_TEMPLATES.length; i++) { if (WEBSITE_TEMPLATES[i].industry === industry) { tpl = WEBSITE_TEMPLATES[i]; break; } }
  if (!tpl) return;

  var bizName = await luPrompt('Enter your business name:', tpl.name, tpl.name + ' Website');
  if (!bizName) return;

  showToast('Building ' + tpl.pages.length + ' pages...', 'info');

  // 1. Create website entry
  var websiteId = 0;
  try {
    var wr = await fetch(API + 'websites', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
      body: JSON.stringify({title: bizName, description: tpl.desc, site_config: {created_from: 'template', industry: industry}})
    });
    var wd = await wr.json();
    websiteId = wd.id || wd.website_id || 0;
  } catch(e) { console.error('Website entry creation failed:', e); }

  // 2. Create pages with website_id
  var createdCount = 0;
  for (var p = 0; p < tpl.pages.length; p++) {
    var pageName = tpl.pages[p];
    var pageData = tpl.page_data[pageName];
    if (!pageData) continue;

    var title = (p === 0) ? bizName : pageName.charAt(0).toUpperCase() + pageName.slice(1);
    var sections = [];

    // Header
    var hdr = JSON.parse(JSON.stringify(tpl.header));
    _tplReplace(hdr, bizName);
    sections.push(hdr);

    // Page sections
    for (var s = 0; s < pageData.length; s++) {
      var sec = JSON.parse(JSON.stringify(pageData[s]));
      _tplReplace(sec, bizName);
      sections.push(sec);
    }

    // Footer
    var ftr = JSON.parse(JSON.stringify(tpl.footer));
    _tplReplace(ftr, bizName);
    sections.push(ftr);

    try {
      var r = await fetch(API + 'builder/create', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
        body: JSON.stringify({title: title, type: pageName, website_id: websiteId})
      });
      var d = await r.json();
      if (d.success && d.page && d.page.id) {
        await fetch(API + 'builder/save', {
          method: 'POST',
          headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
          body: JSON.stringify({page_id: d.page.id, layout: {title: title, type: pageName, sections: sections, theme: tpl.theme || {}}})
        });
        createdCount++;
      }
    } catch(e) { console.error('Template page creation failed:', pageName, e); }
  }

  showToast(bizName + ' website created with ' + createdCount + ' pages!', 'success');

  // 3. Navigate to Websites → open this site's pages
  await wsLoadSites();
  if (websiteId) wsOpenSite(websiteId);
}

// Replace {{business}} in all text fields recursively
function _tplReplace(obj, bizName) {
  if (!obj) return;
  if (typeof obj === 'object') {
    for (var k in obj) {
      if (typeof obj[k] === 'string') obj[k] = obj[k].replace(/\{\{business\}\}/g, bizName);
      else if (typeof obj[k] === 'object') _tplReplace(obj[k], bizName);
    }
  }
}

