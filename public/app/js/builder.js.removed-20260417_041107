function bldDropZoneDrop(e, insertAt) {
  e.preventDefault();
  e.stopPropagation();
  var el = e.currentTarget;
  el.style.height = '6px';
  el.style.background = 'transparent';
  el.style.border = 'none';

  // Check if this is a sidebar block drag
  var blockType = e.dataTransfer.getData('text/bld-block');
  if (blockType) {
    bldInsertCoreBlock(blockType, insertAt);
    return;
  }

  // Check if this is a section reorder drag
  var secData = e.dataTransfer.getData('text/plain');
  if (secData && secData.indexOf('sec:') === 0) {
    var fromSi = parseInt(secData.split(':')[1]);
    if (isNaN(fromSi) || !bldCurrentPage || !bldCurrentPage.sections) return;
    var secs = bldCurrentPage.sections;
    if (fromSi === insertAt || fromSi === insertAt - 1) return; // no-op
    var moved = secs.splice(fromSi, 1)[0];
    var targetIdx = (fromSi < insertAt) ? insertAt - 1 : insertAt;
    secs.splice(targetIdx, 0, moved);
    bldDirty = true;
    bldRenderCanvas();
    try { bldRenderLayers(); } catch(ex) {}
  }
}

