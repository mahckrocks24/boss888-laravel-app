            out += '<div><label style="display:block;font-size:12px;font-weight:600;margin-bottom:4px;opacity:.6">' + escP(f.label || '') + (f.required ? ' *' : '') + '</label>';
            if (f.type === 'textarea') out += '<textarea placeholder="' + escP(f.label||'') + '" style="' + inputStyle + ';min-height:110px;resize:vertical"></textarea>';
            else if (f.type === 'select' && Array.isArray(f.options)) {
              out += '<select style="' + inputStyle + '"><option value="">Select...</option>';
