async function bld_loadWorkerQueue() {
  const el = document.getElementById('view-queue');
  if (!el) return;
  el.innerHTML = loadingCard(300);
  try {
    const [statsRes, tasksRes] = await Promise.all([
      bld_get(API + 'tasks/stats'),
      bld_get(API + 'tasks?wsId=1&limit=50'),
    ]);
    const stats = statsRes || {};
    const tasks = (tasksRes?.tasks || []).slice().reverse(); // newest first
    const byStatus = stats.by_status || {};
    const stCols   = { pending:'var(--t3)', queued:'var(--bl)', in_progress:'var(--am)',
                        completed:'var(--ac)', failed:'var(--rd)', cancelled:'var(--t3)' };
    const stBadge  = { pending:'badge-grey', queued:'badge-blue', in_progress:'badge-amber',
                        completed:'badge-green', failed:'badge-red', cancelled:'badge-grey' };
    const agentColors = { dmm:'var(--p)', james:'var(--bl)', priya:'var(--am)',
                           marcus:'var(--am)', elena:'var(--rd)', alex:'var(--bl)' };

    el.innerHTML = '<div style="padding:24px;max-width:1100px">' +
      '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">' +
        '<div><h1 style="font-size:22px;font-weight:700;margin:0 0 4px">⚡ Worker Queue</h1>' +
        '<p style="color:var(--t3);font-size:13px;margin:0">' + tasks.length + ' tasks · ' + (byStatus.in_progress||0) + ' running</p></div>' +
        '<button class="btn btn-outline btn-sm" onclick="bld_loadWorkerQueue()">↺ Refresh</button>' +
      '<button class="btn btn-primary btn-sm" onclick="queueCreateTask()" style="margin-left:8px">+ New Task</button>' +
      '</div>' +

      // Status summary cards
      '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px;margin-bottom:24px">' +
      ['pending','queued','in_progress','completed','failed','cancelled'].map(s =>
        '<div style="background:var(--s2);border:1px solid var(--bd2);border-radius:10px;padding:14px;text-align:center">' +
          '<div style="font-size:22px;font-weight:700;color:' + (stCols[s]||'var(--t2)') + '">' + (byStatus[s]||0) + '</div>' +
          '<div style="font-size:10px;text-transform:uppercase;letter-spacing:.05em;color:var(--t3);margin-top:4px">' + s.replace('_',' ') + '</div>' +
        '</div>'
      ).join('') +
      '</div>' +

      // Task table
      (tasks.length === 0 ? '<div class="card card-body" style="text-align:center;padding:60px"><div style="font-size:36px;margin-bottom:12px">📭</div><h3 style="margin:0 0 8px">No tasks yet</h3><p style="color:var(--t3);font-size:13px;margin:0">Tasks will appear here when agents are working.</p></div>' :
        '<div class="card"><div class="card-header"><h3>All Tasks</h3>' +
          '<div style="display:flex;gap:6px">' +
            ['all','in_progress','failed','completed'].map(function(s) {
              var active = s==='all' ? ' class="tab active"' : '';
              return '<button' + active + ' data-q-tab="' + s + '" onclick="queueFilterTab(this,\'' + s + '\')">' + (s==='all'?'All':s.replace('_',' ')) + '</button>';
            }).join('') +
          '</div>' +
        '</div>' +
        '<div class="table-wrap"><table id="queue-tbl"><thead><tr>' +
          '<th>Task</th><th>Agent</th><th>Status</th><th>Created</th><th>Duration</th><th></th>' +
        '</tr></thead><tbody>' +
        tasks.map(t => {
          const s   = t.status || 'pending';
          const dur = t.duration_ms ? (t.duration_ms/1000).toFixed(1)+'s' : '—';
          const ts  = t.created_at ? new Date(t.created_at).toLocaleString() : '—';
          const col = agentColors[t.agent_id] || 'var(--t2)';
          const log = (t.log || t.output_summary || '').slice(0, 120);
          return '<tr data-qstatus="' + s + '">' +
            '<td style="max-width:280px"><div style="font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + (t.title||t.task_id||'Task') + '</div>' +
              (log ? '<div style="font-size:11px;color:var(--t3);margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + log + '</div>' : '') +
            '</td>' +
            '<td><span style="font-size:12px;font-weight:600;color:' + col + '">' + (t.agent_id||'—') + '</span></td>' +
            '<td><span class="badge ' + (stBadge[s]||'badge-grey') + '">' + s + '</span></td>' +
            '<td style="font-size:12px;color:var(--t3)">' + ts + '</td>' +
            '<td style="font-size:12px;color:var(--t3)">' + dur + '</td>' +
            '<td>' +
              (s === 'failed' ? '<button class="btn btn-ghost btn-sm" onclick="queueRetry(this)" data-tid="' + t.task_id + '">&#x21ba; Retry</button>' : '') +
            '</td>' +
          '</tr>';
        }).join('') +
        '</tbody></table></div></div>'
