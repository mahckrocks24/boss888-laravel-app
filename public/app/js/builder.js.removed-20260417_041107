// ── Friendly error helper ─────────────────────────────────────────────────────
const _ERR_MAP = {
  'Failed to fetch':   'Could not reach the server. Check your connection.',
  'NetworkError':      'Network error — please refresh and try again.',
  'Unexpected token':  'Invalid response from server. Please try again.',
  '401':               'Authentication required. Please reload the page.',
  '403':               'You do not have permission to perform this action.',
  '404':               'The requested resource was not found.',
  '429':               'Too many requests. Please wait a moment.',
  '500':               'A server error occurred. Please try again shortly.',
};
function friendlyError(e) {
  const msg = (e instanceof Error) ? e.message : String(e);
  for (const [key, friendly] of Object.entries(_ERR_MAP)) {
    if (msg.includes(key)) return friendly;
  }
  return 'Something went wrong. Please try again.';
}

