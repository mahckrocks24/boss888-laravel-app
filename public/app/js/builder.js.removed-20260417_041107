// ═══════════════════════════════════════════════════════════════════════════
// DRAG & DROP — Sections + Components (same-section only)
// ═══════════════════════════════════════════════════════════════════════════
let _bldDragSec = null;      // dragged section index
let _bldDragCmp = null;      // {si, ci} — dragged component

function bldSecDragStart(e, si) {
  _bldDragSec = si;
  _bldDragCmp = null;
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain', 'sec:'+si);
  requestAnimationFrame(() => e.target.classList.add('bld-dragging'));
}

function bldSecDragOver(e, targetSi) {
  e.preventDefault();
  // Accept both section reorder and sidebar block drops
  if (_bldDragSec !== null) {
    e.dataTransfer.dropEffect = 'move';
  } else {
    e.dataTransfer.dropEffect = 'copy';
  }
  var el = e.currentTarget;
  if (!el.classList.contains('bld-drop-target')) el.classList.add('bld-drop-target');
}

function bldSecDragLeave(e) {
  e.currentTarget.classList.remove('bld-drop-target');
}

function bldSecDrop(e, targetSi) {
  e.preventDefault();
  e.stopPropagation();
  e.currentTarget.classList.remove('bld-drop-target');

  // Sidebar block drop → insert before this section
  var blockType = e.dataTransfer.getData('text/bld-block');
  if (blockType) {
    bldInsertCoreBlock(blockType, targetSi);
    _bldDragSec = null;
    return;
  }

  // Section reorder
  if (_bldDragSec === null || _bldDragSec === targetSi) { _bldDragSec = null; return; }
  try {
    var secs = bldCurrentPage.sections;
    var moved = secs.splice(_bldDragSec, 1)[0];
    secs.splice(targetSi, 0, moved);
    bldDirty = true;
    bldRenderCanvas();
    bldRenderLayers();
  } catch(err) { console.warn('[DnD] Section drop error:', err); }
  _bldDragSec = null;
}

function bldSecDragEnd(e) {
  _bldDragSec = null;
  e.target.classList.remove('bld-dragging');
  document.querySelectorAll('.bld-drop-target').forEach(el => el.classList.remove('bld-drop-target'));
}

// ── Component drag (within same section only) ────────────────────────────
function bldCmpDragStart(e, si, ci) {
  _bldDragCmp = {si, ci};
  _bldDragSec = null;
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain', 'cmp:'+si+':'+ci);
  e.stopPropagation(); // don't trigger section drag
  requestAnimationFrame(() => e.target.classList.add('bld-dragging'));
}

function bldCmpDragOver(e, targetSi, targetCi) {
  if (!_bldDragCmp) return;
  if (_bldDragCmp.si !== targetSi) return; // same section only
  e.preventDefault();
  e.stopPropagation();
  e.dataTransfer.dropEffect = 'move';
  if (!e.currentTarget.classList.contains('bld-drop-target')) e.currentTarget.classList.add('bld-drop-target');
}

function bldCmpDragLeave(e) {
  e.currentTarget.classList.remove('bld-drop-target');
}

function bldCmpDrop(e, targetSi, targetCi) {
  e.preventDefault();
  e.stopPropagation();
  e.currentTarget.classList.remove('bld-drop-target');
  if (!_bldDragCmp || _bldDragCmp.si !== targetSi || _bldDragCmp.ci === targetCi) { _bldDragCmp = null; return; }
  try {
    const comps = bldCurrentPage.sections[targetSi].components;
    const moved = comps.splice(_bldDragCmp.ci, 1)[0];
    comps.splice(targetCi, 0, moved);
    bldDirty = true;
    bldRenderCanvas();
    bldRenderLayers();
  } catch(err) { console.warn('[DnD] Component drop error:', err); }
  _bldDragCmp = null;
}

function bldCmpDragEnd(e) {
  _bldDragCmp = null;
  e.target.classList.remove('bld-dragging');
  document.querySelectorAll('.bld-drop-target').forEach(el => el.classList.remove('bld-drop-target'));
}

