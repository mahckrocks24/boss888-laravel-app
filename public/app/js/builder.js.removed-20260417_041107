function bldResolveBg(layout, tokens) {
  const {bg_type='none', bg_value=''} = layout;
  if (bg_type === 'none')   return '';
  if (bg_type === 'color')  return 'background:'+bg_value+';';
  if (bg_type === 'token')  return 'background:var(--lubld-'+bg_value+',' + (tokens[bg_value]||bg_value) + ');';
  if (bg_type === 'gradient') return 'background:'+bg_value+';';
