// ── Task poller ──────────────────────────────────────────────────────
const _pollers = {};   // task_id → intervalId

function startTaskPoller(task_id, interval_ms = 4000) {
  if (_pollers[task_id]) return;   // already polling
  let _taskFails = 0;
  _pollers[task_id] = setInterval(async () => {
    if (_taskFails >= 3) { clearInterval(_pollers[task_id]); delete _pollers[task_id]; return; }
    try {
      const res = await fetch(`${API}agent/poll/${task_id}`, {
        headers: authHeader(),
      });
      const d = await res.json();
      _taskFails = 0; // reset on success
      if (d.error && d.error === 'not_found') return;
      updateTaskPollUI(task_id, d);

      // Stop on terminal state
      const TERMINAL = new Set(['complete','partial','failed','cancelled']);
      if (TERMINAL.has(d.state)) {
        clearInterval(_pollers[task_id]);
        delete _pollers[task_id];
        loadEngineQueue();
      }
    } catch(e) { _taskFails++; }
  }, interval_ms);
}

function stopTaskPoller(task_id) {
  if (_pollers[task_id]) {
    clearInterval(_pollers[task_id]);
    delete _pollers[task_id];
  }
}

const STATE_COLORS = {
  queued:'var(--am)', running:'var(--bl)', retrying:'var(--am)',
  complete:'var(--ac)', partial:'var(--am)', failed:'var(--rd)', cancelled:'#4a5568',
};

function updateTaskPollUI(task_id, state) {
  const panel = document.getElementById('eng-output-panel');
  if (!panel || !panel.classList.contains('active')) return;

  const currentTitle = document.getElementById('eng-out-title')?.textContent;
  if (currentTitle !== task_id) return;  // Different task is displayed — skip

  const col = STATE_COLORS[state.state] || 'var(--t2)';
  const a = ENG_AGENTS[state.agent_id] || { name: state.agent_id || '?', color: 'var(--t2)' };

  document.getElementById('eng-out-meta').innerHTML =
    `<span style="color:${a.color}">${a.name}</span> · <span style="color:${col}">${state.state}</span>` +
    (state.progress != null ? ` · ${state.progress}%` : '') +
    (state.finished_at ? ` · ${Math.round((state.finished_at - (state.started_at||state.queued_at||state.finished_at))/1)}s` : '');

  // State-specific body
  if (state.state === 'running') {
    document.getElementById('eng-out-body').textContent =
      `🔄 Running… ${state.progress != null ? state.progress + '% complete' : ''}`;
  } else if (state.state === 'retrying') {
    document.getElementById('eng-out-body').textContent =
      `🔁 Retrying… attempt ${state.attempts}. Last error: ${state.error || 'unknown'}`;
  } else if (state.state === 'failed') {
    document.getElementById('eng-out-body').textContent =
      `❌ Failed after ${state.attempts} attempts.\n\n${state.error || 'Unknown error'}`;
    document.getElementById('eng-out-type').textContent = 'failed';
    // Show retry button
    const existing = document.getElementById('eng-retry-btn');
    if (!existing) {
      const btn = document.createElement('button');
      btn.id = 'eng-retry-btn';
      btn.className = 'btn-dispatch';
      btn.style.marginTop = '10px';
      btn.style.background = 'rgba(248,113,113,.2)';
      btn.style.border = '1px solid #F87171';
      btn.style.color = 'var(--rd)';
      btn.textContent = '↻ Retry Task';
      btn.onclick = () => engRetryTask(task_id);
      document.getElementById('eng-out-body')?.after(btn);
    }
  } else if (state.state === 'cancelled') {
    document.getElementById('eng-out-body').textContent = '🚫 Task cancelled.';
  }

  // Tool events trace
  if (state.tool_events?.length) {
    const trace = document.getElementById('eng-trace-list');
    if (trace) {
      trace.innerHTML = state.tool_events.map(e =>
        `<div class="eng-trace-row">
          <div class="eng-trace-dot ${e.status}"></div>
          <div class="eng-trace-tool">${e.tool_id}</div>
          <div class="eng-trace-ms">${e.duration_ms || '?'}ms</div>
          ${e.error ? `<div style="color:#F87171;font-size:10px;margin-left:auto">${e.error.slice(0,60)}</div>` : ''}
        </div>`
      ).join('');
    }
  }
}

