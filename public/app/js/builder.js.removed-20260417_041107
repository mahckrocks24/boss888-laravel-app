          }
          out += '<button type="submit" style="background:' + accent + ';color:#fff;border:none;padding:14px 36px;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;width:100%;margin-top:4px;transition:all .2s">' + escP(cmp.submit_label || 'Send Message') + '</button>';
