// ── PROPERTIES PANEL ──────────────────────────────────────────────────
function bldShowComponentProps(cmp, si, ci, mi) {
  // PATCH 6A: Dual-key read — manual components use component_type, AI components use type.
  // Both are synced by _bldSanitizeSections at render, but panel is called BEFORE sanitize
  // on freshly AI-modified components, so we must accept either key here.
  const type    = cmp.component_type || cmp.type;
  const content = cmp.content || {};
  // PATCH 6A: Also read from cmp.style (Arthur writes here) with fallback to cmp.styles (renderer path).
  const styles  = Object.assign({}, cmp.style || {}, cmp.styles || {});
  // Normalize style keys from Arthur's camelCase to panel's snake_case for display
  if (cmp.style) {
    if (cmp.style.fontSize     && !styles.font_size)      styles.font_size      = cmp.style.fontSize;
    if (cmp.style.fontWeight   && !styles.font_weight)    styles.font_weight    = cmp.style.fontWeight;
    if (cmp.style.fontFamily   && !styles.font_family)    styles.font_family    = cmp.style.fontFamily;
    if (cmp.style.textAlign    && !styles.text_align)     styles.text_align     = cmp.style.textAlign;
    if (cmp.style.borderRadius && !styles.border_radius)  styles.border_radius  = cmp.style.borderRadius;
    if (cmp.style.lineHeight   && !styles.line_height)    styles.line_height    = cmp.style.lineHeight;
    if (cmp.style.letterSpacing && !styles.letter_spacing) styles.letter_spacing = cmp.style.letterSpacing;
  }
  // PATCH 6A: Recover legacy flat content — Arthur's normComponent wrote content fields at
  // root level (cmp.text, cmp.src) instead of cmp.content.* — surface them in the panel.
  const ARTHUR_CONTENT_KEYS = ['text','src','href','variant','alt','label','tag','level'];
  ARTHUR_CONTENT_KEYS.forEach(function(k) {
    if (cmp[k] !== undefined && content[k] === undefined) content[k] = cmp[k];
  });
  const panel   = document.getElementById('bld-props-body');

  let html = `<div style="margin-bottom:16px">
    <div style="font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">Content</div>`;

  switch(type) {
    case 'heading':
      html += bldPropText('text','Text',content.text||'','bld-prop-heading-text');
      html += bldPropSelect('level','Level',['1','2','3','4','5','6'],String(content.level||2),'bld-prop-heading-level');
      break;
    case 'text':
      html += bldPropTextarea('text','Content',content.text||'','bld-prop-text-content');
      break;
    case 'button':
      html += bldPropText('label','Label',content.label||'Button','bld-prop-btn-label');
      html += bldPropText('href','Link',content.href||'#','bld-prop-btn-href');
      html += bldPropSelect('variant','Variant',['primary','secondary','outline','ghost'],content.variant||'primary','bld-prop-btn-variant');
      break;
    case 'image':
      html += bldPropText('src','Image URL',content.src||'','bld-prop-img-src');
      html += bldPropText('alt','Alt Text',content.alt||'','bld-prop-img-alt');
      html += bldPropText('link','Link',content.link||'','bld-prop-img-link');
      html += `<button onclick="_bldCreativeGenerate(${si},${ci},${mi},'new')" style="width:100%;margin-top:8px;background:linear-gradient(135deg,var(--p),var(--ac));border:none;border-radius:8px;color:#fff;padding:9px;font-size:12px;font-weight:600;cursor:pointer;font-family:var(--fb)">✨ Generate with AI</button>`;
      break;
    case 'spacer':
      html += bldPropText('height','Height',content.height||'40px','bld-prop-spacer-h');
      break;
    case 'html':
      html += bldPropTextarea('code','HTML Code',content.code||'','bld-prop-html-code');
      break;
    case 'cta':
      html += bldPropText('heading','Heading',content.heading||'','bld-prop-cta-h');
      html += bldPropTextarea('subtext','Subtext',content.subtext||'','bld-prop-cta-sub');
      break;
    case 'testimonial':
      html += bldPropTextarea('quote','Quote',content.quote||'','bld-prop-tes-q');
      html += bldPropText('author','Author',content.author||'','bld-prop-tes-a');
      html += bldPropText('role','Role / Company',content.role||'','bld-prop-tes-r');
      break;
    default:
      html += `<div style="font-size:12px;color:var(--t3);padding:8px;background:var(--s2);border-radius:5px">${type} component</div>`;
  }

  html += `</div>
  <div style="margin-bottom:16px">
    <div style="font-size:11px;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">Styles</div>
    ${bldPropText('color','Text Color',styles.color||'','bld-prop-style-col')}
    ${bldPropText('bg','Background',styles.bg||'','bld-prop-style-bg')}
