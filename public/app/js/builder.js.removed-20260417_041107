// Insert a CORE_BLOCK as a new section into standalone page
function bldInsertCoreBlock(type, atIndex) {
  console.log('[BLD] InsertCoreBlock:', type, 'at:', atIndex);
  var c = document.getElementById('bld-canvas');
  
  if (c) { c.style.outline = '3px solid #10B981'; setTimeout(function(){ c.style.outline = ''; }, 800); }
  
  if (!bldCurrentPage) {
    bldCurrentPage = { title: 'Quick Page', sections: [], theme: {}, _source: 'standalone' };
  }
  if (!bldCurrentPage._source) bldCurrentPage._source = 'standalone';
  
  var block = null;
  var allBlocks = STRUCT_BLOCKS.concat(CORE_BLOCKS).concat(LU_ADVANCED_BLOCKS).concat(LU_DYNAMIC_BLOCKS);
  for (var i = 0; i < allBlocks.length; i++) {
    if (allBlocks[i].type === type) { block = allBlocks[i]; break; }
  }
  if (!block) { block = CORE_BLOCKS[CORE_BLOCKS.length - 1]; }

  var components = JSON.parse(JSON.stringify(block.tpl));
  var newSection = { type: type, label: block.label, components: components };

  if (!bldCurrentPage.sections) bldCurrentPage.sections = [];
  
  // Insert at specific position or append to end
  if (typeof atIndex === 'number' && atIndex >= 0 && atIndex <= bldCurrentPage.sections.length) {
    bldCurrentPage.sections.splice(atIndex, 0, newSection);
  } else {
    bldCurrentPage.sections.push(newSection);
  }
  bldDirty = true;
  
  console.log('[BLD] Sections now:', bldCurrentPage.sections.length);
  
  try {
    bldRenderCanvas();
  } catch(err) {
    console.error('[BLD] Render failed:', err);
    if (c) c.innerHTML = '<div style="padding:40px;color:#F87171"><h2>Render Error</h2><pre>' + String(err) + '</pre></div>';
  }
  
  try { bldRenderLayers(); } catch(e) {}
  showToast(block.label + ' added', 'success');
}

