async function bldInsertBlock(blockType){
  if(!bldCurrentPage||!bldBlocksCache) return;
  const block=bldBlocksCache.find(b=>b.type===blockType);
  if(!block) return;
  const dc=block.default_copy||{};
  const elements=[];
  if(dc.heading) elements.push({component_type:'heading',content:{text:dc.heading,level:2},styles:{},tokens:{},responsive:{}});
  if(dc.subtext) elements.push({component_type:'text',content:{text:dc.subtext},styles:{},tokens:{},responsive:{}});
  if(dc.cta_label) elements.push({component_type:'button',content:{label:dc.cta_label,href:'#',variant:'primary'},styles:{},tokens:{},responsive:{}});
  if(dc.items&&(blockType==='testimonials'||blockType==='faq')){
    if(blockType==='testimonials') dc.items.forEach(i=>elements.push({component_type:'testimonial',content:{quote:i.quote||'',author:i.author||'',role:i.role||''},styles:{},tokens:{},responsive:{}}));
    if(blockType==='faq') elements.push({component_type:'faq',content:{items:dc.items.map(i=>({question:i.q||'',answer:i.a||''}))},styles:{},tokens:{},responsive:{}});
  }
  if(dc.plans&&blockType==='pricing') dc.plans.forEach(p=>elements.push({component_type:'pricing',content:{name:p.name,price:p.price,period:p.period||'/mo',features:p.features||[],cta:{label:p.cta||'Get Started',href:'#'}},styles:{},tokens:{},responsive:{}}));
  if(!elements.length) elements.push({component_type:'heading',content:{text:dc.heading||block.label,level:2},styles:{},tokens:{},responsive:{}});
  const newSection={label:block.label,block_type:blockType,layout:{columns:1,gap:'md',padding_y:'xl',padding_x:'md',full_width:false,bg_type:'none',bg_value:''},styles:{},containers:[{components:elements}]};
  bldCurrentPage.sections.push(newSection);
  bldDirty=true; bldRenderCanvas(); bldRenderLayers();
  try{
    await _bldSafeFetch(bldApi+'pages/'+bldCurrentPageId+'/sections',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'},body:JSON.stringify({columns:1,label:block.label})});
    await bldLoadEditorPage();
  }catch(e){console.warn('bldInsertBlock persist',e);}
}

