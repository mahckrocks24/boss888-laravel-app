    }

    html += '</div>';

    // Category breakdown bars
    var cats = sc.categories || {};
    var catLabels = {conversion:'Conversion',seo:'SEO',trust:'Trust',content:'Content',ux:'UX'};
    var catIcons = {conversion:'\uD83C\uDFAF',seo:'\uD83D\uDD0D',trust:'\uD83D\uDEE1\uFE0F',content:'\uD83D\uDCDD',ux:'\u2728'};
    if (Object.keys(cats).length) {
      html += '<div style="padding:8px 0 6px">';
      for (var ck in catLabels) {
        if (!cats.hasOwnProperty(ck)) continue;
