// MIGRATION RESOLVER — maps imported HTML patterns to native block types
// ═══════════════════════════════════════════════════════════════════════════
function _bldResolveMigratedType(section) {
  if (!section || !section.components) return section;
  var type = (section.type || '').toLowerCase();
  var comps = section.components || [];

  // Already a known type? Keep it
  if (LU_BLOCK_REGISTRY[type]) return section;

  // Pattern matching
  var hasMultipleImages = comps.filter(function(c){return c.type==='image'||c.component_type==='image';}).length >= 3;
  var hasCards = comps.some(function(c){return c.type==='cards'||c.component_type==='cards';});
  var hasForm = comps.some(function(c){return c.type==='form'||c.component_type==='form';});
  var hasMap = comps.some(function(c){return c.type==='map'||c.component_type==='map';});
  var hasCatalog = comps.some(function(c){return c.type==='catalog'||c.component_type==='catalog';});
  var hasEmbed = comps.some(function(c){return c.type==='embed'||c.component_type==='embed';});
  var hasHeading = comps.some(function(c){return c.type==='heading'||c.component_type==='heading';});
  var textCount = comps.filter(function(c){return c.type==='text'||c.component_type==='text';}).length;

  // Resolve
  if (hasMultipleImages && !hasCards) { section.type = 'gallery'; }
  else if (hasMap) { section.type = 'contact'; }
  else if (hasCatalog) { section.type = 'service_grid'; }
  else if (hasForm) { section.type = 'contact_form'; }
  else if (hasEmbed) { section.type = 'custom'; }
  else if (hasCards && type !== 'hero') { section.type = 'features'; }
  else if (hasHeading && textCount >= 2) { section.type = 'text_block'; }
  else if (!hasHeading && textCount >= 1) { section.type = 'text_block'; }
  else { section.type = 'custom'; }

  // Map labels
  if (!section.label || section.label === section.type) {
    var labels = {gallery:'Gallery',contact:'Contact',service_grid:'Services',contact_form:'Contact Form',features:'Features',text_block:'Content',custom:'Section'};
    section.label = labels[section.type] || section.type;
  }

  return section;
}

// Apply resolver to all sections from clone/import
function _bldResolveMigratedSections(sections) {
  if (!Array.isArray(sections)) return sections;
  for (var i = 0; i < sections.length; i++) {
    sections[i] = _bldResolveMigratedType(sections[i]);
  }
  return sections;
}


