    const res = await fetch(API + 'engines', { headers: authHeader() });
    // Fix: guard against HTML 401/403 responses before parsing JSON
    if (!res.ok) {
      console.warn('[LevelUp] Engine bootstrap: /lu/v1/engines returned ' + res.status + ' — check authentication.');
      return;
    }
    const data = await res.json();
    const engines = data.engines || [];
    const BUILTIN = new Set(['crm','marketing','social','calendar','automation','builder','websites','governance','seo']);

    for (const eng of engines) {
      if (BUILTIN.has(eng.slug)) continue;  // already handled by nav()
      // Fetch and evaluate the engine's loader JS (sandboxed IIFE)
      try {
        const lr = await fetch(API + 'engines/' + eng.slug + '/loader', { headers: authHeader() });
        if (!lr.ok) { console.warn('[LevelUp] Engine loader ' + eng.slug + ' returned ' + lr.status); continue; }
        const ld = await lr.json();
        if (ld.js && typeof ld.js === 'string') {
          // eslint-disable-next-line no-new-func
          (new Function(ld.js))();
          console.log('[LevelUp] Engine loader registered:', eng.slug);
        }
      } catch (e) {
        console.warn('[LevelUp] Failed to load engine:', eng.slug, e.message);
      }
    }
  } catch (e) {
    console.warn('[LevelUp] Engine bootstrap failed:', e.message);
