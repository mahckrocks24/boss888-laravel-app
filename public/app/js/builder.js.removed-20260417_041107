    const ACT_ICONS = {
      task_created:'📋', task_started:'▶', agent_reasoning:'💭',
      tool_started:'⚙', tool_completed:'✓', task_completed:'✅',
      task_partial:'⚠', task_failed:'✗',   task_retrying:'↻',
