async function bldSendAI() {
  var input   = document.getElementById('bld-ai-input');
  var command = input.value.trim();
  if (!command || !bldCurrentPage) return;
  input.value = '';

  var messages = document.getElementById('bld-ai-messages');
  messages.insertAdjacentHTML('beforeend', '<div style="background:var(--pu);border-radius:8px;padding:10px 12px;font-size:12px;color:#fff;align-self:flex-end;max-width:90%">' + bld_escH(command) + '</div>');
  messages.insertAdjacentHTML('beforeend', '<div id="bld-ai-thinking" style="background:var(--s2);border-radius:8px;padding:10px 12px;font-size:12px;color:var(--t2)">Thinking...</div>');
  messages.scrollTop = messages.scrollHeight;

  var sendBtn = document.getElementById('bld-ai-send');
  sendBtn.disabled = true;

  try {
    var _ctx5c = _bldGetAIContext();
    _ctx5c.source = 'arthur_chat_panel';
    var r = await fetch(API + 'builder/ai', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'},
      body: JSON.stringify({command: command, action_type: 'chat', context: _ctx5c})
    });
    var d = await r.json();
    var thinkEl = document.getElementById('bld-ai-thinking');
    if (thinkEl) thinkEl.remove();

    if (!d.success) {
      messages.insertAdjacentHTML('beforeend', '<div style="background:rgba(248,113,113,.1);border-radius:8px;padding:10px 12px;font-size:12px;color:#F87171">' + bld_escH(d.error || 'AI request failed.') + '</div>');
    } else if (d.ai_action === 'text_response') {
      messages.insertAdjacentHTML('beforeend', '<div style="background:var(--s2);border-radius:8px;padding:10px 12px;font-size:12px;color:var(--t2)">' + bld_escH(d.explanation) + '</div>');
    } else {
      // Normalize → Validate → Safety → Snapshot → Apply
      d.data = _bldNormalizeAIResponse(d.ai_action, d.data);
      var vResult = _bldValidateAIResponse(d.ai_action, d.data);
      if (!vResult.valid) {
        console.warn('[AI VALIDATOR] Rejected:', vResult.reason, d);
        messages.insertAdjacentHTML('beforeend', '<div style="background:rgba(245,158,11,.1);border-radius:8px;padding:10px 12px;font-size:12px;color:var(--am)">AI returned unusable structure: ' + bld_escH(vResult.reason) + '</div>');
      } else {
        // FORMAT C SAFETY: scope + structure guards (si=null for chat panel — no section lock)
        var safetyCheck = _bldLegacySafetyCheck(d.ai_action, d.data, null);
        if (!safetyCheck.ok) {
          console.warn('[LEGACY SAFETY] Blocked:', safetyCheck.reason, d.ai_action);
          messages.insertAdjacentHTML('beforeend', '<div style="background:rgba(245,158,11,.1);border-radius:8px;padding:10px 12px;font-size:12px;color:var(--am)">Edit blocked: ' + bld_escH(safetyCheck.reason) + '</div>');
        } else {
        _bldSnapshotForUndo();
        var diff = _bldApplyAIResponse(d.ai_action, d.data);
        var msg = bld_escH(d.explanation || 'Changes applied.');
        if (diff) msg += ' <span style="opacity:.7;font-size:10px">(' + bld_escH(diff) + ')</span>';
        messages.insertAdjacentHTML('beforeend', '<div style="background:rgba(16,185,129,.1);border-radius:8px;padding:10px 12px;font-size:12px;color:#10B981">' + msg + ' <span onclick="_bldUndoAI()" style="cursor:pointer;text-decoration:underline;margin-left:6px">Undo</span></div>');
        } // end safety check ok
      }
    }
    messages.scrollTop = messages.scrollHeight;
  } catch(e) {
    var thinkEl = document.getElementById('bld-ai-thinking');
    if (thinkEl) thinkEl.remove();
    messages.insertAdjacentHTML('beforeend', '<div style="background:rgba(248,113,113,.1);border-radius:8px;padding:10px 12px;font-size:12px;color:#F87171">Error: ' + bld_escH(e.message) + '</div>');
  }
  sendBtn.disabled = false;
}

// ═══════════════════════════════════════════════════════════════════════════
// AI VALIDATOR — rejects invalid/unsafe AI responses before canvas mutation
// ═══════════════════════════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════
// BUILDER AI — TYPE REGISTRIES + COMPONENT SCHEMAS
// ═══════════════════════════════════════════════════════════════════════════
var _BLD_ALLOWED_SECTION_TYPES = ['header','navigation','footer','banner','sidebar','hero','features','cta','text_block','testimonials','service_grid','faq','contact_form','pricing','custom','about','team','gallery','stats','logos','newsletter'];
var _BLD_ALLOWED_COMPONENT_TYPES = ['heading','text','button','cards','form','image','divider','spacer','list'];
var _BLD_ALLOWED_ACTIONS = ['create_section','update_section','update_page','create_page','update_component','update_header','update_footer','update_navigation','create_website'];

// Required fields per component type
var _BLD_COMPONENT_SCHEMA = {
  heading: {required: ['text'], defaults: {tag:'h2', text:'Heading'}},
  text:    {required: ['text'], defaults: {text:'Text content'}},
  button:  {required: ['text'], defaults: {text:'Button', variant:'primary', href:'#'}},
  image:   {required: ['src'],  defaults: {src:'', alt:'Image'}},
  cards:   {required: ['items'], defaults: {items:[]}},
  form:    {required: ['fields'], defaults: {fields:[{label:'Name',type:'text',required:true},{label:'Email',type:'email',required:true}]}},
  divider: {required: [], defaults: {}},
  spacer:  {required: [], defaults: {}},
  list:    {required: ['items'], defaults: {items:[]}}
};

var _BLD_HTML_BAN_PATTERNS = ['<div','<section','<p>','<p ','<h1','<h2','<h3','<h4','<span','<style','<script','<table','<ul>','<ol>','<li>','class="','style="','innerHTML'];

// ═══════════════════════════════════════════════════════════════════════════
// AI RESPONSE NORMALIZATION — fills defaults, trims junk, enforces structure
// ═══════════════════════════════════════════════════════════════════════════
function _bldNormalizeAIResponse(action, data) {
  if (!data || typeof data !== 'object') return data;

  // Normalize section
  function normSection(sec) {
    if (!sec || typeof sec !== 'object') return sec;
    // Ensure type
    if (!sec.type) sec.type = 'custom';
    // Ensure components array
    if (!sec.components) sec.components = [];
    if (!Array.isArray(sec.components)) sec.components = [];
    // Normalize each component
    for (var c = 0; c < sec.components.length; c++) {
      sec.components[c] = normComponent(sec.components[c]);
    }
    // Ensure style object
    if (!sec.style) sec.style = {};
    // Remove unknown top-level keys
    // PATCH 2: Expanded allowed keys — previously stripped layout/containers/id which
    // corrupted standalone-schema sections on every AI edit. These keys are required by
    // the lubld renderer (containers), the bg/spacing system (layout), and save/load (id).
    var allowed = ['type','label','style','components','layout','containers','id','settings','columns','tag'];
    var keys = Object.keys(sec);
    for (var k = 0; k < keys.length; k++) {
      if (allowed.indexOf(keys[k]) === -1 && keys[k] !== 'section_index') delete sec[keys[k]];
    }
    return sec;
  }

  // Normalize component — fill required defaults
  function normComponent(cmp) {
    if (!cmp || typeof cmp !== 'object') return {type:'text', text:'Content'};
    if (!cmp.type) cmp.type = 'text';
    var schema = _BLD_COMPONENT_SCHEMA[cmp.type];
    if (schema) {
      // Fill missing required fields with defaults
      for (var f = 0; f < schema.required.length; f++) {
        var field = schema.required[f];
        if (cmp[field] === undefined || cmp[field] === null) {
          cmp[field] = schema.defaults[field];
        }
      }
    }
    return cmp;
  }

  // Apply normalization based on action
  if (action === 'create_section' || action === 'update_section' || action === 'update_header' || action === 'update_footer' || action === 'update_navigation') {
    var sec = data.section || data;
    normSection(sec);
    if (data.section) data.section = sec;
    else data = sec;
  }

  if (action === 'update_page' || action === 'create_page' || action === 'create_website') {
    if (data.sections && Array.isArray(data.sections)) {
      for (var s = 0; s < data.sections.length; s++) {
        data.sections[s] = normSection(data.sections[s]);
      }
    }
    if (data.header) data.header = normSection(data.header);
    if (data.footer) data.footer = normSection(data.footer);
  }

  return data;
}

// ═══════════════════════════════════════════════════════════════════════════
// AI VALIDATOR — rejects invalid/unsafe AI responses AFTER normalization
// ═══════════════════════════════════════════════════════════════════════════
function _bldValidateAIResponse(action, data) {
  // 1. Action must be allowed
  if (_BLD_ALLOWED_ACTIONS.indexOf(action) === -1) {
    return {valid: false, reason: 'Unknown action: ' + action};
  }
  // 2. Data must exist
  if (!data || typeof data !== 'object') {
    return {valid: false, reason: 'Missing or invalid data object'};
  }
  // 3. HTML ban — scan entire payload
  var dataStr = JSON.stringify(data);
  for (var i = 0; i < _BLD_HTML_BAN_PATTERNS.length; i++) {
    if (dataStr.indexOf(_BLD_HTML_BAN_PATTERNS[i]) !== -1) {
      return {valid: false, reason: 'Contains raw HTML (' + _BLD_HTML_BAN_PATTERNS[i] + ')'};
    }
  }

  // Helper: validate a single section
  function validateSection(sec, label) {
    if (!sec || typeof sec !== 'object') return 'Invalid section object in ' + label;
    if (sec.type && _BLD_ALLOWED_SECTION_TYPES.indexOf(sec.type) === -1) {
      return 'Unknown section type: ' + sec.type;
    }
    if (sec.components && Array.isArray(sec.components)) {
      for (var c = 0; c < sec.components.length; c++) {
        var cmp = sec.components[c];
        if (!cmp || !cmp.type) continue;
        if (_BLD_ALLOWED_COMPONENT_TYPES.indexOf(cmp.type) === -1) {
          return 'Unknown component type: ' + cmp.type;
        }
        // Validate required fields
        var schema = _BLD_COMPONENT_SCHEMA[cmp.type];
        if (schema) {
          for (var f = 0; f < schema.required.length; f++) {
            var field = schema.required[f];
            if (cmp[field] === undefined || cmp[field] === null || cmp[field] === '') {
              return cmp.type + ' component missing required field: ' + field;
            }
          }
        }
      }
    }
    return null; // valid
  }

  // 4. Per-action validation
  if (action === 'create_section' || action === 'update_section' || action === 'update_header' || action === 'update_footer' || action === 'update_navigation') {
    var sec = data.section || data;
    var err = validateSection(sec, 'section');
    if (err) return {valid: false, reason: err};
  }

  if (action === 'update_page' || action === 'create_page') {
    if (!data.sections || !Array.isArray(data.sections)) {
      return {valid: false, reason: 'Page action missing sections array'};
    }
    if (data.sections.length === 0) {
      return {valid: false, reason: 'Page has zero sections'};
    }
    for (var s = 0; s < data.sections.length; s++) {
      var serr = validateSection(data.sections[s], 'section[' + s + ']');
      if (serr) return {valid: false, reason: serr};
    }
  }

  if (action === 'create_website') {
    if (!data.pages || !Array.isArray(data.pages) || data.pages.length === 0) {
      return {valid: false, reason: 'create_website requires pages array'};
    }
  }

  if (action === 'update_component') {
    if (typeof data.section_index !== 'number' || typeof data.component_index !== 'number') {
      return {valid: false, reason: 'update_component requires section_index and component_index'};
    }
  }

  return {valid: true, reason: null};
}

// ═══════════════════════════════════════════════════════════════════════════
