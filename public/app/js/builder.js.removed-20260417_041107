}

function _arthurSmartFallback(userText) {
  var lc = (userText || '').toLowerCase().trim();
  var ack = '';
  if (/price|cost|how much|fee|paid/.test(lc))           ack = 'Pricing depends on your project. ';
  else if (/how long|time|quick|fast|how soon/.test(lc)) ack = 'It takes under a minute once I have your details. ';
  else if (/example|sample|demo|show me/.test(lc))       ack = 'I build custom sites tailored to your business. ';
  else if (/help|support|contact/.test(lc))              ack = 'Happy to help! ';
  var dq = _arthurGetDirectQuestion();
