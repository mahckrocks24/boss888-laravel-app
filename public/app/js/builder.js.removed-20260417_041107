// ── Spacing widget (4-side with link toggle) ──────────────────────────────
function _epSpacing(label, idPfx, top, right, bottom, left) {
  var linked = (top === right && right === bottom && bottom === left);
  return '<div style="margin-bottom:10px">'
    + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">'
    + '<label class="ep-lbl-inline">' + label + '</label>'
    + '<button id="' + idPfx + '-link" onclick="_epToggleSpacingLink(\'' + idPfx + '\')" style="background:' + (linked?'rgba(108,92,231,.2)':'var(--s3)') + ';border:1px solid var(--bd);border-radius:4px;padding:2px 7px;font-size:10px;cursor:pointer;color:' + (linked?'var(--p)':'var(--t3)') + '">' + (linked?'🔗':'⛓') + '</button>'
    + '</div>'
    + '<div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:4px">'
    + _epSideInput(idPfx+'-t', top||'', '↑T') + _epSideInput(idPfx+'-r', right||'', 'R→')
    + _epSideInput(idPfx+'-b', bottom||'', '↓B') + _epSideInput(idPfx+'-l', left||'', '←L')
    + '</div></div>';
}
function _epSideInput(id, val, ph) {
  return '<input id="' + id + '" value="' + bld_escH(val) + '" placeholder="' + ph + '"'
    + ' oninput="_epSpacingLinked(\'' + id + '\')"'
    + ' style="width:100%;font-size:11px;padding:4px 5px;text-align:center;border:1px solid var(--bd);border-radius:4px;background:var(--s2);color:var(--t1);box-sizing:border-box">';
}
function _epToggleSpacingLink(pfx) {
  var btn = document.getElementById(pfx + '-link');
  var linked = btn && btn.textContent === '🔗';
  if (btn) {
    btn.textContent = linked ? '⛓' : '🔗';
    btn.style.background = linked ? 'var(--s3)' : 'rgba(108,92,231,.2)';
    btn.style.color = linked ? 'var(--t3)' : 'var(--p)';
  }
}
function _epSpacingLinked(id) {
  var pfx = id.slice(0, id.lastIndexOf('-'));
  var btn = document.getElementById(pfx + '-link');
  if (btn && btn.textContent === '🔗') {
    var val = (document.getElementById(id)||{}).value || '';
    ['t','r','b','l'].forEach(function(s) {
      var el = document.getElementById(pfx + '-' + s);
      if (el && el !== document.getElementById(id)) el.value = val;
    });
  }
}

// ── Tab switcher ──────────────────────────────────────────────────────────
function _epTabs(tabs, activeIdx, switchFn) {
  // FIX 1: switchFn is now a plain function name string (e.g. '_epCmpTabSwitch').
  // The tab index is appended as the LAST argument via the extraArgs prefix.
  // Caller passes switchFn as "fnName|arg1|arg2" — we split on | and build correctly.
  var parts   = switchFn.split('|');
  var fnName  = parts[0];
  var argsPfx = parts.slice(1).join(',');  // e.g. "0,1" for si,ci
  return '<div class="ep-tabs">'
    + tabs.map(function(t, i) {
        var args = argsPfx ? argsPfx + ',' + i : String(i);
        return '<button class="ep-tab' + (i === activeIdx ? ' ep-tab-active' : '') + '" onclick="' + fnName + '(' + args + ')">' + t + '</button>';
      }).join('')
    + '</div>';
}

