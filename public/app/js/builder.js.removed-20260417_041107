// ── Create / Start / Stop ────────────────────────────────────────────────
function showNewCampaignModal() {
  const bg = document.getElementById('cmp-new-bg');
  if (bg) bg.style.display = 'flex';
}
function closeCampaignModal() {
  const bg = document.getElementById('cmp-new-bg');
  if (bg) bg.style.display = 'none';
}

async function createCampaign() {
  const name = document.getElementById('cmp-new-name')?.value?.trim();
  const type = document.getElementById('cmp-new-type')?.value;
  if (!name) { showToast('Campaign name required', 'error'); return; }
  try {
    const res  = await fetch(API + 'campaigns', {
      method: 'POST', headers: { ...authHeader(), 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, campaign_type: type }),
    });
    const data = await res.json();
    if (!res.ok) { showToast(data.error || 'Create failed', 'error'); return; }
    closeCampaignModal();
    showToast('Campaign created!', 'success');
    await bld_loadCampaignsView();
  } catch(e) { showToast('Error: ' + e.message, 'error'); }
}

async function startCampaign(id, btn) {
  if (btn) { btn.disabled = true; btn.textContent = '…'; }
  try {
    const res  = await fetch(API + 'campaigns/' + id + '/start', {
      method: 'POST', headers: authHeader(),
    });
    const data = await res.json();
    if (!res.ok) { showToast(data.error || 'Start failed', 'error'); return; }
    showToast('Campaign started! ' + (data.tasks_queued||0) + ' tasks queued.', 'success');
    await bld_loadCampaignsView();
  } catch(e) { showToast('Error: ' + e.message, 'error'); }
  finally { if (btn) { btn.disabled = false; btn.textContent = '▶ Start'; } }
}

async function stopCampaign(id, btn) {
  if (btn) { btn.disabled = true; btn.textContent = '…'; }
  try {
    const res  = await fetch(API + 'campaigns/' + id + '/stop', {
      method: 'POST', headers: authHeader(),
    });
    const data = await res.json();
    if (!res.ok) { showToast(data.error || 'Stop failed', 'error'); return; }
    showToast('Campaign paused.', 'success');
    await bld_loadCampaignsView();
  } catch(e) { showToast('Error: ' + e.message, 'error'); }
  finally { if (btn) { btn.disabled = false; btn.textContent = '⏸ Pause'; } }
}

