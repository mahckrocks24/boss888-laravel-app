          }
        }
      }
    }

    out += '</div></section>';
  }
  return out;
}


function bldPreviewBuildHead(bg, txt, primary, font, title, fontHeading, gfonts) {
  var bodyFont    = font        || 'DM Sans,sans-serif';
  var headingFont = fontHeading || 'Syne,sans-serif';
  var gFontsQuery = gfonts      || 'DM+Sans:wght@400;500;600;700&family=Syne:wght@600;700;800';
  var h = '<!DOCTYPE html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">';
  h += '<title>' + (title || 'Preview') + '</title>';
  h += '<link href="https://fonts.googleapis.com/css2?family=' + gFontsQuery + '&display=swap" rel="stylesheet">';
  h += '<style>*{margin:0;padding:0;box-sizing:border-box}body{background:' + bg + ';color:' + txt + ';font-family:' + bodyFont + ';line-height:1.6;-webkit-font-smoothing:antialiased}';
  h += '.sec{padding:80px 24px}.sec-inner{max-width:1100px;margin:0 auto}';
  h += 'h1,h2,h3,h4{font-family:' + headingFont + ';line-height:1.15;margin-bottom:16px;font-weight:800;letter-spacing:-.02em}';
  h += 'h1{font-size:clamp(32px,5vw,56px)}h2{font-size:clamp(24px,3.5vw,40px)}h3{font-size:20px}';
  h += 'p{font-size:16px;line-height:1.75;margin-bottom:12px}';
  h += '.btn{display:inline-block;padding:14px 32px;border-radius:10px;font-size:15px;font-weight:700;text-decoration:none;cursor:pointer;border:none;transition:all .25s;margin:4px 8px 4px 0}';
  h += '.btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.15)}';
  h += '.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;margin-top:28px}';
  h += '.card{border-radius:16px;padding:32px}.card-icon{font-size:36px;margin-bottom:16px;display:block}';
  h += '#page-content{min-height:100vh}';
  h += '#loading-overlay{position:fixed;inset:0;background:rgba(255,255,255,.6);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;z-index:999;flex-direction:column;gap:12px}';
  h += '#loading-overlay.active{display:flex}';
  h += '.spinner{width:40px;height:40px;border:3px solid rgba(0,0,0,.1);border-top:3px solid ' + primary + ';border-radius:50%;animation:spin .7s linear infinite}';
  h += '@keyframes spin{to{transform:rotate(360deg)}}';
  h += 'details summary::-webkit-details-marker{display:none}';
  h += 'details summary span:last-child{display:inline-block;transition:transform .2s}';
  h += '</style></head><body>';
  return h;
}

async function bldPreview() {
  if (!bldCurrentPage) { showToast('No page loaded', 'error'); return; }

  // Toggle: if preview already open, close it
  var existingOverlay = document.getElementById('bld-preview-overlay');
  if (existingOverlay) { existingOverlay.remove(); return; }

  // Load sibling pages if needed
  var websiteId = window._wsReturnToSite || (typeof wsCurrentSite !== 'undefined' && wsCurrentSite ? wsCurrentSite.id : 0) || 0;
  // Last resort: fetch website_id from current page
  if (!websiteId && bldCurrentPageId) {
    try {
      var _pgr = await fetch(API + 'builder/load/' + bldCurrentPageId, {headers:{'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'}});
      var _pgd = await _pgr.json();
      if (_pgd.website_id) websiteId = _pgd.website_id;
    } catch(_) {}
  }
  if (websiteId && (!_bldWebsitePages || !_bldWebsitePages.length)) {
    try {
      var r = await fetch(API + 'builder/pages?website_id=' + websiteId, {headers:{'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json'}});
      var res = await r.json();
      _bldWebsitePages = bld_ensureArray(res.pages ?? res);
    } catch(e) { console.warn('[Preview] Could not load sibling pages:', e); }
  }

  // Build page HTML (always use JS renderer — no new tab, no server-cache path)
  var previewHtml = _bldBuildPreviewHtml();

  // ── OUTER OVERLAY ──────────────────────────────────────────────────────
  var overlay = document.createElement('div');
  overlay.id = 'bld-preview-overlay';
  overlay.style.cssText = 'position:fixed;inset:0;z-index:99999;background:#0a0a14;display:flex;flex-direction:column;font-family:DM Sans,sans-serif';

  // ── PREVIEW BAR (top strip) ────────────────────────────────────────────
  var bar = document.createElement('div');
  bar.id = 'bld-preview-bar';
  bar.style.cssText = [
    'display:flex;align-items:center;justify-content:space-between',
    'padding:0 20px;height:52px;flex-shrink:0',
    'background:#0f0d1e',
    'border-bottom:1px solid rgba(255,255,255,.07)',
    'box-shadow:0 2px 16px rgba(0,0,0,.4)',
  ].join(';');

  // Left: logo + mode label + site name
  var siteTitle = bldCurrentPage.title || 'Website';
  bar.innerHTML = [
    '<div style="display:flex;align-items:center;gap:12px">',
      '<div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#6C5CE7,#A855F7);display:flex;align-items:center;justify-content:center;font-size:14px">👁</div>',
      '<span style="font-size:13px;font-weight:600;color:rgba(255,255,255,.9)">Preview Mode</span>',
      '<span style="font-size:11px;color:rgba(255,255,255,.3)">— ' + bld_esc(siteTitle) + '</span>',
    '</div>',
    '<div style="display:flex;align-items:center;gap:10px">',
      '<button id="bld-prev-edit-btn" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.8);padding:7px 16px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s">← Go to Editor</button>',
      '<button id="bld-prev-pub-btn"  style="background:linear-gradient(135deg,#6C5CE7,#A855F7);border:none;color:#fff;padding:7px 18px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s">🚀 Publish</button>',
    '</div>',
  ].join('');

  // ── IFRAME ────────────────────────────────────────────────────────────
  var iframe = document.createElement('iframe');
  iframe.id = 'bld-preview-iframe';
  iframe.style.cssText = 'flex:1;width:100%;border:none;background:#fff';
  iframe.setAttribute('sandbox', 'allow-scripts allow-same-origin allow-forms allow-popups');

  overlay.appendChild(bar);
  overlay.appendChild(iframe);
  document.body.appendChild(overlay);

  // Write HTML into iframe
