    parts.push('<button onclick="event.stopPropagation();bldDeleteSection(' + si + ')" style="background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.2);border-radius:4px;padding:2px 6px;font-size:10px;cursor:pointer;color:#F87171">✕</button>');
    parts.push('</div>');

    // Section header
    parts.push('<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">');
    parts.push('<span style="font-size:16px">' + icon + '</span>');
    parts.push('<span style="font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:.04em">' + bld_esc((sec.type || 'section').replace(/_/g, ' ')) + ' · ' + (si + 1) + '</span>');
    if (sec._layout || (sec.props && sec.props.layout && sec.props.layout !== 'default')) {
      var layoutLabel = (sec._layout || (sec.props && sec.props.layout) || '').replace(/_/g, ' ');
