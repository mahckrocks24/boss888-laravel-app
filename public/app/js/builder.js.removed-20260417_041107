function _arthurResolveColor(str) {
  if (!str) return null;
  str = str.trim().toLowerCase();
  if (_arthurColorMap[str]) return _arthurColorMap[str];
  if (/^#([0-9a-f]{3}|[0-9a-f]{6}|[0-9a-f]{8})$/i.test(str)) return str;
  if (/^rgba?\(/.test(str)) return str;
  if (/^hsla?\(/.test(str)) return str;
  return null;
}

function _arthurResolvePx(str) {
  str = (str || '').trim().toLowerCase().replace('px','').replace('pixels','');
  var n = parseInt(str, 10);
  if (!isNaN(n)) return n + 'px';
  var map = {none:'0px',tiny:'4px',small:'8px',medium:'16px',large:'32px',xl:'48px',xxl:'64px',big:'32px',bigger:'48px',huge:'64px'};
  return map[str] || null;
}

// ── Gradient resolver ─────────────────────────────────────────────────────
function _arthurResolveGradient(str) {
  if (!str) return null;
  str = str.trim();
  if (/^linear-gradient\(/i.test(str)) return str;
  if (/^radial-gradient\(/i.test(str)) return str;
  var lc = str.toLowerCase();
  var angleMap = {
    'to right':90,'left to right':90,'horizontal':90,
    'to left':270,'right to left':270,
    'to bottom':180,'top to bottom':180,'vertical':180,'down':180,
    'to top':0,'bottom to top':0,'up':0,
    'diagonal':135,'to bottom right':135,
    'to top right':45,'to bottom left':225,
  };
  var angle = 135;
  for (var dir in angleMap) {
    if (lc.includes(dir)) { angle = angleMap[dir]; break; }
  }
  var degM = str.match(/(\d+)\s*deg/i);
  if (degM) angle = parseInt(degM[1], 10);
  var stripped = lc.replace(/\d+\s*deg/i,'').replace(/to (right|left|top|bottom)/g,'')
    .replace(/diagonal|horizontal|vertical|from|gradient/g,'').trim();
  var parts = stripped.split(/\s+to\s+|\s*,\s*|\s+/).filter(Boolean);
  var c1 = null, c2 = null;
  for (var i = 0; i < parts.length; i++) {
    var c = _arthurResolveColor(parts[i]);
    if (c) { if (!c1) c1 = c; else if (!c2) { c2 = c; break; } }
  }
  if (c1 && c2) return 'linear-gradient(' + angle + 'deg, ' + c1 + ', ' + c2 + ')';
  if (c1)       return 'linear-gradient(' + angle + 'deg, rgba(0,0,0,0.8), ' + c1 + ')';
  return null;
}

// ── TASK 3: NORMALIZATION LAYER ───────────────────────────────────────────
// Maps loose/aliased keys to canonical schema keys.
// Returns { normalized: {}, rejected: [] }
function _arthurNormalizeChanges(changes) {
  var normalized = {};
  var rejected   = [];

  Object.keys(changes || {}).forEach(function(raw_key) {
    var val = changes[raw_key];
    var key = raw_key.toLowerCase().replace(/\s+/g, '');

    // Already canonical (starts with style. or layout. or components)
    if (/^(style\.|layout\.|components)/.test(raw_key)) {
      normalized[raw_key] = val;
      return;
    }

    // Alias lookup
    var canonical = ARTHUR_KEY_ALIASES[key];

    // Handle "padding" specially — sets both top and bottom
    if (key === 'padding') {
      var px = _arthurResolvePx(String(val));
      if (px) {
        normalized['style.paddingTop']    = px;
        normalized['style.paddingBottom'] = px;
      } else {
        rejected.push(raw_key + ' (invalid px value: ' + val + ')');
      }
      return;
    }

    if (canonical) {
      normalized[canonical] = val;
    } else {
      rejected.push(raw_key);
    }
  });

  return { normalized: normalized, rejected: rejected };
}

// ── TASK 4: HARD VALIDATION GATE ─────────────────────────────────────────
// Returns { valid: true } or { valid: false, errors: [] }
// Validates canonical keys against ARTHUR_SCHEMA.
function _arthurValidateChanges(normalizedChanges) {
  var errors = [];
  var sStyle  = ARTHUR_SCHEMA.section.style;
  var sLayout = ARTHUR_SCHEMA.section.layout;

  Object.keys(normalizedChanges).forEach(function(key) {
    var val = normalizedChanges[key];

    // style.X
    if (key.startsWith('style.')) {
      var prop = key.slice(6);
      var def  = sStyle[prop];
      if (!def) { errors.push('Unknown style property: ' + key); return; }

      // Type checks
      if (def.type === 'color') {
        if (val && val !== '' && !_arthurResolveColor(val) && !/^#|^rgb|^hsl/.test(val)) {
          errors.push('Invalid color for ' + key + ': ' + val);
        }
      } else if (def.type === 'px') {
        if (val && !/^\d+(\.\d+)?px$/.test(val)) {
          errors.push('Invalid px value for ' + key + ': ' + val);
        }
      } else if (def.type === 'enum') {
        if (val && def.values && !def.values.includes(val)) {
          errors.push('Invalid enum for ' + key + ': ' + val + ' (allowed: ' + def.values.join('|') + ')');
        }
      }
      return;
    }

    // layout.X
    if (key.startsWith('layout.')) {
      var prop = key.slice(7);
      if (!sLayout[prop]) { errors.push('Unknown layout property: ' + key); }
      return;
    }

    // components — allow (validated separately by apply)
    if (key === 'components') return;

    errors.push('Unknown top-level key: ' + key);
  });

  return errors.length === 0
    ? { valid: true }
    : { valid: false, errors: errors };
}

// ── TASK 5: COMPONENT TARGETING ───────────────────────────────────────────
// Find component in section by type and optional index.
// Returns { component, index } or null.
// TASK 2: Find ALL components of a type within a SPECIFIC section (si-bound)
function _arthurFindComponents(sec, componentType) {
  var comps = sec ? sec.components || [] : [];
  var matches = [];
  for (var i = 0; i < comps.length; i++) {
    if (comps[i].type === componentType) matches.push({ component: comps[i], index: i });
  }
  return matches; // always section-scoped — never touches other sections
}

// Single-match helper (uses _arthurFindComponents internally)
function _arthurFindComponent(sec, componentType, idx) {
  var all = _arthurFindComponents(sec, componentType);
  if (all.length === 0) return null;
  return all[idx !== undefined ? Math.min(idx, all.length - 1) : 0] || null;
}

// TASK 3: Expand a component-targeted change into one action per matching component,
// all scoped to section si. Never leaks to other sections.
function _arthurExpandComponentActions(si, componentType, changes) {
  var sec = bldCurrentPage && bldCurrentPage.sections && bldCurrentPage.sections[si];
  if (!sec) throw { error: 'scope_violation', message: 'Section ' + si + ' not found.' };

  var matches = _arthurFindComponents(sec, componentType);
  if (matches.length === 0) {
    throw { error: 'target_not_found', message: 'No "' + componentType + '" components found in the selected section.' };
  }

  return matches.map(function(m) {
    return {
      action: 'update',
      target: { type: 'component', component_type: componentType, index: m.index, section_index: si },
      changes: changes,
      _section_index: si, // explicit scope tag
    };
  });
}

// TASK 4: Scope violation guard — verify action targets stay within si
function _arthurGuardScope(action, si) {
  var target = action.target || {};
  // If action carries an explicit section_index, it must match si
  if (typeof action._section_index === 'number' && action._section_index !== si) {
    return { violation: true, message: 'Action targets section ' + action._section_index + ' but selected section is ' + si + '.' };
  }
  if (typeof target.index === 'number' && target.type === 'section' && target.index !== si) {
    return { violation: true, message: 'Action targets section ' + target.index + ' but selected section is ' + si + '.' };
  }
  return { violation: false };
}

// ── TASK 6: SCHEMA SUMMARY FOR AI PAYLOAD ────────────────────────────────
function _arthurBuildSchemaSummary() {
  return {
    section_style_props: Object.keys(ARTHUR_SCHEMA.section.style),
    section_layout_props: Object.keys(ARTHUR_SCHEMA.section.layout),
    component_types: Object.keys(ARTHUR_SCHEMA.components),
    color_examples: ['#hex','red','blue','black','white','brand','accent'],
    gradient_format: 'linear-gradient(135deg, #color1, #color2)',
    spacing_format: 'Npx',
    strict_contract: {
      action: 'update',
      target: { type:'section|component', index:'number', component_type:'heading|text|button|...' },
      changes: { 'style.bg':'color', 'style.gradient':'gradient', 'style.paddingTop':'px' },
    }
  };
}

// ── TASK 5+7: APPLY ENGINE — strict, no silent failures ──────────────────
// Returns { applied: true, summary } or throws with reason
function _arthurApplyChangesMap(si, changes, target) {
  var sec = bldCurrentPage.sections[si];
  if (!sec) throw new Error('Section ' + si + ' not found');

  // TASK 3: Normalize
  var norm = _arthurNormalizeChanges(changes);
  if (norm.rejected.length > 0) {
    console.warn('[ARTHUR] Rejected keys:', norm.rejected);
  }
  var normalized = norm.normalized;

  // TASK 4: Validate — HARD GATE
  var validation = _arthurValidateChanges(normalized);
  if (!validation.valid) {
    // TASK 7: Hard fail — no partial apply
    throw new Error('Validation failed: ' + validation.errors.join('; '));
  }

  if (!sec.style) sec.style = {};
  var applied = [];

  // Apply section-level changes
  Object.keys(normalized).forEach(function(key) {
    var val = normalized[key];

    if (key.startsWith('style.')) {
      var prop = key.slice(6);
      // Gradient/bg mutual exclusion
      if (prop === 'gradient' && val) {
        var resolved = _arthurResolveGradient(val) || val;
        sec.style.gradient = resolved;
        sec.style.bg = '';
        applied.push('gradient');
      } else if (prop === 'bg' && val) {
        sec.style.bg = val;
        sec.style.gradient = '';
        applied.push('bg → ' + val);
      } else if (val === null || val === '') {
        delete sec.style[prop];
        applied.push(prop + ' cleared');
      } else {
        sec.style[prop] = val;
        applied.push(prop + ' → ' + val);
      }
    } else if (key.startsWith('layout.')) {
      if (!sec.layout) sec.layout = {};
      sec.layout[key.slice(7)] = val;
      applied.push(key + ' → ' + val);
    } else if (key === 'components' && Array.isArray(val)) {
      sec.components = val;
      applied.push('components replaced');
    }
  });

  // TASK 5: Handle component-targeted changes
  if (target && target.type === 'component' && target.component_type) {
    var match = _arthurFindComponent(sec, target.component_type, target.index);
    if (match) {
      var cmp = match.component;
      // PATCH 3: Ensure content sub-object exists — Arthur previously wrote directly to
      // cmp.text/cmp.src/cmp.href at root, which the renderer never reads (it reads cmp.content.*).
      if (!cmp.content) cmp.content = {};
      Object.keys(normalized).forEach(function(key) {
        // ── Content field mapping ─────────────────────────────────────────
        // Arthur schema uses root-level keys for content (text, src, href, variant, alt).
        // Canonical renderer reads cmp.content.* — write to both for full compatibility.
        var ARTHUR_CONTENT_KEYS = { text:1, src:1, href:1, variant:1, alt:1, label:1, tag:1, level:1 };
        if (ARTHUR_CONTENT_KEYS[key]) {
          cmp.content[key] = normalized[key]; // canonical nested path (renderer reads this)
          cmp[key] = normalized[key];          // legacy root path (Arthur queries read this)
          applied.push('content.' + key);
          return;
        }
        // ── Style field mapping ───────────────────────────────────────────
        // PATCH 4: Arthur writes to cmp.style.* — also sync into cmp.styles.* which is
        // what bldStylesToInline() reads. Without this sync, all AI style changes are
        // invisible to the renderer.
        if (key.startsWith('style.')) {
          var styleProp = key.slice(6);
          if (!cmp.style) cmp.style = {};
          if (!cmp.styles) cmp.styles = {};
          cmp.style[styleProp] = normalized[key];   // Arthur schema path
          // Map Arthur's camelCase style keys to bldStylesToInline's snake_case keys
          var STYLE_KEY_MAP = {
            'color':         'color',
            'bg':            'bg',
            'fontSize':      'font_size',
            'fontWeight':    'font_weight',
            'fontFamily':    'font_family',
            'textAlign':     'text_align',
            'paddingTop':    'padding',
            'paddingBottom': 'padding',
            'paddingX':      'padding',
            'borderRadius':  'border_radius',
            'border':        'border',
            'shadow':        'shadow',
            'lineHeight':    'line_height',
            'letterSpacing': 'letter_spacing',
            'opacity':       'opacity',
            'maxWidth':      'max_width',
          };
          var rendererKey = STYLE_KEY_MAP[styleProp];
          if (rendererKey) cmp.styles[rendererKey] = normalized[key]; // renderer path
          applied.push(target.component_type + '.' + key);
        }
      });
    } else {
      throw new Error('Component type "' + target.component_type + '" not found in section ' + si);
    }
  }

  // TASK 7: Hard fail if nothing was applied
  if (applied.length === 0) {
    throw new Error('No valid changes to apply');
  }

  return { applied: true, summary: applied.join(', ') };
}

// ══════════════════════════════════════════════════════════════════════════
// ARTHUR MULTI-ACTION EXECUTION ENGINE
// All-or-nothing: validates all actions, snapshots state, executes atomically.
// ══════════════════════════════════════════════════════════════════════════

// TASK 6: Max actions guard
var ARTHUR_MAX_ACTIONS = 5;

// TASK 2+3: Execute an array of validated actions atomically.
// Returns { success:true, applied:N, summaries:[] } or throws with { error, failed_at }.
function _arthurExecuteActions(actions, si_default) {
  if (!Array.isArray(actions) || actions.length === 0) {
    throw { error: 'no_actions', message: 'Actions array is empty or missing.' };
  }

  // Limit guard
  if (actions.length > ARTHUR_MAX_ACTIONS) {
    throw {
      error: 'too_many_actions',
      message: 'Max ' + ARTHUR_MAX_ACTIONS + ' actions per request. Got ' + actions.length + '.',
    };
  }

  // Pre-validate ALL actions before touching state
  var validationErrors = [];
  actions.forEach(function(act, i) {
    var changes  = act.changes || {};
    var norm     = _arthurNormalizeChanges(changes);
    var validate = _arthurValidateChanges(norm.normalized);
    if (!validate.valid) {
      validationErrors.push('Action ' + i + ': ' + validate.errors.join('; '));
    }
    var target_si = (act.target && typeof act.target.index === 'number') ? act.target.index : si_default;
    if (!bldCurrentPage || !bldCurrentPage.sections || !bldCurrentPage.sections[target_si]) {
      validationErrors.push('Action ' + i + ': section ' + target_si + ' not found');
    }
  });

  if (validationErrors.length > 0) {
    throw { error: 'validation_failed', message: validationErrors.join(' | '), failed_at: -1 };
  }

  // GLOBAL SNAPSHOT — full page sections + all components, not per-section
  // Guarantees complete rollback with no partial state, no stale cache, no mixed sections
  var globalSnapshot = JSON.parse(JSON.stringify(bldCurrentPage.sections));

  // TASK 1+4: Execute loop — section-scoped, scope guard on every action
  var summaries = [];
  for (var i = 0; i < actions.length; i++) {
    var act     = actions[i];
    var target  = act.target || { type: 'section', index: si_default };

    // Resolve section index for this action
    var act_si;
    if (target.type === 'component' && typeof target.section_index === 'number') {
      act_si = target.section_index; // component actions carry explicit section_index
    } else if (target.type === 'section' && typeof target.index === 'number') {
      act_si = target.index;
    } else {
      act_si = si_default;
    }

    // TASK 4: Scope guard — reject any action targeting outside si_default
    var scopeCheck = _arthurGuardScope(act, si_default);
    if (scopeCheck.violation) {
      bldCurrentPage.sections = JSON.parse(JSON.stringify(globalSnapshot));
      bldRenderCanvas();
      throw {
        error: 'scope_violation',
        message: 'Command attempted to modify outside selected section. ' + scopeCheck.message,
        failed_at: i,
      };
    }

    var changes    = act.changes || {};
    var cmp_target = (target.type === 'component') ? target : null;

    try {
      var result = _arthurApplyChangesMap(act_si, changes, cmp_target);
      summaries.push(result.summary);
    } catch(e) {
      // FULL STATE ROLLBACK
      bldCurrentPage.sections = JSON.parse(JSON.stringify(globalSnapshot));
      bldRenderCanvas();
      throw {
        error: 'execution_failed',
        message: e.message || String(e),
        failed_at: i,
      };
    }
  }

  return { success: true, applied: actions.length, summaries: summaries };
}

// ══════════════════════════════════════════════════════════════════════════
// ARTHUR GROUP EXECUTION ENGINE
// Groups actions by section_index + component_type before execution.
// Ensures deterministic ordering, clean logs, and full-batch rollback.
// ══════════════════════════════════════════════════════════════════════════

// TASK 1: Group actions by section_index + component_type
// Returns: { 'si:section': [...], 'si:heading': [...], 'si:button': [...] }
function _arthurGroupActions(actions, si_default) {
  var groups = {};
  actions.forEach(function(act) {
    var target = act.target || {};
    var act_si = typeof target.section_index === 'number' ? target.section_index
                 : (target.type === 'section' && typeof target.index === 'number') ? target.index
                 : si_default;
    // Group key: section-level changes under 'N:section', components under 'N:type'
    var groupKey = act_si + ':' + (target.type === 'component' ? (target.component_type || 'component') : 'section');
    if (!groups[groupKey]) groups[groupKey] = [];
    groups[groupKey].push(act);
  });
  return groups;
}

// TASK 2+3: Execute groups sequentially — all-or-nothing per batch
// Returns { success, groups_result, total_applied } or throws
function _arthurExecuteGroups(actions, si_default, input) {
  // Build groups
  var groups = _arthurGroupActions(actions, si_default);
  var groupKeys = Object.keys(groups);

  // TASK 3: Re-verify component indices are fresh (section not mutated between groups)
  // Take global snapshot before any group executes
  var globalSnapshot = JSON.parse(JSON.stringify(bldCurrentPage.sections));

  var groupsResult = {};
  var totalApplied = 0;

  for (var gi = 0; gi < groupKeys.length; gi++) {
    var key        = groupKeys[gi];
    var groupActs  = groups[key];
    var keyParts   = key.split(':');
    var group_si   = parseInt(keyParts[0], 10);
    var group_type = keyParts[1];

    // TASK 3: Re-resolve component indices against current (live) section state
    // Ensures stale index from pre-expansion is refreshed if prior group mutated section
    var refreshed = groupActs.map(function(act) {
      var t = act.target || {};
      if (t.type === 'component' && t.component_type) {
        var sec = bldCurrentPage.sections[group_si];
        if (sec) {
          var allOfType = _arthurFindComponents(sec, t.component_type);
          var match = allOfType[typeof t.index === 'number' ? Math.min(t.index, allOfType.length-1) : 0];
          if (match) {
            // Return action with verified index
            return Object.assign({}, act, {
              target: Object.assign({}, t, { index: match.index })
            });
          }
        }
      }
      return act;
    });

    try {
      var result = _arthurExecuteActions(refreshed, si_default);
      groupsResult[group_type] = { count: result.applied, success: true, summaries: result.summaries };
      totalApplied += result.applied;
    } catch(e) {
      // FULL ROLLBACK of all groups (not just this one)
      bldCurrentPage.sections = JSON.parse(JSON.stringify(globalSnapshot));
      bldRenderCanvas();

      groupsResult[group_type] = { count: groupActs.length, success: false, error: e.message || e.error };

      // TASK 4: Group execution failure log
      console.log('ARTHUR_GROUP_EXECUTION', {
        input:         input || '',
        groups:        groupsResult,
        total_actions: actions.length,
        success:       false,
        failed_group:  key,
        failed_at_group_index: gi,
      });

      throw {
        error:   e.error || 'group_execution_failed',
        message: e.message || 'Group "' + group_type + '" failed: ' + (e.message || String(e)),
        failed_group: key,
      };
    }
  }

  // TASK 4: Success log
  console.log('ARTHUR_GROUP_EXECUTION', {
    input:         input || '',
    groups:        groupsResult,
    total_actions: totalApplied,
    success:       true,
    failed_at_group_index: null,
  });

  return { success: true, groups_result: groupsResult, total_applied: totalApplied };
}

// Helper: wrap interpreter changes into a single-action array (TASK 4)
function _arthurWrapAsActions(changes, si, target) {
  return [{
    action: 'update',
    target: target || { type: 'section', index: si },
    changes: changes,
  }];
}

// ══════════════════════════════════════════════════════════════════════════
// INTERPRETER — Deterministic pattern matching, zero AI
// ══════════════════════════════════════════════════════════════════════════
// ══════════════════════════════════════════════════════════════════════════
// TASK 5 — FONT NORMALIZATION
// ══════════════════════════════════════════════════════════════════════════
var _arthurFontMap = {
