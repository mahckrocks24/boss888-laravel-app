// Polls /lu/v1/system/cron-status every 5 minutes and shows a badge in the
// status bar: 🟢 Cron running | 🔴 Cron stalled | ⚠️ Failed jobs
(function() {
  var POLL_INTERVAL = 300000; // 5 minutes

  function updateCronIndicator(data) {
    var el = document.getElementById('sb-cron-indicator');
    if (!el) return;

    var failedSocial  = (data.social   && data.social.failed)   ? data.social.failed   : 0;
    var failedMktg    = (data.marketing && data.marketing.failed) ? data.marketing.failed : 0;
    var totalFailed   = failedSocial + failedMktg;
    var stalled       = data.stalled;

    el.style.display = 'inline-block';

    if (stalled) {
      el.style.background = 'rgba(214,48,49,0.15)';
      el.style.color       = '#d63031';
      el.textContent       = '🔴 Cron stalled';
      el.title             = 'Last cron run: ' + (data.last_run || 'never') + '. Check WP-Cron.';
    } else if (totalFailed > 0) {
      el.style.background = 'rgba(253,203,110,0.2)';
      el.style.color       = '#e17055';
      el.textContent       = '⚠️ ' + totalFailed + ' failed job' + (totalFailed > 1 ? 's' : '');
      el.title             = 'Social failed: ' + failedSocial + ' | Marketing failed: ' + failedMktg + '. Last run: ' + (data.last_run || 'never');
    } else {
      el.style.background = 'rgba(0,184,148,0.12)';
      el.style.color       = '#00b894';
      el.textContent       = '🟢 Cron OK';
      el.title             = 'Cron running normally. Last run: ' + (data.last_run || 'never');
    }
  }

  async function pollCronStatus() {
    try {
      var nonce = (window.LU_CFG && window.LU_CFG.nonce) ? window.LU_CFG.nonce : '';
      var r = await fetch(API + 'system/cron-status', {
        headers: {'X-WP-Nonce': nonce, 'Content-Type': 'application/json'}
      });
      if (!r.ok) return;
      var data = await r.json();
      updateCronIndicator(data);
    } catch(e) {
      // Silent — don't disrupt UI for monitoring failures
    }
  }

  // Initial poll after page load settles, then every 5 minutes
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(pollCronStatus, 5000);
    setInterval(pollCronStatus, POLL_INTERVAL);
  });
})();

