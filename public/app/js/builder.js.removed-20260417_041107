    iframe.contentDocument.write(previewHtml);
    iframe.contentDocument.close();
  } catch(e) { console.error('[Preview] iframe write failed:', e); }

  // ── BUTTON HANDLERS ───────────────────────────────────────────────────
  document.getElementById('bld-prev-edit-btn').onclick = function() {
    overlay.remove();
  };
  document.getElementById('bld-prev-pub-btn').onclick = async function() {
    var btn = this;
    btn.textContent = 'Publishing...'; btn.disabled = true;
    try {
      var siteId = window._wsReturnToSite || bldCurrentPageId || 0;
      var pr = await fetch(API + 'websites/' + siteId + '/publish', {
        method: 'POST',
        headers: {'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json', 'Content-Type': 'application/json'},
        body: '{}',
      });
      var pd = await pr.json();
      if (pd.success || pd.url) {
        btn.textContent = '✅ Published'; btn.style.background = '#00b894'; btn.disabled = false;
        if (pd.url) {
          var link = document.createElement('a');
          link.href = pd.url; link.target = '_blank';
          link.style.cssText = 'color:#00E5A8;font-size:12px;margin-left:10px;text-decoration:none';
          link.textContent = 'View live →';
          document.getElementById('bld-preview-bar').querySelector('div:first-child').appendChild(link);
        }
      } else {
