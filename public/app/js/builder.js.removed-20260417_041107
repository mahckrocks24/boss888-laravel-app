  } else {
    if (_activityPoller) { clearInterval(_activityPoller); _activityPoller = null; }
  }
}

async function loadActivityFeed() {
  const feed = document.getElementById('ws-activity-feed');
  const dot  = document.getElementById('ws-activity-dot');
  if (!feed) return;
  try {
    // Use WP proxy lu/v1/activity/feed — no runtime secret exposed to browser
    const res  = await fetch(API + 'activity/feed?limit=30', { headers: authHeader() });
    if (!res.ok) throw new Error('proxy_unavailable');
    const data = await res.json();
    const events = data.events || data.log || data.feed || [];
    renderActivityFeed(feed, events);
    if (dot) dot.style.background = 'var(--ac)';
  } catch(e) {
    // Fallback: poll WP exec log via lu/v1/agent/status
    try {
      const fbRes = await fetch(API + 'agent/queue', { headers: authHeader() });
      if (fbRes.ok) {
        const fb = await fbRes.json();
        const evts = (fb.tasks || []).slice(0,15).map(t => ({
          ts:       t.created_at || Date.now()/1000,
          event:    t.status,
          agent_id: t.agent_id,
          task_id:  t.task_id || t.id,
          data:     { title: t.title },
        }));
        renderActivityFeed(feed, evts);
      }
    } catch(_) {}
    if (dot) dot.style.background = 'var(--am)';
  }
}

function renderActivityFeed(feed, events) {
  if (!events || !events.length) {
    feed.innerHTML = '<div style="font-size:11px;color:var(--t3);text-align:center;padding:16px">No activity yet.</div>';
    return;
  }
  const agMap = window.AGENTS || {};
  feed.innerHTML = [...events].reverse().slice(0,20).map(ev => {
    const ag    = agMap[ev.agent_id] || {};
    const col   = ag.color || 'var(--t2)';
    const ts    = ev.ts ? new Date(ev.ts * 1000).toLocaleTimeString() : '';
    const evtLabel = (ev.event||'').replace(/_/g,' ');
    const title    = ev.data?.title || ev.task_id || '';
    return `<div style="display:flex;align-items:flex-start;gap:8px;padding:5px 0;border-bottom:1px solid var(--bd)">
      <div style="width:20px;height:20px;border-radius:4px;background:${col}20;display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;margin-top:1px">${ag.emoji||'⚡'}</div>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:600;color:var(--t1)">${bld_esc(evtLabel)}${title?' · <span style="font-weight:400;color:var(--t3)">'+bld_esc(title)+'</span>':''}</div>
        <div style="font-size:10px;color:var(--t3)">${bld_esc(ag.name||ev.agent_id||'system')} · ${ts}</div>
      </div>
    </div>`;
  }).join('');
}

