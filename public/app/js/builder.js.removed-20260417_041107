// ── Preview renderer helpers (module-level so all callers can access) ──
function isLightColor(c) {
  if (!c || c === 'transparent') return false;
  var hex = c.replace('#','');
  if (hex.length === 3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
  if (hex.length !== 6) return false;
  var r = parseInt(hex.substr(0,2),16), g = parseInt(hex.substr(2,2),16), b = parseInt(hex.substr(4,2),16);
  return (r*299 + g*587 + b*114) / 1000 > 140;
}
function escPreview(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function renderSectionsHTML(sections, pageSlug, accent) {
  var isLight = isLightColor;
  var escP = escPreview;
  var out = '';
  for (var si = 0; si < sections.length; si++) {
    var sec  = sections[si];
    var ss   = sec.style || {};
    // Promote background_image from section data to style
    if (sec.background_image && !ss.bgImage) { ss.bgImage = sec.background_image; ss.bgOverlay = 'linear-gradient(rgba(0,0,0,0.5),rgba(0,0,0,0.6))'; }
    var comps = sec.components || [];
    var secBg = ss.bg || '';
    // No explicit section bg = page background (white in preview)
    var _effectiveBg = secBg || '#ffffff';
    var secStyle = '';
    if (ss.gradient) secStyle += 'background:' + ss.gradient + ';';
    else if (secBg)  secStyle += 'background:' + secBg + ';';
    if (ss.padding)       secStyle += 'padding:' + ss.padding + ';';
    if (ss.paddingTop)    secStyle += 'padding-top:' + ss.paddingTop + ';';
    if (ss.paddingBottom) secStyle += 'padding-bottom:' + ss.paddingBottom + ';';
    if (ss.paddingX)      secStyle += 'padding-left:' + ss.paddingX + ';padding-right:' + ss.paddingX + ';';
    if (ss.borderTop)     secStyle += 'border-top:' + ss.borderTop + ';';
    if (ss.textAlign)     secStyle += 'text-align:' + ss.textAlign + ';';
    if (ss.border)        secStyle += 'border:' + ss.border + ';';
    if (ss.shadow)        secStyle += 'box-shadow:' + ss.shadow + ';';
    if (ss.bgImage)       secStyle += 'background-image:' + (ss.bgOverlay ? ss.bgOverlay + ',' : '') + 'url(' + ss.bgImage + ');background-size:cover;background-position:center;';
    var secTxt = ss.color || '';
    // Override: bgImage with dark overlay = force white text
    if (ss.bgImage) { _effectiveBg = '#000000'; secTxt = '#ffffff'; }
    if (!secTxt) secTxt = isLight(_effectiveBg) ? '#1a1a2e' : '#ffffff';
    if (secTxt) secStyle += 'color:' + secTxt + ';';

    // ── Header: sticky navbar ────────────────────────────────────────
    if (sec.type === 'header') {
      var hdrBg  = secBg || 'rgba(255,255,255,.98)';
      var hdrTxt = ss.color || (isLight(hdrBg) ? '#1a1a2e' : '#ffffff');
      var hdrBrand = '', hdrNav = '', hdrBtn = null;
      for (var hci = 0; hci < comps.length; hci++) {
        if (comps[hci].type === 'heading') hdrBrand = comps[hci].text || '';
        else if (comps[hci].type === 'text') hdrNav = comps[hci].text || '';
        else if (comps[hci].type === 'button') hdrBtn = comps[hci];
      }
      var navLinks = hdrNav.split(/\s*[·|]\s*/).map(function(l){return l.trim();}).filter(Boolean);
      var slugMap  = {home:'home', services:'services', about:'about', 'about us':'about', contact:'contact', pricing:'pricing', blog:'blog', portfolio:'portfolio'};
      out += '<nav style="background:' + hdrBg + ';border-bottom:1px solid rgba(0,0,0,.06);position:sticky;top:0;z-index:100;backdrop-filter:blur(12px)">';
      out += '<div style="max-width:1100px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:68px">';
      out += '<a href="/' + escP(slugMap[pageSlug] || 'home') + '" onclick="if(typeof __nav===\'function\'){__nav(\'' + escP(slugMap[pageSlug] || 'home') + '\');}return false;" style="font-family:\'Syne\',sans-serif;font-size:20px;font-weight:800;color:' + accent + ';text-decoration:none;letter-spacing:-.03em;cursor:pointer">' + escP(hdrBrand || 'Brand') + '</a>';
      out += '<div style="display:flex;align-items:center;gap:28px">';
      for (var nli = 0; nli < navLinks.length; nli++) {
        var navSlug = slugMap[navLinks[nli].toLowerCase()] || navLinks[nli].toLowerCase();
        var isCurrentNav = (navSlug === pageSlug);
        out += '<a href="/' + escP(navSlug) + '" onclick="if(typeof __nav===\'function\'){__nav(\'' + escP(navSlug) + '\');}return false;" style="color:' + (isCurrentNav ? accent : hdrTxt) + ';text-decoration:none;font-size:14px;font-weight:' + (isCurrentNav ? '700' : '500') + ';cursor:pointer;border-bottom:2px solid ' + (isCurrentNav ? accent : 'transparent') + ';padding-bottom:2px;transition:all .2s">' + escP(navLinks[nli]) + '</a>';
      }
      if (hdrBtn) {
