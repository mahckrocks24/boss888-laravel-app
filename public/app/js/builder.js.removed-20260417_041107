          <span class="eng-plan-status ${t.status}">${t.status}</span>
        </div>
      </div>
      <button class="eng-plan-run" onclick="engRunPlanTask('${plan.goal_id}','${t.task_id}')">▶ Run</button>
    </div>`;
  }).join('');
}

async function engRunPlanTask(goal_id, task_id) {
  try {
    const res = await fetch(`${API}agent/dispatch`, {
      method: 'POST',
      headers: { 'Content-Type':'application/json', ...authHeader() },
      body: JSON.stringify({ goal_id, task_id }),
    });
    const d = await res.json();
    if (d.error) { showToast('Error: '+d.error,'error'); return; }
    _eng_current_output = d;
    renderEngineOutput(d);
    // Refresh plan
    const planRes = await fetch(`${API}agent/plan/${goal_id}`, { headers: authHeader() });
    const plan = await planRes.json();
    if (!plan.error) renderEnginePlan(plan);
    loadEngineQueue();
  } catch(e) { showToast('Run failed: '+e.message,'error'); }
}

