    const credits = creditsRes.status === 'fulfilled' && creditsRes.value.ok ? await safeJson(creditsRes.value) : null;
    const sub     = subRes.status    === 'fulfilled' && subRes.value.ok     ? await safeJson(subRes.value)     : null;
    const tasks   = tasksRes.status  === 'fulfilled' && tasksRes.value.ok   ? await safeJson(tasksRes.value)   : null;
    const txData  = txRes.status     === 'fulfilled' && txRes.value.ok      ? await safeJson(txRes.value)      : null;
