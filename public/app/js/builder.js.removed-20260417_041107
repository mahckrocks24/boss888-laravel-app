function filterCampaigns(type, btn) {
  _campaignFilter = type;
  document.querySelectorAll('.cmp-filter').forEach(b => {
    b.style.background = 'var(--s2)';
    b.style.border     = '1px solid var(--bd)';
    b.style.color      = 'var(--t2)';
