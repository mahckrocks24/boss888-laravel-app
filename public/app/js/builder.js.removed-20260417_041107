  // Monospace
  'courier':      'Courier New, Courier, monospace',
  'courier new':  'Courier New, Courier, monospace',
  'consolas':     'Consolas, Monaco, monospace',
  'monaco':       'Monaco, Consolas, monospace',
  'lucida console':'Lucida Console, Monaco, monospace',
  // Display / modern
  'impact':       'Impact, Haettenschweiler, Arial Narrow Bold, sans-serif',
  'oswald':       'Oswald, sans-serif',
  'bebas':        '"Bebas Neue", Impact, sans-serif',
  'bebas neue':   '"Bebas Neue", Impact, sans-serif',
};

function _arthurNormalizeFont(val) {
  if (!val) return null;
  val = val.trim();
  var lc = val.toLowerCase().replace(/['"]/g, '');
  // Already has comma = already a font stack
  if (val.includes(',')) return val;
  // Exact match in map
  if (_arthurFontMap[lc]) return _arthurFontMap[lc];
  // Partial match (e.g. "playfair display" → "Playfair Display")
  for (var k in _arthurFontMap) {
    if (lc.includes(k) || k.includes(lc)) return _arthurFontMap[k];
  }
  // Unknown font: wrap in quotes + add generic fallback
  var cap = val.charAt(0).toUpperCase() + val.slice(1);
  return '"' + cap + '", sans-serif';
}

// ══════════════════════════════════════════════════════════════════════════
// TASKS 1+2 — COMPOUND COMMAND PARSER
// Splits multi-part commands and runs each through the interpreter,
// collecting all resolved actions for atomic multi-action execution.
// ══════════════════════════════════════════════════════════════════════════

// Split compound input into individual commands
function _arthurSplitCommands(input) {
  // Boundaries: " and ", ", ", " also ", " then ", " plus ", " + ", "; "
  // But do NOT split inside a quoted string or a color value like "rgba(0,0,0,.5)"
  // Strategy: split on word-boundary conjunctions only
  var parts = input.split(/\s+(?:and|also|then|plus|&|additionally)\s+|;\s*|,\s+(?=(?:change|set|make|update|add|remove|use|apply|turn|switch))/i);
  return parts
    .map(function(p) { return p.trim(); })
    .filter(function(p) { return p.length > 2; });
}

// Run the interpreter on each split command, return actions array or {handled:false}
// If ALL parts resolve deterministically → returns { handled:true, actions:[] }
// If ANY part doesn't resolve → returns { handled:false } (falls through to AI)
function _arthurInterpretMulti(input, si) {
  var parts = _arthurSplitCommands(input);

  // Single part — run directly (no overhead)
  if (parts.length <= 1) return null; // signal: use single interpreter

  var collectedActions = [];
  for (var i = 0; i < parts.length; i++) {
    var part   = parts[i];
    var result = _arthurInterpretSingle(part, si);
    if (!result.handled) {
      // One part failed to resolve — let AI handle the full compound command
      return { handled: false, unresolved_part: part };
    }
    // Collect the normalized action(s) from this part
    if (result.actions) {
      collectedActions = collectedActions.concat(result.actions);
    }
  }

  return { handled: true, actions: collectedActions };
}

function _arthurInterpretSingle(cmd, si) {
  if (!bldCurrentPage || !bldCurrentPage.sections) return {handled:false};
  var sec = bldCurrentPage.sections[si];
  if (!sec) return {handled:false};

  var raw = cmd.trim();
  var lc  = raw.toLowerCase();

  // Unified executor
  function exec(changes, target) {
    var action = _arthurWrapAsActions(changes, si, target)[0];
    if (execCollectMode) {
      return { handled: true, actions: [action], summary: Object.keys(changes).join('+') };
    }
    try {
      _bldSnapshotForUndo();
      var result = _arthurExecuteActions([action], si);
      bldDirty = true; bldRenderCanvas();
      return { handled: true, actions: [action], summary: result.summaries.join(', ') };
    } catch(e) {
      return { handled: false, error: e.message || String(e) };
    }
  }
  var execCollectMode = false;

  // TASK 3: Expand to all components of type + execute atomically (si-scoped)
  exec._expand = function(componentType, changes, label) {
    try {
      var actions = _arthurExpandComponentActions(si, componentType, changes);
      if (execCollectMode) return { handled: true, actions: actions, summary: label };
      _bldSnapshotForUndo();
      var groupResult = _arthurExecuteGroups(actions, si, label);
      bldDirty = true; bldRenderCanvas();
      return { handled: true, actions: actions, summary: label + ' (' + groupResult.total_applied + ')' };
    } catch(e) {
      return { handled: false, error: e.error || e.message || String(e) };
    }
  };

  // Execute a pre-built actions array (for mixed section+component updates)
  exec._raw = function(actions, label) {
    try {
      if (execCollectMode) return { handled: true, actions: actions, summary: label };
      _bldSnapshotForUndo();
      var groupResult = _arthurExecuteGroups(actions, si, label);
      bldDirty = true; bldRenderCanvas();
      return { handled: true, actions: actions, summary: label };
    } catch(e) {
      return { handled: false, error: e.error || e.message || String(e) };
    }
  };

  // ── TWO-COLOR GRADIENT: "black to blue", "dark to brand" ─────────────
  var twoGrad = lc.match(/^(?:make\s+(?:it\s+|this\s+)?|set\s+(?:to\s+)?|apply\s+)?(.+?)\s+to\s+(.+?)(?:\s+gradient)?(?:\s+background)?$/);
  if (twoGrad) {
    var c1 = _arthurResolveColor(twoGrad[1].trim());
    var c2 = _arthurResolveColor(twoGrad[2].trim());
    if (c1 && c2) return exec({'style.gradient':'linear-gradient(135deg,'+c1+','+c2+')'});
  }

  // ── GRADIENT with "gradient" keyword ─────────────────────────────────
  if (lc.includes('gradient')) {
    var src = raw.replace(/^.*?(?:gradient[:\s]*)/i,'').trim() || raw;
    var grad = _arthurResolveGradient(src) || _arthurResolveGradient(raw);
    if (grad) return exec({'style.gradient': grad});
  }

  // ── BACKGROUND COLOR ─────────────────────────────────────────────────
  var bgM = lc.match(/(?:change|set|make|update)?\s*(?:the\s+)?(?:background|bg|section\s+(?:color|background))(?:\s+color)?\s+(?:to|=|:)\s*(.+)/);
  if (bgM) {
    var col = _arthurResolveColor(bgM[1].trim());
    if (col) return exec({'style.bg': col});
  }

  // ── TEXT / SECTION COLOR — ALL text+heading components in section ──────
  var tcM = lc.match(/(?:change|set|make)?\s*(?:the\s+)?(?:text|font)\s+color\s+(?:to|=|:)\s*(.+)/);
  if (tcM) {
    var col = _arthurResolveColor(tcM[1].trim());
    if (col) {
      // Expand: section style.color + all text/heading components (si-scoped)
      var expandedActions = [{ action:'update', target:{type:'section',index:si}, changes:{'style.color':col} }];
      ['text','heading'].forEach(function(ctype) {
        try {
          var expanded = _arthurExpandComponentActions(si, ctype, {'style.color':col});
          expandedActions = expandedActions.concat(expanded);
        } catch(e) { /* no components of this type — skip */ }
      });
      return exec._raw(expandedActions, 'Text color → '+col);
    }
  }

  // ── HEADING COLOR — ALL heading components in section ───────────────
  var hcM = lc.match(/(?:change|set|make)?\s*(?:the\s+)?heading\s+color\s+(?:to|=|:)\s*(.+)/);
  if (hcM) {
    var col = _arthurResolveColor(hcM[1].trim());
    if (col) return exec._expand('heading', {'style.color':col}, 'Heading color → '+col);
  }

  // ── HEADING TEXT ─────────────────────────────────────────────────────
  var hdM = raw.match(/(?:change|set|update|make)?\s*(?:the\s+)?(?:first\s+|main\s+)?(?:heading|title|h1|h2|h3)\s+(?:to|=|:|says?|reads?)\s*["'"'"]?(.+?)["'"'"]?\s*$/i);
  if (hdM) {
    var m = _arthurFindComponent(sec, 'heading');
    if (m) {
      _bldSnapshotForUndo();
      m.component.text = hdM[1].trim();
      bldDirty=true; bldRenderCanvas();
      return {handled:true, summary:'Heading → "'+hdM[1].trim()+'"'};
    }
  }

  // ── SUBTEXT ──────────────────────────────────────────────────────────
  var txM = raw.match(/(?:change|set|update)?\s*(?:the\s+)?(?:sub\s*text|subtext|paragraph|description|body\s*text|text)\s+(?:to|=|:|says?|reads?)\s*["'"'"]?(.+?)["'"'"]?\s*$/i);
  if (txM) {
    var m = _arthurFindComponent(sec, 'text');
    if (m) {
      _bldSnapshotForUndo();
      m.component.text = txM[1].trim();
      bldDirty=true; bldRenderCanvas();
      return {handled:true, summary:'Text → "'+txM[1].trim()+'"'};
    }
  }

  // ── BUTTON TEXT ──────────────────────────────────────────────────────
  var btM = raw.match(/(?:change|set|update)?\s*(?:the\s+)?(?:button|cta|btn)(?:\s+(?:text|label))?\s+(?:to|=|:|says?|reads?)\s*["'"'"]?(.+?)["'"'"]?\s*$/i);
  if (btM) {
    var m = _arthurFindComponent(sec, 'button');
    if (m) {
      _bldSnapshotForUndo();
      m.component.text = btM[1].trim();
      bldDirty=true; bldRenderCanvas();
      return {handled:true, summary:'Button → "'+btM[1].trim()+'"'};
    }
  }

  // ── BUTTON COLOR — ALL buttons in section ────────────────────────────
  var bcM = lc.match(/(?:change|set|make)?\s*(?:the\s+)?button\s+(?:color|background|bg)\s+(?:to|=|:)\s*(.+)/i);
  if (bcM) {
    var col = _arthurResolveColor(bcM[1].trim());
    if (col) return exec._expand('button', {'style.bg':col}, 'Button color → '+col);
  }

  // ── PADDING ──────────────────────────────────────────────────────────
  var padAll = raw.match(/(?:add|set|change|update)?\s*(?:the\s+)?padding\s+(?:to\s+)?(\d+)\s*px?/i);
  var padTop = raw.match(/padding[-\s]?top\s*(?:to\s+)?(\d+)\s*px?/i);
  var padBot = raw.match(/padding[-\s]?bottom\s*(?:to\s+)?(\d+)\s*px?/i);
  if (padAll || padTop || padBot) {
    var ch = {};
    if (padAll && !padTop && !padBot) { ch['style.paddingTop']=padAll[1]+'px'; ch['style.paddingBottom']=padAll[1]+'px'; }
    if (padTop) ch['style.paddingTop']=padTop[1]+'px';
    if (padBot) ch['style.paddingBottom']=padBot[1]+'px';
    return exec(ch);
  }

  // ── DARK/LIGHT shortcut ───────────────────────────────────────────────
  var dkM = lc.match(/make\s+(?:it\s+|this\s+|the\s+(?:section\s+)?)?(dark|light|darker|lighter)/);
  if (dkM) {
    var isDark = dkM[1].startsWith('dark');
    return exec({'style.bg':isDark?'#0F1117':'#f8f9fa','style.color':isDark?'#ffffff':'#1a1a2e','style.gradient':''});
  }

  // ── FULL WIDTH ────────────────────────────────────────────────────────
  if (lc.match(/full[-\s]?width/)) {
    _bldSnapshotForUndo();
    if (!sec.layout) sec.layout={};
    sec.layout.width='full';
    bldDirty=true; bldRenderCanvas();
    return {handled:true, summary:'Full width'};
  }

  // ── CENTER ────────────────────────────────────────────────────────────
  if (lc.match(/center(?:\s+content|\s+text|\s+align)?/) && !lc.includes('to center')) {
    return exec({'style.textAlign':'center'});
  }

  // ── FONT FAMILY ──────────────────────────────────────────────────────
  // "change font to calibri", "set typeface to georgia", "use arial"
  var fontM = lc.match(/(?:change|set|use|make|update|switch)?\s*(?:the\s+)?(?:font|typeface|fontfamily|font[-\s]?family|font[-\s]?style|font[-\s]?type)\s*(?:to|=|:|as)?\s*(.+)/i);
  if (fontM) {
    var fontVal = _arthurNormalizeFont(fontM[1].trim());
    if (fontVal) return exec({'style.fontFamily': fontVal});
  }

  // ── FONT SIZE ─────────────────────────────────────────────────────────
  // "change font size to 18px", "make text bigger", "font size 24"
  var fszM = lc.match(/(?:change|set|make|update)?\s*(?:the\s+)?(?:font[-\s]?size|text[-\s]?size|size)\s*(?:to|=|:)?\s*(\d+)\s*(?:px)?/i);
  if (fszM) return exec({'style.fontSize': fszM[1]+'px'});

  // ── FONT WEIGHT ───────────────────────────────────────────────────────
  var fwM = lc.match(/(?:change|set|make)?\s*(?:the\s+)?(?:font[-\s]?weight|weight)\s*(?:to|=|:)?\s*(bold|normal|light|\d{3})/i);
  if (fwM) {
    var wMap = {bold:'700',normal:'400',light:'300'};
    return exec({'style.fontWeight': wMap[fwM[1].toLowerCase()] || fwM[1]});
  }
  // "make it bold" shortcut
  if (lc.match(/^make\s+(?:it\s+|the\s+(?:text|heading)\s+)?(bold|italic|light)/)) {
    var wMap2 = {bold:'700',italic:'400',light:'300'};
    var wKey  = lc.match(/bold|italic|light/)[0];
    return exec({'style.fontWeight': wMap2[wKey]});
  }

  // ── REMOVE/HIDE component ─────────────────────────────────────────────
  var rmM = lc.match(/(?:hide|remove|delete)\s+(?:the\s+)?(?:first\s+)?(heading|title|button|cta|text|subtext|image)/i);
  if (rmM) {
    var tgt = rmM[1].toLowerCase();
    if (tgt==='title') tgt='heading'; if (tgt==='cta') tgt='button'; if (tgt==='subtext') tgt='text';
    var m = _arthurFindComponent(sec, tgt);
    if (m) {
      _bldSnapshotForUndo();
      sec.components.splice(m.index, 1);
      bldDirty=true; bldRenderCanvas();
      return {handled:true, summary:tgt+' removed'};
    }
  }

  // TASK 5 (T4): Intercept explicit global-scope commands — reject, explain scope
  var globalPatterns = /(?:entire|whole|all\s+(?:sections?|pages?))\s+(?:page|site|website)|(?:page[-\s]?wide|site[-\s]?wide)/i;
  if (globalPatterns.test(lc)) {
    return {
      handled: false,
      error: 'Global scope not supported. Commands apply to the selected section only.',
      hint: 'global_scope_rejected',
    };
  }

  // Interpreter miss — signal type
  var changeVerbs = /\b(change|set|make|add|remove|update|modify|adjust|turn|switch)\b/;
  return { handled:false, hint: changeVerbs.test(lc) ? 'interpreter_miss_change' : 'interpreter_miss_unknown' };
}

// ── TASK 1+2+6: Public entry point — handles single and compound commands ──
// Returns: { handled:true, summary, actions[] } or { handled:false, hint }
function _arthurInterpretCommand(input, si) {
  // Try compound split first if "and/also/then" is present
  var hasConjunction = /\s+(?:and|also|then|plus)\s+/i.test(input) ||
                       /;\s*/.test(input);

  if (hasConjunction) {
    // Try multi-interpret: runs _arthurInterpretSingle on each part in collect mode
    var parts = _arthurSplitCommands(input);
    if (parts.length > 1) {
      var collectedActions = [];
      var allResolved = true;
      var unresolved  = '';

      for (var i = 0; i < parts.length; i++) {
        // Run in collect mode (no immediate execution)
        var result = _arthurInterpretSingleCollect(parts[i], si);
        if (!result.handled) {
          allResolved = false;
          unresolved  = parts[i];
          break;
        }
        if (result.actions) collectedActions = collectedActions.concat(result.actions);
      }

      if (allResolved && collectedActions.length > 0) {
        // TASK 6: All parts resolved → return multi-action array for atomic execution
        return { handled: true, actions: collectedActions, summary: collectedActions.length + ' changes' };
      }
      // Partial resolution — fall through to AI with hint
      return { handled: false, hint: 'compound_partial', unresolved: unresolved };
    }
  }

  // Single command — run directly (executes immediately)
  return _arthurInterpretSingle(input, si);
}

// Collect-mode wrapper: runs interpreter but returns actions without executing
function _arthurInterpretSingleCollect(cmd, si) {
  // We need the interpreter to collect actions rather than execute them.
  // Technique: run _arthurInterpretSingle with a real section but patch bldCurrentPage
  // temporarily to use a deep-cloned page so exec() writes to the clone.
  // Then extract the action from the difference.
  //
  // Simpler approach: re-parse the command to build the action object directly,
  // using the same pattern matching but bypassing exec().
  var sec = bldCurrentPage && bldCurrentPage.sections && bldCurrentPage.sections[si];
  if (!sec) return { handled: false };

  var raw = cmd.trim();
  var lc  = raw.toLowerCase();

  // Mirror key patterns from _arthurInterpretSingle but return action objects
  function mkAction(changes, target) {
    var norm = _arthurNormalizeChanges(changes);
    return {
      handled: true,
      actions: [_arthurWrapAsActions(norm.normalized, si, target)[0]],
      summary: Object.keys(norm.normalized).join('+'),
    };
  }

  // Gradient
  var twoGrad = lc.match(/^(?:make\s+(?:it\s+|this\s+)?|set\s+(?:to\s+)?|apply\s+)?(.+?)\s+to\s+(.+?)(?:\s+gradient)?(?:\s+background)?$/);
  if (twoGrad) {
    var c1=_arthurResolveColor(twoGrad[1].trim()), c2=_arthurResolveColor(twoGrad[2].trim());
    if (c1&&c2) return mkAction({'style.gradient':'linear-gradient(135deg,'+c1+','+c2+')'});
  }
  if (lc.includes('gradient')) {
    var grad = _arthurResolveGradient(raw.replace(/^.*?gradient[:\s]*/i,'').trim()||raw)||_arthurResolveGradient(raw);
    if (grad) return mkAction({'style.gradient':grad});
  }

  // Background
  var bgM = lc.match(/(?:change|set|make|update)?\s*(?:the\s+)?(?:background|bg|section\s+(?:color|background))(?:\s+color)?\s+(?:to|=|:)\s*(.+)/);
  if (bgM) { var col=_arthurResolveColor(bgM[1].trim()); if (col) return mkAction({'style.bg':col}); }

  // Text color — expand to all text+heading components in section
  var tcM = lc.match(/(?:change|set|make)?\s*(?:the\s+)?(?:text|font)\s+color\s+(?:to|=|:)\s*(.+)/);
  if (tcM) {
    var col=_arthurResolveColor(tcM[1].trim());
    if (col) {
      var expandedActions = [{ action:'update', target:{type:'section',index:si}, changes:{'style.color':col} }];
      ['text','heading'].forEach(function(ctype) {
        try { expandedActions = expandedActions.concat(_arthurExpandComponentActions(si, ctype, {'style.color':col})); } catch(e) {}
      });
      return { handled: true, actions: expandedActions, summary: 'Text color → '+col };
    }
  }

  // Heading color — expand to all headings in section
  var hcM = lc.match(/(?:change|set|make)?\s*(?:the\s+)?heading\s+color\s+(?:to|=|:)\s*(.+)/);
  if (hcM) {
    var col=_arthurResolveColor(hcM[1].trim());
    if (col) {
      try {
        var actions = _arthurExpandComponentActions(si, 'heading', {'style.color':col});
        return { handled: true, actions: actions, summary: 'Heading color → '+col };
      } catch(e) { return mkAction({'style.color':col},{type:'component',component_type:'heading'}); }
    }
  }

  // Heading text
  var hdM = raw.match(/(?:change|set|update|make)?\s*(?:the\s+)?(?:first\s+|main\s+)?(?:heading|title|h1|h2|h3)\s+(?:to|=|:|says?|reads?)\s*["'"'"]?(.+?)["'"'"]?\s*$/i);
  if (hdM) return mkAction({'text':hdM[1].trim()},{type:'component',component_type:'heading'});

  // Subtext
  var txM = raw.match(/(?:change|set|update)?\s*(?:the\s+)?(?:sub\s*text|subtext|paragraph|description|body\s*text|text)\s+(?:to|=|:|says?|reads?)\s*["'"'"]?(.+?)["'"'"]?\s*$/i);
  if (txM) return mkAction({'text':txM[1].trim()},{type:'component',component_type:'text'});

  // Button text
  var btM = raw.match(/(?:change|set|update)?\s*(?:the\s+)?(?:button|cta|btn)(?:\s+(?:text|label))?\s+(?:to|=|:|says?|reads?)\s*["'"'"]?(.+?)["'"'"]?\s*$/i);
  if (btM) return mkAction({'text':btM[1].trim()},{type:'component',component_type:'button'});

  // Button color
  var bcM = lc.match(/(?:change|set|make)?\s*(?:the\s+)?button\s+(?:color|background|bg)\s+(?:to|=|:)\s*(.+)/i);
  if (bcM) { var col=_arthurResolveColor(bcM[1].trim()); if (col) return mkAction({'style.bg':col},{type:'component',component_type:'button'}); }

  // Padding
  var padAll=raw.match(/(?:add|set|change|update)?\s*(?:the\s+)?padding\s+(?:to\s+)?(\d+)\s*px?/i);
  var padTop=raw.match(/padding[-\s]?top\s*(?:to\s+)?(\d+)\s*px?/i);
  var padBot=raw.match(/padding[-\s]?bottom\s*(?:to\s+)?(\d+)\s*px?/i);
  if (padAll||padTop||padBot) {
    var ch={};
    if(padAll&&!padTop&&!padBot){ch['style.paddingTop']=padAll[1]+'px';ch['style.paddingBottom']=padAll[1]+'px';}
    if(padTop)ch['style.paddingTop']=padTop[1]+'px';
    if(padBot)ch['style.paddingBottom']=padBot[1]+'px';
    return mkAction(ch);
  }

  // Font family
  var fontM = lc.match(/(?:change|set|use|make|update|switch)?\s*(?:the\s+)?(?:font|typeface|fontfamily|font[-\s]?family|font[-\s]?style|font[-\s]?type)\s*(?:to|=|:|as)?\s*(.+)/i);
  if (fontM) { var fv=_arthurNormalizeFont(fontM[1].trim()); if (fv) return mkAction({'style.fontFamily':fv}); }

  // Font size
  var fszM = lc.match(/(?:change|set|make|update)?\s*(?:the\s+)?(?:font[-\s]?size|text[-\s]?size|size)\s*(?:to|=|:)?\s*(\d+)\s*(?:px)?/i);
  if (fszM) return mkAction({'style.fontSize':fszM[1]+'px'});

  // Dark/light
  var dkM = lc.match(/make\s+(?:it\s+|this\s+|the\s+(?:section\s+)?)?(dark|light|darker|lighter)/);
  if (dkM) {
    var isDark=dkM[1].startsWith('dark');
    return mkAction({'style.bg':isDark?'#0F1117':'#f8f9fa','style.color':isDark?'#ffffff':'#1a1a2e','style.gradient':''});
  }

  return { handled: false };
}



// ── TASK 1: Strict JSON parse — no extraction, no fallback ───────────────
// Returns parsed object or throws with reason.
function _arthurStrictParse(rawText) {
  if (typeof rawText !== 'string' || !rawText.trim()) {
    throw new Error('empty_response');
  }
  var t = rawText.trim();
  // TASK 2: Remove ONLY markdown code fences — nothing else
  t = t.replace(/^```json\s*/i, '').replace(/^```\s*/i, '').replace(/\s*```$/i, '').trim();
  // Must start with { — hard fail otherwise
  if (t.charAt(0) !== '{') {
    throw new Error('not_json: response starts with "' + t.charAt(0) + '" not "{"');
  }
  // Strict parse — no try-catch suppression, let it throw
  return JSON.parse(t);
}

// ══════════════════════════════════════════════════════════════════════════
// _arthurSendPrompt — Main entry point
// ══════════════════════════════════════════════════════════════════════════
async function _arthurSendPrompt(si) {
  var input = document.getElementById('arthur-prompt');
  if (!input) return;
  var text = input.value.trim();
  if (!text) return;

  var status = document.getElementById('arthur-status');
  var secEl  = document.querySelector('#bld-canvas .bld-sec[data-si="' + si + '"]');

  // ── STEP 1: INTERPRETER — zero AI, instant ────────────────────────────
  var interpreted = _arthurInterpretCommand(text, si);

  // TASK 8: Execution log
  console.log('ARTHUR_EXECUTION', {
    step: 'interpreter',
    input: text,
    section_index: si,
    handled: interpreted.handled,
    summary: interpreted.summary || null,
    actions_count: interpreted.actions ? interpreted.actions.length : 0,
    error: interpreted.error || null,
    hint: interpreted.hint || null,
  });

  if (interpreted.handled) {
    if (interpreted.actions && interpreted.actions.length > 1) {
      // TASK 6: Compound command → atomic multi-action execution
      try {
        _bldSnapshotForUndo();
        var groupResult = _arthurExecuteGroups(interpreted.actions, si, text);
        bldDirty = true; bldRenderCanvas();
        var summary = groupResult.total_applied + ' change' + (groupResult.total_applied !== 1 ? 's' : '') + ' applied';
        if (status) {
          status.style.display = 'block';
          status.textContent = '\u2705 ' + summary;
          setTimeout(function() { if (status) status.style.display = 'none'; }, 2000);
        }
      } catch(e) {
        if (status) { status.style.display='block'; status.textContent='\u274C '+(e.message||e.error||'Execution failed'); }
      }
    } else {
      // Single command already executed inside interpreter
      if (status) {
        status.style.display = 'block';
        status.textContent = '\u2705 ' + interpreted.summary;
        setTimeout(function() { if (status) status.style.display = 'none'; }, 1800);
      }
    }
    input.value = '';
    return;
  }

  // If interpreter encountered a validation error (matched but failed) — hard fail
  if (interpreted.error) {
    if (status) { status.style.display='block'; status.textContent='\u274C '+interpreted.error; }
    input.value = '';
    console.log('ARTHUR_EXECUTION', {step:'interpreter_error', input:text, error:interpreted.error});
    return;
  }

  // ── STEP 2: AI PATH — strict structured mode ──────────────────────────
  input.value = '';
  input.disabled = true;
  if (!_arthurLastAction.action && !_arthurLastAction.label) {
    _arthurLastAction = {action:'pass_to_ai', label:text.length>30?text.substring(0,30)+'...':text};
  }
  if (status) { status.style.display='block'; status.textContent='\u26A1 Working...'; }
  if (secEl) secEl.classList.add('arthur-loading');

  // TASK 2: Build full schema-aware payload
  var currentSec = (bldCurrentPage && bldCurrentPage.sections && bldCurrentPage.sections[si]) || {};
  var ctx = _bldGetAIContext(si);
  ctx.source        = 'arthur';
  ctx.section_index = si;
  ctx.editor_schema = _arthurBuildSchemaSummary();
  ctx.current_section = currentSec;
  ctx.component_tree  = (currentSec.components || []).map(function(c,i){
    return {index:i, type:c.type, text:c.text||null};
  });
  ctx.interpreter_hint = interpreted.hint || null;
  ctx.strict_mode = true; // signal to PHP to enforce strict output

  try {
    var r = await fetch(API + 'builder/ai', {
      method:'POST', headers:{'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'},
      body: JSON.stringify({command:text, action_type:'chat', context:ctx})
    });
    var raw = await r.text();

    // TASK 1+2: STRICT PARSE — no fallback, no extraction
    var d;
    try {
      d = _arthurStrictParse(raw);
    } catch(parseErr) {
      var errMsg = 'AI returned invalid JSON: ' + parseErr.message;
      if (status) status.textContent = '\u274C ' + errMsg;
      console.log('ARTHUR_EXECUTION', {step:'parse_fail', input:text, error:errMsg, raw:raw.slice(0,200)});
      if (secEl) secEl.classList.remove('arthur-loading');
      if (input) { input.disabled=false; input.focus(); }
      return;
    }

    // Confirmation proposal flow
    if (d.success && d.requires_confirmation && d.proposal) {
      if (status) {
        status.innerHTML = '<div style="margin-bottom:8px">'+(d.explanation||'').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br>')+'</div>'
          +'<div style="display:flex;gap:6px">'
          +'<button onclick="event.stopPropagation();_arthurConfirmDecision('+si+',decodeURIComponent(\''+encodeURIComponent(text)+'\'))" style="background:var(--ac);color:#0F1117;border:none;border-radius:6px;padding:6px 14px;font-size:11px;font-weight:600;cursor:pointer">\u2713 Proceed</button>'
          +'<button onclick="event.stopPropagation();arthurHide()" style="background:var(--s3);color:var(--t2);border:1px solid var(--bd);border-radius:6px;padding:6px 14px;font-size:11px;cursor:pointer">\u2715 Cancel</button>'
          +'</div>';
      }
      if (secEl) secEl.classList.remove('arthur-loading');
      if (input) input.disabled = false;
      return;
    }

    // ── TASK 1: Detect response format — array or single action ─────────
    var actions_array = null;

    if (d.actions && Array.isArray(d.actions)) {
      // FORMAT A: { "actions": [...] }
      actions_array = d.actions;
    } else if (d.changes) {
      // FORMAT B: single { action, target, changes } — wrap to array
      actions_array = [{ action: d.action||'update', target: d.target||{type:'section',index:si}, changes: d.changes }];
    } else if (d.data && d.ai_action && d.ai_action !== 'text_response') {
      // FORMAT C: legacy { action, data } from PHP pipeline — hardened with safety layer
      if (d.data && Array.isArray(d.data) && d.data.length === 0) d.data = null;
      if (d.data) {
        d.data = _bldNormalizeAIResponse(d.ai_action, d.data);
        if (typeof d.data.section_index !== 'number') d.data.section_index = si;
        var v = _bldValidateAIResponse(d.ai_action, d.data);
        if (v.valid) {
          // FORMAT C SAFETY: scope guard + structure guard before apply
          var fcSafety = _bldLegacySafetyCheck(d.ai_action, d.data, si);
          if (!fcSafety.ok) {
            if (status) status.textContent = '❌ Blocked: ' + fcSafety.reason;
            console.log('ARTHUR_EXECUTION', {step:'legacy_safety_fail', input:text, action:d.ai_action, reason:fcSafety.reason, applied:false});
          } else {
            _bldSnapshotForUndo();
            _bldApplyAIResponse(d.ai_action, d.data);
            bldDirty=true; bldRenderCanvas();
            setTimeout(function(){bldSelectComponent(si,null);},80);
            if (status) { status.textContent='✅ '+(d.explanation||'Applied!'); setTimeout(arthurHide,1200); }
            console.log('ARTHUR_EXECUTION',{step:'legacy_apply',input:text,action:d.ai_action,applied:true});
          }
        } else {
          if (status) status.textContent='❌ Could not apply: '+v.reason;
          console.log('ARTHUR_EXECUTION',{step:'legacy_validate_fail',input:text,reason:v.reason,applied:false});
        }
        if (secEl) secEl.classList.remove('arthur-loading');
        if (input) { input.disabled=false; input.focus(); }
        return;
      }
    }

    // ── TASK 2+3+6+7+8: Multi-action execution engine ─────────────────
    if (actions_array && actions_array.length > 0) {
      // TASK 6: Max guard
      if (actions_array.length > ARTHUR_MAX_ACTIONS) {
        if (status) status.textContent = '❌ Too many actions ('+actions_array.length+'). Max is '+ARTHUR_MAX_ACTIONS+'.';
        console.log('ARTHUR_GROUP_EXECUTION',{input:text,groups:{},total_actions:actions_array.length,success:false,error:'too_many_actions'});
        if (secEl) secEl.classList.remove('arthur-loading');
        if (input) { input.disabled=false; input.focus(); }
        return;
      }

      // TASK 8: Log start
      console.log('ARTHUR_GROUP_EXECUTION',{
        input:text,
        action_count:actions_array.length,
        actions:actions_array.map(function(a,i){return{i:i,target:a.target,keys:Object.keys(a.changes||{})};})
      });

      try {
        _bldSnapshotForUndo();
        var groupResult = _arthurExecuteGroups(actions_array, si, text);
        bldDirty=true; bldRenderCanvas();
        setTimeout(function(){bldSelectComponent(si,null);},80);
        var summary = groupResult.total_applied+' change'+(groupResult.total_applied!==1?'s':'')+' applied';
        if (status) { status.textContent='✅ '+summary; setTimeout(arthurHide,1600); }
      } catch(execErr) {
        var errMsg = execErr.message || execErr.error || 'Execution failed';
        if (status) status.textContent = '❌ '+errMsg;
        console.log('ARTHUR_GROUP_EXECUTION',{
          input:text,
          action_count:actions_array.length,
          success:false,
          failed_at_index:execErr.failed_at!==undefined?execErr.failed_at:-1,
          error:execErr.error||'execution_failed'
        });
      }
    } else {
      // Hard structured rejection — no actions resolved
      if (status) status.textContent='❌ Unsupported command. Try: "change background to blue" or "black to blue gradient"';
      console.log('ARTHUR_GROUP_EXECUTION',{input:text,action_count:0,success:false,applied:false,error:'unsupported_command'});
    }
  } catch(e) {
    if (status) status.textContent = 'Error: '+e.message;
    console.log('ARTHUR_EXECUTION',{step:'exception',input:text,error:e.message,applied:false});
  }

  if (secEl) secEl.classList.remove('arthur-loading');
  if (input) { input.disabled=false; input.focus(); }
}

// ── Arthur Progress Tracking — record score after successful edits ──
// Last action tracker — set before execution, read by progress recorder
var _arthurLastAction = { action: '', label: '' };

function _arthurRecordProgress() {
  if (!bldCurrentPage || !bldCurrentPageId) return;
  var ctx = _bldGetAIContext();
  ctx.source = 'arthur_progress';
  var payload = { context: ctx };
  // Attach last action for attribution
  if (_arthurLastAction.action || _arthurLastAction.label) {
    payload.action = _arthurLastAction.action;
    payload.label = _arthurLastAction.label;
    _arthurLastAction = { action: '', label: '' }; // Reset after use
  }
  // Fire-and-forget — don't block the UI
  fetch(API + 'arthur/record-progress', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json' },
    body: JSON.stringify(payload)
  }).then(function(r) { return r.json(); }).then(function(d) {
    if (d.recorded) console.log('[PROGRESS] Score recorded:', d.score?.overall);
  }).catch(function() {});
}

// ── Arthur Proactive Intelligence — scan page, show suggestions ──
async function _arthurProactiveScan(si) {
  var btn = document.getElementById('arthur-analyze-btn');
  var sugBox = document.getElementById('arthur-suggestions');
  if (!sugBox) return;
  if (btn) { btn.textContent = '\u2728 Scanning...'; btn.disabled = true; }
  sugBox.style.display = 'block';
  sugBox.innerHTML = '<div style="text-align:center;padding:8px;color:var(--t2);font-size:11px">Analyzing page...</div>';

  try {
    var ctx = _bldGetAIContext(si);
    ctx.source = 'arthur_proactive';
    var r = await fetch(API + 'arthur/proactive', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (localStorage.getItem('lu_token') || ''), 'Accept': 'application/json' },
      body: JSON.stringify({ context: ctx })
    });
    var d = await r.json();

    if (!d.success || (!d.suggestions?.length && !d.score)) {
      sugBox.innerHTML = '<div style="text-align:center;padding:10px;font-size:12px;color:#10B981">\u2705 Page looks good! No critical issues found.</div>';
      if (btn) { btn.textContent = '\uD83E\uDDE0 Analyze Page'; btn.disabled = false; }
      return;
    }

    // ── Render Growth Score + Categories + Roadmap + Suggestions ──
    var html = '<div style="padding:2px 0">';

    // Growth Score header with progress
    var sc = d.score || {};
    var overall = sc.overall || d.design_score || 0;
    var scoreColor = overall >= 70 ? '#10B981' : overall >= 50 ? '#F59E0B' : '#EF4444';
    var prog = d.progress || {};
    var delta = prog.delta || 0;
    var trend = prog.trend || 'flat';
    var trendArrow = trend === 'up' ? '\u2191' : trend === 'down' ? '\u2193' : '\u2192';
    var trendColor = trend === 'up' ? '#10B981' : trend === 'down' ? '#EF4444' : '#6B7280';
    var deltaText = delta > 0 ? '+' + delta : delta < 0 ? '' + delta : '\u00B10';

    html += '<div style="text-align:center;padding:6px 0 10px;border-bottom:1px solid rgba(255,255,255,.06)">'
      + '<div style="font-size:10px;color:var(--t2);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px">Growth Score</div>'
      + '<div style="display:flex;align-items:baseline;justify-content:center;gap:8px">'
      + '<span style="font-size:28px;font-weight:800;color:' + scoreColor + '">' + overall + '<span style="font-size:14px;font-weight:400;color:var(--t2)">/100</span></span>';

    // Show delta badge only if there's history
    if (delta !== 0 || (d.history && d.history.length > 1)) {
      html += '<span style="font-size:13px;font-weight:700;color:' + trendColor + ';background:' + trendColor + '15;padding:2px 6px;border-radius:4px">' + deltaText + ' ' + trendArrow + '</span>';
    }
    html += '</div>';

    // Before / After comparison
    var ba = d.before_after || {};
    if (ba.before && ba.after && ba.delta) {
      var baColor = ba.delta > 0 ? '#10B981' : '#EF4444';
      var baSign = ba.delta > 0 ? '+' : '';
      html += '<div style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:8px;padding:6px 10px;background:' + baColor + '10;border-radius:8px;border:1px solid ' + baColor + '20">'
        + '<span style="font-size:11px;color:var(--t2)">Before</span>'
        + '<span style="font-size:14px;font-weight:700;color:var(--t2)">' + ba.before + '</span>'
        + '<span style="font-size:10px;color:var(--t2)">\u2192</span>'
