function bldApplyProps(si, ci, mi) {
  const cmp  = bldCurrentPage.sections[si]?.containers?.[ci]?.components?.[mi];
  if (!cmp) return;
  // PATCH 6C: Dual-key type read — same fix as bldShowComponentProps.
  const type    = cmp.component_type || cmp.type;
  const content = Object.assign({}, cmp.content || {});
  const styles  = Object.assign({}, cmp.styles  || {});
  const val     = id => document.getElementById(id)?.value ?? '';

  switch(type) {
    case 'heading':    content.text = val('bld-prop-heading-text'); content.level = parseInt(val('bld-prop-heading-level')); break;
    case 'text':       content.text = val('bld-prop-text-content'); break;
    case 'button':     content.label = val('bld-prop-btn-label'); content.href = val('bld-prop-btn-href'); content.variant = val('bld-prop-btn-variant'); break;
    case 'image':      content.src = val('bld-prop-img-src'); content.alt = val('bld-prop-img-alt'); content.link = val('bld-prop-img-link'); break;
    case 'spacer':     content.height = val('bld-prop-spacer-h'); break;
    case 'html':       content.code = val('bld-prop-html-code'); break;
    case 'cta':        content.heading = val('bld-prop-cta-h'); content.subtext = val('bld-prop-cta-sub'); break;
    case 'testimonial':content.quote = val('bld-prop-tes-q'); content.author = val('bld-prop-tes-a'); content.role = val('bld-prop-tes-r'); break;
  }

  // PATCH 6C: Write all style fields (expanded from 5 → 11 controls).
  // Only write non-empty values to avoid clearing AI-set styles that have no UI field yet.
  const _sv = (key, id) => { const v = val(id); if (v !== '') styles[key] = v; };
  _sv('text_align',     'bld-prop-style-ta');
  _sv('padding',        'bld-prop-style-pad');
  _sv('color',          'bld-prop-style-col');
  _sv('bg',             'bld-prop-style-bg');
  _sv('border_radius',  'bld-prop-style-br');
  _sv('font_size',      'bld-prop-style-fs');
  _sv('font_weight',    'bld-prop-style-fw');
  _sv('font_family',    'bld-prop-style-ff');
  _sv('shadow',         'bld-prop-style-sh');
  _sv('line_height',    'bld-prop-style-lh');
  _sv('letter_spacing', 'bld-prop-style-ls');
  _sv('opacity',        'bld-prop-style-op');

  cmp.content = content;
  cmp.styles  = styles;
  // PATCH 6C: Also write back to legacy root-level content fields so Arthur queries still work.
  const ARTHUR_CONTENT_KEYS = ['text','src','href','variant','alt','label','tag','level'];
  ARTHUR_CONTENT_KEYS.forEach(function(k) { if (content[k] !== undefined) cmp[k] = content[k]; });

  bldDirty    = true;
  bldRenderCanvas();
  // PATCH 6C: Refresh property panel after apply so values reflect saved state (was stale before).
  // Refresh panel — always use new Elementor panel regardless of path
  try { _epActiveTab = 0; _bldRenderProps(si, ci); } catch(e) {}

  // Persist to API if component has an ID
  if (cmp.id) {
    _bldSafeFetch(bldApi+'components/'+cmp.id,{method:'PUT',headers:{'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'},body:JSON.stringify({content,styles})}).catch(()=>{});
  }
}

function bldApplySectionProps(si) {
  const sec = bldCurrentPage.sections[si];
  if (!sec) return;
  const val = id => document.getElementById(id)?.value ?? '';
