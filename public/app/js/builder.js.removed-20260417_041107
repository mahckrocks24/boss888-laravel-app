  overlay.style.cssText = 'position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;animation:luFadeIn .15s ease';
  overlay.innerHTML = '<div class="lu-modal" style="background:var(--s1);border:1px solid var(--bd);border-radius:14px;padding:24px;min-width:340px;max-width:460px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.5);animation:luSlideUp .2s ease">' + html + '</div>';
  document.body.appendChild(overlay);
  // Add animations if not present
  if (!document.getElementById('lu-modal-css')) {
    var s = document.createElement('style');
    s.id = 'lu-modal-css';
    s.textContent = '@keyframes luFadeIn{from{opacity:0}to{opacity:1}}@keyframes luSlideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}';
    document.head.appendChild(s);
  }
  return overlay;
}

function luAlert(msg, title) {
  return new Promise(function(resolve) {
    var html = '';
    if (title) html += '<div style="font-family:var(--fh);font-size:16px;font-weight:700;color:var(--t1);margin-bottom:8px">' + bld_escH(title) + '</div>';
    html += '<div style="font-size:13px;color:var(--t2);line-height:1.6;margin-bottom:20px">' + bld_escH(msg) + '</div>';
    html += '<div style="display:flex;justify-content:flex-end"><button id="lu-modal-ok" style="background:var(--p);border:none;color:#fff;border-radius:8px;padding:8px 24px;font-size:13px;font-weight:600;cursor:pointer">OK</button></div>';
    var overlay = _luModal(html);
    var btn = overlay.querySelector('#lu-modal-ok');
    btn.focus();
    btn.onclick = function() { overlay.remove(); resolve(); };
    overlay.addEventListener('click', function(e) { if (e.target === overlay) { overlay.remove(); resolve(); } });
  });
}

function luConfirm(msg, title, confirmLabel, cancelLabel) {
  return new Promise(function(resolve) {
    var html = '';
    if (title) html += '<div style="font-family:var(--fh);font-size:16px;font-weight:700;color:var(--t1);margin-bottom:8px">' + bld_escH(title) + '</div>';
