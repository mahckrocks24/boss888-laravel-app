function bldToggleAI() {
  const panel = document.getElementById('bld-ai-panel');
  const isVisible = panel.style.display === 'flex';
  panel.style.display = isVisible ? 'none' : 'flex';
  document.getElementById('bld-ai-toggle').style.background = isVisible ? 'transparent' : 'var(--pu)';
