// ── OPEN EDITOR ───────────────────────────────────────────────────────
_bldPageSource = 'standalone'; // 'standalone' or 'lubld'
async function bldOpenEditor(pageId, source) {
  bldCurrentPageId = pageId;
  _bldPageSource = source || 'standalone';
  // Sanitize on editor open in case data came from AI
  if (bldCurrentPage && bldCurrentPage.sections) bldCurrentPage.sections = _bldSanitizeSections(bldCurrentPage.sections);
  document.getElementById('bld-list-state').style.display   = 'none';
  document.getElementById('bld-editor-state').style.display = 'flex';
  await bldLoadEditorPage();
  bldLoadLibrary();
  bldLeftTab('blocks');
  _bldEnforceSourceUI();
}

// Disable lubld-dependent features for standalone pages
function _bldEnforceSourceUI() {
  const isStandalone = _bldPageSource === 'standalone' || !window.LU_LUBLD_AVAILABLE;
  const pubBtn = document.getElementById('bld-publish-btn');
  const aiBtn = document.getElementById('bld-ai-toggle');

  if (pubBtn) {
    if (isStandalone) {
      pubBtn.disabled = true;
      pubBtn.style.opacity = '.4';
      pubBtn.style.cursor = 'default';
      pubBtn.title = 'Publishing available in upcoming update';
      pubBtn.onclick = () => showToast('Publishing for standalone pages coming soon.', 'info');
    } else {
      pubBtn.disabled = false;
      pubBtn.style.opacity = '';
      pubBtn.style.cursor = '';
      pubBtn.onclick = bldPublish;
    }
  }
  if (aiBtn) {
    if (isStandalone) {
      aiBtn.disabled = true;
      aiBtn.style.opacity = '.4';
      aiBtn.title = 'AI assistant available in upcoming update';
      aiBtn.onclick = () => showToast('AI builder assistant coming soon.', 'info');
    } else {
      aiBtn.disabled = false;
      aiBtn.style.opacity = '';
      aiBtn.onclick = bldToggleAI;
    }
  }
}

async function bldLoadEditorPage() {
  try {
    let data;
    if (_bldPageSource === 'standalone') {
      // Use core builder endpoint
      const r = await fetch(API+'builder/load/'+bldCurrentPageId, {headers:{'Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'}});
      data = await r.json();
      // Normalize into builder state format — NO page_json shadow copy
      bldCurrentPage = {
        id: data.id,
        title: data.title || 'Untitled',
        slug: data.slug || '',
        status: data.status || 'draft',
        sections: data.sections || (data.page_json?.sections) || [],
        theme: data.theme || {},
        _source: 'standalone',
      };
      // PHASE 6: Check sessionStorage for a more recent unsaved state
      // (e.g. user refreshed mid-edit before autosave fired)
      var recovered = _bldSessionRecover(bldCurrentPageId, data.updated_at);
      if (recovered) {
        bldCurrentPage.sections = recovered.sections || bldCurrentPage.sections;
        bldCurrentPage.theme    = recovered.theme    || bldCurrentPage.theme;
        bldDirty = true; // mark dirty so next autosave persists the recovered state
        showToast('✓ Restored your last unsaved changes', 'success');
        console.log('[BLD Recovery] Session snapshot restored for page', bldCurrentPageId);
      }
      // R1 FIX: Inject wizard context from wsCurrentSite into bldCurrentPage.
      // wsCurrentSite.arthur_context is populated by the PHP websites list endpoint
      // from lu_websites.config. This makes core_service/tone/audience available
      // to _bldGetAIContext() and therefore to every Arthur AI call.
      if (wsCurrentSite && wsCurrentSite.arthur_context) {
        bldCurrentPage.arthur_context = wsCurrentSite.arthur_context;
      } else {
        bldCurrentPage.arthur_context = {};
      }
      console.log('[BLD Load] Standalone page loaded:', bldCurrentPage.id, 'sections:', bldCurrentPage.sections.length);
      // Sanitize loaded sections (may contain AI-generated data)
      if (bldCurrentPage.sections) bldCurrentPage.sections = _bldSanitizeSections(bldCurrentPage.sections);
    } else {
      // Legacy lubld fallback
      const r = await _bldSafeFetch(bldApi+'pages/'+bldCurrentPageId+'/full',{headers:{'Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'}});
      bldCurrentPage = await r.json();
      bldCurrentPage._source = 'lubld';
    }
    document.getElementById('bld-page-title-label').textContent = bldCurrentPage.title;
    const badge = document.getElementById('bld-page-status-badge');
    badge.textContent = bldCurrentPage.status;
    badge.style.background = bldCurrentPage.status === 'published' ? 'rgba(16,185,129,.15)' : 'rgba(245,158,11,.15)';
    badge.style.color       = bldCurrentPage.status === 'published' ? '#10B981' : 'var(--am)';
    bldRenderCanvas();
    bldRenderLayers();
  } catch(e) { console.error('bldLoadEditorPage',e); }
}

async function bldExitEditor() {
  if (bldDirty) { var ok = await luConfirm('You have unsaved changes that will be lost.', 'Unsaved Changes', 'Exit Anyway', 'Stay'); if (!ok) return; }
  bldCurrentPageId = null;
  bldCurrentPage   = null;
  bldDirty         = false;
  bldSelectedComp  = null;
  _bldSessionClear(); // PHASE 6: clear recovery store on clean exit
  bld_arthurHidePanel();
  arthurHide();
  document.getElementById('bld-editor-state').style.display = 'none';

  // Always restore back button label
  var backBtn = document.getElementById('bld-back-btn');
  if (backBtn) backBtn.textContent = '\u2190 Pages';

  // If we came from a website, go back to website pages
  if (window._wsReturnToSite) {
    var siteId = window._wsReturnToSite;
    window._wsReturnToSite = null;
    // Hide view-builder entirely, show view-websites
    document.getElementById('view-builder').style.display = 'none';
    document.getElementById('bld-list-state').style.display = 'none';
    nav('websites');
    setTimeout(function() { wsOpenSite(siteId); }, 50);
    return;
  }

  // Otherwise go back to landing pages list
  document.getElementById('bld-list-state').style.display = 'block';
  bldLoadPages();
}

// ── CANVAS RENDER ─────────────────────────────────────────────────────
function bldRenderCanvas() {
  const canvas = document.getElementById('bld-canvas');
  if (!canvas) return;
  if (!bldCurrentPage) { canvas.innerHTML = '<div style="padding:60px;text-align:center;color:var(--t3)">No page loaded.</div>'; return; }
  // Sanitize sections before render to prevent crashes from AI data
  if (bldCurrentPage.sections) bldCurrentPage.sections = _bldSanitizeSections(bldCurrentPage.sections);
  console.log('[BLD RENDER] Canvas: ' + (bldCurrentPage.sections||[]).length + ' sections, source=' + (bldCurrentPage._source||'?'));

  // PHASE 4: Debounced autosave — fires 2s after any canvas change
  if (bldDirty && bldCurrentPageId) {
    clearTimeout(window._bldAutoSaveTimer);
    window._bldAutoSaveTimer = setTimeout(function() {
      if (bldDirty && bldCurrentPageId) {
        _bldAutoSave();
      }
    }, 2000);
  }

  const widths = {desktop:'100%', tablet:'768px', mobile:'375px'};
  canvas.style.maxWidth = widths[bldDevice];
  canvas.style.overflow = 'auto'; // ensure content is visible

  const isStandalone = bldCurrentPage._source === 'standalone' || _bldPageSource === 'standalone';
  const sections = bldCurrentPage.sections;

  // ── STANDALONE PATH ────────────────────────────────────────────────
  if (isStandalone) {
    try {
      _bldRenderStandalone(canvas, sections);
    } catch(err) {
      console.error('[BLD RENDER ERROR]', err);
      canvas.innerHTML = '<div style="padding:40px;color:#F87171;font-size:14px"><strong>Render Error:</strong> ' + bld_esc(err.message) + '<br><br><button onclick="bldRenderCanvas()" style="background:var(--p);color:#fff;border:none;padding:8px 16px;border-radius:6px;cursor:pointer">Retry</button></div>';
    }
    if (typeof _bldInitCanvasDrag === 'function') _bldInitCanvasDrag();
    return;
  }

  // ── LEGACY LUBLD PATH ──────────────────────────────────────────────
  if ((!sections || !sections.length) && bldCurrentPage.page_json) {
    let bp = bldCurrentPage.page_json;
    if (typeof bp === 'string') try { bp = JSON.parse(bp); } catch(e) { bp = null; }
    if (bp?.sections?.length) { canvas.innerHTML = _bldRenderBlueprintPreview(bp, bldCurrentPage.title); return; }
  }
  if (!sections || !sections.length) {
    canvas.innerHTML = '<div style="padding:80px;text-align:center;color:var(--t3)"><div style="font-size:32px;margin-bottom:12px">+</div><div>Add your first section</div></div>';
    return;
  }
  const theme = bldCurrentPage.theme?.tokens || {};
  let html = bldBuildThemeCssVars(theme) + bldBuildCanvasBaseStyles();
  sections.forEach((sec, si) => { html += bldRenderCanvasSection(sec, si, theme); });
  html += '<div style="padding:24px;text-align:center"><button onclick="bldAddSection()" style="background:transparent;border:1.5px dashed rgba(108,92,231,.4);color:var(--pu);border-radius:8px;padding:10px 24px;font-size:13px;cursor:pointer">+ Add Section</button></div>';
  canvas.innerHTML = html;
}

// ═══════════════════════════════════════════════════════════════════════════
