async function bld_arthurSendCommand(){
  if(!arthurContext||arthurBusy) return;
  const inp=document.getElementById('arthur-input');
  const command=inp.value.trim(); if(!command) return;
  arthurBusy=true;
  onArthurStart(); // Phase 6: enable glow
  const busyEl=document.getElementById('arthur-busy');
  const resEl=document.getElementById('arthur-result');
  const sendBtn=document.getElementById('arthur-send');
  busyEl.classList.add('visible'); resEl.classList.remove('visible');
  if(sendBtn) sendBtn.disabled=true;
  const instruction=`You are Arthur, the LevelUp AI builder assistant inside LevelUp Growth Platform. The user selected a "${arthurContext.type}" element with content: ${JSON.stringify(arthurContext.content)}. Business: ${BN} (${BU}). Request: "${command}". Return ONLY a raw JSON object — the updated content. No markdown, no explanation. Match the existing content structure. For heading/text: {"text":"..."}. For button: {"label":"...","href":"#","variant":"primary"}. For testimonial: {"quote":"...","author":"...","role":"..."}.`;
  try{
    const r=await fetch(API+'assistant',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||'')},
      body:JSON.stringify({message:command,context:'builder_arthur_element',history:[],system_override:instruction,builder_context:{element_type:arthurContext.type,existing_content:arthurContext.content,site_name:BN,task:'builder_element_edit'}})});
    const d=await r.json();
    let newContent=null;
    const raw=(d.reply||d.message||d.content||'').replace(/```json|```/g,'').trim();
    if(raw.startsWith('{')) try{newContent=JSON.parse(raw);}catch(e){}
    if(!newContent&&(arthurContext.type==='heading'||arthurContext.type==='text')) newContent={text:raw.slice(0,500)};
    if(newContent){
      // PATCH B: dual-path resolution — try containers path first (lubld), fall back to flat
      // components[] (standalone/wizard). Silent fail on containers-only was the original bug.
      var cmp = bldCurrentPage?.sections?.[arthurContext.si]?.containers?.[arthurContext.ci]?.components?.[arthurContext.mi];
      if(!cmp) cmp = bldCurrentPage?.sections?.[arthurContext.si]?.components?.[arthurContext.ci];
      if(cmp){
        Object.assign(cmp.content=cmp.content||{},newContent);
        // Also sync root-level keys so Arthur queries and standalone renderer both see values
        const CONTENT_KEYS = ['text','label','href','src','alt','variant','quote','author','role'];
        CONTENT_KEYS.forEach(function(k){ if(newContent[k]!==undefined) cmp[k]=newContent[k]; });
        bldDirty=true; bldRenderCanvas();
        // PATCH B: refresh new Elementor panel, never legacy bldShowComponentProps
        _epActiveTab = 0;
        _bldRenderProps(arthurContext.si, arthurContext.ci);
        resEl.innerHTML='<strong style="color:var(--ac)">✓ Applied.</strong> Canvas updated.';
      }
    } else {
      resEl.innerHTML=`<div style="background:var(--s2);border-radius:6px;padding:8px;margin-bottom:6px;font-size:11px;line-height:1.5">${bld_escH(raw.slice(0,300))}</div><button onclick="arthurApplyManual(${arthurContext.si},${arthurContext.ci},${arthurContext.mi},this)" style="background:var(--p);border:none;border-radius:5px;color:#fff;padding:4px 10px;font-size:11px;cursor:pointer" data-reply="${raw.replace(/"/g,"'")}">Apply as text</button>`;
    }
    resEl.classList.add('visible'); inp.value='';
  }catch(e){resEl.innerHTML=`<span style="color:#F87171">Error: ${bld_escH(e.message)}</span>`;resEl.classList.add('visible');}
  busyEl.classList.remove('visible');
  if(sendBtn) sendBtn.disabled=false;
  arthurBusy=false;
  onArthurFinish(); // Phase 6: disable glow
}

function arthurApplyManual(si,ci,mi,btn){
  const reply=btn.dataset.reply||'';
  // PATCH C: dual-path resolution — containers (lubld) first, flat components[] fallback (standalone)
  var cmp = bldCurrentPage?.sections?.[si]?.containers?.[ci]?.components?.[mi];
  if(!cmp) cmp = bldCurrentPage?.sections?.[si]?.components?.[ci];
  if(!cmp||!reply) return;
  if(!cmp.content) cmp.content={};
  // PATCH C: dual-key type — AI components have cmp.type only
  const cmpType = cmp.component_type || cmp.type || 'text';
  if(cmpType==='heading'||cmpType==='text'){
    cmp.content.text=reply.slice(0,500);
    cmp.text=cmp.content.text; // sync root key for standalone renderer
  } else if(cmpType==='button'){
    cmp.content.label=reply.slice(0,80);
    cmp.text=cmp.content.label;
  } else {
    cmp.content.text=reply.slice(0,500);
    cmp.text=cmp.content.text;
  }
  bldDirty=true; bldRenderCanvas();
  // PATCH C: refresh new Elementor panel, never legacy bldShowComponentProps
  _epActiveTab = 0;
  _bldRenderProps(si, ci);
  const r=document.getElementById('arthur-result');
  if(r) r.innerHTML='<strong style="color:var(--ac)">✓ Applied.</strong>';
  onArthurFinish(); // Phase 6: ensure glow cleared after manual apply
}

