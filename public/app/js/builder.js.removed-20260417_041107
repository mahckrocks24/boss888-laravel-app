async function _bldFetchWorkspaceContext() {
  if (_wsContext && (Date.now() - _wsContextTs < 120000)) return _wsContext;
  try {
    var r = await fetch(API + 'workspace/context', {headers:{'Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'}});
    if (r.ok) {
      _wsContext = await r.json();
      _wsContextTs = Date.now();
    }
  } catch(e) { console.log('[WS] Context fetch failed:', e.message); }
  return _wsContext;
}

// ── Data Cache ───────────────────────────────────────────────────────────
var _dynDataCache = {};
var _dynDataLoading = {};

async function _bldFetchDynamicData(blockType) {
  var cacheKey = blockType;
  var cached = _dynDataCache[cacheKey];
  if (cached && (Date.now() - cached.ts < 180000)) return cached.data; // 3min TTL
  if (_dynDataLoading[cacheKey]) return cached ? cached.data : null; // prevent duplicate calls
  _dynDataLoading[cacheKey] = true;

  var data = null;
  var ctx = _bldGetContext();
  try {
    switch (blockType) {
      case 'review_feed':
        try { var r1 = await fetch(API + 'reviews', {headers:{'Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'}});
          if (r1.ok) data = await r1.json(); }
        catch(e) {} break;

      case 'blog_list':
        try { var r2 = await Promise.resolve(new Response(JSON.stringify([]))); // WP posts disabled
          if (r2.ok) {
            var posts = await r2.json();
            data = Array.isArray(posts) ? posts.map(function(p) {
              return { id:p.id, title:p.title?p.title.rendered:'', excerpt:p.excerpt?p.excerpt.rendered.replace(/<[^>]+>/g,'').slice(0,120):'', link:p.link||'', date:p.date||'', image:(p._embedded&&p._embedded['wp:featuredmedia']&&p._embedded['wp:featuredmedia'][0])?p._embedded['wp:featuredmedia'][0].source_url:'' };
            }) : [];
          }
        } catch(e) {} break;

      case 'product_grid':
      case 'property_list':
        try { var r3 = await fetch(API + 'listings?type=' + blockType + '&workspace_id=' + ctx.workspaceId, {headers:{'Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'}});
          if (r3.ok) data = await r3.json(); }
        catch(e) {} break;

      case 'seo_local':
        try { data = await _bldFetchWorkspaceContext(); }
        catch(e) {} break;

      case 'booking_widget':
        try { var events = await LuAPI.cal.getEvents();
          var bookings = await LuAPI.cal.getBookings();
          data = { events: Array.isArray(events)?events:[], bookings: Array.isArray(bookings)?bookings:[] }; }
        catch(e) {} break;

      case 'social_feed':
        try { var posts2 = await LuAPI.social.getPosts();
          data = Array.isArray(posts2) ? posts2 : []; }
        catch(e) {} break;
    }
  } catch(e) { console.log('[DYN] Fetch error for ' + blockType + ':', e.message); }

  _dynDataCache[cacheKey] = { data: data, ts: Date.now() };
  _dynDataLoading[cacheKey] = false;
  return data;
}

// Sync resolver — returns cached data immediately, fires async prefetch
function _bldGetDynData(blockType) {
  var cached = _dynDataCache[blockType];
  if (cached && cached.data !== undefined) return cached.data;
  _bldFetchDynamicData(blockType); // fire-and-forget
  return null;
}

// Prefetch workspace context + commonly used data on first builder open
var _dynPrefetched = false;
function _bldPrefetchDynamic() {
  if (_dynPrefetched) return;
  _dynPrefetched = true;
  _bldFetchWorkspaceContext();
  // Pre-warm blog data since it's commonly used
  _bldFetchDynamicData('blog_list');
}

