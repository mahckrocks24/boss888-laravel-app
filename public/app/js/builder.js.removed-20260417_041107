// ── GLOBAL NAVIGATION HANDLER ────────────────────────────────────────────────
// __nav is called from onclick attributes in both editor canvas and preview iframe.
// In the editor it switches the builder to the target page.
// In the preview iframe it falls through to the iframe's own __renderPage router.
window.__nav = function(slug) {
  if (!slug) return;
  // Normalize: strip leading slash
  slug = slug.replace(/^\/+/, '').toLowerCase();
  // If inside preview iframe, call parent nav
  if (window !== window.top) {
    try {
      if (typeof window.top.__nav === 'function') {
        // We are in the iframe — let the iframe handle it locally (its own __renderPage)
        // This path is overridden by the embedded __nav in the iframe, so it won't run.
      }
    } catch(e) {}
    return;
  }
  // Editor context: load the page in the builder
  var pages = (wsCurrentSite && wsCurrentSite.pages) || _bldWebsitePages || [];
  var found = null;
  for (var i = 0; i < pages.length; i++) {
    var p = pages[i];
    var pslug = (p.slug || '').replace(/^\/+/, '').toLowerCase();
    if (pslug === slug || pslug === slug + '/' || p.page_type === slug) { found = p; break; }
  }
  if (!found) {
    console.warn('[NAV] Page not found for slug:', slug, '— available:', pages.map(function(p){return p.slug;}));
    return;
  }
  if (typeof wsEditSitePage === 'function') wsEditSitePage(found.id);
};

// ── PART 3: Strict state engine ──────────────────────────────────────
window._arthurState = {
  business_name: null, industry: null, core_service: null,
  location: null, tone: null, audience: null,
  custom_pages: null, page_count: null, design_style: null,
  style: { primary_color: null, secondary_color: null, design_style: null },
  ready: false,
  _confidence: {}, // tracks confidence level per field
};
var _arthurConvo = [];

// ── PART 6: Loop guard counters ───────────────────────────────────────
var _arthurTurnsWithoutProgress = 0;
var _arthurMaxStallTurns = 3;
var _arthurWizRetryCount = 0;
var _arthurMaxRetries = 2;

// ── PART 1: WIZARD INTERPRETER — deterministic extraction before AI ───
// Returns { detected:{}, confidence:'high'|'medium'|'low', filled:[] }
function _arthurWizInterpretInput(text) {
  var detected = {};
  var filled   = [];
  var lc       = text.toLowerCase().trim();

  // ── PART 3: Negative guards — never extract business name from these ──
  var BANNED_STARTS = [
    /^i\s+need/i, /^i\s+want/i, /^we\s+are/i, /^we\s+do/i,
    /^we\s+offer/i, /^we\s+provide/i, /^my\s+name\s+is/i,
    /^our\s+company/i, /^based\s+in/i, /^located\s+in/i,
    /^i'?m\s+build/i, /^create\s+a\s+web/i, /^build\s+a\s+web/i,
    /^i\s+have\s+a/i, /^i\s+run\s+a/i, /^hi\b/i, /^hello\b/i,
    /^can\s+you/i, /^please/i, /^just/i,
  ];
  var startsWithBanned = BANNED_STARTS.some(function(p) { return p.test(lc); });

  // ── PART 2: STRICT business name patterns only ─────────────────────
  var ENTITY_RE = /\b(?:LLC|Ltd|Inc|Co\.|Company|Agency|Studio|Clinic|Bakery|Properties|Interiors|Contracting|Marketing|Media|Technologies|Solutions|Services|Group|Holdings|Ventures|Consulting|Design|Creative|Digital|Fitness|Dental|Legal|Finance|Academy|Institute)\b/i;
  var m = null;

  // P0: "Name — description" or "Name: description" — company name before em-dash/en-dash/colon
  var emDashM = text.match(/^([A-Z][A-Za-z0-9 &'.\-]{2,40}?)\s*[—–]\s/);
  if (!emDashM) emDashM = text.match(/^([A-Z][A-Za-z0-9 &'.\-]{2,40}?)\s*:\s+(?:a\s+|an\s+|the\s+)?[a-z]/);
  if (emDashM && emDashM[1]) {
    var emCand = emDashM[1].trim().replace(/[,.\s]+$/, '');
    if (_arthurIsValidBusinessName && _arthurIsValidBusinessName(emCand)) m = emDashM;
  }

  // P1: "for <n>" — always runs even if sentence starts with "build/create a website for"
  if (!m) m = text.match(/\bfor\s+([A-Z][A-Za-z0-9 &'.\-]{1,40}?)(?:\s*[,.]|\s+(?:a\s+|an\s+|the\s+|is\s+|are\s+|based|located|in\b|we\b|they\b)|$)/);

  if (!m && !startsWithBanned) {
    // P2: "called <n>"
    m = text.match(/\bcalled\s+([A-Z][A-Za-z0-9 &'.\-]{2,40}?)(?:[,.\s]|$)/i);
  }
  if (!m && !startsWithBanned) {
    // P3: "named <n>"
    m = text.match(/\bnamed\s+([A-Z][A-Za-z0-9 &'.\-]{2,40}?)(?:[,.\s]|$)/i);
  }
  if (!m) {
    // P4: "business/company name is <n>" — always valid
    m = text.match(/(?:business|company|brand)\s+name\s+is\s+([A-Z][A-Za-z0-9 &'.\-]{2,40}?)(?:[,.\s]|$)/i);
  }
  if (!m) {
    // P5: Quoted names
    m = text.match(/[\u201c\u201d"'\u2018\u2019]([A-Z][A-Za-z0-9 &'.\-]{2,40})[\u201c\u201d"'\u2018\u2019]/);
    if (!m) m = text.match(/\"([A-Z][A-Za-z0-9 &'.\-]{2,40})\"/);
  }
  if (!m && !startsWithBanned) {
    // P6: Name before comma with entity suffix
    var commaNameM = text.match(/^([A-Z][A-Za-z0-9 &'.\-]{2,40}),\s/);
    if (commaNameM && ENTITY_RE.test(commaNameM[1])) m = commaNameM;
  }
  if (!m && !startsWithBanned) {
    // P7: Multi-word phrase with entity suffix (NOT bare CamelCase without suffix)
    var entityM = text.match(/\b([A-Z][A-Za-z0-9]{2,20}(?:\s+[A-Z][A-Za-z0-9 &]{1,30})+)\b/);
    if (entityM && ENTITY_RE.test(entityM[1])) m = entityM;
    // Single CamelCase (e.g. ApexDental) only if word itself contains entity keyword
    if (!m) {
      var camelM = text.match(/^([A-Z][a-z]+[A-Z][a-z]+(?:[A-Z][a-z]+)*)\s*$/);
      if (camelM && ENTITY_RE.test(camelM[1])) m = camelM;
    }
  }

  if (m && m[1]) {
    var candidate = m[1].trim().replace(/[,.\s]+$/, '');
    if (_arthurIsValidBusinessName(candidate)) {
      detected.business_name = candidate;
      filled.push('business_name');
    }
  }

  // ── Industry patterns ─────────────────────────────────────────────────
  var industries = {
    'real estate':    ['real estate','property','properties','realty','realtor'],
    'construction':   ['construction','building contractor','renovation','fitout','fit-out'],
    'dental':         ['dental','dentist','orthodon'],
    'medical':        ['medical','clinic','doctor','healthcare','physician'],
    'restaurant':     ['restaurant','cafe','catering','bakery','bistro'],
    'hotel':          ['hotel','hospitality','resort','accommodation','lodging'],
    'fitness':        ['fitness','gym','personal trainer','yoga','pilates','workout'],
    'legal':          ['law firm','legal','lawyer','attorney','solicitor'],
    'technology':     ['software','saas','it company','developer'],
    'marketing':      ['marketing agency','advertising','branding','pr firm'],
    'education':      ['school','university','tutoring','training academy','coaching'],
    'retail':         ['retail store','e-commerce','ecommerce','clothing store','fashion'],
    'finance':        ['finance','accounting firm','insurance','investment','wealth management'],
    'cleaning':       ['cleaning','janitorial','housekeeping'],
    'salon':          ['salon','beauty salon','hair salon','spa','barber'],
  };
  for (var ind in industries) {
    var kws = industries[ind];
    for (var j = 0; j < kws.length; j++) {
      if (lc.includes(kws[j])) {
        detected.industry = ind;
        filled.push('industry');
        break;
      }
    }
    if (detected.industry) break;
  }

  // ── Service / core_service patterns ──────────────────────────────────
  var svcM = text.match(/(?:(?:we\s+)?(?:offer|provide|sell|specialize\s+in|focus\s+on|our\s+specialty\s+is|our\s+speciality\s+is)\s+)([a-zA-Z][a-zA-Z ,&\/\-]{3,80}?)(?=\s+(?:target|for\s+|across\s+|serving|aimed|to\s+[a-z]+\s+client)|[.,]|$)/i);
  if (!svcM) svcM = text.match(/(?:our\s+(?:main\s+)?(?:service|product|specialty|speciality)\s+is\s+)([a-zA-Z][a-zA-Z ,&\/\-]{3,80}?)(?=\s+(?:target|for\s+|across\s+)|[.,]|$)/i);
  if (svcM && svcM[1]) {
    var svc = svcM[1].trim().replace(/[.,]+$/, '').replace(/\s+and\s*$/, '');
    var genericWords = /^(?:everything|stuff|various|services|things|many|much|more|a\s+lot)$/i;
    // Allow up to 10 words for detailed service descriptions
    if (svc.split(' ').length <= 10 && !genericWords.test(svc.trim())) {
      detected.core_service = svc;
      filled.push('core_service');
    }
  }

  // ── Location patterns ─────────────────────────────────────────────────
  var locM = text.match(/(?:(?:based|located|operating)\s+(?:in|at)\s+)([A-Z][A-Za-z]+(?: [A-Za-z]+)?)/i);
  if (!locM) locM = text.match(/(?:location\s*[:=]\s*)([A-Z][A-Za-z ,\-]{2,40})/i);
  // Explicit city append: "in Dubai", "in Abu Dhabi", "in Riyadh" — 2 words max
  if (!locM) {
    var cityM = text.match(/\bin\s+([A-Z][a-z]+(?:\s+[A-Z][a-z]+)?)\b/);
    if (cityM) {
      var notLoc = ['The','Our','We','It','This','That','Your','For','And','But','My','A','An'];
      if (!notLoc.includes(cityM[1].split(' ')[0])) locM = cityM;
    }
  }
  if (locM && locM[1]) {
    var notLoc2 = ['My','The','Our','We','It','This','That','Your','For','And','But'];
    if (!notLoc2.includes(locM[1].split(' ')[0])) {
      detected.location = locM[1].trim();
      filled.push('location');
    }
  }

  // ── Color patterns ────────────────────────────────────────────────────
  var colorKws = {
    blue:'#3b82f6',red:'#ef4444',green:'#22c55e',purple:'#a855f7',
    gold:'#f59e0b',orange:'#f97316',black:'#000000',white:'#ffffff',
    teal:'#14b8a6',navy:'#1e3a5f',pink:'#ec4899',indigo:'#6366f1',
  };
  var colM = text.match(/(?:color[s]?\s*(?:is|are|should be|:)?\s*|primary\s+color\s*[:=]?\s*)([a-z]+)/i);
  if (colM && colorKws[colM[1].toLowerCase()]) {
    detected.primary_color = colorKws[colM[1].toLowerCase()];
    filled.push('primary_color');
  }
  var hexM = text.match(/#([0-9a-fA-F]{6}|[0-9a-fA-F]{3})/);
  if (hexM && !detected.primary_color) {
    detected.primary_color = hexM[0];
    filled.push('primary_color');
  }

  // ── Tone extraction ─────────────────────────────────────────────────────
  var toneKws = {
    luxury:       ['luxury','luxurious','premium','high-end','high end','exclusive','sophisticated','elegant','upscale'],
    playful:      ['playful','fun','friendly','casual','lighthearted','cheerful','energetic'],
    professional: ['professional','corporate','formal','business-like','authoritative'],
    minimal:      ['minimal','minimalist','clean','simple','sleek'],
    bold:         ['bold','powerful','striking','dynamic','impactful'],
    warm:         ['warm','welcoming','approachable','caring','inviting'],
  };
  for (var tk in toneKws) {
    for (var ti = 0; ti < toneKws[tk].length; ti++) {
      if (lc.indexOf(toneKws[tk][ti]) !== -1) {
        detected.tone = tk;
        filled.push('tone');
        break;
      }
    }
    if (detected.tone) break;
  }

  // ── Audience extraction ──────────────────────────────────────────────────
  // ── Audience extraction — capture full list including "X, Y, and Z" ─────
  // Strategy: find the audience trigger word, then grab everything until a period
  // or a sentence-ending clause, respecting commas and "and"
  var audM = text.match(/(?:target(?:ing|ed)?|audience(?:\s+is)?|aimed?\s+at|serving|catering\s+to)\s+([a-zA-Z][a-zA-Z0-9,\s\-&']+?)(?:\s+(?:across|from|in|based|who\s+are|with\s+budgets?)\b|\.\s|\s*$)/i);
  if (audM && audM[1]) {
    var aud = audM[1].trim().replace(/\s+/g,' ').replace(/,\s*$/, '').replace(/\s+and\s*$/, '');
    var audSingle = /^(a|an|the|our|my|your)$/i;
    if (aud.length > 3 && aud.length <= 120 && !audSingle.test(aud)) {
      detected.audience = aud.slice(0, 80); // cap at 80 chars
      filled.push('audience');
    }
  }

  // ── Custom pages extraction ──────────────────────────────────────────────
  var pageCountM = text.match(/\b(\d+)\s+pages?\b/i);
  if (pageCountM) {
    detected.page_count = Math.min(parseInt(pageCountM[1]), 10);
    filled.push('page_count');
  }

  // Strategy A: explicit page list after "pages:", "I want X pages:" etc.
  var explicitListM = text.match(/(?:i want|i need|pages?:|including:?|pages? (?:are|include|:))\s*\d*\s*pages?[:\s]+([a-zA-Z][a-zA-Z0-9,\s\-]+?)(?:\.|$)/i);
  if (!explicitListM) {
    // Strategy B: "pages: home, about, ..." anywhere
    explicitListM = text.match(/pages?:\s*([a-zA-Z][a-zA-Z0-9,\s\-]+?)(?:\.|$)/i);
  }
  if (explicitListM && explicitListM[1]) {
    // Parse comma/space separated list, normalize to slugs
    var rawList = explicitListM[1];
    var parsedPages = rawList.split(/[\s,]+/)
      .map(function(p){ return p.toLowerCase().replace(/[^a-z0-9\-]/g,'').replace(/page$/,'').replace(/-+$/,''); })
      .filter(function(p){ return p.length >= 2 && p.length <= 30; });
    // Deduplicate
    var seen = {};
    parsedPages = parsedPages.filter(function(p){ if(seen[p]) return false; seen[p]=true; return true; });
    if (parsedPages.length >= 2) {
      detected.custom_pages = parsedPages;
      filled.push('custom_pages');
    }
  } else {
    // Strategy C: match only known page names from the whole text
    var knownPageNames = ['home','about','services','contact','pricing','portfolio','gallery','blog','faq','team','booking','careers','testimonials','case-studies','press'];
    var detectedPages = knownPageNames.filter(function(pg) {
      return new RegExp('\\b' + pg.replace(/-/g,'[\\s\\-]') + '\\b', 'i').test(lc);
    });
    if (detectedPages.length >= 2) {
      detected.custom_pages = detectedPages;
      filled.push('custom_pages');
    }
  }

  // ── Design style extraction ──────────────────────────────────────────────
  var styleKws = {
    dark:    ['dark mode','dark theme','dark design','dark website'],
    light:   ['light mode','light theme','clean white','bright design'],
    modern:  ['modern design','contemporary','fresh look'],
    classic: ['classic','traditional','timeless'],
  };
  for (var sk in styleKws) {
    for (var si2 = 0; si2 < styleKws[sk].length; si2++) {
      if (lc.indexOf(styleKws[sk][si2]) !== -1) {
        detected.design_style = sk;
        filled.push('design_style');
        break;
      }
    }
    if (detected.design_style) break;
  }

  // PART 6: Only count validated business_name as progress
  var validFilled = filled.filter(function(f) {
    if (f === 'business_name') return !!(detected.business_name && _arthurIsValidBusinessName(detected.business_name));
    return true;
  });

  var confidence = validFilled.length >= 2 ? 'high' : validFilled.length === 1 ? 'medium' : 'low';
  return { detected: detected, confidence: confidence, filled: filled, validFilled: validFilled };
}


// ── PART 4: Business name validator ─────────────────────────────────
var _arthurBannedNames = [
  /^i\s+(need|want|have|run|own)/i,
  /^we\s+(are|do|offer|provide|sell|need|want)/i,
  /^(my|our)\s+(name|company|business|brand)/i,
  /^(create|build|make|design|bld_get|have)\s+(a|an|the)?\s*web/i,
  /^(based|located|operating)\s+in/i,
  /^(hello|hi|hey)/i,
  /^(yes|no|ok|okay|sure|great)/i,
  /^(the|a|an)\s+/i,
  /^(dental|medical|legal|fitness|cleaning|marketing|technology|restaurant|hotel|salon|retail|finance)\s*$/i, // only an industry keyword
];
var _arthurBannedWords = ['website','site','page','help','build','create','want','need','looking'];

function _arthurIsValidBusinessName(val) {
  if (!val || typeof val !== 'string') return false;
  var v = val.trim();
  if (v.length < 2 || v.length > 60) return false;
  // Must start with uppercase letter
  if (!/^[A-Z]/.test(v)) return false;
  // Reject if matches banned pattern
  for (var i = 0; i < _arthurBannedNames.length; i++) {
    if (_arthurBannedNames[i].test(v)) return false;
  }
  // Reject if contains banned words (instruction-style text)
  var lv = v.toLowerCase();
  for (var j = 0; j < _arthurBannedWords.length; j++) {
    if (lv.split(/\s+/).indexOf(_arthurBannedWords[j]) > -1) return false;
  }
  // Reject if first word is a common pronoun/article
  var firstWord = v.split(/\s+/)[0].toLowerCase();
  var pronouns = ['i','we','my','our','the','a','an','it','this','that','for','in','at','on'];
  if (pronouns.indexOf(firstWord) > -1) return false;
  // Minimum: must contain at least one letter sequence (not just numbers/symbols)
  if (!/[a-zA-Z]{2}/.test(v)) return false;
  return true;
}

// ── PART 4: Hardened readiness check — business_name must pass validator ─
function _arthurCheckReady() {
  var S = window._arthurState;
  return !!(
    S.business_name && _arthurIsValidBusinessName(S.business_name) &&
    S.industry
  );
}

function _arthurMergeDetected(detected, confidence, source) {
  var S = window._arthurState;
  var updated = [];
  var confOrder = {none:0, low:1, medium:2, high:3};

  var simpleFields = ['business_name','industry','core_service','location','tone','audience','design_style'];
  simpleFields.forEach(function(key) {
    var val = detected[key];
    if (!val) return;
    var prev = S[key];
    var prevConf = S._confidence[key] || 'none';
    if (!prev || confOrder[confidence] >= confOrder[prevConf]) {
      S[key] = val;
      S._confidence[key] = confidence;
      updated.push(key);
    }
  });

  // primary_color lives inside S.style
  if (detected.primary_color) {
    var prev = S.style.primary_color;
    var prevConf = S._confidence['primary_color'] || 'none';
    if (!prev || confOrder[confidence] >= confOrder[prevConf]) {
      S.style.primary_color = detected.primary_color;
      S._confidence['primary_color'] = confidence;
      updated.push('primary_color');
    }
  }

  // design_style also mirrors into S.style
  if (detected.design_style && !S.style.design_style) {
    S.style.design_style = detected.design_style;
    S.design_style = detected.design_style;
    updated.push('design_style');
  }

  // custom_pages — array merge, deduplicate
  if (Array.isArray(detected.custom_pages) && detected.custom_pages.length >= 2) {
    S.custom_pages = detected.custom_pages;
    updated.push('custom_pages');
  }

  // page_count — only set if no custom_pages override
  if (detected.page_count && !S.custom_pages) {
    S.page_count = detected.page_count;
    updated.push('page_count');
  }

  return updated;
}

