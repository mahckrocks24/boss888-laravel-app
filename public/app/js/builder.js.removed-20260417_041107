        parts.push('<div style="margin:8px 0;padding-left:16px;' + selCss + extraCss + '"' + clk + '>');
        for (var li = 0; li < listItems.length; li++) {
          var item = typeof listItems[li] === 'string' ? listItems[li] : (listItems[li].text || listItems[li].label || '');
