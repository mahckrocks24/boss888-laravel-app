    var _p2Items = []; // extract cards items for section-level rendering
    var _p2Heading = '';
    var _p2Text = '';
    for (var _pi = 0; _pi < comps.length; _pi++) {
      if ((comps[_pi].type === 'cards' || comps[_pi].component_type === 'cards') && Array.isArray(comps[_pi].items || (comps[_pi].content && comps[_pi].content.items))) {
