      agGrid.innerHTML = agData.agents.map(ag => {
        const ongoing   = allTasks.filter(t => (t.agent_id || t.assignee) === ag.agent_id && (t.status === 'in_progress' || t.status === 'queued')).length;
        const done      = allTasks.filter(t => (t.agent_id || t.assignee) === ag.agent_id && t.status === 'completed').length;
