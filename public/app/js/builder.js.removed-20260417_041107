  }, skelSections.length * skelStaggerMs + 400);

  // ── Wait for both: build response AND minimum cinematic duration ──────────
  var buildResponse = null;
  var buildError    = null;
  try {
    buildResponse = await buildPromise;
    console.log('[Arthur] Build response:', JSON.stringify(buildResponse).slice(0, 300));
  } catch(e) {
    clearTimeout(_genTimeout);
    if (e.name === 'AbortError') {
      buildError = 'Generation timed out — your website foundation is taking longer than expected. Please try again.';
    } else {
      buildError = e.message;
    }
    console.error('[Arthur] Build exception:', e.name, e.message);
  }

  // Ensure minimum cinematic duration
  var elapsed = Date.now() - buildStart;
  if (elapsed < MIN_DURATION) {
    await new Promise(function(res){ setTimeout(res, MIN_DURATION - elapsed); });
  }

  clearInterval(stepTimer);
  clearInterval(skelRevealTimer);

  // ── Handle hard error ─────────────────────────────────────────────────────
  if (buildError || !buildResponse || buildResponse.error) {
    var errMsg = buildError || (buildResponse && buildResponse.error) || 'Unknown error';
    if (buildResponse && buildResponse.error && _arthurClassifyError(buildResponse.error) === 'MISSING_PARAM') {
      // Missing param — go back to chat
      overlay.style.opacity = '0';
      setTimeout(function() { overlay.remove(); }, 500);
      _bldShowAIInterview();
      setTimeout(function() {
        S.ready = false;
        _arthurBub(_arthurUserFriendlyError('MISSING_PARAM', buildResponse.error));
      }, 600);
      return;
    }
    // Show calm error state
    _acSetBar(0);
    _acSetStatus('');
    var headline = document.getElementById('ac-headline');
    if (headline) headline.innerHTML = 'Something went wrong';
    var sub = document.getElementById('ac-sub');
    if (sub) sub.textContent = 'We could not connect to the server. Please try again.';
    var stepsEl = document.getElementById('ac-steps');
    if (stepsEl) stepsEl.innerHTML = '';
    var acLeft = document.getElementById('ac-left');
    if (acLeft) {
      var errDiv = document.createElement('div');
      errDiv.style.cssText = 'margin-top:16px;display:flex;flex-direction:column;gap:10px';
      errDiv.innerHTML = '<button id="ac-retry" style="background:linear-gradient(135deg,#6C5CE7,#A855F7);border:none;border-radius:10px;color:#fff;padding:12px 24px;font-size:14px;font-weight:600;cursor:pointer">Try Again</button>'
        + '<button id="ac-cancel" style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:10px;color:rgba(255,255,255,.5);padding:12px 24px;font-size:13px;cursor:pointer">Cancel</button>';
      acLeft.appendChild(errDiv);
      document.getElementById('ac-retry').onclick = function() {
        overlay.remove();
        _bldShowAIInterview();
      };
      document.getElementById('ac-cancel').onclick = function() {
        overlay.style.opacity = '0';
        setTimeout(function() { overlay.remove(); }, 400);
      };
    }
    return;
  }

  websiteId = buildResponse.id || buildResponse.website_id;
  var pagesCreated  = buildResponse.pages_created || (buildResponse.pages && buildResponse.pages.length) || 1;
  var usedFallback  = !!buildResponse.used_fallback;
  var firstPageId   = buildResponse.pages && buildResponse.pages[0] && buildResponse.pages[0].id;

  // ── All steps done ────────────────────────────────────────────────────────
  for (var si2 = 0; si2 < buildSteps.length; si2++) { _acStepDone(si2); }
  _acSetBar(100);
  _acSetStatus(usedFallback ? 'Layout optimized automatically' : 'Ready');

  var headline2 = document.getElementById('ac-headline');
  if (headline2) headline2.innerHTML = '<span style="color:' + brandColor + '">' + S.business_name + '</span><br>is live!';
  _acSetCaption(pagesCreated + ' pages built · Preview loading…');

  // ── Silently load first page in builder (background) ─────────────────────
  nav('websites');
  await new Promise(function(res){ setTimeout(res, 300); });
  wsOpenSite(websiteId);
  await new Promise(function(res){ setTimeout(res, 900); });

  var loadedPageId = null;
  var grid = document.getElementById('ws-pages-grid');
  if (grid) {
    var firstPageDiv = grid.querySelector('[onclick*="wsEditSitePage"]');
    if (firstPageDiv) {
      var onclickVal = firstPageDiv.getAttribute('onclick') || '';
      var match      = onclickVal.match(/wsEditSitePage\((\d+)\)/);
      loadedPageId   = match ? parseInt(match[1]) : null;
    }
  }
  if (loadedPageId && typeof wsEditSitePage === 'function') {
    wsEditSitePage(loadedPageId);
  }

  // ── Wait for bldCurrentPage to be populated ───────────────────────────────
  var maxWait = 40;
  await new Promise(function(res) {
    var attempts = 0;
    var check = setInterval(function() {
      attempts++;
      if ((bldCurrentPage && bldCurrentPage.sections && bldCurrentPage.sections.length) || attempts > maxWait) {
        clearInterval(check); res();
      }
    }, 200);
  });

  // ── Render preview HTML into the canvas iframe ────────────────────────────
  if (bldCurrentPage && typeof _bldBuildPreviewHtml === 'function') {
    var previewHtml  = _bldBuildPreviewHtml();
    var previewFrame = document.getElementById('ac-preview-frame');
    if (previewFrame) {
      var ifr = document.createElement('iframe');
      ifr.style.cssText = 'width:100%;height:100%;border:none';
      ifr.setAttribute('sandbox', 'allow-scripts allow-same-origin allow-forms');
      previewFrame.appendChild(ifr);
      // Inject stagger CSS into preview HTML before writing
      var staggerCSS = '<style id="ac-stagger-in">'
        + '.sec{opacity:0;transform:translateY(18px);filter:blur(3px);transition:opacity .55s ease,transform .55s ease,filter .55s ease}'
        + '</style>';
      var previewHtmlStaggered = previewHtml.replace('</head>', staggerCSS + '</head>');

      // Write HTML to iframe
      ifr.contentDocument.open();
      ifr.contentDocument.write(previewHtmlStaggered);
      ifr.contentDocument.close();

      // Wait for iframe to parse and render
      await new Promise(function(res){ setTimeout(res, 600); });

      // Cross-fade: skeleton out, preview in (blurred initially)
      var skelEl = document.getElementById('ac-skeleton');
      if (skelEl) { skelEl.style.transition = 'opacity .7s ease'; skelEl.style.opacity = '0'; }
      previewFrame.style.opacity = '1';
      _acSetCaption('Your website · Preview');

      // Stagger sections in one by one: fade + slide up + unblur
      await new Promise(function(res){ setTimeout(res, 300); });
      try {
        var ifrSecs = ifr.contentDocument ? ifr.contentDocument.querySelectorAll('.sec') : [];
        var staggerDelay = 0;
        Array.prototype.forEach.call(ifrSecs, function(sec) {
          setTimeout(function() {
            sec.style.opacity    = '1';
            sec.style.transform  = 'translateY(0)';
            sec.style.filter     = 'blur(0)';
          }, staggerDelay);
          staggerDelay += 180; // 180ms stagger per section
        });
        // Remove stagger CSS after animation completes so builder controls work
        setTimeout(function() {
          try {
            var staggerStyle = ifr.contentDocument.getElementById('ac-stagger-in');
            if (staggerStyle) staggerStyle.remove();
          } catch(e) {}
        }, staggerDelay + 800);
      } catch(e) { console.warn('[Arthur] Stagger inject failed:', e.message); }
    }
  }

  // ── Brief success pause ───────────────────────────────────────────────────
  await new Promise(function(res){ setTimeout(res, 1800); });

  // ── Add "Edit Instead" button ─────────────────────────────────────────────
  var acLeft2 = document.getElementById('ac-left');
  if (acLeft2) {
    var editDiv = document.createElement('div');
    editDiv.style.cssText = 'margin-top:24px;animation:acFadeUp .4s ease forwards';
    editDiv.innerHTML = '<button id="ac-edit-btn" style="background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:10px;color:rgba(255,255,255,.6);padding:10px 20px;font-size:13px;cursor:pointer;transition:all .2s">✏️ Edit in Builder</button>';
    acLeft2.appendChild(editDiv);
    document.getElementById('ac-edit-btn').onclick = function() {
      overlay.style.opacity = '0';
      setTimeout(function() { overlay.remove(); }, 400);
    };
  }

  // ── Auto-open full preview after brief success state ─────────────────────
  await new Promise(function(res){ setTimeout(res, 1800); });

  // Launch preview FIRST — before any fade — so it's ready underneath
  if (bldCurrentPage && typeof bldPreview === 'function') {
    await bldPreview();
  }
  // Give preview overlay one paint cycle to mount and display
  await new Promise(function(res){ setTimeout(res, 60); });

  // Cinematic exit: zoom + fade out, revealing the preview underneath
  overlay.style.transition  = 'opacity .7s ease, transform .7s cubic-bezier(.4,0,.2,1)';
  overlay.style.transformOrigin = 'center center';
  overlay.style.transform   = 'scale(1.025)';
  overlay.style.opacity     = '0';

  // Wait for fade to complete, then remove cinematic
  await new Promise(function(res){ setTimeout(res, 720); });
  overlay.remove();
  window._arthurGenerating = false;
  window._arthurWizardComplete = true; // PHASE 7: mark as fully complete
}

