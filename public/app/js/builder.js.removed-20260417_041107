        txFeed.innerHTML = txData.transactions.slice(0,15).map(tx => {
          const isDeduct = parseFloat(tx.credits_delta) < 0;
          const sign     = isDeduct ? '−' : '+';
          const col      = isDeduct ? 'var(--am)' : 'var(--ac)';
          const amt      = Math.abs(parseFloat(tx.credits_delta)).toFixed(3);
          const ts       = new Date(tx.created_at).toLocaleString();
          return `<div style="display:flex;align-items:center;gap:8px;padding:6px 8px;background:var(--s2);border-radius:6px;font-size:11px">
