// ── normalizeStyleInput — Phase 3: convert any UI value to valid CSS ──────
function normalizeStyleInput(key, raw) {
  if (!raw && raw !== 0) return '';
  var v = String(raw).trim();
  if (!v) return '';
  // px enforcement for numeric-only sizing keys
  var pxKeys = ['fontSize','letterSpacing','borderRadius','marginTop','marginBottom','marginLeft','marginRight',
                 'paddingTop','paddingBottom','paddingLeft','paddingRight'];
  if (pxKeys.indexOf(key) !== -1 && /^\d+(\.\d+)?$/.test(v)) return v + 'px';
  return v;
}

// ── _epColor: color picker widget (NO default value — FIX 1) ──────────────
function _epColor(label, id, val) {
  // FIX 1+2: NO default color injected into picker. val may be empty string.
  // Picker and hex field sync bidirectionally. ONLY hex-text field value is
