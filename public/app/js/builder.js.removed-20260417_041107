  } catch(e) {
    console.error('[CommandCenter]', e);
  }

  // Phase 10: Load execution + decision widgets
  try {
    const [execRes, decRes] = await Promise.allSettled([
      fetch(API + 'exec/history?limit=8', { headers: authHeader() }),
      fetch(API + 'decisions?limit=8', { headers: authHeader() }),
    ]);

    const execData = execRes.status === 'fulfilled' && execRes.value.ok ? await safeJson(execRes.value) : null;
    const decData  = decRes.status === 'fulfilled' && decRes.value.ok ? await safeJson(decRes.value) : null;

    const execFeed = document.getElementById('cmd-exec-feed');
    if (execFeed && execData?.history?.length) {
      execFeed.innerHTML = execData.history.map(r => {
        const ok = parseInt(r.success);
        return `<div style="display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;background:var(--s2);font-size:11px">
          <span>${ok?'✅':'❌'}</span>
          <span style="font-weight:600;color:var(--t1);flex:1">${r.tool_id||'?'}</span>
          <span style="color:var(--t3)">${r.agent_id||''}</span>
          <span style="color:var(--t3);font-size:10px">${new Date(r.created_at).toLocaleDateString()}</span>
        </div>`;
      }).join('');
    } else if (execFeed) {
      execFeed.innerHTML = '<div style="font-size:11px;color:var(--t3);text-align:center;padding:16px">No executions yet.</div>';
    }

    const decFeed = document.getElementById('cmd-dec-feed');
    if (decFeed && decData?.decisions?.length) {
      decFeed.innerHTML = decData.decisions.map(r => {
        const sc = r.status==='approved'?'var(--ac)':r.status==='rejected'?'#F87171':'var(--am)';
        return `<div style="display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;background:var(--s2);font-size:11px">
          <span style="font-weight:700;color:${sc};font-size:9px;text-transform:uppercase;min-width:50px">${r.status}</span>
          <span style="color:var(--t1);flex:1;font-weight:500">${(r.title||'').slice(0,50)}</span>
          <span style="color:var(--t3);font-size:10px">${new Date(r.created_at).toLocaleDateString()}</span>
        </div>`;
