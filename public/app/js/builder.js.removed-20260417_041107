// Global helper: close nearest modal-backdrop ancestor
window.closestModal = function(el) {
  var p = el;
  while (p && (p.className||'').indexOf('modal-backdrop') < 0) p = p.parentElement;
  if (p) p.remove();
};

// ══════════════════════════════════════════════════════════════════════════════
// PHASE 5.5A — CREATIVE TASKS UI
// Exposes lucreative/v1/tasks full lifecycle in the Worker Queue view.
// Tab: "🎨 Creative Tasks" alongside existing agent task tabs.
// All API calls use _lu55a_fetch() which mirrors the _get/_post/_del pattern.
// ══════════════════════════════════════════════════════════════════════════════

(function() {
  // Internal API helpers — mirror LuAPI internals but target lucreative/v1
  const _ct_base  = () => window.location.origin + '/api/creative/';
  const _ct_nonce = () => window.LU_CFG?.nonce || NONCE;
  const _ct_hdr   = () => ({'Content-Type':'application/json','X-WP-Nonce':_ct_nonce()});

  const _ct_get  = async (path) => {
    const r = await fetch(_ct_base() + path + (path.includes('?')?'&':'?') + '_t='+Date.now(), {headers:{'X-WP-Nonce':_ct_nonce(),'Cache-Control':'no-cache'}});
    if (!r.ok) { const d = await r.json().catch(()=>({})); throw new Error(d.message||d.error||'Request failed ('+r.status+')'); }
    return r.json();
  };
  const _ct_post = async (path, body) => {
    const r = await fetch(_ct_base() + path, {method:'POST', headers:_ct_hdr(), body:JSON.stringify(body||{})});
    if (!r.ok) { const d = await r.json().catch(()=>({})); throw new Error(d.message||d.error||'Request failed ('+r.status+')'); }
    return r.json();
  };

  // Status display helpers
  const CT_STATUS_COLOR = {
    pending:    'var(--am)',
    approved:   'var(--ac)',
    queued:     'var(--bl)',
    processing: 'var(--bl)',
    completed:  'var(--ac)',
    failed:     'var(--rd)',
    rejected:   'var(--t3)',
    executed:   'var(--ac)',  // legacy compat
  };
  const CT_STATUS_BADGE = {
    pending:    'badge-amber',
    approved:   'badge-green',
    queued:     'badge-blue',
    processing: 'badge-blue',
    completed:  'badge-green',
    failed:     'badge-red',
    rejected:   'badge-grey',
    executed:   'badge-green',
  };

  // ── State ──────────────────────────────────────────────────────────────────
  let _ctFilter = 'all';
  let _ctTasks  = [];
  let _ctPollTimer = null;

  // ── Poll for processing tasks ──────────────────────────────────────────────
  function _ctStartPoll() {
    _ctStopPoll();
    _ctPollTimer = setInterval(async () => {
      const hasProcessing = _ctTasks.some(t => t.status === 'processing' || t.status === 'queued');
      if (!hasProcessing) { _ctStopPoll(); return; }
      try {
        const res = await _ct_get('tasks?limit=50');
        _ctTasks = Array.isArray(res.tasks) ? res.tasks : (Array.isArray(res) ? res : []);
        _ctRenderTable();
      } catch(e) { /* silent — poll will retry */ }
    }, 4000);
  }
  function _ctStopPoll() {
    if (_ctPollTimer) { clearInterval(_ctPollTimer); _ctPollTimer = null; }
  }

  // ── Main loader — called when Creative Tasks tab is clicked ────────────────
  window.ctLoadTasks = async function() {
    const panel = document.getElementById('ct-panel');
    if (!panel) return;
    panel.innerHTML = loadingCard ? loadingCard(200) : '<div style="padding:32px;text-align:center;color:var(--t3)">Loading…</div>';
    try {
      const res = await _ct_get('tasks?limit=50');
      _ctTasks = Array.isArray(res.tasks) ? res.tasks : (Array.isArray(res) ? res : []);
      _ctRenderPanel(panel);
      // Auto-poll if any tasks are in-flight
      if (_ctTasks.some(t => t.status === 'processing' || t.status === 'queued')) _ctStartPoll();
    } catch(e) {
      panel.innerHTML =
        '<div style="padding:40px;text-align:center">' +
          '<div style="font-size:28px;margin-bottom:12px">⚠️</div>' +
          '<div style="font-size:13px;color:var(--rd);margin-bottom:16px">Creative Tasks failed to load: ' + (e.message||'unknown') + '</div>' +
          '<button class="btn btn-outline btn-sm" onclick="ctLoadTasks()">↺ Retry</button>' +
        '</div>';
    }
  };

  // ── Render the full creative tasks panel ──────────────────────────────────
  function _ctRenderPanel(panel) {
    const byStatus = {};
    _ctTasks.forEach(t => { const s = t.status||'pending'; byStatus[s] = (byStatus[s]||0)+1; });
    const statuses = ['pending','approved','queued','processing','completed','failed','rejected'];

    panel.innerHTML =
      // Toolbar
      '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">' +
        '<div style="display:flex;gap:6px;flex-wrap:wrap">' +
          ['all','pending','approved','queued','processing','completed','failed','rejected'].map(s => {
            const cnt = s==='all' ? _ctTasks.length : (byStatus[s]||0);
            const active = _ctFilter===s ? ' class="tab active"' : ' class="tab"';
            const lbl = s==='all' ? 'All ('+cnt+')' : s.charAt(0).toUpperCase()+s.slice(1)+(cnt?' ('+cnt+')':'');
            return '<button'+active+' data-ct-tab="'+s+'" onclick="ctSetTab(this,this.dataset.ctTab)">'+lbl+'</button>';
          }).join('') +
        '</div>' +
        '<button class="btn btn-outline btn-sm" onclick="ctLoadTasks()">↺ Refresh</button>' +
        '<button class="btn btn-primary btn-sm" id="ct-run-btn" onclick="ctRunWorker(this)" style="margin-left:6px">▶ Run Worker</button>' +
      '</div>' +
      // Table
      '<div id="ct-tbl-wrap"></div>';

    _ctRenderTable();
  }

  // ── Render the task table (reused by poll updates) ─────────────────────────
  function _ctRenderTable() {
    const wrap = document.getElementById('ct-tbl-wrap');
    if (!wrap) return;

    const filtered = _ctFilter === 'all' ? _ctTasks
      : _ctTasks.filter(t => (t.status||'pending') === _ctFilter);

    if (filtered.length === 0) {
      wrap.innerHTML =
        '<div class="card card-body" style="text-align:center;padding:48px 20px">' +
          '<div style="font-size:36px;margin-bottom:12px">🎨</div>' +
          '<h3 style="margin:0 0 8px">No ' + (_ctFilter==='all'?'creative':_ctFilter) + ' tasks</h3>' +
          '<p style="color:var(--t3);font-size:13px;margin:0">Tasks are created automatically by the agent intelligence system when generating creative assets.</p>' +
        '</div>';
      return;
    }

    wrap.innerHTML =
      '<div class="card"><div class="table-wrap"><table id="ct-tbl"><thead><tr>' +
        '<th>Task</th><th>Type</th><th>Agent</th><th>Status</th><th>Created</th><th></th>' +
      '</tr></thead><tbody>' +
      filtered.map(t => {
        const s   = t.status || 'pending';
        const ts  = t.created_at ? new Date(t.created_at).toLocaleString() : '—';
        const col = CT_STATUS_COLOR[s] || 'var(--t2)';
        const bdg = CT_STATUS_BADGE[s] || 'badge-grey';
        const title = (t.title || t.task_type || 'Task').slice(0, 60);
        const desc  = (t.description || '').slice(0, 80);
        // Action buttons — contextual per status
        let actions = '';
        if (s === 'pending') {
          actions =
            '<button class="btn btn-outline btn-sm" style="font-size:11px" onclick="ctApproveTask('+t.id+',this)">✓ Approve</button> ' +
            '<button class="btn btn-ghost btn-sm" style="font-size:11px;color:var(--rd)" onclick="ctRejectTask('+t.id+',this)">✕ Reject</button>';
        } else if (s === 'approved') {
          actions = '<button class="btn btn-primary btn-sm" style="font-size:11px" onclick="ctExecuteTask('+t.id+',this)">▶ Execute</button>';
        } else if (s === 'queued' || s === 'processing') {
          actions = '<span style="font-size:11px;color:var(--bl)">⏳ In progress</span>';
        } else if (s === 'completed' || s === 'executed') {
          actions = '<button class="btn btn-ghost btn-sm" style="font-size:11px" onclick="ctShowResult('+t.id+')">📄 Result</button>';
        } else if (s === 'failed') {
          actions =
            '<button class="btn btn-ghost btn-sm" style="font-size:11px" onclick="ctShowResult('+t.id+')">📄 Detail</button>';
        }
        return '<tr data-ct-status="'+s+'">' +
          '<td style="max-width:260px">' +
            '<div style="font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+bld_esc(title)+'</div>' +
            (desc?'<div style="font-size:11px;color:var(--t3);margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+bld_esc(desc)+'</div>':'') +
          '</td>' +
          '<td style="font-size:12px;color:var(--t2)">'+bld_esc(t.task_type||'—')+'</td>' +
          '<td style="font-size:12px;color:var(--t2)">'+bld_esc(t.target_agent||t.target_adapter||'—')+'</td>' +
          '<td><span class="badge '+bdg+'" style="font-size:10px">'+s+'</span></td>' +
          '<td style="font-size:11px;color:var(--t3)">'+ts+'</td>' +
          '<td><div style="display:flex;gap:4px;align-items:center">'+actions+'</div></td>' +
        '</tr>';
      }).join('') +
      '</tbody></table></div></div>';
  }

  // ── Tab filter ─────────────────────────────────────────────────────────────
  window.ctSetTab = function(btn, tab) {
    document.querySelectorAll('[data-ct-tab]').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
    _ctFilter = tab;
    _ctRenderTable();
  };

  // ── Approve task ───────────────────────────────────────────────────────────
  window.ctApproveTask = async function(taskId, btn) {
    if (btn) { btn.disabled=true; btn.textContent='…'; }
    try {
      const res = await _ct_post('tasks/'+taskId+'/approve', {});
      if (res.success === false) throw new Error(res.message||'Approve failed');
      showToast('Task approved.','success');
      // Update local state optimistically
      const t = _ctTasks.find(x=>x.id===taskId||x.id==taskId);
      if (t) t.status = 'approved';
      _ctRenderTable();
    } catch(e) {
      showToast('Approve failed: '+e.message,'error');
      if (btn) { btn.disabled=false; btn.textContent='✓ Approve'; }
    }
  };

  // ── Reject task ────────────────────────────────────────────────────────────
  window.ctRejectTask = async function(taskId, btn) {
    const ok = await luConfirm('Reject this creative task?','Reject Task','Reject','Keep');
    if (!ok) return;
    if (btn) { btn.disabled=true; btn.textContent='…'; }
    try {
      const res = await _ct_post('tasks/'+taskId+'/reject', {});
      if (res.success === false) throw new Error(res.message||'Reject failed');
      showToast('Task rejected.','info');
      const t = _ctTasks.find(x=>x.id===taskId||x.id==taskId);
      if (t) t.status = 'rejected';
      _ctRenderTable();
    } catch(e) {
      showToast('Reject failed: '+e.message,'error');
      if (btn) { btn.disabled=false; btn.textContent='✕ Reject'; }
    }
  };

  // ── Execute task (Phase 5 real execution) ──────────────────────────────────
  window.ctExecuteTask = async function(taskId, btn) {
    if (btn) { btn.disabled=true; btn.textContent='Queueing…'; }
    try {
      // POST /lucreative/v1/tasks/{id}/execute
      const res = await _ct_post('tasks/'+taskId+'/execute', {});
      if (res.success === false && !res.duplicate) throw new Error(res.message||'Execute failed');

      if (res.duplicate) {
        showToast('Task is already '+res.status+'. No duplicate queued.','info');
      } else {
        showToast('Task queued for execution! Job #'+(res.job_id||'—'),'success');
        // Update local state + start polling
        const t = _ctTasks.find(x=>x.id===taskId||x.id==taskId);
        if (t) t.status = 'queued';
        _ctRenderTable();
        _ctStartPoll();
        // Auto-run worker once to kick off processing immediately
        setTimeout(async () => {
          try { await _ct_post('exec-jobs/run', {}); } catch(e) { /* non-fatal */ }
          await ctLoadTasks();
        }, 800);
      }
    } catch(e) {
      showToast('Execute failed: '+e.message,'error');
      if (btn) { btn.disabled=false; btn.textContent='▶ Execute'; }
    }
  };

  // ── Show result / detail modal ─────────────────────────────────────────────
  window.ctShowResult = async function(taskId) {
    let task = _ctTasks.find(t => t.id===taskId||t.id==taskId) || {};
    // Fetch full detail from /tasks/{id}/detail
    try {
      const det = await _ct_get('tasks/'+taskId+'/detail');
      if (det.task) task = det.task;
    } catch(e) { /* fallback to local copy */ }

    const s = task.status || 'unknown';
    const result = task.execution_result || (task.execution_result_json ? JSON.parse(task.execution_result_json) : null);
    const errMsg = task.error_message || '';
    const bdg = CT_STATUS_BADGE[s] || 'badge-grey';

    // Extract asset URL if present
    let assetHtml = '';
    if (result && result.assets && result.assets.length) {
      assetHtml = result.assets.map(a =>
        '<div style="margin-top:12px;padding:12px;border:1px solid var(--bd);border-radius:8px">' +
          (a.url ? '<div style="margin-bottom:8px"><img src="'+a.url+'" style="max-width:100%;max-height:200px;border-radius:6px;object-fit:contain"></div>' : '') +
          '<div style="font-size:11px;color:var(--t3)">Asset ID: '+(a.asset_id||'—')+'</div>' +
          (a.url ? '<div style="font-size:11px"><a href="'+a.url+'" target="_blank" style="color:var(--bl)">🔗 Open asset →</a></div>' : '') +
          '<div style="font-size:11px;color:var(--t3)">Layout: '+(a.layout||'—')+' · Style: '+(a.style||'—')+'</div>' +
        '</div>'
      ).join('');
    }

    const timestamps = [
      ['Created',    task.created_at],
      ['Approved',   task.approved_at],
      ['Queued',     task.queued_at],
      ['Started',    task.started_at],
      ['Completed',  task.completed_at],
      ['Failed',     task.failed_at],
    ].filter(([,v])=>v)
     .map(([k,v])=>'<div style="display:flex;justify-content:space-between;font-size:11px;padding:4px 0;border-bottom:1px solid var(--bd)"><span style="color:var(--t3)">'+k+'</span><span>'+new Date(v).toLocaleString()+'</span></div>')
     .join('');

    const bd = document.createElement('div'); bd.className='modal-backdrop'; bd.onclick=e=>{if(e.target===bd)bd.remove();};
    bd.innerHTML =
      '<div class="modal" style="max-width:520px;max-height:85vh;overflow-y:auto">' +
        '<div class="modal-header">' +
          '<h3>Task Detail</h3>' +
          '<button class="modal-close" onclick="closestModal(this)">✕</button>' +
        '</div>' +
        '<div class="modal-body" style="padding:20px">' +
          '<div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">' +
            '<span class="badge '+bdg+'" style="font-size:11px">'+s+'</span>' +
            '<span style="font-size:13px;font-weight:600;color:var(--t1)">'+bld_esc(task.title||task.task_type||'Task #'+taskId)+'</span>' +
          '</div>' +
          (task.description ? '<p style="font-size:13px;color:var(--t2);margin:0 0 14px">'+bld_esc(task.description)+'</p>' : '') +
          (errMsg ? '<div style="background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);border-radius:8px;padding:10px 12px;font-size:12px;color:var(--rd);margin-bottom:14px">⚠️ Error: '+bld_esc(errMsg)+'</div>' : '') +
          (assetHtml ? '<div style="margin-bottom:14px"><div style="font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Generated Assets</div>'+assetHtml+'</div>' : '') +
          (timestamps ? '<div style="margin-bottom:14px"><div style="font-size:11px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Timeline</div>'+timestamps+'</div>' : '') +
          (task.target_adapter ? '<div style="font-size:11px;color:var(--t3)">Adapter: '+bld_esc(task.target_adapter)+'</div>' : '') +
        '</div>' +
        '<div class="modal-footer">' +
          (s==='approved' ? '<button class="btn btn-primary" onclick="ctExecuteTask('+taskId+',this)">▶ Execute Now</button>' : '') +
          '<button class="btn btn-outline" onclick="closestModal(this)">Close</button>' +
        '</div>' +
      '</div>';
    document.body.appendChild(bd); bd.style.opacity='1'; bd.style.pointerEvents='all';
  };

  // ── Run Worker (POST /lucreative/v1/exec-jobs/run) ───────────────────────────
  window.ctRunWorker = async function(btn) {
    const btnEl = btn || document.getElementById('ct-run-btn');
    const origText = btnEl ? btnEl.textContent : 'Run Worker';
    if (btnEl) { btnEl.disabled = true; btnEl.textContent = '⏳ Running…'; }
    try {
      const res = await _ct_post('exec-jobs/run', {});
      if (res.processed) {
        const msg = res.status === 'completed'
          ? '✓ Job #' + res.job_id + ' completed.'
          : '✓ Worker ran: ' + (res.message || res.status);
        showToast(msg, 'success');
      } else if (res.status === 'no_jobs') {
        showToast('No queued jobs to process right now.', 'info');
      } else {
        showToast('Worker: ' + (res.message || 'ran'), 'info');
      }
      // Refresh task list after worker run
      await ctLoadTasks();
    } catch(e) {
      showToast('Worker failed: ' + e.message, 'error');
    } finally {
      if (btnEl) { btnEl.disabled = false; btnEl.textContent = origText; }
    }
  };

  // ── Patch bld_loadWorkerQueue to add Creative Tasks tab ────────────────────────
  const _origLoadWorkerQueue = window.bld_loadWorkerQueue;
  window.bld_loadWorkerQueue = async function() {
    // Call original — it renders the Worker Queue HTML into view-queue
    if (_origLoadWorkerQueue) await _origLoadWorkerQueue.call(this);

    // After original renders, inject Creative Tasks tab into the header
    const el = document.getElementById('view-queue');
    if (!el) return;

    // Check if we already injected (guard against double-call)
    if (el.querySelector('#ct-tab-btn')) return;

    // Find the header title div and inject a tab button
    const h1 = el.querySelector('h1');
    if (!h1) return;
    const headerDiv = h1.closest('div');
    if (!headerDiv) return;

    // Inject Creative Tasks tab button next to Refresh button
    const ctTabBtn = document.createElement('button');
    ctTabBtn.id = 'ct-tab-btn';
    ctTabBtn.className = 'btn btn-outline btn-sm';
    ctTabBtn.textContent = '🎨 Creative Tasks';
    ctTabBtn.onclick = function() { _ctTogglePanel(el); };
    headerDiv.appendChild(ctTabBtn);

    // Inject the Creative Tasks panel (hidden by default)
    const ctPanel = document.createElement('div');
    ctPanel.id = 'ct-panel-wrap';
    ctPanel.style.cssText = 'display:none;padding:0 0 24px';
    ctPanel.innerHTML = '<div id="ct-panel"><div style="padding:40px;text-align:center;color:var(--t3);font-size:13px">Click ↑ to load Creative Tasks</div></div>';
    el.querySelector('div[style*="padding:24px"]')?.appendChild(ctPanel)
      || el.appendChild(ctPanel);
  };

  function _ctTogglePanel(el) {
    const wrap = document.getElementById('ct-panel-wrap');
    if (!wrap) return;
    const isHidden = wrap.style.display === 'none';
    wrap.style.display = isHidden ? 'block' : 'none';
    const btn = document.getElementById('ct-tab-btn');
    if (btn) {
      btn.textContent = isHidden ? '✕ Hide Creative Tasks' : '🎨 Creative Tasks';
      btn.style.borderColor = isHidden ? 'var(--ac)' : '';
      btn.style.color = isHidden ? 'var(--ac)' : '';
    }
    if (isHidden) ctLoadTasks();
    else _ctStopPoll();
  }

  // Also wire from the queue view navigation
  const _origNav = window.nav;
  window.nav = async function(view) {
    const result = _origNav ? await _origNav.apply(this, arguments) : undefined;
    if (view !== 'queue') _ctStopPoll();
    return result;
  };

})(); // end Phase 5.5A Creative Tasks IIFE


async function bld_loadCommandCenter() {
  try {
    const [creditsRes, subRes, tasksRes, txRes, agentsRes] = await Promise.allSettled([
      fetch(API + 'workspace/credits',               { headers: authHeader() }),
      fetch(API + 'workspace/subscription',          { headers: authHeader() }),
      fetch(API + 'tasks?wsId=1',                    { headers: authHeader() }),
      fetch(API + 'workspace/credits/transactions?limit=20', { headers: authHeader() }),
      fetch(API + 'agents',                          { headers: authHeader() }),
