function initDrag(){
  const canvas = document.getElementById('canvas-agents');

  document.querySelectorAll('.agent-node').forEach(node=>{
    let startX,startY,ox,oy,dragging=false,didMove=false;
    node.addEventListener('mousedown',e=>{
      if(e.target.classList.contains('an-name')||e.target.classList.contains('an-open-btn')) return;
      dragging=true; didMove=false;
      startX=e.clientX; startY=e.clientY;
      const id=node.dataset.agent;
      if(!nodePos[id]) nodePos[id]={x:parseInt(node.style.left)||0, y:parseInt(node.style.top)||0};
      ox=nodePos[id].x; oy=nodePos[id].y;
      node.style.cursor='grabbing'; e.preventDefault(); e.stopPropagation();
    });
    document.addEventListener('mousemove',e=>{
      if(!dragging) return;
      const dx=e.clientX-startX, dy=e.clientY-startY;
      if(Math.abs(dx)>3||Math.abs(dy)>3) didMove=true;
      const id=node.dataset.agent;
      if(!nodePos[id]) nodePos[id]={x:0,y:0};
      nodePos[id].x=ox+dx; nodePos[id].y=oy+dy;
      node.style.left=nodePos[id].x+'px'; node.style.top=nodePos[id].y+'px';
      drawCanvas(); drawZones();
    });
    document.addEventListener('mouseup',e=>{
      if(!dragging) return;
      dragging=false; node.style.cursor='grab';
      if(!didMove) {
        // Click — toggle selection with shift/ctrl, or clear and select one
        if(e.shiftKey||e.ctrlKey||e.metaKey) {
          toggleAgentSelect(node.dataset.agent, node);
        } else {
          // If clicking an already-selected node without modifier, clear others
          if(selectedAgents.has(node.dataset.agent) && selectedAgents.size === 1) {
            clearSelection();
          } else if(!e.shiftKey && !e.ctrlKey) {
            clearSelection();
          }
        }
      }
    });
  });

  // Task node drag — event delegation since task-nodes are recreated each render
  let tnDrag = null; // {id, ox, oy, startX, startY}
  canvas.addEventListener('mousedown', e => {
    const tn = e.target.closest('.task-node');
    if (!tn) return;
    e.stopPropagation(); // prevent canvas drag-select
    const id = tn.dataset.taskId;
    if (!id) return;
    tnDrag = {
      id,
      el: tn,
      startX: e.clientX,
      startY: e.clientY,
      ox: parseInt(tn.style.left) || 0,
      oy: parseInt(tn.style.top)  || 0,
      didMove: false,
    };
    tn.style.cursor = 'grabbing';
    tn.style.zIndex = '99';
    e.preventDefault();
  });
  document.addEventListener('mousemove', e => {
    if (!tnDrag) return;
    const dx = e.clientX - tnDrag.startX;
    const dy = e.clientY - tnDrag.startY;
    if (Math.abs(dx) > 2 || Math.abs(dy) > 2) tnDrag.didMove = true;
    const nx = tnDrag.ox + dx;
    const ny = tnDrag.oy + dy;
    tnDrag.el.style.left = nx + 'px';
    tnDrag.el.style.top  = ny + 'px';
    // Store position so it persists through redraws
    taskNodePos[tnDrag.id] = { x: nx, y: ny };
    // Redraw only SVG lines — fast, no full re-render
    _redrawTaskLines(tnDrag.id, nx, ny, tnDrag.el.dataset.taskAgents?.split(',') || []);
  });
  document.addEventListener('mouseup', e => {
    if (!tnDrag) return;
    tnDrag.el.style.cursor = 'pointer';
    tnDrag.el.style.zIndex = '2';
    if (!tnDrag.didMove) {
      // It was a click — open task drawer
      const task = allTasks.find(t => String(t.id) === String(tnDrag.id));
      if (task && openTaskDrawer) openTaskDrawer(task.id);
    }
    tnDrag = null;
  });

  // Canvas drag-select box
  if (canvas) {
    let selStart=null, selBox=null;
    canvas.addEventListener('mousedown', e => {
      if (e.target !== canvas && !e.target.classList.contains('zone-overlay') && !e.target.classList.contains('zone-label') && !e.target.classList.contains('canvas-agents')) return;
      const cr = canvas.getBoundingClientRect();
      selStart = { x: e.clientX-cr.left, y: e.clientY-cr.top };
      selBox = document.getElementById('drag-select-box');
      if (selBox) { selBox.style.display='block'; selBox.style.left=selStart.x+'px'; selBox.style.top=selStart.y+'px'; selBox.style.width='0'; selBox.style.height='0'; }
      if (!e.shiftKey && !e.ctrlKey) clearSelection();
      e.preventDefault();
    });
    document.addEventListener('mousemove', e => {
      if (!selStart) return;
      const cr = canvas.getBoundingClientRect();
      const cx = e.clientX-cr.left, cy = e.clientY-cr.top;
      const x=Math.min(cx,selStart.x), y=Math.min(cy,selStart.y);
      const w=Math.abs(cx-selStart.x), h=Math.abs(cy-selStart.y);
      if (selBox) { selBox.style.left=x+'px'; selBox.style.top=y+'px'; selBox.style.width=w+'px'; selBox.style.height=h+'px'; }
    });
    document.addEventListener('mouseup', e => {
      if (!selStart) return;
      const cr = canvas.getBoundingClientRect();
      const selR = { left:parseInt(selBox?.style.left||0)+cr.left, top:parseInt(selBox?.style.top||0)+cr.top, right:parseInt(selBox?.style.left||0)+parseInt(selBox?.style.width||0)+cr.left, bottom:parseInt(selBox?.style.top||0)+parseInt(selBox?.style.height||0)+cr.top };
      if (parseInt(selBox?.style.width||0) > 8 && parseInt(selBox?.style.height||0) > 8) {
        document.querySelectorAll('.agent-node').forEach(node => {
          const nr = node.getBoundingClientRect();
          const overlap = nr.left < selR.right && nr.right > selR.left && nr.top < selR.bottom && nr.bottom > selR.top;
          if (overlap) { selectedAgents.add(node.dataset.agent); node.classList.add('selected'); }
        });
        updateSelectionToolbar();
      }
      if (selBox) selBox.style.display='none';
      selStart = null;
    });
  }
}


