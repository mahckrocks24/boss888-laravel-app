        parts.push('</div>');
      }
      else if (cmp.type === 'form') {
        var fields = Array.isArray(cmp.fields) ? cmp.fields : [];
        parts.push('<div style="display:flex;flex-direction:column;gap:8px;margin:8px 0;max-width:400px;' + selCss + extraCss + 'padding:2px"' + clk + '>');
        for (var fi = 0; fi < fields.length; fi++) {
          var f = fields[fi] || {};
          parts.push('<div><div style="font-size:10px;color:var(--t3);margin-bottom:4px">' + bld_esc(f.label || f.name || 'Field') + '</div>');
          parts.push('<div style="background:var(--s3);border:1px solid var(--bd);border-radius:6px;padding:8px 10px;font-size:12px;color:var(--t3);' + ((f.type === 'textarea' || f.field_type === 'textarea') ? 'min-height:60px' : '') + '">' + bld_esc(f.label || f.name || '') + '...</div></div>');
        }
        if (!fields.length) parts.push('<div style="padding:12px;text-align:center;color:var(--t3);font-size:11px;border:1px dashed var(--bd);border-radius:6px">No fields — edit in properties</div>');
        parts.push('</div>');
      }
      else if (cmp.type === 'divider') {
        parts.push('<hr style="border:none;border-top:1px solid var(--bd);margin:12px 0;' + selCss + extraCss + '"' + clk + '>');
      }
      else if (cmp.type === 'spacer') {
        parts.push('<div style="height:' + (cmp.height || cmp.size || '40px') + ';' + selCss + extraCss + '"' + clk + '></div>');
      }
      else if (cmp.type === 'image') {
