function bldShowGenerate() {
  document.getElementById('bld-gen-panel').style.display = 'block';
  document.getElementById('bld-import-panel').style.display = 'none';
}
function bldShowImport() {
  document.getElementById('bld-import-panel').style.display = 'block';
  document.getElementById('bld-gen-panel').style.display = 'none';
}

async function bldRunGenerate() {
  const prompt = document.getElementById('bld-gen-prompt')?.value?.trim();
  const title  = document.getElementById('bld-gen-title')?.value?.trim() || 'AI Generated Page';
  const sections = parseInt(document.getElementById('bld-gen-sections')?.value || '6');
  if (!prompt) { showToast('Describe the page layout first.','warning'); return; }
  const btn = document.getElementById('bld-gen-btn');
  btn.textContent = 'Generating…'; btn.disabled = true;
  try {
    // 1) Generate layout
    const genR = await _bldSafeFetch(bldApi+'ai/generate-layout',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'},body:JSON.stringify({prompt,sections})});
    const genD = await genR.json();
    if (!genD.success) throw new Error(genD.error||'Generation failed');
    // 2) Create landing page
    const pageR = await _bldSafeFetch(bldApi+'pages',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'},body:JSON.stringify({title: genD.layout?.title || title, page_type: 'landing', status: 'draft'})});
    const pageD = await pageR.json();
    if (!pageD.id) throw new Error('Failed to create page');
    // 3) Save the generated JSON directly
    await _bldSafeFetch(bldApi+'pages/'+pageD.id+'/save-json',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'},body:JSON.stringify({page_json:genD.layout})});
    btn.textContent = '✓ Done!';
    document.getElementById('bld-gen-panel').style.display = 'none';
    await bldLoadPages();
    bldOpenEditor(pageD.id);
  } catch(e) { showToast('Error: '+e.message,'error'); }
  btn.textContent = 'Generate →'; btn.disabled = false;
}

async function bldRunImport() {
  const url   = document.getElementById('bld-import-url')?.value?.trim();
  const html  = document.getElementById('bld-import-html')?.value?.trim();
  const title = document.getElementById('bld-import-title')?.value?.trim() || 'Imported Page';
  if (!url && !html) { showToast('Provide a URL or HTML to import.','warning'); return; }
  const btn = document.getElementById('bld-import-btn');
