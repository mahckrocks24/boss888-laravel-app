// ═══════════════════════════════════════════════════════════════════════════
function _bldRenderProps(si, ci) {
  _epInjectCSS();
  const panel = document.getElementById('bld-props-body');
  if (!panel) return;
  const sec = bldCurrentPage?.sections?.[si];

  // ── PAGE SETTINGS (no section selected) ──────────────────────────────────
  if (si === -1 || si === null || si === undefined) {
    var theme = bldCurrentPage?.theme || {};
    panel.innerHTML =
      '<div style="padding:4px 0">'
      + '<div style="font-size:11px;font-weight:700;color:var(--t1);margin-bottom:12px">🎨 Page Settings</div>'
      + _epColor('Background', 'bld-p-pg-bg', theme.bg || '')
      + _epColor('Text Color', 'bld-p-pg-txt', theme.text || '')
      + _epColor('Primary', 'bld-p-pg-primary', theme.primary || '')
      + _epSelect('Font', 'bld-p-pg-font',
          ['','DM Sans','Syne','Inter','Poppins','Outfit','Space Grotesk','Playfair Display','Roboto','Montserrat','Raleway','Lato'],
          theme.font || '')
      + _epInput('Border Radius', 'bld-p-pg-radius', theme.radius || '', '8px')
      + '</div>';
    setTimeout(function() { _bldAttachRealtime(function() { _bldApplyPageSettings(); }); }, 30);
    return;
  }

  if (!sec) { bldDeselectComponent(); return; }

  // ── SECTION PANEL ─────────────────────────────────────────────────────────
  if (ci === null || ci === undefined) {
    _epRenderSectionPanel(panel, sec, si);
    return;
  }

  // ── COMPONENT PANEL ───────────────────────────────────────────────────────
  const cmp = sec.components?.[ci];
  if (!cmp) { bldDeselectComponent(); return; }
  _epRenderComponentPanel(panel, cmp, si, ci);
}

// ═══════════════════════════════════════════════════════════════════════════
// SECTION PANEL
// ═══════════════════════════════════════════════════════════════════════════
function _epRenderSectionPanel(panel, sec, si) {
  var ss = sec.style || {};
  var tabIdx = _epActiveTab;
  // Section only has Style + Advanced
  if (tabIdx === 0) tabIdx = 1; // no Content tab for sections

  var html = _epTabs(['Style','Advanced'], tabIdx - 1, '_epSecTabSwitch|' + si);
  // No bld_post-processing needed — _epTabs generates correct onclick directly

  if (tabIdx <= 1) {
    // Style tab
    var _isBgGrad = ss.bg && ss.bg.indexOf('gradient') !== -1;
    var _bgColor  = (!_isBgGrad && ss.bg) ? ss.bg : '';
    var _bgGrad   = ss.gradient || (_isBgGrad ? ss.bg : '');

    html += _epSection('Background');
    html += '<div class="ep-bg-tabs">'
      + '<button id="ep-sec-bg-tab-color" class="ep-bg-tab' + (!_bgGrad && !ss.bgImage ? ' active' : '') + '" onclick="_epSecBgTab(\'' + si + '\',\'color\')" >Color</button>'
      + '<button id="ep-sec-bg-tab-gradient" class="ep-bg-tab' + (_bgGrad ? ' active' : '') + '" onclick="_epSecBgTab(\'' + si + '\',\'gradient\')">Gradient</button>'
      + '<button id="ep-sec-bg-tab-image" class="ep-bg-tab' + (ss.bgImage ? ' active' : '') + '" onclick="_epSecBgTab(\'' + si + '\',\'image\')">Image</button>'
      + '</div>';
    html += '<div id="ep-sec-bg-color" style="display:' + (!_bgGrad && !ss.bgImage ? 'block' : 'none') + '">'
      + _epColor('Color', 'bld-p-sec-bg', _bgColor) + '</div>';
    html += '<div id="ep-sec-bg-gradient" style="display:' + (_bgGrad ? 'block' : 'none') + '">'
      + _epInput('Gradient CSS', 'bld-p-sec-gradient', _bgGrad, 'linear-gradient(135deg,#6C5CE7,#00E5A8)')
      + '</div>';
    html += '<div id="ep-sec-bg-image" style="display:' + (ss.bgImage ? 'block' : 'none') + '">'
      + _epInput('Image URL', 'bld-p-sec-bgimg', ss.bgImage || '', 'https://…')
      + _epSelect('Size', 'bld-p-sec-bgsize', ['cover','contain','auto'], ss.bgSize || 'cover')
      + _epColor('Overlay', 'bld-p-sec-overlay', ss.overlay || '')
      + '</div>';

    html += _epSection('Typography');
    html += _epColor('Text Color', 'bld-p-sec-color', ss.color || '');
    html += _epSelect('Font Family', 'bld-p-sec-font',
      ['','DM Sans','Syne','Inter','Poppins','Outfit','Space Grotesk','Playfair Display','Roboto','Montserrat','Raleway','Oswald','Lato'],
      ss.fontFamily || '');
    html += _epSelect('Align', 'bld-p-sec-align', ['','left','center','right'], ss.textAlign || '');

    html += _epSection('Effects');
    html += _epSlider('Opacity', 'bld-p-sec-opacity', ss.opacity || '1', '0', '1', '0.05', '');
    html += _epInput('Border', 'bld-p-sec-border', ss.border || '', '1px solid rgba(255,255,255,.1)');
    html += _epInput('Border Radius', 'bld-p-sec-radius', ss.borderRadius || '', '12px');
    html += _epInput('Box Shadow', 'bld-p-sec-shadow', ss.shadow || '', '0 4px 20px rgba(0,0,0,.3)');

  } else {
    // Advanced tab
    html += _epSection('Layout');
    html += _epSelect('Content Width', 'bld-p-sec-maxw', ['','800px','960px','1100px','1280px','100%'], ss.maxWidth || '');
    html += _epSelect('Layout', 'bld-p-sec-layout', ['','stack','columns-2','columns-3','columns-4'], ss.layout || '');
    html += _epInput('Gap', 'bld-p-sec-gap', ss.gap || '', '20px');

    html += _epSection('Spacing');
    html += _epSpacing('Padding', 'bld-p-sec-pad', ss.paddingTop || '60px', ss.paddingX || '24px', ss.paddingBottom || '60px', ss.paddingX || '24px');
    html += _epInput('Margin Bottom', 'bld-p-sec-mb', ss.marginBottom || '', '0');

    html += _epSection('Label');
    html += _epInput('Section Label', 'bld-p-sec-label', sec.label || sec.type);
  }

  html += '<button onclick="bldDeleteSection(' + si + ')" style="width:100%;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);color:#F87171;border-radius:6px;padding:7px;font-size:11px;font-weight:600;cursor:pointer;margin-top:12px">Delete Section</button>';

  panel.innerHTML = html;
  setTimeout(function() { _bldAttachRealtime(function() { _bldApplySecProps(si); }); }, 30);
}

function _epSecTabSwitch(si, tabIdx) {
  // Section tabs: 0=Style, 1=Advanced — map to _epActiveTab values 1 and 2
  _epActiveTab = tabIdx + 1;
  _bldRenderProps(si, null);
}

function _epSecBgTab(si, tab) {
  ['color','gradient','image'].forEach(function(t) {
    var el = document.getElementById('ep-sec-bg-' + t);
    var btn = document.getElementById('ep-sec-bg-tab-' + t);
    if (el) el.style.display = (t === tab) ? 'block' : 'none';
    if (btn) btn.classList.toggle('active', t === tab);
  });
}

// ═══════════════════════════════════════════════════════════════════════════
// COMPONENT PANEL — tabbed: Content | Style | Advanced
// ═══════════════════════════════════════════════════════════════════════════
function _epRenderComponentPanel(panel, cmp, si, ci) {
  // FIX 6: dual-key type read
  var type = cmp.component_type || cmp.type || 'text';
  var cs   = cmp.style || {};
  var tab  = _epActiveTab;

  var tabHtml = _epTabs(['Content','Style','Advanced'], tab,
    '_epCmpTabSwitch|' + si + '|' + ci);
  // No bld_post-processing needed — _epTabs generates clean onclick directly

  var html = tabHtml;

  // ── CONTENT TAB ──────────────────────────────────────────────────────────
  if (tab === 0) {
    html += _epContentFields(cmp, type, si, ci);

  // ── STYLE TAB ────────────────────────────────────────────────────────────
  } else if (tab === 1) {
    html += _epSection('Text');
    html += _epColor('Color', 'bld-p-cmp-color', cs.color || '');
    html += _epSelect('Font', 'bld-p-cmp-font',
      ['','DM Sans','Syne','Inter','Poppins','Outfit','Space Grotesk','Playfair Display','Roboto','Montserrat','Raleway','Oswald','Lato'],
      cs.fontFamily || '');
    html += _epInput('Size', 'bld-p-cmp-fsize', cs.fontSize || '', '16px');
    html += _epSelect('Weight', 'bld-p-cmp-fweight',
      [{ value:'',label:'—' }, {value:'300',label:'Light 300'},{value:'400',label:'Regular 400'},
       {value:'500',label:'Medium 500'},{value:'600',label:'SemiBold 600'},
       {value:'700',label:'Bold 700'},{value:'800',label:'ExtraBold 800'},{value:'900',label:'Black 900'}],
      cs.fontWeight || '');
    html += _epInput('Line Height', 'bld-p-cmp-lh', cs.lineHeight || '', '1.5');
    html += _epInput('Letter Spacing', 'bld-p-cmp-ls', cs.letterSpacing || '', '0px');
    html += _epSelect('Transform', 'bld-p-cmp-transform',
      ['','none','uppercase','lowercase','capitalize'], cs.textTransform || '');
    html += _epSelect('Decoration', 'bld-p-cmp-deco',
      ['','none','underline','line-through'], cs.textDecoration || '');

    html += _epDivider();
    html += _epSection('Background');
    // BG sub-tabs
    var _isBgGrad = cs.bg && cs.bg.indexOf('gradient') !== -1;
    var _bgColor  = (!_isBgGrad && cs.bg) ? cs.bg : '';
    var _bgGrad   = cs.gradient || (_isBgGrad ? cs.bg : '');
    html += '<div class="ep-bg-tabs">'
      + '<button id="ep-cmp-bg-tab-color" class="ep-bg-tab' + (!_bgGrad ? ' active' : '') + '" onclick="_epCmpBgTab(\'color\')">Color</button>'
      + '<button id="ep-cmp-bg-tab-gradient" class="ep-bg-tab' + (_bgGrad ? ' active' : '') + '" onclick="_epCmpBgTab(\'gradient\')">Gradient</button>'
      + '</div>';
    html += '<div id="ep-cmp-bg-color" style="display:' + (!_bgGrad ? 'block' : 'none') + '">'
      + _epColor('Color', 'bld-p-cmp-bg', _bgColor) + '</div>';
    html += '<div id="ep-cmp-bg-gradient" style="display:' + (_bgGrad ? 'block' : 'none') + '">'
      + _epInput('Gradient CSS', 'bld-p-cmp-gradient', _bgGrad, 'linear-gradient(135deg,#6C5CE7,#A855F7)') + '</div>';

    html += _epDivider();
    html += _epSection('Border');
    html += _epInput('Border', 'bld-p-cmp-border', cs.border || '', '1px solid rgba(255,255,255,.1)');
    html += _epInput('Radius', 'bld-p-cmp-radius', cs.borderRadius || '', '8px');

    html += _epSection('Shadow');
    html += '<div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px">'
      + ['none','0 2px 8px rgba(0,0,0,.2)','0 4px 20px rgba(0,0,0,.3)','0 8px 40px rgba(0,0,0,.5)','0 0 20px rgba(108,92,231,.4)'].map(function(ps, pi) {
          var icons = ['✕','☁','🌤','⛅','✨'];
          return '<span class="ep-shadow-preset" title="' + bld_escH(ps) + '" onclick="document.getElementById(\'bld-p-cmp-shadow\').value=\'' + bld_escH(ps) + '\';_bldRealtime();">' + icons[pi] + '</span>';
        }).join('')
      + '</div>';
    html += _epInput('Custom', 'bld-p-cmp-shadow', cs.boxShadow || '', '0 4px 16px rgba(0,0,0,.2)');

  // ── ADVANCED TAB ─────────────────────────────────────────────────────────
  } else {
    html += _epSection('Spacing');
    // Decompose padding / margin
    var pt = cs.paddingTop || '', pb = cs.paddingBottom || '', pl = cs.paddingLeft || '', pr = cs.paddingRight || '';
    var mt = cs.marginTop  || '', mb = cs.marginBottom  || '', ml = cs.marginLeft  || '', mr = cs.marginRight  || '';
    // Fallback: if shorthand padding/margin set, show it in top field
    if (!pt && cs.padding)  pt = cs.padding;
    if (!mt && cs.margin)   mt = cs.margin;
    html += _epSpacing('Padding', 'bld-p-cmp-pad', pt, pr, pb, pl);
    html += _epSpacing('Margin',  'bld-p-cmp-mar', mt, mr, mb, ml);

    html += _epSection('Layout');
    html += _epInput('Max Width', 'bld-p-cmp-maxw', cs.maxWidth || '', '600px');
    html += _epInput('Width',     'bld-p-cmp-width', cs.width || '', '100%');
    html += _epSelect('Align', 'bld-p-cmp-align',
      ['','left','center','right','justify'], cs.textAlign || '');

    html += _epSection('Effects');
    html += _epSlider('Opacity', 'bld-p-cmp-opacity', cs.opacity || '1', '0', '1', '0.05', '');
  }

  html += '<button onclick="_bldDeleteCmp(' + si + ',' + ci + ')" style="width:100%;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);color:#F87171;border-radius:6px;padding:6px;font-size:11px;cursor:pointer;margin-top:10px">Delete Element</button>';

  panel.innerHTML = html;
  setTimeout(function() {
    _bldAttachRealtime(function() { _bldApplyCmpProps(si, ci); });
  }, 30);
}

function _epCmpTabSwitch(si, ci, tabIdx) {
  _epActiveTab = tabIdx;
  _bldRenderProps(si, ci);
}

function _epCmpBgTab(tab) {
  ['color','gradient'].forEach(function(t) {
    var el  = document.getElementById('ep-cmp-bg-' + t);
    var btn = document.getElementById('ep-cmp-bg-tab-' + t);
    if (el) el.style.display = (t === tab) ? 'block' : 'none';
    if (btn) btn.classList.toggle('active', t === tab);
  });
}

// ── Content fields per component type ────────────────────────────────────
function _epContentFields(cmp, type, si, ci) {
  var html = '';
  if (type === 'heading') {
    html += _epTextarea('Text', 'bld-p-text', cmp.text || '');
    html += _epSelect('Tag', 'bld-p-tag', ['h1','h2','h3','h4','h5','h6'], cmp.tag || 'h2');
    html += _epSelect('Align', 'bld-p-align', ['','left','center','right'], cmp.textAlign || '');
  } else if (type === 'text') {
    html += _epTextarea('Content', 'bld-p-text', cmp.text || '');
    html += _epSelect('Align', 'bld-p-align', ['','left','center','right'], cmp.textAlign || '');
  } else if (type === 'button') {
    html += _epInput('Label', 'bld-p-text', cmp.text || 'Button');
    html += _epInput('Link URL', 'bld-p-href', cmp.href || '#', 'https://…');
    html += _epSelect('Variant', 'bld-p-variant', ['primary','outline','secondary','ghost'], cmp.variant || 'primary');
    html += _epSelect('Align', 'bld-p-align', ['','left','center','right'], cmp.textAlign || '');
  } else if (type === 'image') {
    html += _epInput('Image URL', 'bld-p-src', cmp.src || '', 'https://…');
    html += '<button onclick="_epOpenWPMedia(' + si + ',' + ci + ')" style="width:100%;background:var(--s3);border:1px solid var(--bd);color:var(--t2);border-radius:6px;padding:7px;font-size:12px;cursor:pointer;margin-bottom:8px">📁 Select from Media Library</button>';
    html += _epInput('Alt Text', 'bld-p-alt', cmp.alt || '');
    html += '<button onclick="_bldCreativeGenerate(' + si + ',' + ci + ',null,\'old\')" style="width:100%;background:linear-gradient(135deg,var(--p),var(--ac));border:none;border-radius:8px;color:#fff;padding:9px;font-size:12px;font-weight:600;cursor:pointer;font-family:var(--fb)">✨ Generate with AI</button>';
  } else if (type === 'spacer') {
    html += _epInput('Height', 'bld-p-height', cmp.height || '40px', '40px');
  } else if (type === 'html') {
    html += _epTextarea('HTML Code', 'bld-p-code', cmp.code || (cmp.content && cmp.content.code) || '');
  } else if (type === 'cards' && Array.isArray(cmp.items)) {
    cmp.items.forEach(function(card, ki) {
      html += '<div class="ep-content-chip">'
        + '<div style="font-size:10px;color:var(--t3);margin-bottom:5px;font-weight:600">Card ' + (ki+1) + '</div>'
        + _epInput('Icon', 'bld-p-card-icon-'+ki, card.icon || '⭐')
        + _epInput('Heading', 'bld-p-card-head-'+ki, card.heading || '')
        + _epInput('Text', 'bld-p-card-text-'+ki, card.text || '')
        + '</div>';
    });
    html += '<button onclick="_bldAddCard(' + si + ',' + ci + ')" style="width:100%;background:var(--s3);border:1px dashed var(--bd);color:var(--t2);border-radius:6px;padding:6px;font-size:11px;cursor:pointer;margin-top:4px">+ Add Card</button>';
  } else if (type === 'form' && Array.isArray(cmp.fields)) {
    cmp.fields.forEach(function(f, fi) {
      html += '<div class="ep-content-chip">'
        + '<div style="font-size:10px;color:var(--t3);margin-bottom:5px;font-weight:600">Field ' + (fi+1) + '</div>'
        + _epInput('Label', 'bld-p-field-label-'+fi, f.label || '')
        + _epSelect('Type', 'bld-p-field-type-'+fi, ['text','email','tel','textarea','select','number'], f.type || 'text')
        + '</div>';
    });
    html += '<button onclick="_bldAddField(' + si + ',' + ci + ')" style="width:100%;background:var(--s3);border:1px dashed var(--bd);color:var(--t2);border-radius:6px;padding:6px;font-size:11px;cursor:pointer;margin-top:4px">+ Add Field</button>';
  } else if (type === 'testimonial_cards' && Array.isArray(cmp.items)) {
    cmp.items.forEach(function(t, ti) {
      html += '<div class="ep-content-chip">'
        + '<div style="font-size:10px;color:var(--t3);margin-bottom:5px;font-weight:600">Testimonial ' + (ti+1) + '</div>'
        + _epInput('Name', 'bld-p-tname-'+ti, t.name || '')
        + _epInput('Role', 'bld-p-trole-'+ti, t.role || '')
        + _epTextarea('Quote', 'bld-p-ttext-'+ti, t.text || '')
        + '</div>';
    });
  } else if (type === 'accordion' && Array.isArray(cmp.items)) {
    cmp.items.forEach(function(q, qi) {
      html += '<div class="ep-content-chip">'
        + '<div style="font-size:10px;color:var(--t3);margin-bottom:5px;font-weight:600">Item ' + (qi+1) + '</div>'
        + _epInput('Question', 'bld-p-aquestion-'+qi, q.question || q.heading || '')
        + _epTextarea('Answer', 'bld-p-aanswer-'+qi, q.answer || q.text || '')
        + '</div>';
    });
  } else {
    // Generic fallback
    html += '<div style="font-size:10px;color:var(--t3);margin-bottom:6px">Type: <strong>' + bld_esc(type) + '</strong></div>';
    if (cmp.text !== undefined)    html += _epTextarea('Text', 'bld-p-text', cmp.text || '');
    if (cmp.heading !== undefined) html += _epInput('Heading', 'bld-p-text', cmp.heading || '');
  }
  return html;
}

// WordPress media library opener (gracefully skips if not in WP context)
function _epOpenWPMedia(si, ci) {
  if (typeof wp === 'undefined' || !wp.media) {
    var url = window.prompt('Paste image URL:', '');
    if (url) {
      var cmp = bldCurrentPage?.sections?.[si]?.components?.[ci];
      if (cmp) { cmp.src = url; cmp.alt = cmp.alt || ''; if (!cmp.content) cmp.content = {}; cmp.content.src = url; }
      var inp = document.getElementById('bld-p-src');
      if (inp) inp.value = url;
      bldDirty = true; bldRenderCanvas();
    }
    return;
  }
  var frame = wp.media({ title: 'Select Image', button: { text: 'Use Image' }, multiple: false });
  frame.on('select', function() {
    var attachment = frame.state().bld_get('selection').first().toJSON();
    var cmp = bldCurrentPage?.sections?.[si]?.components?.[ci];
    if (cmp) {
      cmp.src = attachment.url; cmp.alt = attachment.alt || '';
      if (!cmp.content) cmp.content = {};
      cmp.content.src = attachment.url; cmp.content.alt = attachment.alt || '';
    }
    var inp = document.getElementById('bld-p-src');
    if (inp) inp.value = attachment.url;
    bldDirty = true; bldRenderCanvas();
  });
  frame.open();
}

// Expose for shadow preset onclick
function _bldRealtime() {
  clearTimeout(_bldRealtimeTimer);
  _bldRealtimeTimer = setTimeout(function() {
    if (_bldSelSec !== null && _bldSelCmp !== null) _bldApplyCmpProps(_bldSelSec, _bldSelCmp);
    else if (_bldSelSec !== null) _bldApplySecProps(_bldSelSec);
  }, 50);
}

// ═══════════════════════════════════════════════════════════════════════════
// _bldAttachRealtime — live update on every input change
// ═══════════════════════════════════════════════════════════════════════════
_bldRealtimeTimer = null;
function _bldAttachRealtime(applyFn) {
  var panel = document.getElementById('bld-props-body');
  if (!panel) return;
  var inputs = panel.querySelectorAll('input, textarea, select');
  for (var i = 0; i < inputs.length; i++) {
    inputs[i].addEventListener('input', function() {
      clearTimeout(_bldRealtimeTimer);
      _bldRealtimeTimer = setTimeout(function() { applyFn(); }, 200);
    });
    inputs[i].addEventListener('change', function() {
      clearTimeout(_bldRealtimeTimer);
      applyFn();
    });
  }
}

// ═══════════════════════════════════════════════════════════════════════════
// _bldApplyPageSettings
// ═══════════════════════════════════════════════════════════════════════════
function _bldApplyPageSettings() {
  // FIX 2: hex field only for color reads
  var v = function(id) { return (document.getElementById(id) || {}).value || ''; };
  if (!bldCurrentPage) return;
  if (!bldCurrentPage.theme) bldCurrentPage.theme = {};
  var bg  = v('bld-p-pg-bg');   // hex text field
  var txt = v('bld-p-pg-txt');
  var pri = v('bld-p-pg-primary');
  if (bg)  bldCurrentPage.theme.bg      = bg;
  if (txt) bldCurrentPage.theme.text    = txt;
  if (pri) bldCurrentPage.theme.primary = pri;
  bldCurrentPage.theme.font   = v('bld-p-pg-font');
  bldCurrentPage.theme.radius = v('bld-p-pg-radius');
  bldDirty = true;
  bldRenderCanvas();
}

// ═══════════════════════════════════════════════════════════════════════════
// _bldApplySecProps — FIX 2+3: hex-only, no fallback
// ═══════════════════════════════════════════════════════════════════════════
function _bldApplySecProps(si) {
  var sec = bldCurrentPage?.sections?.[si];
  if (!sec) return;
  var v = function(id) { return (document.getElementById(id) || {}).value || ''; };
  if (!sec.style) sec.style = {};

  sec.label = v('bld-p-sec-label') || sec.type;

  // FIX 2+3: ONLY hex text fields for all color reads — NO picker fallback
  var bgColor   = v('bld-p-sec-bg');       // hex text field only
  var bgGrad    = v('bld-p-sec-gradient');
  var bgImg     = v('bld-p-sec-bgimg');
  var secColor  = v('bld-p-sec-color');    // hex text field only

  if (bgGrad) {
    sec.style.gradient = bgGrad;
    sec.style.bg = '';
  } else if (bgColor && bgColor.indexOf('gradient') === -1) {
    sec.style.bg = bgColor;
    sec.style.gradient = '';
  }
  if (bgImg) { sec.style.bgImage = bgImg; sec.style.bgSize = v('bld-p-sec-bgsize') || 'cover'; }
  var overlay = v('bld-p-sec-overlay');
  if (overlay) sec.style.overlay = overlay;
  if (secColor) sec.style.color = secColor;

  // Non-color properties — always write (empty = cleared, that's fine)
  sec.style.fontFamily   = v('bld-p-sec-font');
  sec.style.textAlign    = v('bld-p-sec-align');
  sec.style.maxWidth     = v('bld-p-sec-maxw');
  sec.style.layout       = v('bld-p-sec-layout');
  sec.style.opacity      = v('bld-p-sec-opacity') || '1';
  sec.style.border       = v('bld-p-sec-border');
  sec.style.borderRadius = v('bld-p-sec-radius');
  sec.style.shadow       = v('bld-p-sec-shadow');
  sec.style.gap          = v('bld-p-sec-gap');

  // Spacing (4-side)
  var ppt = v('bld-p-sec-pad-t'), ppb = v('bld-p-sec-pad-b'), ppx = v('bld-p-sec-pad-r') || v('bld-p-sec-pad-l');
  if (ppt) sec.style.paddingTop    = normalizeStyleInput('paddingTop', ppt);
  if (ppb) sec.style.paddingBottom = normalizeStyleInput('paddingBottom', ppb);
  if (ppx) sec.style.paddingX      = normalizeStyleInput('paddingX', ppx);
  var mb = v('bld-p-sec-mb');
  if (mb) sec.style.marginBottom = normalizeStyleInput('marginBottom', mb);

  bldDirty = true;
  bldRenderCanvas();
}

// ═══════════════════════════════════════════════════════════════════════════
// _bldApplyCmpProps — FIX 2+3: hex-only, complete style coverage
// ═══════════════════════════════════════════════════════════════════════════
function _bldApplyCmpProps(si, ci) {
  var cmp = bldCurrentPage?.sections?.[si]?.components?.[ci];
  if (!cmp) return;
  var v = function(id) { return (document.getElementById(id) || {}).value || ''; };

  // FIX 6: dual-key type read
  var type = cmp.component_type || cmp.type || '';

  // Content fields
  if (type === 'heading') {
    if (v('bld-p-text')) cmp.text = v('bld-p-text');
    cmp.tag = v('bld-p-tag') || 'h2';
    if (v('bld-p-align')) cmp.textAlign = v('bld-p-align');
  } else if (type === 'text') {
    if (v('bld-p-text')) cmp.text = v('bld-p-text');
    if (v('bld-p-align')) cmp.textAlign = v('bld-p-align');
  } else if (type === 'button') {
    if (v('bld-p-text')) cmp.text = v('bld-p-text');
    cmp.href = v('bld-p-href') || cmp.href || '#';
    cmp.variant = v('bld-p-variant') || 'primary';
    if (v('bld-p-align')) cmp.textAlign = v('bld-p-align');
  } else if (type === 'image') {
    if (v('bld-p-src')) {
      cmp.src = v('bld-p-src');
      // FIX 7: always also write to content.src for canonical schema
      if (!cmp.content) cmp.content = {};
      cmp.content.src = cmp.src;
    }
    if (v('bld-p-alt') !== undefined) {
      cmp.alt = v('bld-p-alt');
      if (cmp.content) cmp.content.alt = cmp.alt;
    }
  } else if (type === 'spacer') {
    if (v('bld-p-height')) cmp.height = v('bld-p-height');
  } else if (type === 'html') {
    var code = v('bld-p-code');
    if (code) { cmp.code = code; if (!cmp.content) cmp.content = {}; cmp.content.code = code; }
  } else if (type === 'cards' && Array.isArray(cmp.items)) {
    for (var ki = 0; ki < cmp.items.length; ki++) {
      cmp.items[ki].icon    = v('bld-p-card-icon-'+ki) || cmp.items[ki].icon;
      cmp.items[ki].heading = v('bld-p-card-head-'+ki) || cmp.items[ki].heading;
      cmp.items[ki].text    = v('bld-p-card-text-'+ki) || cmp.items[ki].text;
    }
  } else if (type === 'form' && Array.isArray(cmp.fields)) {
    for (var fi = 0; fi < cmp.fields.length; fi++) {
      cmp.fields[fi].label = v('bld-p-field-label-'+fi) || cmp.fields[fi].label;
      cmp.fields[fi].type  = v('bld-p-field-type-'+fi)  || cmp.fields[fi].type;
    }
  } else if (type === 'testimonial_cards' && Array.isArray(cmp.items)) {
    for (var ti = 0; ti < cmp.items.length; ti++) {
      if (v('bld-p-tname-'+ti)) cmp.items[ti].name = v('bld-p-tname-'+ti);
      if (v('bld-p-trole-'+ti)) cmp.items[ti].role = v('bld-p-trole-'+ti);
      if (v('bld-p-ttext-'+ti)) cmp.items[ti].text = v('bld-p-ttext-'+ti);
    }
  } else if (type === 'accordion' && Array.isArray(cmp.items)) {
    for (var ai = 0; ai < cmp.items.length; ai++) {
      if (v('bld-p-aquestion-'+ai)) cmp.items[ai].question = v('bld-p-aquestion-'+ai);
      if (v('bld-p-aanswer-'+ai))   cmp.items[ai].answer   = v('bld-p-aanswer-'+ai);
    }
  } else {
    if (v('bld-p-text') && cmp.text  !== undefined) cmp.text    = v('bld-p-text');
    if (v('bld-p-text') && cmp.heading !== undefined) cmp.heading = v('bld-p-text');
  }

  // ── Style properties — FIX 2+3: ONLY hex text field for colors, NO fallback ──
  if (!cmp.style) cmp.style = {};
  var color = v('bld-p-cmp-color');   // hex text ONLY
  var cbg   = v('bld-p-cmp-bg');      // hex text ONLY
  var grad  = v('bld-p-cmp-gradient');

  if (color) cmp.style.color = color;
  if (grad)  { cmp.style.gradient = grad; cmp.style.bg = ''; }
  else if (cbg) { cmp.style.bg = cbg; cmp.style.gradient = ''; }

  // Typography
  cmp.style.fontFamily     = v('bld-p-cmp-font');
  cmp.style.fontSize       = normalizeStyleInput('fontSize',       v('bld-p-cmp-fsize'));
  cmp.style.fontWeight     = v('bld-p-cmp-fweight');
  cmp.style.lineHeight     = v('bld-p-cmp-lh');
  cmp.style.letterSpacing  = normalizeStyleInput('letterSpacing',  v('bld-p-cmp-ls'));
  cmp.style.textTransform  = v('bld-p-cmp-transform');
  cmp.style.textDecoration = v('bld-p-cmp-deco');
  if (v('bld-p-align')) cmp.style.textAlign = v('bld-p-align');
  // also propagate to textAlign on cmp root for standalone renderer
  if (v('bld-p-align')) cmp.textAlign = v('bld-p-align');

  // Border + shadow
  cmp.style.border       = v('bld-p-cmp-border');
  cmp.style.borderRadius = normalizeStyleInput('borderRadius',  v('bld-p-cmp-radius'));
  cmp.style.boxShadow    = v('bld-p-cmp-shadow');

  // Spacing (4-side)
  var ppt = v('bld-p-cmp-pad-t'), ppb = v('bld-p-cmp-pad-b'),
      ppl = v('bld-p-cmp-pad-l'), ppr = v('bld-p-cmp-pad-r');
  var mmt = v('bld-p-cmp-mar-t'), mmb = v('bld-p-cmp-mar-b'),
      mml = v('bld-p-cmp-mar-l'), mmr = v('bld-p-cmp-mar-r');
  // Combine to shorthand if all set, else individual
  if (ppt && ppb && ppl && ppr) {
    cmp.style.padding = ppt + ' ' + ppr + ' ' + ppb + ' ' + ppl;
  } else {
    if (ppt) cmp.style.paddingTop    = normalizeStyleInput('paddingTop',    ppt);
    if (ppb) cmp.style.paddingBottom = normalizeStyleInput('paddingBottom', ppb);
    if (ppl) cmp.style.paddingLeft   = normalizeStyleInput('paddingLeft',   ppl);
    if (ppr) cmp.style.paddingRight  = normalizeStyleInput('paddingRight',  ppr);
  }
  if (mmt && mmb && mml && mmr) {
    cmp.style.margin = mmt + ' ' + mmr + ' ' + mmb + ' ' + mml;
  } else {
    if (mmt) cmp.style.marginTop    = normalizeStyleInput('marginTop',    mmt);
    if (mmb) cmp.style.marginBottom = normalizeStyleInput('marginBottom', mmb);
    if (mml) cmp.style.marginLeft   = normalizeStyleInput('marginLeft',   mml);
    if (mmr) cmp.style.marginRight  = normalizeStyleInput('marginRight',  mmr);
  }

  // Layout
  cmp.style.maxWidth = v('bld-p-cmp-maxw');
  cmp.style.width    = v('bld-p-cmp-width');
  var op = v('bld-p-cmp-opacity');
  if (op && op !== '1') cmp.style.opacity = op; else if (!op) delete cmp.style.opacity;

  bldDirty = true;
  bldRenderCanvas();
}

