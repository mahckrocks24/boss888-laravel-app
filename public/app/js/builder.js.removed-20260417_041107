// Restore saved position from sessionStorage on panel open
function _arthurRestorePos() {
  try {
    var saved = sessionStorage.getItem('lu_arthur_pos');
    if (saved) { _arthurPos = JSON.parse(saved); _arthurApplyPos(); }
  } catch(e) {}
