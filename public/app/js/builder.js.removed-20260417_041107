function renderCommandTaskHistory(tasks) {
  const el = document.getElementById('cmd-task-history');
  if (!el) return;
  const sorted = [...tasks].sort((a,b) => (b.created_at||0) - (a.created_at||0)).slice(0,20);
  if (!sorted.length) {
    el.innerHTML = '<div style="font-size:12px;color:var(--t3);text-align:center;padding:20px">No tasks yet.</div>';
    return;
  }
  const agentsMap = window.AGENTS || {};
  el.innerHTML = sorted.map(t => {
    const ag      = agentsMap[t.agent_id || t.assignee] || {};
    const col     = ag.color || 'var(--t2)';
    const stCol   = t.status==='completed'?'var(--ac)':t.status==='in_progress'?'var(--am)':t.status==='queued'?'var(--bl)':'var(--t3)';
    const ts      = t.created_at ? new Date(t.created_at*1000).toLocaleDateString() : '';
    return `<div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:var(--s2);border-radius:6px;font-size:12px">
      <div style="width:6px;height:6px;border-radius:50%;background:${stCol};flex-shrink:0"></div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:600;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${bld_esc(t.title||t.task_id||'Task')}</div>
        <div style="color:var(--t3);font-size:10px">${bld_esc(ag.name||t.agent_id||'—')} · ${ts}</div>
      </div>
      <div style="font-size:10px;font-weight:600;color:${stCol};flex-shrink:0">${t.status||'unknown'}</div>
    </div>`;
  }).join('');
}

