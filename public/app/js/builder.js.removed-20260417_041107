window.seoEmbedNav = function(slug) {
  if (!window._seoIframe) return;
  if (window._seoActiveSlug === slug && window._seoIframeReady) return; // already there

  window._seoActiveSlug = slug;
  _seoMarkActiveTab(slug);

  // Phase 3B: Refresh bridge panel for this tool (non-blocking)
  var bridgeKey = _seoSlugToBridge[slug] || null;
  var seoRoot = document.getElementById('seo-root') || document.getElementById('view-seo');
  if (bridgeKey && seoRoot) {
    var slot = seoRoot.querySelector('#seo-bridge-slot');
    if (slot) slot.innerHTML = '<div style="padding:10px 16px;font-size:11px;color:var(--t3)">Loading bridge data\u2026</div>';
    bld_luFetchBridgeData(bridgeKey).then(function(bd) {
      if (bd && seoRoot) bld_luRenderBridgePanel(seoRoot, bd, bridgeKey.replace(/_/g,' '));
      else if (slot) slot.innerHTML = '';
    }).catch(function() { if (slot) slot.innerHTML = ''; });
  } else if (seoRoot) {
    // No bridge tool for this slug — clear panel
    var slot2 = seoRoot.querySelector('#seo-bridge-slot');
    if (slot2) slot2.innerHTML = '';
  }

  // Show spinner again while navigating
  var spinner = document.getElementById('seo-iframe-spinner');
  if (spinner) spinner.style.display = 'flex';
  window._seoIframe.style.opacity = '0';
  window._seoIframeReady = false;

  // Navigate the existing frame — does NOT recreate the iframe
  var base = (window._WP_ORIGIN || window.location.origin);
  var url  = base + '/app/#' + slug;
  try {
    // Use replace() so back button in iframe doesn't stack
    window._seoIframe.contentWindow.location.replace(url);
  } catch(e) {
    // Fallback: assign src (only if contentWindow not accessible)
    window._seoIframe.src = url;
  }
};

function _seoMarkActiveTab(slug) {
  document.querySelectorAll('[data-slug]').forEach(function(btn) {
    var on = btn.dataset.slug === slug;
    btn.style.background  = on ? 'var(--s2)'  : 'transparent';
    btn.style.color       = on ? 'var(--t1)'  : 'var(--t3)';
    btn.style.borderColor = on ? 'var(--bd2)' : 'transparent';
  });
}

function _seoUpdateActiveTab(src) {
  var slug = (src.match(/[?&]page=([^&]+)/) || [])[1] || _seoPages[0].slug;
  _seoMarkActiveTab(slug);
}


async function loadSeoInsights() {
  const body  = document.getElementById('cmd-seo-body');
