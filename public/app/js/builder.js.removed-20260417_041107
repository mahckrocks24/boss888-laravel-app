  sec.components.splice(ci, 1);
  bldDirty = true;
  bldDeselectComponent();
  bldRenderCanvas();
  bldRenderLayers();
}

function _bldAddCard(si, ci) {
  const cmp = bldCurrentPage?.sections?.[si]?.components?.[ci];
  if (!cmp) return;
  if (!cmp.items) cmp.items = [];
  cmp.items.push({icon:'⭐', heading:'New Card', text:'Description'});
