      let s0 = typeof cSlides[0]==='string'?{src:cSlides[0]}:cSlides[0];
      return '<div style="position:relative;border-radius:6px;overflow:hidden">' + (s0.src ? `<img src="${bld_escH(s0.src)}" style="width:100%;height:180px;object-fit:cover">` : `<div style="height:150px;background:rgba(255,255,255,.05);display:flex;align-items:center;justify-content:center">${bld_escH(s0.text||s0.heading||'Slide')}</div>`) + '<div style="position:absolute;bottom:6px;left:50%;transform:translateX(-50%);display:flex;gap:4px">' + cSlides.slice(0,5).map((_,i) => `<div style="width:6px;height:6px;border-radius:50%;background:${i===0?'#fff':'rgba(255,255,255,.4)'}"></div>`).join('') + '</div></div>';
    }
    case 'embed': {
      let eUrl = t('src') || t('url') || t('embedUrl');
