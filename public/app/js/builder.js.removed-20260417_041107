function bldStylesToInline(styles, tokens, themeTokens) {
  const parts = [];
  // PATCH 5: Expanded CSS property map — previously only 9 keys; AI (Railway + Arthur)
  // writes font_family, line_height, letter_spacing, opacity, max_width, width etc.
  // Unlisted keys were silently dropped. Added all properties from ARTHUR_SCHEMA.
  const props = {
    color:          'color',
    bg:             'background',
    font_size:      'font-size',
    font_weight:    'font-weight',
    font_family:    'font-family',
    text_align:     'text-align',
    line_height:    'line-height',
    letter_spacing: 'letter-spacing',
    padding:        'padding',
    margin:         'margin',
    border_radius:  'border-radius',
    border:         'border',
    shadow:         'box-shadow',
    opacity:        'opacity',
    max_width:      'max-width',
    width:          'width',
    gradient:       'background', // gradient value is a full CSS gradient string
  };
  const merged = Object.assign({}, styles, tokens);
  for (const [k, v] of Object.entries(merged)) {
    if (!v || !props[k]) continue;
    const resolved = v.startsWith('@') ? 'var(--lubld-'+v.slice(1)+','+(themeTokens[v.slice(1)]||v)+')' : v;
    parts.push(props[k]+':'+resolved);
  }
  return parts.join(';');
}

