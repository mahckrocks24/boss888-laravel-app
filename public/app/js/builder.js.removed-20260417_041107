        if (cmp.src) {
          parts.push('<img src="' + bld_esc(cmp.src) + '" alt="' + bld_esc(cmp.alt || '') + '" style="max-width:100%;border-radius:8px">');
        } else {
          parts.push('<div style="background:var(--s3);border:1px dashed var(--bd);border-radius:8px;padding:40px;text-align:center;color:var(--t3);font-size:12px">Set image URL in properties</div>');
        }
        parts.push('</div>');
      }
      else if (cmp.type === 'list') {
