        + '</div>';
    }

    // History timeline with action labels
    var hist = d.history || [];
    if (hist.length > 1) {
      html += '<div style="display:flex;align-items:center;justify-content:center;gap:4px;margin-top:6px;flex-wrap:wrap">';
      hist.forEach(function(h, hi) {
        var hScore = (typeof h === 'object') ? (h.score || 0) : h;
        var hLabel = (typeof h === 'object') ? (h.label || '') : '';
        var hDelta = (typeof h === 'object') ? (h.delta || 0) : 0;
        var hc = hScore >= 70 ? '#10B981' : hScore >= 50 ? '#F59E0B' : '#EF4444';
        var isLast = hi === hist.length - 1;
        html += '<span style="font-size:' + (isLast ? '12px' : '10px') + ';font-weight:' + (isLast ? '700' : '400') + ';color:' + (isLast ? hc : 'var(--t2)') + '">' + hScore + '</span>';
        if (hi < hist.length - 1) html += '<span style="font-size:8px;color:var(--t2)">\u2192</span>';
      });
      html += '</div>';
      // Action labels under scores (for entries with delta)
      var actionLabels = hist.filter(function(h) { return typeof h === 'object' && h.delta && h.delta > 0 && h.label && h.label !== 'Page Scan'; });
      if (actionLabels.length > 0) {
        html += '<div style="display:flex;flex-wrap:wrap;justify-content:center;gap:4px;margin-top:3px">';
        actionLabels.forEach(function(h) {
          html += '<span style="font-size:8px;color:#10B981;background:rgba(16,185,129,.1);padding:1px 5px;border-radius:3px">+' + h.delta + ' ' + bld_esc(h.label) + '</span>';
