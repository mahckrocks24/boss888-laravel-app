          + '<button onclick="event.stopPropagation();_arthurApplySuggestion(' + si + ',' + i + ',\'' + encodeURIComponent(s.action||'') + '\',\'' + encodeURIComponent(s.title||'') + '\')" '
          + 'style="flex-shrink:0;background:rgba(108,92,231,.15);border:1px solid rgba(108,92,231,.2);border-radius:5px;color:#A78BFA;font-size:9px;padding:3px 8px;cursor:pointer">Apply</button></div>';
      });
      html += '</div></details>';
    }

    html += '</div>';
    sugBox.innerHTML = html;

    // Cache suggestions for apply
    window._arthurSuggestions = d.suggestions;
  } catch (e) {
    sugBox.innerHTML = '<div style="text-align:center;padding:8px;color:#F87171;font-size:11px">Scan failed: ' + bld_esc(e.message) + '</div>';
  }

  if (btn) { btn.textContent = '\uD83E\uDDE0 Analyze Page'; btn.disabled = false; }
}

// Apply a suggestion — routes through existing Arthur pipeline with confirmation
async function _arthurApplySuggestion(si, index, encodedAction, encodedTitle) {
  var action = decodeURIComponent(encodedAction);
  var title = decodeURIComponent(encodedTitle);
  var suggestion = (window._arthurSuggestions || [])[index];

  // Track action for progress attribution
  _arthurLastAction = { action: action || 'pass_to_ai', label: title || 'Applied Suggestion' };

  // Build a natural command from the suggestion
  var command = title;
  if (suggestion && suggestion.reason) {
    command = title + '. ' + suggestion.reason;
  }

  // Route through the existing Arthur prompt pipeline (respects risk classification)
  var input = document.getElementById('arthur-prompt');
  if (input) {
    input.value = command;
    _arthurSendPrompt(si);
  }
}

// ── Arthur decision confirmation — resends with confirmed=true ──
async function _arthurConfirmDecision(si, originalText) {
  var status = document.getElementById('arthur-status');
  if (status) { status.style.display = 'block'; status.textContent = '\u2728 Arthur is applying changes...'; }
  var secEl = document.querySelector('#bld-canvas .bld-sec[data-si="' + si + '"]');
  if (secEl) secEl.classList.add('arthur-loading');

  try {
    var ctx = _bldGetAIContext(si);
    ctx.source = 'arthur';
    ctx.confirmed = true;
    var r = await fetch(API + 'builder/ai', {
      method:'POST', headers:{'Content-Type':'application/json','Authorization':'Bearer '+(localStorage.getItem('lu_token')||''),'Accept':'application/json'},
      body: JSON.stringify({command: originalText, action_type: 'chat', context: ctx})
    });
    var d = await r.json();
    if (d.success && d.data && d.ai_action && d.ai_action !== 'text_response') {
      d.data = _bldNormalizeAIResponse(d.ai_action, d.data);
      var v = _bldValidateAIResponse(d.ai_action, d.data);
      if (v.valid) {
        _bldSnapshotForUndo();
        var diff = _bldApplyAIResponse(d.ai_action, d.data);
        if (status) { status.textContent = '\u2705 ' + (d.explanation || diff || 'Applied!'); setTimeout(arthurHide, 1200); }
      } else {
        if (status) status.textContent = 'Could not apply: ' + v.reason;
      }
    } else if (d.explanation) {
      if (status) status.textContent = d.explanation;
    } else {
      // Hard rejection — no soft fallback
      console.log('ARTHUR_EXECUTION', {input:'(exec)', applied:false, error:'unsupported_command'});
      if (status) status.textContent = '❌ Unsupported command. Try: "change background to blue"';
    }
  } catch(e) {
    if (status) status.textContent = 'Error: ' + e.message;
  }
  if (secEl) secEl.classList.remove('arthur-loading');
}

// Called by bldSelectComponent
function arthurUpdateSelection(type, si, ci) {
  if (typeof si === 'number') {
    _arthurSelection = {section_index: si, component_index: ci};
    arthurShow(si, ci);
  } else {
    _arthurSelection = null;
    arthurHide();
  }
}

