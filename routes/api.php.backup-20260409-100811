// User Registration
Route::post('/auth/register', function (\Illuminate\Http\Request $r) {
    $r->validate([
        'name' => 'required|string|max:255',
        'email' => 'required|email|unique:users,email',
        'password' => 'required|string|min:8',
    ]);

    $user = \App\Models\User::create([
        'name' => $r->input('name'),
        'email' => $r->input('email'),
        'password' => \Illuminate\Support\Facades\Hash::make($r->input('password')),
    ]);

    // Create default workspace
    $ws = \App\Models\Workspace::create([
        'name' => $r->input('name') . "'s Workspace",
        'slug' => \Illuminate\Support\Str::slug($r->input('name')) . '-' . \Illuminate\Support\Str::random(4),
        'created_by' => $user->id,
    ]);
    $ws->users()->attach($user->id, ['role' => 'owner']);

    // Assign free plan
    $freePlan = \App\Models\Plan::where('slug', 'free')->first();
    if ($freePlan) {
        \App\Models\Subscription::create([
            'workspace_id' => $ws->id, 'plan_id' => $freePlan->id,
            'status' => 'active', 'started_at' => now(),
        ]);
    }

    // Create credits
    \App\Models\Credit::create(['workspace_id' => $ws->id, 'balance' => 0, 'reserved_balance' => 0]);

    // Generate auth tokens
    $authService = app(\App\Core\Auth\AuthService::class);
    $tokens = $authService->login($r->input('email'), $r->input('password'));

    return response()->json(array_merge($tokens, [
        'user' => $user,
        'workspaces' => [['id' => $ws->id, 'name' => $ws->name, 'role' => 'owner', 'plan' => 'free']],
        'current_workspace_id' => $ws->id,
    ]), 201);
});
