# LevelUp Growth Platform — Environment Configuration
# Version: D12 / 2026-04-05
# Target: Digital Ocean Frankfurt (production) | Railway (runtime)

# ── Application ───────────────────────────────────────────────────
APP_NAME="LevelUp Growth Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.levelupgrowth.io
APP_VERSION=1.0.0

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=
JWT_TTL=43200
JWT_REFRESH_TTL=2592000

# ── Database (Digital Ocean Managed MySQL) ────────────────────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=25060
DB_DATABASE=levelup_production
DB_USERNAME=levelup
DB_PASSWORD=
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# ── Cache & Queue (Railway Redis) ────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=10080
REDIS_URL=
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────
MAIL_MAILER=postmark
MAIL_FROM_ADDRESS=hello@levelupgrowth.io
MAIL_FROM_NAME="LevelUp Growth"
POSTMARK_TOKEN=

# ── AI Providers ──────────────────────────────────────────────────
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
MINIMAX_API_KEY=
RUNWAY_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_
STRIPE_PUBLISHABLE_KEY=pk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# ── Node.js Runtime (Railway) ─────────────────────────────────────
RUNTIME_URL=https://levelup-runtime2-production.up.railway.app
RUNTIME_SECRET=
LU_SECRET=

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN_EXTRA=

# ── Social ────────────────────────────────────────────────────────
SOCIAL_CONNECTOR_URL=
SOCIAL_CONNECTOR_API_KEY=
SOCIAL_MOCK_MODE=false
EMAIL_CONNECTOR_DRIVER=postmark

# ── Security ─────────────────────────────────────────────────────
IDEMPOTENCY_LOCK_TTL=300
CB_DEFAULT_THRESHOLD=5
CB_DEFAULT_COOLDOWN=60
CB_DEFAULT_WINDOW=300

# ── Rate Limits ──────────────────────────────────────────────────
RL_WS_PER_MINUTE=60
RL_WS_PER_HOUR=600
RL_WS_PER_DAY=5000
RL_AGENT_PER_MINUTE=20
RL_AGENT_PER_HOUR=200
RL_AGENT_PER_DAY=2000

# ── Queue ────────────────────────────────────────────────────────
QUEUE_WS_CONCURRENCY=10
QUEUE_AGENT_CONCURRENCY=5
QUEUE_STALE_TIMEOUT=600

# ── Debug — MUST be false in production ──────────────────────────
VERIFY_ENABLED=true
BOSS888_DEBUG_ENABLED=false

# ── STAGING OVERRIDES ────────────────────────────────────────────
# APP_ENV=staging
# APP_URL=https://staging1.shukranuae.com
# APP_DEBUG=true
# DB_DATABASE=shukranu_staging
# STRIPE_SECRET_KEY=sk_test_

# CHATBOT888 Add-on (Stripe)
CHATBOT_ADDON_PRICE_ID=
STRIPE_MODE=
SENTRY_LARAVEL_DSN=
