        "about_p2": {
            "type": "text",
            "label": "About P2",
            "default": "My work lives between the editorial page and the family archive. I like photographs that feel like they were remembered, not taken — the glance between a father and daughter, the moment light touches a fabric just once a day, the small ceremony of a bride catching her reflection."
        },
        "about_p3": {
            "type": "text",
