        "member_3_bio": { "type": "text", "label": "Member 3 Bio", "default": "RCA Milan, twelve years with a Milanese joinery workshop before moving to Dubai. Bespoke furniture, lighting and ceramics sit on her desk before they sit in your room." },
        "member_4_image": { "type": "image", "label": "Member 4 Image", "default": "/storage/builder-heroes/architecture.jpg" },
