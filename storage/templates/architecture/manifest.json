        "testimonial_3_quote": { "type": "text", "label": "Testimonial 3 Quote", "default": "Zariba is the most visited project in our portfolio. Every guest asks who designed it. Foliage brought a gentleness to the desert that none of us thought possible on the brief we started with." },
