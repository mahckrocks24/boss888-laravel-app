        "testimonial_1_quote": { "type": "text", "label": "Testimonial 1 Quote", "default": "Foliage designed our home in Emirates Hills over three very patient years. What we ended up with is quieter and more specific than anything we could have briefed for. They drew every door handle." },
        "testimonial_1_author": { "type": "text", "label": "Testimonial 1 Author", "default": "Sara Al-Mutawa" },
        "testimonial_1_company": { "type": "text", "label": "Testimonial 1 Company", "default": "Private Client, Emirates Hills" },
        "testimonial_1_result": { "type": "text", "label": "Testimonial 1 Result", "default": "Ghaf House · 2024" },
        "testimonial_2_quote": { "type": "text", "label": "Testimonial 2 Quote", "default": "We hired them for the DIFC fit-out because they felt rigorous. They delivered something materially considered and completely on budget — which in this industry is almost unheard of." },
        "testimonial_2_author": { "type": "text", "label": "Testimonial 2 Author", "default": "Omar Haddad" },
