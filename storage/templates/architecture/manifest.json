        "team_eyebrow": { "type": "text", "label": "Team Eyebrow", "default": "THE STUDIO" },
        "team_title": { "type": "text", "label": "Team Title", "default": "Twelve people, three partners." },
        "team_intro": { "type": "text", "label": "Team Intro", "default": "A deliberately small team — one that lets the partners stay close to every drawing and every site visit. Each project is led personally by one partner, with a named architect, a landscape lead, and an interiors lead." },
        "member_1_image": { "type": "image", "label": "Member 1 Image", "default": "/storage/builder-heroes/architecture.jpg" },
        "member_1_name": { "type": "text", "label": "Member 1 Name", "default": "Farah Al-Qassimi" },
        "member_1_role": { "type": "text", "label": "Member 1 Role", "default": "Founding Partner · Architect" },
        "member_1_bio": { "type": "text", "label": "Member 1 Bio", "default": "RIBA chartered, AA London-trained, 21 years in Gulf architecture. Led our residential work since 2014; sits on the Dubai Design District advisory board." },
        "member_2_image": { "type": "image", "label": "Member 2 Image", "default": "/storage/builder-heroes/architecture.jpg" },
        "member_2_name": { "type": "text", "label": "Member 2 Name", "default": "Rami Haddad" },
        "member_2_role": { "type": "text", "label": "Member 2 Role", "default": "Partner · Head of Urbanism" },
        "member_2_bio": { "type": "text", "label": "Member 2 Bio", "default": "Harvard GSD, previously at OMA Rotterdam and Foster + Partners. Leads our urban planning practice. Obsessed with how buildings meet the ground and each other." },
        "member_3_image": { "type": "image", "label": "Member 3 Image", "default": "/storage/builder-heroes/architecture.jpg" },
