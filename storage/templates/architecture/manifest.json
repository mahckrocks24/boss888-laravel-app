        "member_4_bio": { "type": "text", "label": "Member 4 Bio", "default": "Cambridge-trained landscape architect. Specialises in low-water native planting schemes; his Liwa courtyard at Zariba Desert Lodge halved the brief's irrigation load." },

        "testimonials_eyebrow": { "type": "text", "label": "Testimonials Eyebrow", "default": "FROM THE CLIENTS" },
