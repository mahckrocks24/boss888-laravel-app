        "services_eyebrow": { "type": "text", "label": "Services Eyebrow", "default": "WHAT WE DO" },
        "services_title": { "type": "text", "label": "Services Title", "default": "An integrated design practice." },
        "services_intro": { "type": "text", "label": "Services Intro", "default": "Six disciplines, one studio. We draw every project through architecture, landscape, and interior — so the detail at 1:1 is consistent with the idea at 1:500." },
        "service_1_icon": { "type": "text", "label": "Service 1 Icon", "default": "01" },
        "service_1_title": { "type": "text", "label": "Service 1 Title", "default": "Architecture" },
        "service_1_text": { "type": "text", "label": "Service 1 Text", "default": "Private villas, commercial buildings, hospitality and cultural work — from concept through tender and construction administration. Always led personally by one of the three partners." },
        "service_2_icon": { "type": "text", "label": "Service 2 Icon", "default": "02" },
        "service_2_title": { "type": "text", "label": "Service 2 Title", "default": "Urban Planning" },
        "service_2_text": { "type": "text", "label": "Service 2 Text", "default": "Masterplans, framework strategies and public-realm design. Two of our masterplans have gone on to win WAF-shortlisted recognition for context-driven, human-scale urbanism." },
        "service_3_icon": { "type": "text", "label": "Service 3 Icon", "default": "03" },
        "service_3_title": { "type": "text", "label": "Service 3 Title", "default": "Landscape" },
        "service_3_text": { "type": "text", "label": "Service 3 Text", "default": "In-house landscape architecture — courtyards, roof gardens, desert planting schemes. We design landscape from day one of every project, never as an afterthought." },
        "service_4_icon": { "type": "text", "label": "Service 4 Icon", "default": "04" },
        "service_4_title": { "type": "text", "label": "Service 4 Title", "default": "Interior Design" },
        "service_4_text": { "type": "text", "label": "Service 4 Text", "default": "Residential and commercial interiors, including bespoke joinery, lighting schemes and art curation. Our interiors team works alongside the architects — not sequentially — so the building and the room are one thought." },
        "service_5_icon": { "type": "text", "label": "Service 5 Icon", "default": "05" },
        "service_5_title": { "type": "text", "label": "Service 5 Title", "default": "Structural Collaboration" },
        "service_5_text": { "type": "text", "label": "Service 5 Text", "default": "Ten-year relationships with our engineering consultants in Dubai and London. Complex structures — long spans, cantilevers, exposed concrete — detailed in the office, not outsourced." },
        "service_6_icon": { "type": "text", "label": "Service 6 Icon", "default": "06" },
        "service_6_title": { "type": "text", "label": "Service 6 Title", "default": "Sustainability" },
        "service_6_text": { "type": "text", "label": "Service 6 Text", "default": "LEED and Estidama accredited team members on every job. Passive strategies, local materials, embodied-carbon accounting — treated as design constraints, not add-ons." },

        "process_eyebrow": { "type": "text", "label": "Process Eyebrow", "default": "HOW WE WORK" },
        "process_title": { "type": "text", "label": "Process Title", "default": "Five stages, one conversation." },
        "process_intro": { "type": "text", "label": "Process Intro", "default": "Every project runs through the same five-stage arc. You're in the room at every stage — our approvals are recorded, not assumed." },
        "step_1_title": { "type": "text", "label": "Step 1 Title", "default": "Brief" },
        "step_1_text": { "type": "text", "label": "Step 1 Text", "default": "Two to three long conversations, a site visit, a reading of the constraints. We leave with a written brief — the document we all come back to for three years." },
        "step_2_title": { "type": "text", "label": "Step 2 Title", "default": "Concept" },
        "step_2_text": { "type": "text", "label": "Step 2 Text", "default": "Hand-drawn studies, a physical model, two or three architectural ideas tested against the brief. We present on paper, not screens. Six to ten weeks." },
        "step_3_title": { "type": "text", "label": "Step 3 Title", "default": "Design" },
        "step_3_text": { "type": "text", "label": "Step 3 Text", "default": "The idea is developed in plan, section and detail. Materials are chosen, mocked up, and touched. Consultants are brought in. Authority approvals filed." },
        "step_4_title": { "type": "text", "label": "Step 4 Title", "default": "Build" },
        "step_4_text": { "type": "text", "label": "Step 4 Text", "default": "Weekly site presence from a partner — never an intern. We detail in the office, we supervise on site. Shop drawings are checked by the same person who drew the concept." },
        "step_5_title": { "type": "text", "label": "Step 5 Title", "default": "Deliver" },
        "step_5_text": { "type": "text", "label": "Step 5 Text", "default": "Handover, a 12-month snagging period, and a proper architectural photo shoot. We stay in touch — many of our clients have come back for second and third projects." },

