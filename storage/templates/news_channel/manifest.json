    "story_5_reading_time":{ "type": "text", "label": "Story 5 Read Time","default": "8 min" },
    "story_5_image":    { "type": "image", "label": "Story 5 Image",     "default": "" },

    "story_6_category": { "type": "text", "label": "Story 6 Category",   "default": "BUSINESS" },
