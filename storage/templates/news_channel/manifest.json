    "story_3_category": { "type": "text", "label": "Story 3 Category",   "default": "SPORTS" },
    "story_3_title":    { "type": "text", "label": "Story 3 Headline",   "default": "Champions League draw confirms heavyweight quarter-finals" },
    "story_3_excerpt":  { "type": "text", "label": "Story 3 Excerpt",    "default": "First legs to be played in early April; broadcasters confirm regional kick-off times." },
