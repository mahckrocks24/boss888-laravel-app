{
  "id": "news_channel",
  "name": "News Channel",
  "version": "1.0.0",
  "industry": "news_channel",
  "description": "Premium editorial template for online news channels — breaking ticker, hero story, top stories grid, category strips, opinion columnists, newsletter capture. Playfair Display + Inter typography, broadcast-style red accent.",
  "variation": "editorial",
  "preview_image": "preview.jpg",
  "created_at": "2026-05-09",
  "industry_tags": ["news", "media", "journalism", "editorial", "press", "broadcast"],
  "social_fields": ["facebook_url", "twitter_url", "instagram_url", "linkedin_url", "youtube_url", "tiktok_url", "telegram_url"],
  "blog": { "enabled": true, "posts_per_page": 12 },
  "contact_form": { "enabled": true },

  "blocks": [
    { "id": "ticker", "name": "Breaking Ticker", "fields": ["ticker_label", "ticker_text"] },
    { "id": "nav", "name": "Navigation", "fields": ["business_name", "nav_cta"] },
    { "id": "hero", "name": "Hero Story", "fields": ["hero_category", "hero_eyebrow", "hero_title", "hero_subtitle", "hero_byline", "hero_date", "hero_reading_time", "hero_cta", "hero_image"] },
    { "id": "top_stories", "name": "Top Stories Grid", "fields": ["stories_eyebrow", "stories_title"] },
    { "id": "category_strips", "name": "Category Strips", "fields": ["cat_1_name", "cat_2_name", "cat_3_name", "cat_4_name"] },
    { "id": "video", "name": "Featured Video", "fields": ["video_eyebrow", "video_title", "video_subtitle", "video_url"] },
    { "id": "opinion", "name": "Opinion / Editorial", "fields": ["opinion_eyebrow", "opinion_title"] },
    { "id": "newsletter", "name": "Newsletter CTA", "fields": ["newsletter_eyebrow", "newsletter_title", "newsletter_subtitle", "newsletter_cta"] },
    { "id": "contact", "name": "Contact", "fields": ["contact_email", "contact_phone"] },
    { "id": "footer", "name": "Footer", "fields": ["footer_text", "footer_legal"] }
  ],

  "variables": {
    "business_name":    { "type": "text", "label": "Channel Name",   "default": "The Gulf Tribune" },
    "business_tagline": { "type": "text", "label": "Tagline",        "default": "Independent news from the Gulf · Dubai" },
    "meta_description": { "type": "text", "label": "Meta Description","default": "The Gulf Tribune — premium online news channel covering politics, business, technology, sports, and culture across the Gulf region." },
    "canonical_url":    { "type": "url",  "label": "Canonical URL",  "default": "https://thegulftribune.com" },
    "og_locale":        { "type": "text", "label": "OG Locale",      "default": "en_US" },
    "og_image":         { "type": "image","label": "OG Image",       "default": "/storage/builder-heroes/news_channel.jpg" },

    "primary_color":   { "type": "color", "label": "Primary (red)",      "default": "#C41E3A" },
    "secondary_color": { "type": "color", "label": "Secondary (navy)",   "default": "#1A1A2E" },
    "accent_color":    { "type": "color", "label": "Accent (amber)",     "default": "#F5A623" },
    "bg_color":        { "type": "color", "label": "Background",         "default": "#F8F8F8" },
    "ink_color":       { "type": "color", "label": "Body Text",          "default": "#1F1F2A" },
    "muted_color":     { "type": "color", "label": "Muted Text",         "default": "#6B6B78" },
    "border_color":    { "type": "color", "label": "Border",             "default": "#E4E4ED" },

    "ticker_label":    { "type": "text", "label": "Ticker Label",        "default": "BREAKING" },
    "ticker_text":     { "type": "text", "label": "Ticker Text",         "default": "Markets close higher on tech rally  ·  Cabinet approves new digital economy law  ·  Dubai metro extension breaks ground  ·  COP31 negotiators reach climate-finance deal  ·  Champions League draw confirmed" },

    "nav_cta":         { "type": "text", "label": "Nav CTA",             "default": "Subscribe" },
    "nav_link_1":      { "type": "text", "label": "Nav Link 1",          "default": "Politics" },
    "nav_link_2":      { "type": "text", "label": "Nav Link 2",          "default": "Business" },
    "nav_link_3":      { "type": "text", "label": "Nav Link 3",          "default": "Technology" },
    "nav_link_4":      { "type": "text", "label": "Nav Link 4",          "default": "Sports" },
    "nav_link_5":      { "type": "text", "label": "Nav Link 5",          "default": "Culture" },
    "nav_link_6":      { "type": "text", "label": "Nav Link 6",          "default": "Opinion" },

    "hero_category":   { "type": "text", "label": "Hero Category Tag",   "default": "POLITICS" },
    "hero_eyebrow":    { "type": "text", "label": "Hero Eyebrow",        "default": "LIVE COVERAGE" },
    "hero_title":      { "type": "text", "label": "Hero Title",          "default": "Cabinet votes to overhaul digital economy framework" },
    "hero_subtitle":   { "type": "text", "label": "Hero Subtitle",       "default": "The reforms — among the most significant in a decade — set new licensing rules, AI-governance standards, and protections for cross-border data flows. Implementation begins in Q3." },
    "hero_byline":     { "type": "text", "label": "Hero Byline",         "default": "By Layla Al-Mansoori" },
    "hero_date":       { "type": "text", "label": "Hero Date",           "default": "2 hours ago" },
    "hero_reading_time":{ "type": "text","label": "Hero Reading Time",   "default": "6 min read" },
    "hero_cta":        { "type": "text", "label": "Hero CTA",            "default": "Read the full story" },
    "hero_image":      { "type": "image","label": "Hero Image",          "default": "/storage/builder-heroes/news_channel.jpg" },

    "stories_eyebrow": { "type": "text", "label": "Top Stories Eyebrow", "default": "TODAY'S COVERAGE" },
    "stories_title":   { "type": "text", "label": "Top Stories Title",   "default": "Top Stories" },

    "story_1_category": { "type": "text", "label": "Story 1 Category",   "default": "BUSINESS" },
    "story_1_title":    { "type": "text", "label": "Story 1 Headline",   "default": "Markets close higher as tech sector leads regional rally" },
    "story_1_excerpt":  { "type": "text", "label": "Story 1 Excerpt",    "default": "Strong earnings from cloud and semiconductor names lift the index for a third straight session." },
    "story_1_byline":   { "type": "text", "label": "Story 1 Byline",     "default": "Karim Hashem" },
    "story_1_date":     { "type": "text", "label": "Story 1 Date",       "default": "3 hours ago" },
    "story_1_reading_time":{ "type": "text", "label": "Story 1 Read Time","default": "4 min" },
    "story_1_image":    { "type": "image", "label": "Story 1 Image",     "default": "" },

    "story_2_category": { "type": "text", "label": "Story 2 Category",   "default": "TECHNOLOGY" },
    "story_2_title":    { "type": "text", "label": "Story 2 Headline",   "default": "AI safety regulators to publish new audit framework next month" },
    "story_2_excerpt":  { "type": "text", "label": "Story 2 Excerpt",    "default": "The framework will require independent evaluations for high-risk frontier models." },
