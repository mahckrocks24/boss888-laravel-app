    "cat_1_tagline":    { "type": "text", "label": "Category 1 Tagline", "default": "Power, policy, and the people who shape them." },
    "cat_2_name":       { "type": "text", "label": "Category 2 Name",    "default": "Business" },
    "cat_2_tagline":    { "type": "text", "label": "Category 2 Tagline", "default": "Markets, deals, and the regional economy." },
    "cat_3_name":       { "type": "text", "label": "Category 3 Name",    "default": "Technology" },
    "cat_3_tagline":    { "type": "text", "label": "Category 3 Tagline", "default": "AI, startups, and the fight for digital sovereignty." },
    "cat_4_name":       { "type": "text", "label": "Category 4 Name",    "default": "Culture" },
    "cat_4_tagline":    { "type": "text", "label": "Category 4 Tagline", "default": "Art, ideas, and the stories behind the headlines." },

    "video_eyebrow":    { "type": "text", "label": "Video Eyebrow",      "default": "WATCH" },
