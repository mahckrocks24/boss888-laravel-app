    "story_3_date":     { "type": "text", "label": "Story 3 Date",       "default": "6 hours ago" },
    "story_3_reading_time":{ "type": "text", "label": "Story 3 Read Time","default": "3 min" },
    "story_3_image":    { "type": "image", "label": "Story 3 Image",     "default": "" },

    "story_4_category": { "type": "text", "label": "Story 4 Category",   "default": "CULTURE" },
