    "story_title": {
      "type": "text",
      "label": "Story Title",
      "default": "A Small Room, Built on Good Coffee and Slower Mornings"
    },
    "story_p1": {
      "type": "text",
      "label": "Story P1",
      "default": "Ember & Bean started in 2019 with a second-hand espresso machine, one roasted bag of Ethiopian beans, and a very small corner in Marina. We were three friends who'd met while working on the London specialty-coffee scene and had moved home \u2014 homesick not for a city, but for a room where people knew your drink."
    },
    "story_p2": {
      "type": "text",
      "label": "Story P2",
      "default": "Seven years later, we roast our own beans every Tuesday, bake our pastries from scratch every morning at 5am, and still hand-write the specials board by sunrise. The machine has been upgraded. The coffee is better. Everything else is exactly as we intended."
    },
    "story_p3": {
      "type": "text",
      "label": "Story P3",
      "default": "We're a small team of eight. We know most regulars' drinks by name \u2014 and many by face. That's not a policy. It's the only way we know how to make a good coffee shop."
    },
    "story_signature": {
      "type": "text",
      "label": "Story Signature",
      "default": "\u2014 Mira, Samir & Jules"
    },
    "story_role": {
      "type": "text",
      "label": "Story Role",
      "default": "Founders, Ember & Bean"
    },
