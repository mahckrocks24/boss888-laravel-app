    "step_3_text": {
      "type": "text",
      "label": "Step 3 Text",
      "default": "Roasted beans rest for 5\u201310 days in vacuum before being ground. It sounds fussy \u2014 but the cup is dramatically cleaner with proper resting."
    },
    "step_4_title": {
