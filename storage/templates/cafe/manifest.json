    "step_2_text": {
      "type": "text",
      "label": "Step 2 Text",
      "default": "Beans are roasted every Tuesday on our in-house Giesen W6A. Light to medium profile \u2014 the way the farmers wanted them tasted."
    },
    "step_3_title": {
