        "pillar_2_title": { "type": "text", "label": "Pillar 2 Title", "default": "Evidence-Informed" },
        "pillar_2_text": { "type": "text", "label": "Pillar 2 Text", "default": "Every modality is grounded in research and clinical practice. Tradition plus evidence — never one without the other." },
        "pillar_3_title": { "type": "text", "label": "Pillar 3 Title", "default": "Slow By Design" },
        "pillar_3_text": { "type": "text", "label": "Pillar 3 Text", "default": "Ninety-minute sessions, ten-minute buffers. We build in time for silence, because silence is where change actually happens." },
        "pillar_4_title": { "type": "text", "label": "Pillar 4 Title", "default": "Held, Not Fixed" },
        "pillar_4_text": { "type": "text", "label": "Pillar 4 Text", "default": "You are not a problem to solve. Our work is to hold space for your own answers to surface — and to guide you gently toward them." },

